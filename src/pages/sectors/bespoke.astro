---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TrustStrip from '@/components/TrustStrip.astro';
import { site } from '@/config/site';

const steps = [
  {
    n: '01',
    title: 'Discuss',
    body: "Send a sketch, a photo, a half-finished drawing or just a description. We will ring you back same day with the right questions — sizes, loadings, finishes, access, deadline. No charge, no pressure.",
  },
  {
    n: '02',
    title: 'Design',
    body: 'Our in-house design team produce CAD layouts and structural calcs to Eurocode 2 (BS EN 1992). You get drawings to sign off before any concrete goes in a mould. Revisions are part of the price.',
  },
  {
    n: '03',
    title: 'Manufacture',
    body: 'Cast in our Holsworthy yard. C40/50 sulphate-resisting as standard, exposed-aggregate, board-marked and acid-etched finishes available. Cube-tested, marked, photographed before it leaves.',
  },
  {
    n: '04',
    title: 'Deliver',
    body: 'On our own Hiab lorry, with our driver. We unload to your slab, your shed, your site — not the gate. South West weekly, nationwide on planned runs. Install crew available on request.',
  },
];

const examples = [
  {
    label: 'Architectural casts',
    meta: 'Board-marked & exposed-aggregate',
    desc: 'Feature panels for a Devon barn conversion — reclaimed-board pattern, lime-aggregate finish, lifted into place in five panels.',
  },
  {
    label: 'Custom plinths',
    meta: 'Generator, transformer and plant bases',
    desc: 'Cable ducts cast in, holding-down bolts to template, levelled to within 2mm. Made for a substation upgrade in Cornwall.',
  },
  {
    label: 'One-off retaining systems',
    meta: 'Curved L-blocks, transition sections',
    desc: 'A horseshoe retainer for a holiday-park terrace. Cast in three radial sections, faced in exposed flint aggregate.',
  },
  {
    label: 'Specialist agricultural',
    meta: 'Calf creeps, race walls, push-off ends',
    desc: 'Bespoke calf-rearing layout cast as a kit of parts. Drainage falls and feed-trough rebates cast in — no concrete on site.',
  },
  {
    label: 'Drainage & water',
    meta: 'Tank lids, flow-control chambers',
    desc: 'A reinforced lid with cast-in covers and a step-iron recess for a private water company. Lifted in one piece by 50t crane.',
  },
  {
    label: 'Heritage & infill',
    meta: 'Cast-stone copings, bollards, lintels',
    desc: 'Replacement copings and bollards for a Grade-II listed walled garden — colour-matched to the original by sample.',
  },
];
---

<BaseLayout
  title="Bespoke precast — if it can be cast and delivered, we can make it"
  description="Custom and one-off precast concrete from our Holsworthy yard. In-house design to Eurocode 2, exposed-aggregate and board-marked finishes, delivered on our own Hiab. Tell us what you need."
  image="/images/sector-bespoke.jpg"
  schema="Service"
  schemaData={{
    serviceType: 'Bespoke precast concrete manufacture',
    provider: { '@type': 'LocalBusiness', name: site.name, telephone: site.contact.phone },
    areaServed: site.areasServed,
    description:
      'Bespoke and one-off precast concrete: architectural panels, custom plinths, retaining specials, heritage cast-stone. In-house design to BS EN 1992. Cast in North Devon since 1971.',
  }}
>
  <TrustStrip />

  <!-- Hero -->
  <section class="relative bg-navy text-white overflow-hidden">
    <div class="relative container-wccp py-20 md:py-28">
      <div class="max-w-3xl">
        <p class="eyebrow text-yellow mb-6">Custom · one-off · architectural</p>
        <h1 class="font-display text-display-2xl text-white mb-6">
          If it's precast<br />
          and it can be delivered,<br />
          <span class="text-yellow">we can make it.</span>
        </h1>
        <p class="text-lg md:text-xl text-white/90 max-w-2xl mb-10 leading-relaxed">
          Fifty-five years of casting one-offs. Send a sketch, a photo or a half-finished drawing —
          we will design, cast and deliver. In-house engineering, exposed-aggregate finishes,
          and a yard that says yes when others say specials are too much trouble.
        </p>
        <div class="flex flex-wrap gap-3">
          <a href="/quote" class="btn-primary">Tell us what you need</a>
          <a href={`tel:${site.contact.phoneIntl}`} class="btn-yellow">
            Call {site.contact.phone}
          </a>
          <a href="#examples" class="btn-ghost border-white text-white hover:bg-white hover:text-navy">
            See examples
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="container-wccp py-20">
    <div class="max-w-2xl mb-12">
      <p class="eyebrow text-cast mb-3">How bespoke works here</p>
      <h2 class="font-display text-display-lg mb-4">Four steps from sketch to slab.</h2>
      <p class="text-cast-700 text-lg">
        We have done this enough times that the path is short. Most bespoke jobs go from
        first phone call to first delivery in 6 to 10 weeks.
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
      {steps.map((s) => (
        <div class="card p-7 relative">
          <div class="font-display font-bold text-display-md text-yellow mb-3">{s.n}</div>
          <h3 class="font-display text-xl font-bold text-navy mb-2">{s.title}</h3>
          <p class="text-cast-700 leading-relaxed">{s.body}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- In-house design block -->
  <section class="bg-bone-200 py-20">
    <div class="container-wccp">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <p class="eyebrow text-cast mb-3">In-house design</p>
          <h2 class="font-display text-display-lg mb-6">We design what we cast.</h2>
          <p class="text-cast-700 text-lg leading-relaxed mb-4">
            Our design team detail every bespoke job in CAD, run the structural calcs to BS EN 1992,
            and issue drawings for sign-off before a mould is built. That means no surprises at the
            yard gate and no awkward calls to your engineer at 4pm.
          </p>
          <p class="text-cast-700 text-lg leading-relaxed mb-6">
            For architectural work we sample finishes, aggregates and pigments before we commit.
            For structural work we carry CDP responsibility on the elements we design — no shifting
            it back to your team.
          </p>
          <div class="flex flex-wrap gap-3">
            <a href="/about" class="btn-secondary">Our story</a>
            <a href="/case-studies" class="btn-ghost">See past jobs</a>
          </div>
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div class="card p-6">
            <p class="font-display font-bold text-display-md text-navy mb-1">CAD</p>
            <p class="text-cast text-sm">Drawings issued for sign-off before any mould is cut.</p>
          </div>
          <div class="card p-6">
            <p class="font-display font-bold text-display-md text-navy mb-1">EC2</p>
            <p class="text-cast text-sm">Structural calcs to BS EN 1992. CDP cover available.</p>
          </div>
          <div class="card p-6">
            <p class="font-display font-bold text-display-md text-navy mb-1">Sample</p>
            <p class="text-cast text-sm">Finish samples sent before commit on architectural work.</p>
          </div>
          <div class="card p-6">
            <p class="font-display font-bold text-display-md text-navy mb-1">Cast</p>
            <p class="text-cast text-sm">Made in our yard, by our crew, photographed before dispatch.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Examples grid -->
  <section id="examples" class="container-wccp py-20">
    <div class="max-w-2xl mb-12">
      <p class="eyebrow text-cast mb-3">Recent bespoke</p>
      <h2 class="font-display text-display-lg mb-4">Six things we cast that aren't in the catalogue.</h2>
      <p class="text-cast-700 text-lg">
        A snapshot of one-offs from the last twelve months. None of them sit on our standard list —
        all of them got delivered on time.
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {examples.map((e) => (
        <div class="card p-6 group">
          <div class="aspect-[16/10] bg-cast-100 mb-5 rounded overflow-hidden">
            <div class="w-full h-full bg-gradient-to-br from-cast-200 to-cast-100"></div>
          </div>
          <h3 class="font-display text-xl font-bold text-navy mb-1">{e.label}</h3>
          <p class="text-cast text-sm font-medium mb-3">{e.meta}</p>
          <p class="text-cast text-sm leading-relaxed">{e.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Final CTA -->
  <section class="bg-yellow text-navy py-20">
    <div class="container-wccp text-center">
      <p class="eyebrow text-navy mb-4">Tell us what you need</p>
      <h2 class="font-display text-display-xl mb-4">Sketch on a napkin? That'll do.</h2>
      <p class="text-lg max-w-xl mx-auto mb-8">
        Send a photo, a drawing, a description — whatever you've got.
        We will come back same day with the questions that get us to a quote.
      </p>
      <div class="flex flex-wrap justify-center gap-3">
        <a href="/quote" class="btn bg-navy text-white hover:bg-navy-700">Start a bespoke enquiry</a>
        <a href={`https://wa.me/${site.contact.whatsapp.replace('+', '')}`} class="btn-secondary">
          WhatsApp a photo
        </a>
        <a href={`tel:${site.contact.phoneIntl}`} class="btn-ghost border-navy text-navy hover:bg-navy hover:text-white">
          Call {site.contact.phone}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
