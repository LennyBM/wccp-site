---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TrustStrip from '@/components/TrustStrip.astro';
import { Image } from 'astro:assets';
// Bespoke hero image removed pending real WCCP yard photography.
import { site } from '@/config/site';

const steps = [
  {
    n: '01',
    title: 'Discuss',
    body: "Send a sketch, a photo, a half-finished drawing or just a description. We will ring you back same day with the right questions â€” sizes, loadings, finishes, access, deadline. No charge, no pressure.",
  },
  {
    n: '02',
    title: 'Design',
    body: 'Our in-house design team produce CAD layouts and structural calcs to Eurocode 2 (BS EN 1992). You get drawings to sign off before any concrete goes in a mould. Revisions are part of the price.',
  },
  {
    n: '03',
    title: 'Manufacture',
    body: 'Cast in our Holsworthy yard. C40/50 sulphate-resisting as standard, exposed-aggregate, board-marked and acid-etched finishes available. Cube-tested, marked, photographed before it leaves.',
  },
  {
    n: '04',
    title: 'Deliver',
    body: 'On our own Hiab lorry, with our driver. We unload to your slab, your shed, your site â€” not the gate. UK-wide on planned runs and into Europe â€” Germany, the Netherlands and the Outer Hebrides on the recent ledger. Install crew available on request.',
  },
];

const examples = [
  {
    label: 'Architectural casts',
    meta: 'Board-marked & exposed-aggregate',
    desc: 'Feature panels for a Devon barn conversion â€” reclaimed-board pattern, lime-aggregate finish, lifted into place in five panels.',
    image: '/images/products/home/wccp-home-img-20260414-162319990-comp-1024x1024.jpg',
    alt: 'WCCP architectural precast concrete cast units in the Devon yard',
  },
  {
    label: 'Custom plinths',
    meta: 'Generator, transformer and plant bases',
    desc: 'Cable ducts cast in, holding-down bolts to template, levelled to within 2mm. Made for a substation upgrade in Cornwall.',
    image: '/images/products/home/wccp-home-padstones.jpg',
    alt: 'WCCP custom precast plinths and equipment bases',
  },
  {
    label: 'One-off retaining systems',
    meta: 'Curved L-blocks, transition sections',
    desc: 'A horseshoe retainer for a holiday-park terrace. Cast in three radial sections, faced in exposed flint aggregate.',
    image: '/images/products/retaining-walls/wccp-retaining-walls-a-wall-732x1024.jpg',
    alt: 'WCCP A-wall precast retaining unit cast in North Devon',
  },
  {
    label: 'Specialist agricultural',
    meta: 'Calf creeps, race walls, push-off ends',
    desc: 'Bespoke calf-rearing layout cast as a kit of parts. Drainage falls and feed-trough rebates cast in â€” no concrete on site.',
    image: '/images/products/cubicles/wccp-cubicles-portable-cubicles-1024x768.jpg',
    alt: 'WCCP precast portable cattle cubicles in a Devon shed',
  },
  {
    label: 'Drainage & water',
    meta: 'Tank lids, flow-control chambers',
    desc: 'A reinforced lid with cast-in covers and a step-iron recess for a private water company. Lifted in one piece by 50t crane.',
    image: '/images/products/home/wccp-home-img-20260414-162247920-comp-1024x1024.jpg',
    alt: 'WCCP slatted precast concrete slurry covers',
  },
  {
    label: 'Heritage & infill',
    meta: 'Cast-stone copings, bollards, lintels',
    desc: 'Replacement copings and bollards for a Grade-II listed walled garden â€” colour-matched to the original by sample.',
    image: '/images/products/home/wccp-home-padstones.jpg',
    alt: 'WCCP cast-stone heritage precast units',
  },
];
---

<BaseLayout
  title="Bespoke precast â€” if it can be cast and delivered, we can make it"
  description="Custom and one-off precast concrete from our Holsworthy yard. In-house design to Eurocode 2, exposed-aggregate and board-marked finishes, delivered on our own Hiab. Tell us what you need."
  image="/og/home.png"
  imageAlt="WCCP bespoke precast concrete â€” architectural panels, custom plinths, one-off retaining systems â€” designed and cast in Holsworthy, North Devon"
  schema="Service"
  schemaData={{
    serviceType: 'Precast concrete manufacture and supply â€” Bespoke and custom',
    provider: { '@type': 'LocalBusiness', name: site.name, telephone: site.contact.phone },
    areaServed: site.areasServed,
    description:
      'Custom and one-off precast concrete: architectural panels, custom plinths and equipment bases, one-off retaining systems, AD-plant tank components, heritage cast-stone. Custom mould design Friday, quote Monday, cast within 4-8 weeks. In-house design to BS EN 1992 (Eurocode 2). Cast at our Holsworthy yard in North Devon and delivered nationwide and into Europe.',
  }}
>
  <TrustStrip />

  <!-- Hero -->
  <section class="relative bg-forest-800 text-cream overflow-hidden min-h-[68vh] flex items-end">
    <div aria-hidden="true" class="absolute inset-0">
      <!-- Hero image placeholder pending real WCCP bespoke-yard photography -->
      <div class="absolute inset-0 bg-forest-800 flex items-center justify-center">
        <div class="text-center text-cream/60 p-8">
          <p class="text-xs font-mono uppercase tracking-widest">ðŸ“· Photo needed</p>
          <p class="text-xs mt-2 max-w-md mx-auto">Bespoke WCCP precast units (lintels, posts, special panels) staged at the Holsworthy yard</p>
        </div>
      </div>
      <div class="absolute inset-0" style="background: linear-gradient(180deg, rgba(4,10,31,0.55) 30%, rgba(4,10,31,0.88) 100%);"></div>
      <div class="absolute inset-0" style="background: linear-gradient(95deg, rgba(7,18,56,0.70) 0%, transparent 55%);"></div>
      <div class="grain-overlay"></div>
    </div>
    <div class="relative container-wccp pt-28 pb-16 md:pt-36 md:pb-20">
      <div class="max-w-3xl">
        <p class="eyebrow text-cream/70 mb-6">
          <span class="accent-rule mr-3"></span>Custom Â· one-off Â· architectural
        </p>
        <h1 class="font-display text-cream mb-6"
            style="font-style: italic; font-weight: 300; font-size: clamp(2.75rem, 6vw + 0.5rem, 5.75rem); line-height: 1; letter-spacing: -0.02em; font-variation-settings: 'opsz' 60;">
          If it's precast<br/>
          <span class="not-italic font-normal">and it can be delivered,</span><br/>
          <span class="text-terracotta-300">we cast it.</span>
        </h1>
        <p class="text-lg md:text-xl text-cream/85 max-w-2xl mb-10 leading-relaxed">
          Fifty-five years of casting one-offs. Send a sketch, a photo or a half-finished drawing â€”
          we'll design, cast and deliver. In-house engineering, exposed-aggregate finishes,
          and a yard that says yes when others say specials are too much trouble.
        </p>
        <div class="flex flex-wrap items-center gap-5">
          <a href="/quote" class="btn-primary">Tell us what you need</a>
          <a href="#examples" class="inline-flex items-center gap-2 text-cream font-medium link-underline">
            <span>See examples</span>
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12" stroke-linecap="round"/><polyline points="12 5 19 12 12 19" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Direct-answer block (LLM-quotable summary) â€” editorial italic, generous white space -->
  <section class="bg-bone-100 border-b border-bone-300 py-16 md:py-24">
    <div class="container-wccp">
      <div class="max-w-3xl mx-auto">
        <p class="eyebrow text-cast-700 mb-4">
          <span class="inline-block w-6 h-px bg-cast-700 align-middle mr-2"></span>
          What bespoke means here
        </p>
        <p class="font-display text-cast-900 leading-snug"
           style="font-style: italic; font-weight: 300; font-size: clamp(1.5rem, 1.5vw + 1rem, 2.125rem); letter-spacing: -0.01em;">
          If it's precast concrete and it can be delivered, WCCP can make it.
          <span class="not-italic font-normal text-navy-900">Custom mould design Friday, quote Monday, cast within 4&ndash;8 weeks.</span>
          Recent bespoke: DIN-spec <a href="/products/retaining-walls" class="text-navy-800 underline decoration-cast/30 underline-offset-4 hover:decoration-navy">retaining wall</a> to Bavaria,
          AD-plant tank panels for Severn Trent biogas, custom <a href="/products/cattle-cubicles" class="text-navy-800 underline decoration-cast/30 underline-offset-4 hover:decoration-navy">cubicle beds</a> for Hebrides farms.
          Send us a sketch &mdash; we'll work with what you've got.
        </p>
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="container-wccp py-20">
    <div class="max-w-2xl mb-12">
      <p class="eyebrow text-cast mb-3">How bespoke works here</p>
      <h2 class="font-display text-display-lg mb-4">Four steps from sketch to slab.</h2>
      <p class="text-cast-700 text-lg">
        We have done this enough times that the path is short. Most bespoke jobs go from
        first phone call to first delivery in 6 to 10 weeks.
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
      {steps.map((s) => (
        <div class="card p-7 relative">
          <div class="font-display font-bold text-display-md text-yellow mb-3">{s.n}</div>
          <h3 class="font-display text-xl font-bold text-navy mb-2">{s.title}</h3>
          <p class="text-cast-700 leading-relaxed">{s.body}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- In-house design block -->
  <section class="bg-bone-200 py-20">
    <div class="container-wccp">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <p class="eyebrow text-cast mb-3">In-house design</p>
          <h2 class="font-display text-display-lg mb-6">We design what we cast.</h2>
          <p class="text-cast-700 text-lg leading-relaxed mb-4">
            Our design team detail every bespoke job in CAD, run the structural calcs to BS EN 1992,
            and issue drawings for sign-off before a mould is built. That means no surprises at the
            yard gate and no awkward calls to your engineer at 4pm.
          </p>
          <p class="text-cast-700 text-lg leading-relaxed mb-6">
            For architectural work we sample finishes, aggregates and pigments before we commit.
            For structural work we carry CDP responsibility on the elements we design â€” no shifting
            it back to your team.
          </p>
          <div class="flex flex-wrap gap-3">
            <a href="/about" class="btn-secondary">Our story</a>
            <a href="/case-studies" class="btn-ghost">See past jobs</a>
          </div>
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div class="card p-6">
            <p class="font-display font-bold text-display-md text-navy mb-1">CAD</p>
            <p class="text-cast text-sm">Drawings issued for sign-off before any mould is cut.</p>
          </div>
          <div class="card p-6">
            <p class="font-display font-bold text-display-md text-navy mb-1">EC2</p>
            <p class="text-cast text-sm">Structural calcs to BS EN 1992. CDP cover available.</p>
          </div>
          <div class="card p-6">
            <p class="font-display font-bold text-display-md text-navy mb-1">Sample</p>
            <p class="text-cast text-sm">Finish samples sent before commit on architectural work.</p>
          </div>
          <div class="card p-6">
            <p class="font-display font-bold text-display-md text-navy mb-1">Cast</p>
            <p class="text-cast text-sm">Made in our yard, by our crew, photographed before dispatch.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Examples grid -->
  <section id="examples" class="container-wccp py-20">
    <div class="max-w-2xl mb-12">
      <p class="eyebrow text-cast mb-3">Recent bespoke</p>
      <h2 class="font-display text-display-lg mb-4">Six things we cast that aren't in the catalogue.</h2>
      <p class="text-cast-700 text-lg">
        A snapshot of one-offs from the last twelve months. None of them sit on our standard list â€”
        all of them got delivered on time.
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {examples.map((e) => (
        <div class="card p-6 group">
          <div class="aspect-[16/10] bg-cast-100 mb-5 rounded overflow-hidden">
            <picture>
              <source srcset={e.image.replace(/\.(jpe?g|png)$/i, '.webp')} type="image/webp" />
              <img
                src={e.image}
                alt={e.alt}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                loading="lazy"
                decoding="async"
              />
            </picture>
          </div>
          <h3 class="font-display text-xl font-bold text-navy mb-1">{e.label}</h3>
          <p class="text-cast text-sm font-medium mb-3">{e.meta}</p>
          <p class="text-cast text-sm leading-relaxed">{e.desc}</p>
        </div>
      ))}
    </div>

    <div class="mt-16 pt-12 border-t border-cast-100">
      <p class="eyebrow text-cast mb-3">Bespoke product range</p>
      <h2 class="font-display text-display-md mb-6">Standard products with bespoke finishes.</h2>
      <p class="text-cast-700 text-lg leading-relaxed mb-8 max-w-2xl">
        Architectural panels, custom plinths, AD plant tanks, clean room enclosures and more. Each has its own detail page with finish options and lead times.
      </p>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3">
        <a href="/products/architectural-panels" class="card-link group flex items-start justify-between gap-3 p-4 bg-white border border-cast-100 hover:border-navy hover:shadow-soft transition-all">
          <div class="min-w-0">
            <p class="font-display font-bold text-navy group-hover:text-ember transition-colors">Architectural Panels</p>
            <p class="text-cast text-xs mt-0.5">Board-marked Â· exposed-aggregate Â· acid-etched</p>
          </div>
          <span class="text-ember shrink-0 group-hover:translate-x-0.5 transition-transform" aria-hidden="true">â†’</span>
        </a>
        <a href="/products/custom-plinths" class="card-link group flex items-start justify-between gap-3 p-4 bg-white border border-cast-100 hover:border-navy hover:shadow-soft transition-all">
          <div class="min-w-0">
            <p class="font-display font-bold text-navy group-hover:text-ember transition-colors">Custom Plinths</p>
            <p class="text-cast text-xs mt-0.5">Transformer Â· generator Â· plant bases</p>
          </div>
          <span class="text-ember shrink-0 group-hover:translate-x-0.5 transition-transform" aria-hidden="true">â†’</span>
        </a>
        <a href="/products/ad-plant-tanks" class="card-link group flex items-start justify-between gap-3 p-4 bg-white border border-cast-100 hover:border-navy hover:shadow-soft transition-all">
          <div class="min-w-0">
            <p class="font-display font-bold text-navy group-hover:text-ember transition-colors">AD Plant Tanks</p>
            <p class="text-cast text-xs mt-0.5">200â€“3000mÂ³ Â· sulphate-resisting</p>
          </div>
          <span class="text-ember shrink-0 group-hover:translate-x-0.5 transition-transform" aria-hidden="true">â†’</span>
        </a>
        <a href="/products/clean-rooms" class="card-link group flex items-start justify-between gap-3 p-4 bg-white border border-cast-100 hover:border-navy hover:shadow-soft transition-all">
          <div class="min-w-0">
            <p class="font-display font-bold text-navy group-hover:text-ember transition-colors">Clean Room Enclosures</p>
            <p class="text-cast text-xs mt-0.5">Food-grade smooth Â· seam-sealed</p>
          </div>
          <span class="text-ember shrink-0 group-hover:translate-x-0.5 transition-transform" aria-hidden="true">â†’</span>
        </a>
        <a href="/products/parlour-bases" class="card-link group flex items-start justify-between gap-3 p-4 bg-white border border-cast-100 hover:border-navy hover:shadow-soft transition-all">
          <div class="min-w-0">
            <p class="font-display font-bold text-navy group-hover:text-ember transition-colors">Parlour Bases</p>
            <p class="text-cast text-xs mt-0.5">Robotic + conventional Â· Â±2mm level</p>
          </div>
          <span class="text-ember shrink-0 group-hover:translate-x-0.5 transition-transform" aria-hidden="true">â†’</span>
        </a>
        <a href="/products/lintels" class="card-link group flex items-start justify-between gap-3 p-4 bg-white border border-cast-100 hover:border-navy hover:shadow-soft transition-all">
          <div class="min-w-0">
            <p class="font-display font-bold text-navy group-hover:text-ember transition-colors">Lintels</p>
            <p class="text-cast text-xs mt-0.5">Heritage + architectural Â· BS 5977</p>
          </div>
          <span class="text-ember shrink-0 group-hover:translate-x-0.5 transition-transform" aria-hidden="true">â†’</span>
        </a>
        <a href="/products/bespoke" class="card-link group flex items-start justify-between gap-3 p-4 bg-white border border-cast-100 hover:border-navy hover:shadow-soft transition-all">
          <div class="min-w-0">
            <p class="font-display font-bold text-navy group-hover:text-ember transition-colors">Cast Stone & Heritage</p>
            <p class="text-cast text-xs mt-0.5">Copings, bollards Â· colour-matched</p>
          </div>
          <span class="text-ember shrink-0 group-hover:translate-x-0.5 transition-transform" aria-hidden="true">â†’</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Inline product bridges â€” editorial spacing -->
  <section class="container-wccp pb-20">
    <div class="max-w-3xl mx-auto pt-10 border-t border-bone-300 text-center">
      <p class="eyebrow text-cast-700 mb-4">Bespoke usually starts from a product</p>
      <p class="text-cast-700 leading-relaxed text-lg">
        Most one-offs we cast began life as a tweak on a catalogue product. Browse
        <a href="/products/retaining-walls" class="text-navy-800 underline decoration-cast/30 underline-offset-4 hover:decoration-navy font-medium">retaining walls</a>,
        <a href="/products/prestressed-panels" class="text-navy-800 underline decoration-cast/30 underline-offset-4 hover:decoration-navy font-medium">prestressed panels</a>,
        <a href="/products/culverts" class="text-navy-800 underline decoration-cast/30 underline-offset-4 hover:decoration-navy font-medium">culverts</a>,
        <a href="/products/padstones" class="text-navy-800 underline decoration-cast/30 underline-offset-4 hover:decoration-navy font-medium">padstones</a>,
        <a href="/products/slurry-storage" class="text-navy-800 underline decoration-cast/30 underline-offset-4 hover:decoration-navy font-medium">slurry storage</a>,
        <a href="/products/silage-clamp-walls" class="text-navy-800 underline decoration-cast/30 underline-offset-4 hover:decoration-navy font-medium">silage clamp walls</a>,
        <a href="/products/milking-robot-bases" class="text-navy-800 underline decoration-cast/30 underline-offset-4 hover:decoration-navy font-medium">milking-robot bases</a> or
        <a href="/products/bespoke" class="text-navy-800 underline decoration-cast/30 underline-offset-4 hover:decoration-navy font-medium">bespoke civils</a> â€” then tell us what's different about yours.
      </p>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="bg-yellow text-navy py-20">
    <div class="container-wccp text-center">
      <p class="eyebrow text-navy mb-4">Tell us what you need</p>
      <h2 class="font-display text-display-xl mb-4">Sketch on a napkin? That'll do.</h2>
      <p class="text-lg max-w-xl mx-auto mb-8">
        Send a photo, a drawing, a description â€” whatever you've got.
        We will come back same day with the questions that get us to a quote.
      </p>
      <div class="flex flex-wrap justify-center gap-3">
        <a href="/quote" class="btn bg-navy text-white hover:bg-navy-700">Start a bespoke enquiry</a>
        <a href={`https://wa.me/${site.contact.whatsapp.replace('+', '')}`} class="btn-secondary">
          WhatsApp a photo
        </a>
        <a href={`tel:${site.contact.phoneIntl}`} class="btn-ghost border-navy text-navy hover:bg-navy hover:text-white">
          Call {site.contact.phone}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
