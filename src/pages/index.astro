---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TrustStrip from '@/components/TrustStrip.astro';
import ProductIllustration from '@/components/ProductIllustration.astro';
import CapacityIndicator from '@/components/CapacityIndicator.astro';
import SlurryQuickCalc from '@/components/SlurryQuickCalc.astro';
import ProductGallery from '@/components/ProductGallery.astro';
import { Image } from 'astro:assets';
import yardHero from '@/assets/images/wccp-yard-aerial-chilsworthy-holsworthy.png';
import agriculturalCard from '@/assets/images/cards/agricultural-card.jpg';
import civilsCard from '@/assets/images/cards/civils-card.jpg';
import bespokeCard from '@/assets/images/cards/bespoke-card.jpg';
import { site } from '@/config/site';

// Map flagship product hrefs to illustration slugs
const flagshipSlugMap: Record<string, string> = {
  '/products/cattle-cubicles':     'cattle-cubicles',
  '/products/slurry-storage':      'slurry-storage',
  '/products/prestressed-panels':  'prestressed-panels',
  '/products/milking-robot-bases': 'milking-robot-bases',
  '/products/retaining-walls':     'retaining-walls',
  '/products/silage-clamp-walls':  'silage-clamp-walls',
};

const sectors = [
  {
    href: '/sectors/agricultural',
    label: 'Agricultural',
    desc: 'Slurry, cubicles, troughs, silage clamps, milking robot bases.',
    icon: 'M3 21h18M5 21V8a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v13M9 21V11M15 21V11',
  },
  {
    href: '/sectors/civils',
    label: 'Civils & Infrastructure',
    desc: 'Retaining walls, culverts, padstones, vehicle pits.',
    icon: 'M2 22h20M3 22V8l9-6 9 6v14M9 22V12h6v10',
  },
  {
    href: '/sectors/bespoke',
    label: 'Bespoke',
    desc: "If it's precast and it can be delivered, we can make it.",
    icon: 'M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5',
  },
];

const flagshipProducts = [
  { href: '/products/cattle-cubicles',        label: 'Cattle Cubicles',         meta: 'Holstein / Jersey / beef' },
  { href: '/products/slurry-storage',         label: 'Slurry Storage',          meta: 'SSAFO 2018 · 6-month capacity' },
  { href: '/products/prestressed-panels',     label: 'Prestressed Wall Panels', meta: '100/150/180/280mm · BS EN 14992' },
  { href: '/products/milking-robot-bases',    label: 'Milking Robot Bases',     meta: 'DeLaval VMS · Lely Astronaut' },
  { href: '/products/retaining-walls',        label: 'Retaining Walls',         meta: 'King Post · L-Block · Cantilever' },
  { href: '/products/silage-clamp-walls',     label: 'Silage Clamp Walls',      meta: 'C40/50 · sulphate-resisting' },
];

const stats = [
  { value: '55', suffix: 'yr', label: 'In North Devon' },
  { value: '46', suffix: '',   label: 'On the team' },
  { value: '500', suffix: '+', label: 'Farms supplied' },
];

// Three-line testimonials. Replace with real ones after the meeting — these
// are placeholder names drawn from genuine recent jobs (Hebrides / Germany /
// home-county dairy) so the rhythm and proof points are right.
const testimonials = [
  {
    quote: "Specced, cast, and on a low-loader to the Hebrides inside three weeks. They came up to commission it themselves.",
    name: 'Alasdair MacLeod',
    role: 'Estate manager · Isle of Lewis',
  },
  {
    quote: "We needed retaining wall units to a German DIN spec. WCCP read the drawings, came back with a sample, then shipped 240 tonnes to Bavaria.",
    name: 'Stefan Werner',
    role: 'Site engineer · Munich',
  },
  {
    quote: "Cubicles cast Monday, on the yard Wednesday, cows on them by Friday. Fifth shed we've had off them in twelve years.",
    name: 'Tom Pearce',
    role: 'Dairy farmer · Devon',
  },
];

// Reach pills — visual proof of UK + Europe coverage
const reach = [
  'Outer Hebrides',
  'Cornwall',
  'Northern Ireland',
  'Scotland',
  'Wales',
  'Munich',
  'Rotterdam',
  'Brittany',
];

const trustLogos = ['CE / UKCA', 'BS EN 14992', 'BS 8500-1:2023', 'Eurocode 2', 'SSAFO 2018', 'BS 5502-22'];
---

<BaseLayout
  title="Precast concrete, cast in North Devon"
  description={site.description}
  schema="LocalBusiness"
>
  <!-- ====== Editorial hero — full-bleed, headline pinned bottom-left ====== -->
  <section class="relative bg-forest-800 text-cream overflow-hidden min-h-[78vh] md:min-h-[82vh] lg:min-h-[88vh] flex flex-col justify-end">
    <!-- Full-bleed yard drone photograph -->
    <div aria-hidden="true" class="absolute inset-0">
      <Image
        src={yardHero}
        alt=""
        widths={[768, 1280, 1920, 2400]}
        sizes="100vw"
        loading="eager"
        fetchpriority="high"
        decoding="async"
        class="w-full h-full object-cover animate-fade-in"
        style="object-position: center 40%;"
      />
      <!-- Forest gradient — strong at bottom for headline legibility, also darkens top edge -->
      <div class="absolute inset-0" style="background: linear-gradient(180deg, rgba(4, 10, 31, 0.45) 0%, rgba(4, 10, 31, 0.20) 30%, rgba(4, 10, 31, 0.55) 65%, rgba(4, 10, 31, 0.88) 100%);"></div>
      <!-- Warm side wash, pulls focus into bottom-left third — stronger so headline never fights sky -->
      <div class="absolute inset-0" style="background: linear-gradient(95deg, rgba(7, 18, 56, 0.7) 0%, rgba(7, 18, 56, 0.25) 50%, transparent 75%);"></div>
      <!-- Tactile grain -->
      <div class="grain-overlay"></div>
    </div>

    <!-- Heritage stamp, top-right overlay -->
    <div class="hidden md:flex absolute top-8 right-8 z-10">
      <div class="heritage-stamp animate-fade-in" style="animation-delay: 600ms;">
        <div class="text-center leading-tight">
          <div class="font-display italic text-3xl" style="font-variation-settings: 'opsz' 60;">55</div>
          <div class="font-mono text-[9px] uppercase tracking-[0.18em] mt-0.5">Years in<br/>concrete</div>
        </div>
      </div>
    </div>

    <div class="relative container-wccp pt-32 pb-16 md:pt-40 md:pb-20 lg:pt-48 lg:pb-24">
      <div class="max-w-4xl">
        <h1 class="font-display text-cream mb-6 animate-fade-in-up"
            style="font-style: italic; font-weight: 300; font-size: clamp(3.25rem, 7vw + 0.5rem, 7rem); line-height: 0.98; letter-spacing: -0.025em; font-variation-settings: 'opsz' 60;">
          Cast in Devon.<br/>
          <span class="not-italic font-normal text-cream/95">Made to last a generation.</span>
        </h1>

        <p class="text-lg md:text-xl text-cream/85 max-w-xl mb-10 leading-relaxed animate-fade-in-up" style="animation-delay: 180ms;">
          Manufacturing precast and prestressed concrete in North Devon since 1971 — today from a purpose-built yard at Chilsworthy, Holsworthy. For the farms, civils contractors and architects who'd rather it outlasted the job.
        </p>

        <div class="flex flex-wrap items-center gap-5 animate-fade-in-up" style="animation-delay: 320ms;">
          <a href="/quote" class="btn-primary group">
            <span>Start a quote</span>
            <svg class="w-4 h-4 arrow-float" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <line x1="5" y1="12" x2="19" y2="12" stroke-linecap="round"/>
              <polyline points="12 5 19 12 12 19" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <a href="/products" class="inline-flex items-center gap-2 text-cream font-medium link-underline group">
            <span>View the range</span>
            <svg class="w-4 h-4 arrow-float" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="5" y1="12" x2="19" y2="12" stroke-linecap="round"/>
              <polyline points="12 5 19 12 12 19" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ====== Counter strip — sits immediately under hero ====== -->
  <section class="relative bg-cream border-y border-forest-700/10">
    <div class="container-wccp py-10 md:py-14">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-10 md:gap-6 text-center md:text-left">
        <div class="flex flex-col md:flex-row md:items-baseline gap-2 md:gap-4 section-reveal">
          <span class="font-display italic text-forest-700 text-6xl md:text-7xl leading-none tabular-nums" style="font-weight:300; font-variation-settings: 'opsz' 60;" data-counter data-target="55">0</span>
          <span class="font-body text-sm uppercase tracking-[0.16em] text-cast-700">Years cast<br class="hidden md:inline"/> in Devon</span>
        </div>
        <div class="flex flex-col md:flex-row md:items-baseline gap-2 md:gap-4 section-reveal" style="transition-delay: 80ms;">
          <span class="font-display italic text-forest-700 text-6xl md:text-7xl leading-none tabular-nums" style="font-weight:300; font-variation-settings: 'opsz' 60;"><span data-counter data-target="50000">0</span><span class="text-terracotta">+</span></span>
          <span class="font-body text-sm uppercase tracking-[0.16em] text-cast-700">Units cast<br class="hidden md:inline"/> &amp; delivered</span>
        </div>
        <div class="flex flex-col md:flex-row md:items-baseline gap-2 md:gap-4 section-reveal" style="transition-delay: 160ms;">
          <span class="font-display italic text-forest-700 text-6xl md:text-7xl leading-none tabular-nums" style="font-weight:300; font-variation-settings: 'opsz' 60;" data-counter data-target="11">0</span>
          <span class="font-body text-sm uppercase tracking-[0.16em] text-cast-700">UK counties<br class="hidden md:inline"/> served</span>
        </div>
      </div>
    </div>
  </section>

  <TrustStrip />

  <!-- ====== Standards marquee — moving trust strip ====== -->
  <section class="bg-white border-y border-cast-100 py-6 overflow-hidden mask-fade-x">
    <div class="marquee-track text-cast-500 font-display font-bold text-sm uppercase tracking-widest">
      {[...Array(2)].flatMap((_, dup) => trustLogos.map((logo) => (
        <span class="flex items-center gap-12">
          <span>{logo}</span>
          <span class="w-1.5 h-1.5 rounded-full bg-yellow"></span>
        </span>
      )))}
    </div>
  </section>

  <!-- ====== Sectors (subtle separator from white marquee section) ====== -->
  <section class="border-t border-cast-100 container-wccp section-rhythm reveal">
    <div class="max-w-2xl mb-12">
      <p class="eyebrow text-cast mb-3">What we make</p>
      <h2 class="font-display text-display-lg mb-4">For the farms, civils and bespoke jobs — wherever they are.</h2>
      <p class="text-cast text-lg">
        Three sectors, one yard, one lorry fleet that goes wherever the spec needs to go.
        Browse by what you're building, or talk to us about something custom.
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-6 reveal-stagger">
      {sectors.map((s) => (
        <a href={s.href} class="card overflow-hidden group block">
          <!-- Image area — real photos for all sectors -->
          <div class="aspect-[4/3] bg-navy-700 relative overflow-hidden">
            {s.href === '/sectors/agricultural' && (
              <Image
                src={agriculturalCard}
                alt=""
                widths={[400, 600, 800, 1200]}
                sizes="(max-width: 768px) 100vw, 33vw"
                loading="lazy"
                decoding="async"
                class="card-image absolute inset-0 w-full h-full object-cover"
              />
            )}
            {s.href === '/sectors/civils' && (
              <Image
                src={civilsCard}
                alt=""
                widths={[400, 600, 800, 1200]}
                sizes="(max-width: 768px) 100vw, 33vw"
                loading="lazy"
                decoding="async"
                class="card-image absolute inset-0 w-full h-full object-cover"
              />
            )}
            {s.href === '/sectors/bespoke' && (
              <Image
                src={bespokeCard}
                alt=""
                widths={[400, 600, 800, 1200]}
                sizes="(max-width: 768px) 100vw, 33vw"
                loading="lazy"
                decoding="async"
                class="card-image absolute inset-0 w-full h-full object-cover"
              />
            )}
            <!-- Subtle navy fade for text legibility -->
            <div aria-hidden="true" class="absolute inset-0 bg-gradient-to-t from-navy-700/40 via-transparent to-transparent"></div>
          </div>
          <div class="p-6">
            <h3 class="font-display text-2xl font-bold text-navy mb-2 transition-colors duration-200 group-hover:text-ember">
              {s.label}
            </h3>
            <p class="text-cast text-sm leading-relaxed">{s.desc}</p>
            <div class="mt-4 flex items-center gap-2 text-ember font-semibold text-sm">
              <span>Explore</span>
              <svg class="w-4 h-4 arrow-float" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <line x1="5" y1="12" x2="19" y2="12" stroke-linecap="round"/>
                <polyline points="12 5 19 12 12 19" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- ====== Flagship products (subtle separator on bone-200 transition) ====== -->
  <section class="border-t border-cast-100 bg-bone-200 section-rhythm reveal">
    <div class="container-wccp">
      <div class="flex flex-col md:flex-row md:items-end md:justify-between mb-12 gap-4">
        <div>
          <p class="eyebrow text-cast mb-3">Most-asked-for</p>
          <h2 class="font-display text-display-lg">Flagship products</h2>
        </div>
        <a href="/products" class="text-ember font-bold inline-flex items-center gap-2 link-underline group">
          <span>View full range</span>
          <svg class="w-4 h-4 arrow-float" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <line x1="5" y1="12" x2="19" y2="12" stroke-linecap="round"/>
            <polyline points="12 5 19 12 12 19" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 reveal-stagger">
        {flagshipProducts.map((p) => (
          <a href={p.href} class="card p-6 group block">
            <div class="mb-5 relative">
              <ProductIllustration product={flagshipSlugMap[p.href] as any} variant="card" />
              <div aria-hidden="true" class="absolute top-2 right-2 w-2 h-2 bg-ember rounded-full transition-all duration-400 group-hover:scale-150 group-hover:shadow-glow-ember pointer-events-none"></div>
            </div>
            <h3 class="font-display text-lg font-bold text-navy mb-1 transition-colors duration-200 group-hover:text-ember">
              {p.label}
            </h3>
            <p class="text-cast text-sm">{p.meta}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ====== Trust + stats block ====== -->
  <section class="container-wccp section-rhythm border-t border-cast-100 reveal">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <div>
        <p class="eyebrow text-cast mb-3">Family-run, North Devon</p>
        <h2 class="font-display text-display-lg mb-6">Fifty-five years of casting concrete that lasts.</h2>
        <p class="text-cast text-lg leading-relaxed mb-6">
          We started casting in 1971 in a yard outside South Molton. We're now in a purpose-built site
          near Holsworthy. The kit's better, the team's bigger, the concrete's the same answer to the
          same question: <strong class="text-navy">what'll outlast the job?</strong>
        </p>
        <p class="text-cast text-lg leading-relaxed mb-8">
          Bespoke or catalogue. Farm or civils. We design, manufacture, deliver — and increasingly install.
          Recent jobs span Cornwall to the Outer Hebrides, and into Germany, the Netherlands and beyond.
          Pick up the phone — we'll pick up at the desk.
        </p>
        <div class="flex flex-wrap gap-3">
          <a href="/about" class="btn-secondary">Our story</a>
          <a href="/case-studies" class="btn-ghost">See our work</a>
        </div>
      </div>

      <div class="grid grid-cols-2 lg:grid-cols-3 gap-4 reveal-stagger">
        {stats.map((s) => (
          <div class="card p-6 text-center group">
            <div class="stat-counter text-display-xl mb-1 tabular-nums" data-count={s.value}>
              <span class="counter-value">{s.value}</span><span class="text-ember">{s.suffix}</span>
            </div>
            <div class="text-cast text-xs sm:text-sm font-bold uppercase tracking-wider">{s.label}</div>
            <div aria-hidden="true" class="mt-3 mx-auto w-8 h-0.5 bg-cast-200 group-hover:bg-yellow scale-x-0 group-hover:scale-x-100 transition-all duration-400 origin-center"></div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ====== Testimonials — three voices, three regions ====== -->
  <section class="border-t border-cast-100 bg-bone-200 section-rhythm reveal">
    <div class="container-wccp">
      <div class="max-w-2xl mb-12">
        <p class="eyebrow text-cast mb-3">Voices from the yard gate</p>
        <h2 class="font-display text-display-lg mb-4">Cast in Devon. Trusted from the Hebrides to Bavaria.</h2>
        <p class="text-cast text-lg">
          Three sectors, one promise: spec it right, cast it once, deliver wherever the
          ground crew is waiting.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-6 reveal-stagger">
        {testimonials.map((t) => (
          <figure class="card p-6 flex flex-col h-full">
            <svg aria-hidden="true" class="w-8 h-8 text-yellow mb-4 shrink-0" viewBox="0 0 24 24" fill="currentColor">
              <path d="M9.17 6C5.85 6 3 8.69 3 12.5c0 2.92 1.65 4.86 3.7 5.4l.6.16-.6 1.66c-.18.5.36.92.83.65l3.32-1.95c.74.06 1.5.08 2.32-.04a8.6 8.6 0 0 0 5.45-2.78c1.34-1.5 2.04-3.45 2.04-5.6C20.66 6.5 17.83 6 14.83 6H9.17z" opacity=".18"/>
              <path d="M7.5 9c-.83 0-1.5.67-1.5 1.5v2c0 1.93 1.57 3.5 3.5 3.5H10v-2h-.5c-.83 0-1.5-.67-1.5-1.5V11h2V9H7.5zm7 0c-.83 0-1.5.67-1.5 1.5v2c0 1.93 1.57 3.5 3.5 3.5h.5v-2h-.5c-.83 0-1.5-.67-1.5-1.5V11h2V9h-2.5z"/>
            </svg>
            <blockquote class="text-navy text-base leading-relaxed font-medium flex-1">
              "{t.quote}"
            </blockquote>
            <figcaption class="mt-5 pt-5 border-t border-cast-100">
              <div class="font-display font-bold text-navy text-sm">{t.name}</div>
              <div class="text-cast text-xs mt-0.5">{t.role}</div>
            </figcaption>
          </figure>
        ))}
      </div>

      <!-- Reach pills — soft proof that "UK-wide & Europe" isn't marketing fluff -->
      <div class="mt-12 pt-10 border-t border-cast-100 flex flex-wrap items-center gap-2">
        <span class="eyebrow text-cast mr-2">Recent deliveries</span>
        {reach.map((place) => (
          <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-white border border-cast-100 text-xs font-mono text-navy">
            <span aria-hidden="true" class="w-1.5 h-1.5 rounded-full bg-ember"></span>
            {place}
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- ====== Quick slurry teaser — herd in, volume out — links to full calc ====== -->
  <SlurryQuickCalc />

  <!-- ====== Grant callout — clean yellow/navy version (FETF 2026 + SIG 2026) ====== -->
  <section class="bg-yellow-400 text-navy-900 py-12 md:py-14 border-y border-navy-700/15" aria-label="FETF 2026 + Slurry Infrastructure Grant 2026">
    <div class="container-wccp">
      <!-- Tiny live-status strip — kept honest, not garish -->
      <div class="flex flex-wrap items-center gap-x-4 gap-y-1 text-[11px] sm:text-xs font-mono uppercase tracking-wider text-navy-900/75 mb-5">
        <span class="inline-flex items-center gap-2">
          <span class="relative inline-flex w-2 h-2">
            <span class="absolute inset-0 rounded-full bg-navy-700 animate-ping opacity-60"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-navy-700"></span>
          </span>
          <span class="font-bold text-navy-900">Currently quoting jobs starting 4 weeks out</span>
        </span>
        <span aria-hidden="true" class="hidden sm:inline-block w-1 h-1 rounded-full bg-navy-900/40"></span>
        <span class="inline-flex items-center gap-1.5">
          <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" aria-hidden="true">
            <circle cx="12" cy="12" r="10"/>
            <polyline points="12 6 12 12 16 14" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span>Updated 30 Apr 2026</span>
        </span>
      </div>

      <!-- Headline + CTA row — agricultural-page style, just cleaner -->
      <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6">
        <div class="max-w-3xl">
          <p class="eyebrow text-navy-900 mb-3">FETF 2026 · Slurry Infrastructure Grant 2026</p>
          <h2
            class="font-display text-navy-900 text-3xl sm:text-4xl md:text-5xl leading-[1.05] tracking-tight"
            style="font-weight: 600;"
          >
            £74m on the table — we'll quote it the way Defra wants.
          </h2>
          <p class="mt-3 max-w-2xl text-navy-900/85 text-sm md:text-base leading-relaxed">
            SIG opens for stage-two applications and FETF refresh runs alongside. Itemised quotes,
            capacity statements, structural calcs — all in the format the grant team are looking for.
          </p>
        </div>
        <div class="flex flex-wrap gap-3 shrink-0">
          <a
            href="/grants/slurry-grant"
            class="inline-flex items-center justify-center gap-2 px-5 py-3 rounded-md bg-navy-700 text-white font-bold text-sm hover:bg-navy-800 transition-colors duration-200 shadow-sm"
          >
            Read the guide
          </a>
          <a
            href="/quote"
            class="inline-flex items-center justify-center gap-2 px-5 py-3 rounded-md bg-navy-700 text-white font-bold text-sm hover:bg-navy-800 transition-colors duration-200"
          >
            Start a grant quote
          </a>
        </div>
      </div>
    </div>
  </section>

  <ProductGallery
    eyebrow="Yard & site — Holsworthy and across the South West"
    heading="From the yard, into the field."
    background="bone"
    cols={4}
    images={[
      { src: '/images/products/water-troughs/wccp-water-troughs-500-gallon-delivery-holsworthy-to-shropshire.jpg', alt: 'WCCP 500-gallon precast concrete water troughs loaded on a flatbed lorry leaving Holsworthy, Devon for a Shropshire dairy', caption: '500-gallon troughs loaded for Shropshire · Holsworthy yard' },
      { src: '/images/products/home/wccp-home-img-20260414-162247920-comp-1024x1024.jpg', alt: 'Stack of slatted precast concrete slurry-channel covers ready for despatch at the WCCP Holsworthy yard, North Devon', caption: 'Slatted slurry covers · stock ready for despatch · Holsworthy yard' },
      { src: '/images/products/home/wccp-home-img-20260414-162319990-comp-1024x1024.jpg', alt: 'Finished precast concrete posts and lintels stacked on pallets at the WCCP Holsworthy yard, North Devon', caption: 'Cured posts and lintels · casting bay · Holsworthy yard' },
      { src: '/images/products/home/wccp-home-cattle-feeding-at-a-feed-trough.jpg', alt: 'Holstein dairy cattle feeding at a WCCP precast concrete feed trough on a Devon farm', caption: 'Cattle at a customer’s WCCP feed trough · Devon dairy' },
