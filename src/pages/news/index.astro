---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { site } from '@/config/site';
import { newsPosts } from '@/data/news';

const posts = newsPosts;


const categoryColors: Record<string, string> = {
  'Company news': 'text-ember',
  'Trade show': 'text-navy',
  'Industry update': 'text-yellow-700',
  'Product launch': 'text-ember',
};

---

<BaseLayout
  title="News & updates — from the yard"
  description="Latest news from the West Country Concrete yard: new products, grant updates, trade show recaps and company news. Plain-English updates from North Devon."
>
  <div data-success-banner="subscribed" class="hidden bg-success text-white py-4 border-b-4 border-navy">
    <div class="container-wccp flex items-center gap-3">
      <svg class="w-6 h-6 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
        <polyline points="20 6 9 17 4 12" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <p class="font-semibold">You're subscribed — see you in the next quarterly update.</p>
    </div>
  </div>
  <script is:inline>
    if (new URLSearchParams(window.location.search).get('subscribed') === 'true') {
      document.querySelector('[data-success-banner="subscribed"]')?.classList.remove('hidden');
    }
  </script>

  <!-- Hero -->
  <section class="relative bg-navy text-white overflow-hidden">
    <div class="relative container-wccp py-20 md:py-24">
      <div class="max-w-3xl">
        <p class="eyebrow text-yellow mb-6">News & updates</p>
        <h1 class="font-display text-display-2xl text-white mb-6">
          From the yard.<br />
          <span class="text-yellow">News, shows, grants, kit.</span>
        </h1>
        <p class="text-lg md:text-xl text-white/90 max-w-2xl leading-relaxed">
          What we're making, where we're showing it, and what's changing in the grants and
          regulations that matter to our customers. Updated when there's something to say.
        </p>
      </div>
    </div>
  </section>

  <!-- Filter strip -->
  <section class="bg-bone-200 py-6 border-b border-cast-200">
    <div class="container-wccp flex flex-wrap items-center gap-3">
      <span class="eyebrow text-cast mr-2">Filter:</span>
      <button class="btn-ghost text-xs px-3 py-1.5">All</button>
      <button class="btn-ghost text-xs px-3 py-1.5">Company news</button>
      <button class="btn-ghost text-xs px-3 py-1.5">Trade shows</button>
      <button class="btn-ghost text-xs px-3 py-1.5">Industry updates</button>
      <button class="btn-ghost text-xs px-3 py-1.5">Product launches</button>
    </div>
  </section>

  <!-- Posts grid -->
  <section class="container-wccp py-20">
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {posts.map((p) => (
        <a href={p.slug.startsWith('#') ? '#' : `/news/${p.slug}`} class="card group flex flex-col overflow-hidden">
          {p.image ? (
            <div class="aspect-[16/10] bg-cast-100 overflow-hidden">
              <picture>
                <source srcset={p.image.replace(/\.(jpe?g|png)$/i, '.webp')} type="image/webp" />
                <img src={p.image} alt={p.imageAlt ?? p.title} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.03]" loading="lazy" decoding="async" />
              </picture>
            </div>
          ) : (
            <div class="aspect-[16/10] bg-cast-100 overflow-hidden flex items-center justify-center border-2 border-dashed border-cast-300 p-6 text-center">
              <div>
                <p class="text-cast-600 text-sm font-mono">Photo needed</p>
                <p class="text-cast text-xs mt-2 leading-snug">{p.imageDescription}</p>
              </div>
            </div>
          )}
          <div class="p-6 flex-1 flex flex-col">
            <div class="flex items-center gap-3 mb-3">
              <span class={`eyebrow ${categoryColors[p.category] || 'text-ember'}`}>{p.category}</span>
              <time datetime={p.iso} class="text-cast text-xs">{p.date}</time>
            </div>
            <h2 class="font-display text-xl font-bold text-navy mb-3 group-hover:text-ember leading-snug">
              {p.title}
            </h2>
            <p class="text-cast text-sm leading-relaxed flex-1">{p.excerpt}</p>
            <span class="mt-4 text-ember font-semibold text-sm inline-flex items-center gap-2">
              Read more
              <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <line x1="5" y1="12" x2="19" y2="12" stroke-linecap="round"/>
                <polyline points="12 5 19 12 12 19" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- Newsletter strip -->
  <section class="bg-yellow text-navy py-12">
    <div class="container-wccp">
      <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6">
        <div>
          <p class="eyebrow text-navy mb-2">Don't miss the next one</p>
          <h2 class="font-display text-display-md">Newsletter — quarterly, no fluff.</h2>
          <p class="text-navy mt-2">Grant deadlines, new kit, show dates. Four times a year.</p>
        </div>
        <form
          name="newsletter"
          method="POST"
          data-netlify="true"
          netlify-honeypot="bot-field"
          action="/news?subscribed=true"
          class="w-full md:w-auto"
        >
          <input type="hidden" name="form-name" value="newsletter" />
          <p class="hidden"><label>Don't fill: <input name="bot-field" /></label></p>
          <div class="flex flex-col sm:flex-row gap-3 mb-4">
            <input
              type="email"
              name="email"
              required
              placeholder="your@email.co.uk"
              class="input flex-1"
              autocomplete="email"
            />
            <button type="submit" class="btn bg-navy text-white hover:bg-navy-700 shrink-0">Sign me up</button>
          </div>
          <div class="space-y-2">
            <label class="flex items-start gap-3 cursor-pointer group">
              <input type="checkbox" name="consent_data" value="yes" required class="mt-0.5 w-4 h-4 accent-ember cursor-pointer" />
              <span class="text-navy text-xs leading-relaxed">
                <span class="font-semibold">I consent to WCCP storing my email</span> to send me the quarterly newsletter.
              </span>
            </label>
            <label class="flex items-start gap-3 cursor-pointer group">
              <input type="checkbox" name="consent_contact" value="yes" required class="mt-0.5 w-4 h-4 accent-ember cursor-pointer" />
              <span class="text-navy text-xs leading-relaxed">
                <span class="font-semibold">I consent to be contacted</span> by email about relevant WCCP grants and products.
              </span>
            </label>
          </div>
        </form>
      </div>
    </div>
  </section>
</BaseLayout>
