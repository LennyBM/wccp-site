---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { site } from '@/config/site';

const commitments = [
  { title: 'Yard hours', body: 'Mon–Fri 7am–5pm, Sat 7am–12pm. No HGV movements before 7am or after 6pm. Sundays and bank holidays no movements.' },
  { title: 'Dust suppression', body: 'Yard sweeper twice a day, water bowser on hardstanding in dry weather, all aggregate stockpiles bunded and covered. /* CLIENT: confirm exact dust-control method */' }, // CLIENT: confirm
  { title: 'Noise commitment', body: 'No loud plant before 7am. Concrete batching and pour scheduled to working hours. Reversing alarms on lorries set to broadband (white-noise) where local noise is a concern.' }, // CLIENT: confirm
  { title: 'Traffic', body: 'HGV routing agreed with Devon County Council uses the A388 and avoids the village centre. Drivers briefed on the route every quarter.' }, // CLIENT: confirm route specifics
  { title: 'Local employment', body: '38 jobs created on the move to Chilsworthy in 2023. Most of the team live locally. We back local apprentices and run open days for North Devon schools.' },
  { title: 'Direct line', body: `If something at the yard concerns you — noise, dust, traffic, lorry movements — please call us directly on ${site.contact.phone}. The phone is answered by the yard, not a call centre.` },
];

// Trade and farming shows where you'll find Kim, Claire and the team in person.
// Photos sit in /images/team — they double as community pages and team pages.
const shows = [
  {
    name: 'North Devon Show',
    image: '/images/team/wccp-team-kim-claire-north-devon-show.jpg',
    imageWebp: '/images/team/wccp-team-kim-claire-north-devon-show.webp',
    alt: 'Kim Rumsam and Claire Mumford on the WCCP stand at the North Devon Show',
    body: 'Our home show. Kim and Claire are on the stand both days every August — drawings welcome.',
  },
  {
    name: 'Royal Welsh Show',
    image: '/images/team/wccp-team-kim-claire-royal-welsh-show.jpg',
    imageWebp: '/images/team/wccp-team-kim-claire-royal-welsh-show.webp',
    alt: 'Kim and Claire on the WCCP stand at the Royal Welsh Show, Llanelwedd',
    body: 'Llanelwedd in July — four days of dairy, beef and an unbroken queue at the cubicle stand.',
  },
  {
    name: 'Great Yorkshire Show',
    image: '/images/team/wccp-team-kim-claire-yorkshire-agricultural-show.jpg',
    imageWebp: '/images/team/wccp-team-kim-claire-yorkshire-agricultural-show.webp',
    alt: 'WCCP at the Great Yorkshire Show, Harrogate',
    body: 'A long way from North Devon — and worth the drive. The Yorkshire dairy crowd run the same kit we cast for.',
  },
  {
    name: 'West Country Farming & Machinery Show',
    image: '/images/team/wccp-team-claire-west-country-farming-machinery-show.jpg',
    imageWebp: '/images/team/wccp-team-claire-west-country-farming-machinery-show.webp',
    alt: 'Claire Mumford on the WCCP stand at the West Country Farming & Machinery Show',
    body: 'The Westpoint show in Exeter — a regular fixture and the best place to talk slurry without the wind.',
  },
];
---

<BaseLayout
  title="Cast in Chilsworthy. Built for the community."
  description="WCCP at Chilsworthy — yard hours, dust and noise commitments, local employment, direct contact line. The good-neighbour page for our Holsworthy neighbours."
>
  <section class="bg-forest-700 text-cream">
    <div class="container-wccp py-20 md:py-28">
      <p class="eyebrow text-cream/70 mb-4">Good neighbour · Chilsworthy</p>
      <h1 class="font-display text-display-2xl text-cream mb-6 max-w-4xl">
        Cast in Chilsworthy.<br />
        <em class="text-terracotta not-italic font-display italic">Built for the community.</em>
      </h1>
      <p class="text-cream/85 text-lg leading-relaxed max-w-2xl">
        We moved the yard to Chilsworthy in 2023. That's a real change for the village, and we
        take being a good neighbour seriously. This page sets out how we operate and how to
        reach us if there's a problem.
      </p>
    </div>
  </section>

  <section class="container-wccp py-16 md:py-20 section-reveal">
    <div class="max-w-3xl mb-12">
      <p class="eyebrow text-cast mb-3">Our commitments</p>
      <h2 class="font-display text-display-md text-forest-700 mb-4">How the yard runs.</h2>
      <p class="text-cast-700 text-lg leading-relaxed">
        Six commitments we make to the village and the wider Chilsworthy / Holsworthy area.
        If any of these slips, we want to know.
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-6 max-w-4xl">
      {commitments.map((c) => (
        <div class="card p-6 border-l-4 border-terracotta">
          <h3 class="font-display text-xl font-bold text-forest-700 mb-2">{c.title}</h3>
          <p class="text-cast-700 leading-relaxed">{c.body}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="bg-cream-200 py-16 md:py-20 section-reveal">
    <div class="container-wccp">
      <div class="grid lg:grid-cols-2 gap-10 items-start">
        <div>
          <p class="eyebrow text-cast mb-3">Local employment</p>
          <h2 class="font-display text-display-md text-forest-700 mb-4">38 jobs, mostly local.</h2>
          <p class="text-cast-700 text-lg leading-relaxed mb-4">
            The Chilsworthy move created 38 jobs in 2023 — drivers, batchers, fitters, design
            engineers, yard hands and admin. Most of the team live locally.
          </p>
          <p class="text-cast-700 text-lg leading-relaxed">
            We host open days for North Devon schools and back local apprentices through the
            casting and HGV-driving routes. If you know someone looking for an apprenticeship,
            we are always glad of a CV.
          </p>
          <div class="mt-6 flex flex-wrap gap-3">
            <a href="/careers" class="btn-primary">See current vacancies</a>
            <a href="/about" class="btn-yellow">Our story</a>
          </div>
        </div>
        <div class="aspect-[4/3] bg-cast-100 rounded overflow-hidden">
          <picture>
            <source srcset="/images/wccp-yard-aerial-chilsworthy-holsworthy.webp" type="image/webp" />
            <img src="/images/wccp-yard-aerial-chilsworthy-holsworthy.png" alt="Aerial view of the WCCP precast yard at Chilsworthy, Holsworthy — in the heart of the North Devon community" class="w-full h-full object-cover" loading="lazy" decoding="async" />
          </picture>
        </div>
      </div>
    </div>
  </section>

  <!-- Trade & farming shows — where you'll find us in person -->
  <section class="container-wccp py-16 md:py-20 section-reveal">
    <div class="max-w-3xl mb-10">
      <p class="eyebrow text-cast mb-3">On the road</p>
      <h2 class="font-display text-display-md text-forest-700 mb-4">Trade shows &amp; farming shows.</h2>
      <p class="text-cast-700 text-lg leading-relaxed">
        We turn up — every year, in person, with the kettle on. Across the summer Kim, Claire and
        the team work the county-show circuit from Devon to Yorkshire and the Royal Welsh, and
        across the winter we are at LAMMA, Dairy-Tech and the West Country Farming &amp; Machinery
        Show. If you would like to talk slurry, cubicles, panels or a one-off bespoke piece face to
        face, the show stand is the right place. Bring drawings, bring photos, bring questions.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
      {shows.map((s) => (
        <figure class="card overflow-hidden flex flex-col">
          <div class="aspect-[4/3] bg-cast-100 overflow-hidden">
            <picture>
              <source srcset={s.imageWebp} type="image/webp" />
              <img src={s.image} alt={s.alt} class="w-full h-full object-cover" loading="lazy" decoding="async" />
            </picture>
          </div>
          <figcaption class="p-5 flex-1 flex flex-col">
            <p class="font-display text-lg font-bold text-forest-700">{s.name}</p>
            <p class="text-cast-700 text-sm leading-relaxed mt-1">{s.body}</p>
          </figcaption>
        </figure>
      ))}
    </div>

    <p class="text-cast text-sm mt-6 max-w-3xl">
      Confirmed 2026 dates and stand numbers go up on the <a href="/news" class="text-terracotta font-semibold hover:underline">news page</a>
      ahead of each show. Drop us a line if you want to book a slot at the stand and we will hold a
      space.
    </p>
  </section>

  <!-- Local roots — sponsorships, schools, biogas neighbour -->
  <section class="bg-cream-200 py-16 md:py-20 section-reveal">
    <div class="container-wccp">
      <div class="grid lg:grid-cols-3 gap-8">
        <div class="card p-6 border-l-4 border-terracotta">
          <p class="eyebrow text-cast mb-2">Local sponsorships</p>
          <h3 class="font-display text-xl font-bold text-forest-700 mb-2">North Devon farming community.</h3>
          <p class="text-cast-700 leading-relaxed">
            We back the North Devon Show every year and contribute to local young-farmer clubs,
            ploughing matches and dairy discussion groups. If you run a North Devon farming
            initiative and need a hand, please ask — we'd rather say yes when we can.
          </p>
        </div>

        <div class="card p-6 border-l-4 border-terracotta">
          <p class="eyebrow text-cast mb-2">Schools &amp; apprenticeships</p>
          <h3 class="font-display text-xl font-bold text-forest-700 mb-2">Open days &amp; training routes.</h3>
          <p class="text-cast-700 leading-relaxed">
            We run open days for North Devon schools and back local apprentices through the casting
            and HGV-driving routes. We recently funded one of our drivers, Jake, through his C+E
            ticket because the right person was worth the time.
          </p>
        </div>

        <div class="card p-6 border-l-4 border-terracotta">
          <p class="eyebrow text-cast mb-2">Severn Trent neighbour</p>
          <h3 class="font-display text-xl font-bold text-forest-700 mb-2">The biogas plant next door.</h3>
          <p class="text-cast-700 leading-relaxed">
            Across the road sits the Holsworthy Biogas Plant, run by Severn Trent Green Power. They
            turn farm slurry into renewable electricity; we cast the AD-plant components that hold
            it. Two businesses doing complementary work for the same farms — a circular relationship
            that suits the area.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="container-wccp py-16 md:py-20 section-reveal">
    <div class="max-w-3xl">
      <p class="eyebrow text-cast mb-3">Talk to us</p>
      <h2 class="font-display text-display-md text-forest-700 mb-4">If something at the yard concerns you, call.</h2>
      <p class="text-cast-700 text-lg leading-relaxed mb-6">
        The yard phone is answered by yard staff in working hours and by our director out of hours.
        It is not a call centre. If a lorry movement, noise event or dust issue worries you, the
        fastest way to fix it is to ring.
      </p>
      <div class="bg-forest-700 text-cream p-8 rounded-lg max-w-2xl">
        <p class="eyebrow text-cream/70 mb-2">Direct line</p>
        <a href={`tel:${site.contact.phoneIntl}`} class="font-display text-3xl text-cream hover:text-terracotta block mb-3">{site.contact.phone}</a>
        <p class="text-cream/85 text-sm leading-relaxed">
          Mon–Fri working hours, with an out-of-hours number on the answerphone.<br />
          {site.address.street}, {site.address.locality}, {site.address.town}, {site.address.postcode}
        </p>
      </div>
    </div>
  </section>

  <section class="bg-forest-700 text-cream py-16">
    <div class="container-wccp text-center max-w-2xl mx-auto">
      <h2 class="font-display text-display-md text-cream mb-3">Made in Devon. Made for Devon.</h2>
      <p class="text-cream/85 mb-8">Family-led, fifty-plus years of casting concrete on the Devon / Cornwall border.</p>
      <div class="flex flex-wrap justify-center gap-3">
        <a href="/about" class="btn-primary">Read our story</a>
        <a href="/team" class="btn-yellow">Meet the team</a>
      </div>
    </div>
  </section>
</BaseLayout>
