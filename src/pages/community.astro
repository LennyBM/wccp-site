---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { site } from '@/config/site';

const commitments = [
  { title: 'Yard hours', body: 'Mon–Fri 7am–5pm, Sat 7am–12pm. No HGV movements before 7am or after 6pm. Sundays and bank holidays no movements.' },
  { title: 'Dust suppression', body: 'Yard sweeper twice a day, water bowser on hardstanding in dry weather, all aggregate stockpiles bunded and covered. /* CLIENT: confirm exact dust-control method */' }, // CLIENT: confirm
  { title: 'Noise commitment', body: 'No loud plant before 7am. Concrete batching and pour scheduled to working hours. Reversing alarms on lorries set to broadband (white-noise) where local noise is a concern.' }, // CLIENT: confirm
  { title: 'Traffic', body: 'HGV routing agreed with Devon County Council uses the A388 and avoids the village centre. Drivers briefed on the route every quarter.' }, // CLIENT: confirm route specifics
  { title: 'Local employment', body: '46 jobs created on the move to Chilsworthy in 2023. Over 90% of the team live within 15 miles of Holsworthy. We back local apprentices and run open days for North Devon schools.' },
  { title: 'Direct line', body: `If something at the yard concerns you — noise, dust, traffic, lorry movements — please call us directly on ${site.contact.phone}. The phone is answered by the yard, not a call centre.` },
];
---

<BaseLayout
  title="Cast in Chilsworthy. Built for the community."
  description="WCCP at Chilsworthy — yard hours, dust and noise commitments, local employment, direct contact line. The good-neighbour page for our Holsworthy neighbours."
>
  <section class="bg-forest-700 text-cream">
    <div class="container-wccp py-20 md:py-28">
      <p class="eyebrow text-cream/70 mb-4">Good neighbour · Chilsworthy</p>
      <h1 class="font-display text-display-2xl text-cream mb-6 max-w-4xl">
        Cast in Chilsworthy.<br />
        <em class="text-terracotta not-italic font-display italic">Built for the community.</em>
      </h1>
      <p class="text-cream/85 text-lg leading-relaxed max-w-2xl">
        We moved the yard to Chilsworthy in 2023. That's a real change for the village, and we
        take being a good neighbour seriously. This page sets out how we operate and how to
        reach us if there's a problem.
      </p>
    </div>
  </section>

  <section class="container-wccp py-16 md:py-20 section-reveal">
    <div class="max-w-3xl mb-12">
      <p class="eyebrow text-cast mb-3">Our commitments</p>
      <h2 class="font-display text-display-md text-forest-700 mb-4">How the yard runs.</h2>
      <p class="text-cast-700 text-lg leading-relaxed">
        Six commitments we make to the village and the wider Chilsworthy / Holsworthy area.
        If any of these slips, we want to know.
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-6 max-w-4xl">
      {commitments.map((c) => (
        <div class="card p-6 border-l-4 border-terracotta">
          <h3 class="font-display text-xl font-bold text-forest-700 mb-2">{c.title}</h3>
          <p class="text-cast-700 leading-relaxed">{c.body}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="bg-cream-200 py-16 md:py-20 section-reveal">
    <div class="container-wccp">
      <div class="grid lg:grid-cols-2 gap-10 items-start">
        <div>
          <p class="eyebrow text-cast mb-3">Local employment</p>
          <h2 class="font-display text-display-md text-forest-700 mb-4">46 jobs, mostly within 15 miles.</h2>
          <p class="text-cast-700 text-lg leading-relaxed mb-4">
            The Chilsworthy move created 46 jobs in 2023 — drivers, batchers, fitters, design
            engineers, yard hands and admin. Over 90% of those roles are filled by people living
            within 15 miles of the yard.
          </p>
          <p class="text-cast-700 text-lg leading-relaxed">
            We host open days for North Devon schools and back local apprentices through the
            casting and HGV-driving routes. If you know someone looking for an apprenticeship,
            we are always glad of a CV.
          </p>
          <div class="mt-6 flex flex-wrap gap-3">
            <a href="/careers" class="btn-primary">See current vacancies</a>
            <a href="/about" class="btn-yellow">Our story</a>
          </div>
        </div>
        <div class="aspect-[4/3] bg-cast-100 rounded overflow-hidden">
          <img src="/images/factory/wccp-yard-hero.jpg" alt="The WCCP yard at Chilsworthy, Holsworthy — Devon precast concrete works"
               class="w-full h-full object-cover" loading="lazy" decoding="async" />
          <!-- CLIENT: confirm yard / fence-line photo of choice -->
        </div>
      </div>
    </div>
  </section>

  <section class="container-wccp py-16 md:py-20 section-reveal">
    <div class="max-w-3xl">
      <p class="eyebrow text-cast mb-3">Talk to us</p>
      <h2 class="font-display text-display-md text-forest-700 mb-4">If something at the yard concerns you, call.</h2>
      <p class="text-cast-700 text-lg leading-relaxed mb-6">
        The yard phone is answered by yard staff in working hours and by our director out of hours.
        It is not a call centre. If a lorry movement, noise event or dust issue worries you, the
        fastest way to fix it is to ring.
      </p>
      <div class="bg-forest-700 text-cream p-8 rounded-lg max-w-2xl">
        <p class="eyebrow text-cream/70 mb-2">Direct line</p>
        <a href={`tel:${site.contact.phoneIntl}`} class="font-display text-3xl text-cream hover:text-terracotta block mb-3">{site.contact.phone}</a>
        <p class="text-cream/85 text-sm leading-relaxed">
          Mon–Fri working hours, with an out-of-hours number on the answerphone.<br />
          {site.address.street}, {site.address.locality}, {site.address.town}, {site.address.postcode}
        </p>
      </div>
    </div>
  </section>

  <section class="bg-forest-700 text-cream py-16">
    <div class="container-wccp text-center max-w-2xl mx-auto">
      <h2 class="font-display text-display-md text-cream mb-3">Made in Devon. Made for Devon.</h2>
      <p class="text-cream/85 mb-8">Family-led, fifty-plus years of casting concrete on the Devon / Cornwall border.</p>
      <div class="flex flex-wrap justify-center gap-3">
        <a href="/about" class="btn-primary">Read our story</a>
        <a href="/team" class="btn-yellow">Meet the team</a>
      </div>
    </div>
  </section>
</BaseLayout>
