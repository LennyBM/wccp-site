---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ProductWarrantyLine from '@/components/ProductWarrantyLine.astro';
import TrustStrip from '@/components/TrustStrip.astro';
import FittedVsSupply from '@/components/FittedVsSupply.astro';
import SpecSheetButton from '@/components/SpecSheetButton.astro';
import ProductGallery from '@/components/ProductGallery.astro';
import { site } from '@/config/site';
import RelatedProductGrid from '@/components/RelatedProductGrid.astro';
import ProductPageTOC from '@/components/ProductPageTOC.astro';

const tocSections = [
  { id: 'overview', label: 'Overview' },
  { id: 'specifications', label: 'Specifications' },
  { id: 'gallery', label: 'Gallery' },
  { id: 'related', label: 'Related' },
  { id: 'faq', label: 'FAQ' },
  { id: 'downloads', label: 'Downloads' },
];

// Cattle grids — highway-grade BS EN 1991-2, HB37.5 loadings.
const specs = [
  { variant: 'Standard Farm Grid 3.0m × 2.4m', bed: '3000 × 2400 × 600mm pit', style: 'Galvanised top bars · concrete base unit', use: 'Farm entrances and field gate replacements' },
  { variant: 'Standard Farm Grid 3.6m × 2.4m', bed: '3600 × 2400 × 600mm pit', style: 'Galvanised top bars · wider span', use: 'Farm yards and double-track entrances' },
  { variant: 'Highway Grid 4.0m × 2.4m', bed: '4000 × 2400 × 750mm pit', style: 'BS EN 1991-2 HB37.5 · highway-grade', use: 'County and rural-road cattle grids' },
  { variant: 'Estate Grid 5.0m × 3.0m', bed: '5000 × 3000 × 750mm pit', style: 'Heavy-duty highway · 40-tonne rated', use: 'A-roads, estate boundaries, NFA hauliers' },
  { variant: 'Bespoke Cattle Grid', bed: 'To suit road width', style: 'Engineer-detailed for the loading', use: 'Bespoke widths and specialist applications' },
];

const applications = [
  'Farm entrances replacing field gates',
  'County-road cattle grids on rural moorland and common land',
  'National Park access points (Dartmoor, Exmoor, Lake District, Brecon)',
  'Highways England and Welsh Government A-road improvements',
  'Estate boundaries and shooting-ground access tracks',
  'Forestry Commission and woodland access roads',
  'Agricultural vehicle routes — 40-tonne tractor and trailer rated',
];

const related = [
  { href: '/products/culverts', label: 'Culverts', meta: 'Reinforced precast · DMRB CD 360' },
  { href: '/products/headwalls-wing-walls', label: 'Headwalls & Wing Walls', meta: 'CIRIA C786 · 600–3000mm' },
  { href: '/products/kerbs', label: 'Kerbs', meta: 'BS EN 1340 · highway-grade' },
  { href: '/products/soakaways-chambers', label: 'Soakaways & Chambers', meta: 'BS EN 1917 · drainage' },
];

const faqs = [
  { q: 'What loading do they take?', a: 'Our farm grids are rated to BS EN 1991-2 LM1 — that covers any normal agricultural vehicle including a fully-loaded 40-tonne articulated lorry. Highway-grade grids on county and A-roads carry HB37.5 (the abnormal load case for heavy hauliers). The structural calc comes signed off with the order.' },
  { q: 'How deep is the pit?', a: '600mm minimum for a farm grid, 750mm for a highway-grade. The pit depth keeps the cattle from stepping across — anything shallower and a determined heifer will work it out within a fortnight. We supply a precast pit base as part of the package or detail to suit a poured-in-situ base.' },
  { q: 'How do you stop the pit filling with mud?', a: 'A perforated drainage pipe in the base, falling to a soakaway or ditch outfall, plus a hinged maintenance grille at one end so you can rake out twice a year. CIRIA C786 detailing applies where the grid drains to a watercourse.' },
  { q: 'Do they need a side gate?', a: 'Yes — the highway and bridleway code requires a pedestrian and equestrian bypass alongside any cattle grid. We supply matching galvanised gates and bypass kerbs as part of the package, sized to BHS guidance for horse-and-rider bypass.' },
  { q: 'What is the lead time?', a: 'Catalogue farm grids run 4 to 6 weeks. Highway and estate-grade grids 6 to 10 weeks because the structural sign-off is more involved. Highways England and county council adoption schemes add 2 weeks for client design approval.' },
];

const productSchema = {
  name: 'Precast Cattle Grids',
  description: 'Highway-grade precast cattle grids for farm entrances and rural roads. Cast to BS EN 1991-2 LM1 and HB37.5 loadings. Galvanised top bars, integral pit base. Cast at our Holsworthy yard.',
  brand: { '@type': 'Brand', name: site.name },
  manufacturer: { '@type': 'Organization', name: site.name },
  category: 'Precast concrete cattle grid',
  material: 'Reinforced concrete, C40/50 (BS 8500-1:2023) with galvanised steel top bars',
  additionalProperty: [
    { '@type': 'PropertyValue', name: 'Loading standard', value: 'BS EN 1991-2 LM1 (farm) / HB37.5 (highway)' },
    { '@type': 'PropertyValue', name: 'Concrete grade', value: 'C40/50 (BS 8500-1:2023)' },
    { '@type': 'PropertyValue', name: 'Top bar coating', value: 'Hot-dip galvanised to BS EN ISO 1461' },
    { '@type': 'PropertyValue', name: 'Standard widths', value: '3.0m, 3.6m, 4.0m, 5.0m + bespoke' },
    { '@type': 'PropertyValue', name: 'Pit depth', value: '600mm farm / 750mm highway' },
    { '@type': 'PropertyValue', name: 'Bypass gate', value: 'Pedestrian and equestrian bypass supplied' },
    { '@type': 'PropertyValue', name: 'Lead time', value: '4–6 weeks farm, 6–10 weeks highway' },
    { '@type': 'PropertyValue', name: 'Country of origin', value: 'United Kingdom (Devon)' },
  ],
  offers: { '@type': 'Offer', availability: 'https://schema.org/InStock', areaServed: 'GB', seller: { '@type': 'Organization', name: site.name } },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<BaseLayout
  title="Cattle Grids — Highway-grade precast · BS EN 1991-2 HB37.5"
  description="Highway-grade precast cattle grids for farm entrances and rural roads. BS EN 1991-2 LM1 and HB37.5 loadings. Galvanised top bars, precast pit. Cast in North Devon."
  image="/og/home.png"
  schema="Product"
  schemaData={productSchema}
  whatsappContext="Cattle Grids"
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)} slot="head" />
  <TrustStrip />
  <ProductPageTOC sections={tocSections} />

  <!-- Hero -->
  <section id="overview" class="bg-navy text-white">
    <div class="container-wccp py-16 md:py-20">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <p class="eyebrow text-yellow mb-4">Civils · highways · agricultural</p>
          <h1 class="font-display text-display-xl text-white mb-4">Cattle Grids.</h1>
          <p class="font-display italic text-xl md:text-2xl text-yellow leading-tight mb-5">No gate. No latch. No livestock on the road.</p>
          <p class="text-lg lg:text-xl text-cast leading-relaxed font-medium text-white/95 mb-6 max-w-xl">
            Highway-grade precast cattle grids for farm entrances, county roads and estate
            boundaries. Cast to BS EN 1991-2 LM1 (farm) and HB37.5 (highway) loadings.
            Galvanised steel top bars on a reinforced precast pit. Catalogue widths 3m to 5m,
            bespoke to suit. Civils lead time 4-6 weeks.
          </p>
          <blockquote class="font-display italic text-base md:text-lg text-white/95 leading-relaxed mb-6 pl-4 border-l-2 border-yellow max-w-xl">
            A cattle grid is a road-spanning frame of parallel bars over a pit, designed so
            vehicles cross unimpeded but cattle, sheep and ponies will not. UK highway grids
            carry BS EN 1991-2 LM1 and HB37.5 loads. WCCP cast the precast pit and supply
            the galvanised top frame as a single delivered package.
          </blockquote>
          <p class="text-base text-white/85 leading-relaxed mb-6 max-w-xl">
            We cast and deliver across the UK from the Holsworthy yard. Used on Dartmoor,
            Exmoor, the Brecon Beacons, the Lake District and county roads in between.
          </p>
          <ul class="grid grid-cols-2 gap-3 text-sm mb-8 max-w-md">
            <li class="flex gap-2"><span class="text-yellow">·</span> BS EN 1991-2</li>
            <li class="flex gap-2"><span class="text-yellow">·</span> HB37.5 highway</li>
            <li class="flex gap-2"><span class="text-yellow">·</span> Galvanised top bars</li>
            <li class="flex gap-2"><span class="text-yellow">·</span> Precast pit base</li>
            <li class="flex gap-2"><span class="text-yellow">·</span> Bypass gate inc.</li>
            <li class="flex gap-2"><span class="text-yellow">·</span> 4–6 week lead</li>
          </ul>
          <div class="flex flex-wrap gap-3">
            <a href="/quote?product=Cattle%20Grids" class="btn-primary">Configure a quote</a>
            <a href="mailto:engineering@wccp.co.uk?subject=Spec%20sheet%20request%20%E2%80%94%20Cattle%20Grids&amp;body=Hi%20WCCP%20engineering%2C%0A%0APlease%20send%20the%20spec%20sheet%20for%20Cattle%20Grids.%0A%0AProject%20details%3A%0A%E2%80%A2%20Project%20name%3A%0A%E2%80%A2%20Site%20location%3A%0A%E2%80%A2%20Required%20spec%20%2F%20standard%3A%0A%0AThanks" class="btn-yellow">Request spec sheet</a>
            <a href={`tel:${site.contact.phoneIntl}`} class="btn-ghost border-white text-white hover:bg-white hover:text-navy">
              Call {site.contact.phone}
            </a>
          </div>
        </div>
        <div class="aspect-[4/3] bg-cast-100 rounded overflow-hidden flex items-center justify-center border-2 border-dashed border-cast-300 p-8 text-center">
          <div>
            <p class="text-cast-600 text-sm font-mono">ðŸ“· Photo needed</p>
            <p class="text-cast text-xs mt-2">Hero shot — installed cattle grid on a Dartmoor or Exmoor road, three-quarter view showing top bars, pit, side bypass gate and rural setting</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Spec table -->
  <section id="specifications" class="container-wccp py-20">
    <div class="max-w-2xl mb-10">
      <p class="eyebrow text-cast mb-3">Specification</p>
      <h2 class="font-display text-display-lg mb-4">Widths, loadings and pit depths.</h2>
      <p class="text-cast-700 text-lg">
        Catalogue widths from 3m to 5m, with farm and highway loading options. Bespoke
        widths and heavier loadings detailed by our consulting engineer.
      </p>
    </div>

    <div class="overflow-x-auto">
      <table class="spec-table w-full text-left border-collapse">
        <thead class="bg-navy text-white">
          <tr>
            <th class="px-4 py-3 font-display text-sm uppercase tracking-wide">Variant</th>
            <th class="px-4 py-3 font-display text-sm uppercase tracking-wide">Dimensions</th>
            <th class="px-4 py-3 font-display text-sm uppercase tracking-wide">Detail</th>
            <th class="px-4 py-3 font-display text-sm uppercase tracking-wide">Typical use</th>
          </tr>
        </thead>
        <tbody>
          {specs.map((s, i) => (
            <tr class={i % 2 === 0 ? 'bg-white' : 'bg-bone-200'}>
              <td class="px-4 py-3 font-bold text-navy">{s.variant}</td>
              <td class="px-4 py-3">{s.bed}</td>
              <td class="px-4 py-3">{s.style}</td>
              <td class="px-4 py-3 text-cast">{s.use}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    <p class="text-cast text-sm mt-4">
      Top bars are 75mm × 50mm hollow section, hot-dip galvanised to BS EN ISO 1461, set
      at 125mm centres — proven to deter cattle, sheep and ponies. Bypass gate matches.
    </p>
  </section>

  <!-- Gallery -->
  <section id="gallery" class="bg-bone-200 py-20">
    <div class="container-wccp">
      <div class="max-w-2xl mb-10">
        <p class="eyebrow text-cast mb-3">The range</p>
        <h2 class="font-display text-display-lg mb-4 text-navy">Cattle grids in service.</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {[
          'Highway-grade cattle grid installed on a county road in Devon',
          'Galvanised top bars detail — close-up of bar spacing',
          'Precast pit being lifted into excavated formation by 50t crane',
          'Pedestrian and equestrian bypass gate alongside the grid',
          'Drainage detail — perforated pipe in the pit base',
          'Estate-grade 5m grid at a National Park boundary',
          'Cross-section drawing of grid, pit and bypass',
          'Yard storage — galvanised top frames stacked at Holsworthy',
        ].map((d) => (
          <figure>
            <div class="aspect-[4/3] bg-cast-100 rounded overflow-hidden flex items-center justify-center border-2 border-dashed border-cast-300 p-8 text-center">
              <div>
                <p class="text-cast-600 text-sm font-mono">ðŸ“· Photo needed</p>
                <p class="text-cast text-xs mt-2">{d}</p>
              </div>
            </div>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- Applications -->
  <section class="bg-white py-20">
    <div class="container-wccp">
      <div class="grid lg:grid-cols-2 gap-12">
        <div>
          <p class="eyebrow text-cast mb-3">Where they go</p>
          <h2 class="font-display text-display-lg mb-6">Common applications.</h2>
          <p class="text-cast-700 text-lg leading-relaxed mb-6">
            From a single-track farm entrance in West Devon to a 5m highway grid at a
            National Park boundary, the engineering scales — and the precast pit and
            galvanised top frame come from the same Holsworthy yard.
          </p>
          <ul class="space-y-3">
            {applications.map((a) => (
              <li class="flex gap-3 text-cast-700 leading-relaxed">
                <span class="text-ember font-bold mt-1">·</span>
                <span>{a}</span>
              </li>
            ))}
          </ul>
        </div>

        <div class="card p-8">
          <p class="eyebrow text-cast mb-3">Standards & references</p>
          <h3 class="font-display text-2xl font-bold text-navy mb-4">Cast and detailed to current best practice.</h3>
          <dl class="space-y-4 text-sm">
            <div>
              <dt class="font-bold text-navy">BS EN 1991-2:2003+A1:2010</dt>
              <dd class="text-cast">Eurocode 1 — actions on structures, traffic loads on bridges and similar structures.</dd>
            </div>
            <div>
              <dt class="font-bold text-navy">DMRB CD 357</dt>
              <dd class="text-cast">Design Manual for Roads and Bridges — cattle grid design and loading requirements.</dd>
            </div>
            <div>
              <dt class="font-bold text-navy">BS 8500-1:2023</dt>
              <dd class="text-cast">Concrete specification — C40/50 mix for the buried pit structure.</dd>
            </div>
            <div>
              <dt class="font-bold text-navy">BS EN ISO 1461</dt>
              <dd class="text-cast">Hot-dip galvanising — coating thickness on the steel top frame and bypass gate.</dd>
            </div>
            <div>
              <dt class="font-bold text-navy">BHS Bypass Guidance</dt>
              <dd class="text-cast">British Horse Society — pedestrian and equestrian bypass dimensions and gate requirements.</dd>
            </div>
          </dl>
        </div>
      </div>
    </div>
  </section>

  <!-- Configurator CTA -->
  <section class="bg-yellow text-navy py-16">
    <div class="container-wccp">
      <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6">
        <div>
          <p class="eyebrow text-navy mb-2">Configure your grid</p>
          <h2 class="font-display text-display-md">Send road width, loading class and access — we will quote inside 48 hours.</h2>
        </div>
        <div class="flex flex-wrap gap-3 shrink-0">
          <a href="/quote?product=Cattle%20Grids" class="btn bg-navy text-white hover:bg-navy-700">Open the configurator</a>
          <a href={`mailto:${site.contact.quotesEmail}`} class="btn-secondary">Email quotes</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Related -->
  <section id="related" class="container-wccp py-20">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between mb-10 gap-4">
      <div>
        <p class="eyebrow text-cast mb-3">Related products</p>
        <h2 class="font-display text-display-lg">Often ordered alongside.</h2>
      </div>
      <a href="/products" class="text-ember font-bold hover:text-ember-700 inline-flex items-center gap-2">
        View full range
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <line x1="5" y1="12" x2="19" y2="12" stroke-linecap="round" />
          <polyline points="12 5 19 12 12 19" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </a>
    </div>
    <RelatedProductGrid items={related} />
  </section>

  <!-- FAQ -->
  <section id="faq" class="bg-bone-200 py-20">
    <div class="container-wccp">
      <div class="max-w-2xl mb-12">
        <p class="eyebrow text-cast mb-3">Common questions</p>
        <h2 class="font-display text-display-lg mb-4">What people ask about cattle grids.</h2>
        <p class="text-cast-700 text-lg">
          Five questions we answer most weeks. If yours is not here, ring the yard.
        </p>
      </div>
      <div class="max-w-3xl space-y-4">
        {faqs.map((f) => (
          <details class="card p-6 group">
            <summary class="font-display text-lg font-bold text-navy cursor-pointer list-none flex justify-between items-start gap-4">
              <span>{f.q}</span>
              <span class="text-ember text-2xl leading-none group-open:rotate-45 transition-transform shrink-0">+</span>
            </summary>
            <p class="text-cast-700 leading-relaxed mt-4">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Supply-only vs Fitted -->
  <section class="container-wccp section-rhythm border-t border-cast-100">
    <FittedVsSupply
      productName="Cattle Grids"
      defaultMode="supply"
      supply={{
        price: 'Bespoke quote',
        leadTime: '4–6 weeks',
        includes: [
          'Precast pit unit cast in C40/50',
          'Galvanised steel top frame and bars',
          'Pedestrian and equestrian bypass gate',
          'Structural calcs and delivery on our HIAB',
        ],
        excludes: [
          'Excavation and base concrete',
          'Drainage outfall and surfacing reinstatement',
        ],
      }}
      fitted={{
        price: 'Bespoke quote (incl. install)',
        leadTime: '6–10 weeks (incl. site slot)',
        includes: [
          'Everything in supply only',
          'CSCS-carded install crew with crane',
          'Drainage make-up and bypass gate fit',
          '12-month workmanship warranty',
        ],
        excludes: [
          'Excavation, base concrete and tarmac surfacing',
          'Highway closure, traffic management and adoption fees',
        ],
      }}
      note=". Highway-adopted cattle grids and Highways England schemes priced individually — send the long-section and loading class and we'll come back within two working days."
    />
  </section>

  <!-- Final CTA -->
  <section class="bg-navy text-white py-20">
    <div class="container-wccp text-center">
      <h2 class="font-display text-display-xl mb-4 text-white">Ready to spec it?</h2>
      <p class="text-white/90 text-lg max-w-xl mx-auto mb-8">
        Send us road width, loading class and a site sketch. Quote within 48 hours.
      </p>
      <div class="flex flex-wrap justify-center gap-3">
        <a href="/quote?product=Cattle%20Grids" class="btn-yellow">Configure a quote</a>
        <a href={`tel:${site.contact.phoneIntl}`} class="btn-secondary">Call {site.contact.phone}</a>
        <a href={`mailto:${site.contact.quotesEmail}`} class="btn-primary">Email quotes</a>
      </div>
    </div>
  </section>

  <SpecSheetButton productSlug="cattle-grids" productName="Cattle Grids" />
  <ProductWarrantyLine />
</BaseLayout>
