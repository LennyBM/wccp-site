---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ProductWarrantyLine from '@/components/ProductWarrantyLine.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import CTAStrip from '@/components/CTAStrip.astro';
import RelatedProductGrid from '@/components/RelatedProductGrid.astro';
import { site } from '@/config/site';

const components = [
  {
    title: 'Tank panels',
    body: 'Prestressed precast wall panels for digester tanks and digestate stores. Cast in C40/50 sulphate-resisting (CEM III/A available). Up to 10 m unsupported span; CE/UKCA marked to BS EN 14992.',
  },
  {
    title: 'Slurry & digestate channels',
    body: 'Precast channel sections, slats and covers for digestate handling. Sized to BS EN 12737 with cover loadings to suit yard traffic.',
  },
  {
    title: 'Retaining walls',
    body: 'L-blocks, T-blocks and cantilever retaining walls for feedstock bays, push walls and clamp areas. Surcharge-rated to your engineer\'s schedule.',
  },
  {
    title: 'Hardstanding bases',
    body: 'Heavy-duty precast hardstanding for separator units, pump skids and CHP enclosures. Levelled to manufacturer template.',
  },
];

const related = [
  { href: '/products/prestressed-panels', label: 'Prestressed Wall Panels', meta: 'BS EN 14992 · 100/150/180/280 mm · 10 m span' },
  { href: '/products/slurry-storage', label: 'Slurry Storage', meta: 'SSAFO 2018-ready · grant-friendly' },
  { href: '/products/retaining-walls', label: 'Retaining Walls', meta: 'L-block, cantilever, surcharge to spec' },
  { href: '/sectors/civils', label: 'Civils sector', meta: 'Adoptable, Eurocode 2, full schedule' },
];
---

<BaseLayout
  title="AD Plant Precast Components — Anaerobic Digestion infrastructure"
  description="Precast concrete tank panels, channels, retaining walls and hardstanding bases for the UK's anaerobic digestion plants. Cast next door to Severn Trent's Holsworthy biogas plant — the UK's first food-waste AD site."
  schema="Product"
>
  <!-- Hero -->
  <section class="relative bg-navy-700 text-white overflow-hidden">
    <div aria-hidden="true" class="absolute inset-0 grid-pattern opacity-30"></div>
    <div class="relative container-wccp py-12 lg:py-16">
      <div class="mb-10">
        <Breadcrumbs items={[{ label: 'Products', href: '/products' }, { label: 'AD plant components' }]} variant="navy" />
      </div>
      <div class="grid lg:grid-cols-12 gap-10 items-end">
        <div class="lg:col-span-8">
          <p class="eyebrow text-yellow mb-6">Civils &middot; Anaerobic Digestion &middot; Renewable Infrastructure</p>
          <h1 class="font-display text-display-2xl text-white mb-5">
            Precast for the UK's <span class="text-yellow">720 anaerobic digestion plants</span>.
          </h1>
          <p class="font-display italic text-xl md:text-2xl text-yellow leading-tight mb-6 max-w-2xl">
            Cast next door to the UK's first food-waste biogas plant — Severn Trent's Holsworthy site.
          </p>
          <p class="text-base lg:text-lg text-white/85 leading-relaxed max-w-2xl mb-8">
            Tank panels, slurry channels, retaining walls and hardstanding bases — supplied to AD
            operators, EPC contractors and farm-scale builders nationwide. We know the kit because
            we sit beside one of the biggest AD plants in the country.
          </p>
          <div class="flex flex-wrap gap-3">
            <a href="/quote?product=AD%20plant%20components" class="btn-primary">Configure a quote</a>
            <a href={`tel:${site.contact.phoneIntl}`} class="btn-yellow">Call {site.contact.phone}</a>
          </div>
        </div>
        <div class="lg:col-span-4 lg:pb-2">
          <p class="text-white/70 text-sm leading-relaxed">
            38 new on-farm AD builds went live across the UK in 2025 alone. The next decade of
            renewable-gas infrastructure is being cast right now — concrete is on the critical path.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- What we supply -->
  <section class="container-wccp section-rhythm">
    <div class="max-w-2xl mb-12">
      <p class="eyebrow text-cast mb-3">What we supply</p>
      <h2 class="font-display text-display-lg">The four families AD operators ask for.</h2>
    </div>
    <div class="grid md:grid-cols-2 gap-4">
      {components.map((c) => (
        <div class="card p-7">
          <h3 class="font-display text-display-sm text-navy-700 mb-3">{c.title}</h3>
          <p class="text-cast-700 leading-relaxed">{c.body}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Severn Trent neighbour story -->
  <section class="bg-bone-200 section-rhythm">
    <div class="container-wccp">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <p class="eyebrow text-cast mb-3">The neighbour story</p>
          <h2 class="font-display text-display-lg mb-5">A circular-economy site, by design.</h2>
          <p class="text-cast-700 text-lg leading-relaxed mb-5">
            The Chilsworthy yard sits adjacent to the Holsworthy Biogas Plant, owned by
            <strong class="text-navy-700">Severn Trent Green Power</strong> — the FTSE-100
            utility's renewable arm. Food-waste digestate one side of the fence, precast concrete
            the other.
          </p>
          <p class="text-cast-700 text-lg leading-relaxed">
            We don't just supply the AD industry. We live next to it. That informs every spec we
            quote — corrosion exposure, traffic loadings, hatch detailing, deck tolerances.
          </p>
        </div>
        <div class="card p-8 bg-white">
          <p class="eyebrow text-ember mb-3">Standards</p>
          <ul class="space-y-3 text-cast-700">
            <li><strong class="text-navy-700">BS EN 14992</strong> — precast concrete wall elements (CE/UKCA marking)</li>
            <li><strong class="text-navy-700">BS 8500-1:2023</strong> — concrete specification, including XA exposure classes</li>
            <li><strong class="text-navy-700">BS EN 1992-3</strong> — design of liquid-retaining structures</li>
            <li><strong class="text-navy-700">SSAFO 2018</strong> — silage, slurry and agricultural fuel oil regulations (England)</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Related -->
  <section id="related" class="container-wccp section-rhythm">
    <div class="max-w-2xl mb-10">
      <p class="eyebrow text-cast mb-3">Related</p>
      <h2 class="font-display text-display-lg">Other things we cast for AD operators.</h2>
    </div>
    <RelatedProductGrid items={related} />
  </section>

  <CTAStrip
    eyebrow="Talk to the yard"
    title="One supplier. Tank panels, channels, walls, bases."
    description="Quoted off your engineer's schedule. Delivered on our own HIAB fleet. Cast in Devon, beside the biogas plant."
    primaryCta={{ href: '/quote?product=AD%20plant%20components', label: 'Configure a quote' }}
    secondaryCta={{ href: `tel:${site.contact.phoneIntl}`, label: `Call ${site.contact.phone}` }}
    variant="navy"
  />
  <ProductWarrantyLine />
</BaseLayout>
