---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TrustStrip from '@/components/TrustStrip.astro';
import { site } from '@/config/site';

const specs = [
  { variant: 'Holstein standard', bed: '2.4m × 1.2m', neckRail: '1.15m', brisket: '1.7m', weight: '95 kg/division', use: 'Mature dairy cows up to 750kg' },
  { variant: 'Holstein large', bed: '2.5m × 1.25m', neckRail: '1.20m', brisket: '1.75m', weight: '105 kg/division', use: 'Higher-yielding Holstein groups' },
  { variant: 'Jersey / Friesian', bed: '2.2m × 1.1m', neckRail: '1.05m', brisket: '1.55m', weight: '85 kg/division', use: 'Jersey and smaller Friesian cows' },
  { variant: 'Beef suckler', bed: '2.3m × 1.15m', neckRail: '1.10m', brisket: '1.60m', weight: '90 kg/division', use: 'Beef suckler cows and stores' },
  { variant: 'Youngstock', bed: '2.0m × 1.0m', neckRail: '0.95m', brisket: '1.40m', weight: '70 kg/division', use: 'Heifers 12–18 months' },
  { variant: 'Portable cantilever', bed: '2.4m × 1.2m', neckRail: '1.15m (adj.)', brisket: '1.7m', weight: '180 kg/unit', use: 'Reroofed barns, retro-fits, lets' },
];

const applications = [
  'Loose-housed dairy parlours retro-fitted with cubicles',
  'New-build robotic milking sheds — DeLaval, Lely, GEA',
  'Beef suckler housing on grant-funded steel-frame buildings',
  'Heifer rearing units with grouped age bands',
  'Tenanted units needing portable, removable cubicle rows',
  'Calving and dry-cow accommodation with wider beds',
  'Conversions of straw-yard buildings to cubicle bedding',
];

const related = [
  { href: '/products/cubicle-end-walls', label: 'Cubicle End Walls', meta: 'Single + double row · trough option' },
  { href: '/products/water-troughs', label: 'Water Troughs', meta: 'Single + double row · 1300×600' },
  { href: '/products/milking-robot-bases', label: 'Milking Robot Bases', meta: 'DeLaval VMS · Lely Astronaut' },
  { href: '/products/slurry-storage', label: 'Slurry Storage', meta: 'SSAFO 2018-compliant' },
];

const faqs = [
  { q: 'What sizing do you follow for the cubicles?', a: 'We work to AHDB Dairy 2024 dimensions: 2.4m × 1.2m bed for the mature Holstein, neck rail at 1.15m, brisket board at 1.7m. Jersey, Friesian and beef variants follow the same logic, scaled by liveweight. We size on the heaviest 15% of the herd, not the average — that is the AHDB recommendation and it is what stops cubicle-rejection lameness.' },
  { q: 'Fixed or portable — which do I want?', a: 'Fixed cubicles bolt to a cast-in upstand or floor pocket and are the standard for new builds. Portable cantilever cubicles sit on a base rail and can be lifted out — they suit reroofed sheds, tenanted units and farms that want to flex bed numbers between groups. Portable units cost about 25% more per cubicle.' },
  { q: 'How long does install take?', a: 'A two-man crew with a HIAB sets a 60-cubicle row in a day on a flat slab. We deliver to programme, supply the install drawing and the bedding-mortar spec. We can also project-manage the install if you want a turn-key job — talk to the yard.' },
  { q: 'Do they suit a robot herd?', a: 'Yes — robot herds need the cubicle right because the cow chooses when to lie. We size to the higher-yielding 15%, set the neck rail forward, and use a soft brisket board so cows rise easily and head to the robot. Lely, DeLaval and GEA all publish cow-flow guides we work to.' },
  { q: 'What is the lead time?', a: 'Catalogue cubicle divisions ship in 2 to 3 weeks. Bespoke heights or finishes run 4 to 6 weeks. Spring and autumn are our busy seasons — get the order in early if your shed is going up to a programme.' },
];

const productSchema = {
  name: 'Precast Cattle Cubicles',
  description: 'Fixed and portable precast cattle cubicle systems sized to AHDB Dairy 2024 dimensions. Holstein, Jersey, Friesian, beef-suckler and youngstock variants. Cast at our Holsworthy yard in C40/50 concrete.',
  brand: { '@type': 'Brand', name: site.name },
  manufacturer: { '@type': 'Organization', name: site.name },
  category: 'Precast concrete cattle cubicle',
  material: 'Reinforced concrete, C40/50 (BS 8500-1:2023)',
  weight: {
    '@type': 'QuantitativeValue',
    minValue: 70,
    maxValue: 180,
    unitCode: 'KGM',
    unitText: 'kilogram per division',
  },
  additionalProperty: [
    { '@type': 'PropertyValue', name: 'Standard', value: 'BS 5502-22:2003 (agricultural buildings)' },
    { '@type': 'PropertyValue', name: 'Concrete grade', value: 'C40/50 (BS 8500-1:2023)' },
    { '@type': 'PropertyValue', name: 'Sizing reference', value: 'AHDB Dairy 2024 cubicle dimensions' },
    { '@type': 'PropertyValue', name: 'Standard bed size', value: '2.4m × 1.2m (Holstein)' },
    { '@type': 'PropertyValue', name: 'Neck rail height', value: '1.15m (Holstein standard)' },
    { '@type': 'PropertyValue', name: 'Brisket board position', value: '1.70m from kerb' },
    { '@type': 'PropertyValue', name: 'Variants', value: 'Holstein / Jersey / Beef / Youngstock / Portable' },
    { '@type': 'PropertyValue', name: 'Lead time', value: '2–3 weeks catalogue, 4–6 weeks bespoke' },
    { '@type': 'PropertyValue', name: 'Country of origin', value: 'United Kingdom (Devon)' },
  ],
  offers: {
    '@type': 'Offer',
    priceCurrency: 'GBP',
    availability: 'https://schema.org/InStock',
    seller: { '@type': 'Organization', name: site.name },
  },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<BaseLayout
  title="Cattle Cubicles — Fixed & Portable · AHDB 2024 sizing"
  description="Precast cattle cubicles to AHDB 2024 dimensions. Holstein 2.4m × 1.2m bed, neck rail 1.15m, brisket 1.7m. Jersey, beef and portable variants. Cast in North Devon."
  image="/images/products/cattle-cubicles.jpg"
  schema="Product"
  schemaData={productSchema}
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)} slot="head" />
  <TrustStrip />

  <!-- Hero -->
  <section class="bg-navy text-white">
    <div class="container-wccp py-16 md:py-20">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <p class="eyebrow text-yellow mb-4">Agricultural · dairy · beef</p>
          <h1 class="font-display text-display-xl text-white mb-4">Cattle Cubicles.</h1>
          <p class="text-lg text-white/90 leading-relaxed mb-6">
            Fixed and portable precast cubicle systems sized to AHDB 2024 dimensions.
            Holstein, Jersey, Friesian, beef-suckler and youngstock variants. We cast,
            deliver and install across the South West.
          </p>
          <ul class="grid grid-cols-2 gap-3 text-sm mb-8 max-w-md">
            <li class="flex gap-2"><span class="text-yellow">·</span> AHDB 2024 sized</li>
            <li class="flex gap-2"><span class="text-yellow">·</span> 2.4m × 1.2m bed</li>
            <li class="flex gap-2"><span class="text-yellow">·</span> Neck rail 1.15m</li>
            <li class="flex gap-2"><span class="text-yellow">·</span> Brisket 1.7m</li>
            <li class="flex gap-2"><span class="text-yellow">·</span> Fixed + portable</li>
            <li class="flex gap-2"><span class="text-yellow">·</span> 2–3 week lead</li>
          </ul>
          <div class="flex flex-wrap gap-3">
            <a href="/quote?product=Cattle+Cubicles" class="btn-primary">Configure a quote</a>
            <a href="/spec-sheets/cattle-cubicles.pdf" class="btn-yellow">Download spec sheet</a>
            <a href={`tel:${site.contact.phoneIntl}`} class="btn-ghost border-white text-white hover:bg-white hover:text-navy">
              Call {site.contact.phone}
            </a>
          </div>
        </div>
        <div class="aspect-[4/3] bg-cast-100 rounded overflow-hidden">
          <div class="w-full h-full bg-gradient-to-br from-cast-300 via-cast to-navy"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Spec table -->
  <section class="container-wccp py-20">
    <div class="max-w-2xl mb-10">
      <p class="eyebrow text-cast mb-3">Specification</p>
      <h2 class="font-display text-display-lg mb-4">Variants, sizing and weights.</h2>
      <p class="text-cast-700 text-lg">
        AHDB Dairy 2024 dimensions for the standard catalogue. Bespoke sizes — wider beds,
        adjusted neck-rail heights, dished kerb profiles — quoted on application.
      </p>
    </div>

    <div class="overflow-x-auto">
      <table class="spec-table w-full text-left border-collapse">
        <thead class="bg-navy text-white">
          <tr>
            <th class="px-4 py-3 font-display text-sm uppercase tracking-wide">Variant</th>
            <th class="px-4 py-3 font-display text-sm uppercase tracking-wide">Bed size</th>
            <th class="px-4 py-3 font-display text-sm uppercase tracking-wide">Neck rail</th>
            <th class="px-4 py-3 font-display text-sm uppercase tracking-wide">Brisket</th>
            <th class="px-4 py-3 font-display text-sm uppercase tracking-wide">Weight</th>
            <th class="px-4 py-3 font-display text-sm uppercase tracking-wide">Typical use</th>
          </tr>
        </thead>
        <tbody>
          {specs.map((s, i) => (
            <tr class={i % 2 === 0 ? 'bg-white' : 'bg-bone-200'}>
              <td class="px-4 py-3 font-bold text-navy">{s.variant}</td>
              <td class="px-4 py-3">{s.bed}</td>
              <td class="px-4 py-3">{s.neckRail}</td>
              <td class="px-4 py-3">{s.brisket}</td>
              <td class="px-4 py-3">{s.weight}</td>
              <td class="px-4 py-3 text-cast">{s.use}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <p class="text-cast text-sm mt-4">
      Size cubicles on the heaviest 15% of the herd, not the average — AHDB Dairy 2024 recommendation.
      We will size them with you against your milk records before you order.
    </p>
  </section>

  <!-- Applications -->
  <section class="bg-bone-200 py-20">
    <div class="container-wccp">
      <div class="grid lg:grid-cols-2 gap-12">
        <div>
          <p class="eyebrow text-cast mb-3">Where they go</p>
          <h2 class="font-display text-display-lg mb-6">Common applications.</h2>
          <p class="text-cast-700 text-lg leading-relaxed mb-6">
            From a 60-cow Devon dairy retrofit to a 400-cow robot shed in Somerset, we cast
            the same cubicle system — sized to your herd, delivered to your programme.
          </p>
          <ul class="space-y-3">
            {applications.map((a) => (
              <li class="flex gap-3 text-cast-700 leading-relaxed">
                <span class="text-ember font-bold mt-1">·</span>
                <span>{a}</span>
              </li>
            ))}
          </ul>
        </div>

        <div class="card p-8">
          <p class="eyebrow text-cast mb-3">Standards & references</p>
          <h3 class="font-display text-2xl font-bold text-navy mb-4">Cast and sized to current best practice.</h3>
          <dl class="space-y-4 text-sm">
            <div>
              <dt class="font-bold text-navy">AHDB Dairy 2024</dt>
              <dd class="text-cast">Cubicle dimensions guide — bed size, neck rail, brisket board sized to herd liveweight distribution.</dd>
            </div>
            <div>
              <dt class="font-bold text-navy">BS 5502-22:2003</dt>
              <dd class="text-cast">Buildings and structures for agriculture — cattle housing. Loadings and detailing.</dd>
            </div>
            <div>
              <dt class="font-bold text-navy">BS 8500-1:2023</dt>
              <dd class="text-cast">Concrete specification — C40/50 mix designed for the dairy environment.</dd>
            </div>
            <div>
              <dt class="font-bold text-navy">BS EN 13369</dt>
              <dd class="text-cast">Common rules for precast concrete products — factory production control.</dd>
            </div>
            <div>
              <dt class="font-bold text-navy">DEFRA Code of Recommendations</dt>
              <dd class="text-cast">Welfare of livestock — cattle. Stocking densities and lying-comfort guidance.</dd>
            </div>
          </dl>
        </div>
      </div>
    </div>
  </section>

  <!-- Configurator CTA -->
  <section class="bg-yellow text-navy py-16">
    <div class="container-wccp">
      <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6">
        <div>
          <p class="eyebrow text-navy mb-2">Configure your cubicle row</p>
          <h2 class="font-display text-display-md">Tell us herd size, breed and shed dimensions — we will quote inside 24 hours.</h2>
        </div>
        <div class="flex flex-wrap gap-3 shrink-0">
          <a href="/quote?product=Cattle+Cubicles" class="btn bg-navy text-white hover:bg-navy-700">Open the configurator</a>
          <a href={`mailto:${site.contact.quotesEmail}`} class="btn-secondary">Email quotes</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Related -->
  <section class="container-wccp py-20">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between mb-10 gap-4">
      <div>
        <p class="eyebrow text-cast mb-3">Related products</p>
        <h2 class="font-display text-display-lg">Often ordered alongside.</h2>
      </div>
      <a href="/products" class="text-ember font-bold hover:text-ember-700 inline-flex items-center gap-2">
        View full range
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <line x1="5" y1="12" x2="19" y2="12" stroke-linecap="round" />
          <polyline points="12 5 19 12 12 19" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </a>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
      {related.map((r) => (
        <a href={r.href} class="card p-5 group">
          <div class="aspect-[16/10] bg-cast-100 mb-4 rounded overflow-hidden">
            <div class="w-full h-full bg-gradient-to-br from-cast-200 to-cast-100"></div>
          </div>
          <h3 class="font-display text-base font-bold text-navy mb-1 group-hover:text-ember">{r.label}</h3>
          <p class="text-cast text-xs">{r.meta}</p>
        </a>
      ))}
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-bone-200 py-20">
    <div class="container-wccp">
      <div class="max-w-2xl mb-12">
        <p class="eyebrow text-cast mb-3">Common questions</p>
        <h2 class="font-display text-display-lg mb-4">What people ask about cubicles.</h2>
        <p class="text-cast-700 text-lg">
          Five questions we answer most weeks. If yours is not here, ring the yard.
        </p>
      </div>
      <div class="max-w-3xl space-y-4">
        {faqs.map((f) => (
          <details class="card p-6 group">
            <summary class="font-display text-lg font-bold text-navy cursor-pointer list-none flex justify-between items-start gap-4">
              <span>{f.q}</span>
              <span class="text-ember text-2xl leading-none group-open:rotate-45 transition-transform shrink-0">+</span>
            </summary>
            <p class="text-cast-700 leading-relaxed mt-4">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="bg-navy text-white py-20">
    <div class="container-wccp text-center">
      <h2 class="font-display text-display-xl mb-4 text-white">Ready to spec it?</h2>
      <p class="text-white/90 text-lg max-w-xl mx-auto mb-8">
        Send us herd size, breed and a sketch of the shed. Quote and lead-time same day.
      </p>
      <div class="flex flex-wrap justify-center gap-3">
        <a href="/quote?product=Cattle+Cubicles" class="btn-yellow">Configure a quote</a>
        <a href={`tel:${site.contact.phoneIntl}`} class="btn-secondary">Call {site.contact.phone}</a>
        <a href={`mailto:${site.contact.quotesEmail}`} class="btn-primary">Email quotes</a>
      </div>
    </div>
  </section>
</BaseLayout>
