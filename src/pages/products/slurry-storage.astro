---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TrustStrip from '@/components/TrustStrip.astro';
import { site } from '@/config/site';

const specs = [
  { thickness: '200mm', height: '2.4m', weight: '1,152 kg/m', capacity: '~250 m³ store', use: 'Smaller dairy units, weeping walls' },
  { thickness: '200mm', height: '3.0m', weight: '1,440 kg/m', capacity: '~500 m³ store', use: 'Mid-size dairy slurry stores' },
  { thickness: '250mm', height: '3.6m', weight: '2,160 kg/m', capacity: '~1,000 m³ store', use: 'Larger dairy and beef slurry' },
  { thickness: '250mm', height: '4.5m', weight: '2,700 kg/m', capacity: '~2,000 m³ store', use: 'High-capacity 6-month stores' },
  { thickness: '300mm', height: '5.0m', weight: '3,600 kg/m', capacity: '~3,500 m³ store', use: 'Grant-funded SSAFO upgrades' },
  { thickness: '300mm', height: '6.0m', weight: '4,320 kg/m', capacity: '~5,000 m³ store', use: 'Maximum-capacity strategic stores' },
];

const applications = [
  'New SSAFO 2018-compliant slurry stores for dairy units',
  'Slurry Infrastructure Grant 2026 capacity upgrades',
  'Above-ground rectangular and circular tank walls',
  'Reception pits and pre-store buffer tanks',
  'Slurry separation and lagoon containment walls',
  'Anaerobic digester feed pits and storage',
  'Beef and pig housing under-slat slurry channels',
];

const related = [
  { href: '/products/prestressed-panels', label: 'Prestressed Wall Panels', meta: 'BS EN 14992 · 100/150/180/280mm' },
  { href: '/products/silage-clamp-walls', label: 'Silage Clamp Walls', meta: 'C40/50 · sulphate-resisting' },
  { href: '/products/cattle-cubicles', label: 'Cattle Cubicles', meta: 'AHDB 2024 sized' },
  { href: '/grants/slurry-grant', label: 'Slurry Grant 2026', meta: '£74m available · close 30 Sept 2026' },
];

const faqs = [
  { q: 'Are your stores SSAFO 2018 compliant?', a: 'Yes — every slurry store we ship comes with the SSAFO 2018 capacity statement, structural calcs to BS EN 1992 and the BS 8500 mix certificate. The minimum 6-month storage requirement is the design driver, with freeboard and rainfall load added per the regs.' },
  { q: 'What concrete grade do you use?', a: 'C40/50 to BS 8500-1:2023, with sulphate-resisting CEM III/A or CEM II/B-V binder for aggressive-chemical class XA3 (DC-3 / DC-4 designation). Slurry pH and ammonium are nasty on standard cement — the SR mix is what gives the 50-year design life.' },
  { q: 'How thick a wall do I need?', a: 'For a free-standing rectangular store, 200mm at 2.4–3.0m, 250mm at 3.0–4.5m and 300mm at 4.5–6.0m is the catalogue. We always do a site-specific design — surcharge from earth or vehicles, and the corner detail, can change the answer. Read our wall-thickness guide for the long version.' },
  { q: 'Can you supply for the Slurry Infrastructure Grant?', a: 'Yes — we have shipped panels for dozens of grant-funded stores already. We supply the capacity calc and SSAFO statement that goes with the grant claim, and we can recommend a contractor if you need install too.' },
  { q: 'What is the lead time?', a: 'Catalogue thicknesses run 3 to 5 weeks. The grant rush in spring and autumn lengthens that — get the order in by early summer if you are claiming this round. Bespoke pocket details and corner units run 6 to 8 weeks.' },
];

const productSchema = {
  name: 'Precast Slurry Storage Walls & Tanks',
  description: 'SSAFO 2018-compliant precast slurry storage walls and tanks. 200mm, 250mm and 300mm thicknesses, heights to 6.0m, designed for 6-month storage. C40/50 sulphate-resisting concrete cast in Holsworthy.',
  brand: { '@type': 'Brand', name: site.name },
  manufacturer: { '@type': 'Organization', name: site.name },
  category: 'Precast slurry storage',
  material: 'Prestressed reinforced concrete, C40/50 sulphate-resisting (BS 8500-1:2023, XA3)',
  weight: {
    '@type': 'QuantitativeValue',
    minValue: 1152,
    maxValue: 4320,
    unitCode: 'KGM',
    unitText: 'kilogram per linear metre',
  },
  additionalProperty: [
    { '@type': 'PropertyValue', name: 'Standard', value: 'SSAFO 2018 / BS EN 14992' },
    { '@type': 'PropertyValue', name: 'Concrete grade', value: 'C40/50 sulphate-resisting (XA3)' },
    { '@type': 'PropertyValue', name: 'Concrete specification', value: 'BS 8500-1:2023' },
    { '@type': 'PropertyValue', name: 'Storage capacity', value: '6-month minimum (SSAFO 2018)' },
    { '@type': 'PropertyValue', name: 'Wall thicknesses', value: '200mm / 250mm / 300mm' },
    { '@type': 'PropertyValue', name: 'Maximum height', value: '6.0 m' },
    { '@type': 'PropertyValue', name: 'Design life', value: '50 years' },
    { '@type': 'PropertyValue', name: 'Lead time', value: '3–5 weeks catalogue, 6–8 weeks bespoke' },
    { '@type': 'PropertyValue', name: 'Country of origin', value: 'United Kingdom (Devon)' },
  ],
  offers: {
    '@type': 'Offer',
    priceCurrency: 'GBP',
    availability: 'https://schema.org/InStock',
    seller: { '@type': 'Organization', name: site.name },
  },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<BaseLayout
  title="Slurry Storage — SSAFO 2018-compliant precast walls & tanks"
  description="SSAFO 2018-compliant precast slurry storage. 200/250/300mm walls to 6.0m, C40/50 sulphate-resisting, 6-month capacity. Grant-ready. Cast in North Devon."
  image="/images/products/slurry-storage.jpg"
  schema="Product"
  schemaData={productSchema}
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)} slot="head" />
  <TrustStrip />

  <section class="bg-navy text-white">
    <div class="container-wccp py-16 md:py-20">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <p class="eyebrow text-yellow mb-4">Agricultural · slurry · grant-ready</p>
          <h1 class="font-display text-display-xl text-white mb-4">Slurry Storage.</h1>
          <p class="text-lg text-white/90 leading-relaxed mb-6">
            SSAFO 2018-compliant precast walls and tanks. 200, 250 and 300mm thicknesses,
            heights to 6.0m, six-month storage as standard. Cast in C40/50 sulphate-resisting
            concrete. Grant-ready paperwork supplied with every store.
          </p>
          <ul class="grid grid-cols-2 gap-3 text-sm mb-8 max-w-md">
            <li class="flex gap-2"><span class="text-yellow">·</span> SSAFO 2018 compliant</li>
            <li class="flex gap-2"><span class="text-yellow">·</span> 6-month capacity</li>
            <li class="flex gap-2"><span class="text-yellow">·</span> C40/50 SR mix</li>
            <li class="flex gap-2"><span class="text-yellow">·</span> Heights to 6.0m</li>
            <li class="flex gap-2"><span class="text-yellow">·</span> 50-year design life</li>
            <li class="flex gap-2"><span class="text-yellow">·</span> 3–5 week lead</li>
          </ul>
          <div class="flex flex-wrap gap-3">
            <a href="/quote?product=Slurry+Storage" class="btn-primary">Configure a quote</a>
            <a href="/spec-sheets/slurry-storage.pdf" class="btn-yellow">Download spec sheet</a>
            <a href={`tel:${site.contact.phoneIntl}`} class="btn-ghost border-white text-white hover:bg-white hover:text-navy">Call {site.contact.phone}</a>
          </div>
        </div>
        <div class="aspect-[4/3] bg-cast-100 rounded overflow-hidden">
          <div class="w-full h-full bg-gradient-to-br from-cast-300 via-cast to-navy"></div>
        </div>
      </div>
    </div>
  </section>

  <section class="container-wccp py-20">
    <div class="max-w-2xl mb-10">
      <p class="eyebrow text-cast mb-3">Specification</p>
      <h2 class="font-display text-display-lg mb-4">Wall thicknesses, heights and capacities.</h2>
      <p class="text-cast-700 text-lg">
        Catalogue panel sizes for typical store dimensions. Site-specific design always to BS EN 1992.
      </p>
    </div>
    <div class="overflow-x-auto">
      <table class="spec-table w-full text-left border-collapse">
        <thead class="bg-navy text-white">
          <tr>
            <th class="px-4 py-3 font-display text-sm uppercase tracking-wide">Wall thickness</th>
            <th class="px-4 py-3 font-display text-sm uppercase tracking-wide">Height</th>
            <th class="px-4 py-3 font-display text-sm uppercase tracking-wide">Weight</th>
            <th class="px-4 py-3 font-display text-sm uppercase tracking-wide">Indicative store</th>
            <th class="px-4 py-3 font-display text-sm uppercase tracking-wide">Typical use</th>
          </tr>
        </thead>
        <tbody>
          {specs.map((s, i) => (
            <tr class={i % 2 === 0 ? 'bg-white' : 'bg-bone-200'}>
              <td class="px-4 py-3 font-bold text-navy">{s.thickness}</td>
              <td class="px-4 py-3">{s.height}</td>
              <td class="px-4 py-3">{s.weight}</td>
              <td class="px-4 py-3">{s.capacity}</td>
              <td class="px-4 py-3 text-cast">{s.use}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    <p class="text-cast text-sm mt-4">
      Capacities are indicative for a rectangular plan. Final structural design and capacity statement
      issued with the order pack.
    </p>
  </section>

  <section class="bg-bone-200 py-20">
    <div class="container-wccp">
      <div class="grid lg:grid-cols-2 gap-12">
        <div>
          <p class="eyebrow text-cast mb-3">Where they go</p>
          <h2 class="font-display text-display-lg mb-6">Common applications.</h2>
          <p class="text-cast-700 text-lg leading-relaxed mb-6">
            From a small Devon dairy adding 300m³ of capacity to a strategic 5,000m³ AD-feed store —
            same panels, same paperwork, same yard.
          </p>
          <ul class="space-y-3">
            {applications.map((a) => (
              <li class="flex gap-3 text-cast-700 leading-relaxed">
                <span class="text-ember font-bold mt-1">·</span>
                <span>{a}</span>
              </li>
            ))}
          </ul>
        </div>
        <div class="card p-8">
          <p class="eyebrow text-cast mb-3">Standards & certification</p>
          <h3 class="font-display text-2xl font-bold text-navy mb-4">SSAFO-compliant, factory-controlled.</h3>
          <dl class="space-y-4 text-sm">
            <div><dt class="font-bold text-navy">SSAFO 2018</dt><dd class="text-cast">Silage, Slurry and Agricultural Fuel Oil regs. Capacity statement supplied.</dd></div>
            <div><dt class="font-bold text-navy">BS EN 14992</dt><dd class="text-cast">Precast wall elements — UKCA marked, factory production control.</dd></div>
            <div><dt class="font-bold text-navy">BS 8500-1:2023</dt><dd class="text-cast">Concrete spec — DC-3 / DC-4 designations for aggressive ground.</dd></div>
            <div><dt class="font-bold text-navy">BS EN 1992 (Eurocode 2)</dt><dd class="text-cast">Structural design of concrete — site-specific calcs by our design team.</dd></div>
            <div><dt class="font-bold text-navy">BS EN 13369</dt><dd class="text-cast">Common rules for precast — factory production control framework.</dd></div>
          </dl>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-yellow text-navy py-16">
    <div class="container-wccp">
      <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6">
        <div>
          <p class="eyebrow text-navy mb-2">Configure your slurry store</p>
          <h2 class="font-display text-display-md">Tell us herd size and store dimensions — we will quote inside 24 hours.</h2>
        </div>
        <div class="flex flex-wrap gap-3 shrink-0">
          <a href="/quote?product=Slurry+Storage" class="btn bg-navy text-white hover:bg-navy-700">Open the configurator</a>
          <a href={`mailto:${site.contact.quotesEmail}`} class="btn-secondary">Email quotes</a>
        </div>
      </div>
    </div>
  </section>

  <section class="container-wccp py-20">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between mb-10 gap-4">
      <div>
        <p class="eyebrow text-cast mb-3">Related products</p>
        <h2 class="font-display text-display-lg">Often ordered alongside.</h2>
      </div>
      <a href="/products" class="text-ember font-bold hover:text-ember-700 inline-flex items-center gap-2">View full range
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12" stroke-linecap="round" /><polyline points="12 5 19 12 12 19" stroke-linecap="round" stroke-linejoin="round" /></svg>
      </a>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
      {related.map((r) => (
        <a href={r.href} class="card p-5 group">
          <div class="aspect-[16/10] bg-cast-100 mb-4 rounded overflow-hidden">
            <div class="w-full h-full bg-gradient-to-br from-cast-200 to-cast-100"></div>
          </div>
          <h3 class="font-display text-base font-bold text-navy mb-1 group-hover:text-ember">{r.label}</h3>
          <p class="text-cast text-xs">{r.meta}</p>
        </a>
      ))}
    </div>
  </section>

  <section class="bg-bone-200 py-20">
    <div class="container-wccp">
      <div class="max-w-2xl mb-12">
        <p class="eyebrow text-cast mb-3">Common questions</p>
        <h2 class="font-display text-display-lg mb-4">What people ask about slurry stores.</h2>
        <p class="text-cast-700 text-lg">Five questions we answer most weeks. If yours is not here, ring the yard.</p>
      </div>
      <div class="max-w-3xl space-y-4">
        {faqs.map((f) => (
          <details class="card p-6 group">
            <summary class="font-display text-lg font-bold text-navy cursor-pointer list-none flex justify-between items-start gap-4">
              <span>{f.q}</span>
              <span class="text-ember text-2xl leading-none group-open:rotate-45 transition-transform shrink-0">+</span>
            </summary>
            <p class="text-cast-700 leading-relaxed mt-4">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-navy text-white py-20">
    <div class="container-wccp text-center">
      <h2 class="font-display text-display-xl mb-4 text-white">Ready to spec it?</h2>
      <p class="text-white/90 text-lg max-w-xl mx-auto mb-8">Send us herd size, current capacity and a sketch. Quote and lead-time same day.</p>
      <div class="flex flex-wrap justify-center gap-3">
        <a href="/quote?product=Slurry+Storage" class="btn-yellow">Configure a quote</a>
        <a href={`tel:${site.contact.phoneIntl}`} class="btn-secondary">Call {site.contact.phone}</a>
        <a href={`mailto:${site.contact.quotesEmail}`} class="btn-primary">Email quotes</a>
      </div>
    </div>
  </section>
</BaseLayout>
