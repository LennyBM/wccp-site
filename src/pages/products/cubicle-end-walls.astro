---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TrustStrip from '@/components/TrustStrip.astro';
import { site } from '@/config/site';

const specs = [
  { type: 'Single-row end wall', size: '2280 × 1200 × 100mm', weight: '660 kg', water: 'Optional integrated trough', use: 'End of single cubicle row' },
  { type: 'Double-row end wall', size: '4400 × 1200 × 100mm', weight: '1,265 kg', water: 'Optional integrated trough', use: 'End of double (back-to-back) row' },
  { type: 'Single + integrated trough', size: '2280 × 1200 × 200mm', weight: '910 kg', water: '180 L cast-in trough', use: 'Single row with drinking facility' },
  { type: 'Double + integrated trough', size: '4400 × 1200 × 200mm', weight: '1,750 kg', water: '360 L cast-in trough', use: 'Double row, both sides drink' },
  { type: 'Tall end wall (heifer)', size: '2280 × 1500 × 100mm', weight: '825 kg', water: 'Optional', use: 'Heifer / youngstock pens' },
  { type: 'Bespoke length', size: 'To drawing × 1200 × 100mm', weight: 'On application', water: 'Optional', use: 'Non-standard row lengths' },
];

const applications = [
  'End of single-row cubicle banks at parlour return',
  'End of double-row (back-to-back) cubicle layouts',
  'Cross-passage divisions in multi-row sheds',
  'Robot-shed cubicle row terminations',
  'Heifer and dry-cow group divisions',
  'Combined end-wall + drink station for cow flow',
  'Stock-handling pen separators',
];

const related = [
  { href: '/products/cattle-cubicles', label: 'Cattle Cubicles', meta: 'AHDB 2024 sized' },
  { href: '/products/water-troughs', label: 'Water Troughs', meta: 'Single + double row' },
  { href: '/products/feed-troughs', label: 'Feed Troughs', meta: 'L-shape · 2440×900' },
  { href: '/products/milking-robot-bases', label: 'Robot Bases', meta: 'DeLaval · Lely · GEA' },
];

const faqs = [
  { q: 'Single or double row — what do I need?', a: 'Single-row end walls (2280 × 1200 × 100mm, 660kg) cap a single bank of cubicles. Double-row walls (4400 × 1200 × 100mm, 1,265kg) cap a back-to-back layout, the typical robot-shed configuration. We also do a tall version for heifer pens at 1500mm height.' },
  { q: 'How does the integrated trough option work?', a: 'On the integrated-trough version, the bottom 400mm of the wall is cast as a 180L (single) or 360L (double) water trough. You get a cubicle-row terminator and a drink station in one unit. Plumbing comes in via a side entry to a side-mount float valve; the panel above doubles as the cow-side splash guard.' },
  { q: 'How are they fixed?', a: 'M16 anchor sockets cast into the bottom edge bolt down to a 100mm slab kicker, or to your existing cubicle floor. We supply the install drawing and the bedding mortar spec. The 4.4m double-row wall comes off the lorry in a single lift on a 16-tonne HIAB.' },
  { q: 'What about the lifting?', a: 'Two cast-in lifting eyes per unit. The 4.4m double at 1,265kg lifts comfortably on a 12-tonne SWL chain. We provide the lifting cert with the wall.' },
  { q: 'Lead time?', a: 'Catalogue end walls run 2 to 3 weeks. Integrated-trough versions and tall heifer-grade walls run 3 to 4 weeks. Bespoke lengths to non-standard row drawings, 4 to 6 weeks.' },
];

const productSchema = {
  name: 'Cubicle Row End Walls',
  description: 'Precast end-wall panels for cubicle row terminations. Single 2280×1200×100mm at 660kg, double 4400×1200×100mm at 1265kg. Integrated water trough option (180L / 360L). For dairy cubicle and robot sheds.',
  brand: { '@type': 'Brand', name: site.name },
  manufacturer: { '@type': 'Organization', name: site.name },
  category: 'Precast cubicle end wall',
  material: 'Reinforced concrete, C40/50 (BS 8500-1:2023)',
  weight: { '@type': 'QuantitativeValue', minValue: 660, maxValue: 1750, unitCode: 'KGM', unitText: 'kilogram per panel' },
  additionalProperty: [
    { '@type': 'PropertyValue', name: 'Standard', value: 'BS EN 13369 / BS 5502-22:2003' },
    { '@type': 'PropertyValue', name: 'Concrete grade', value: 'C40/50 (BS 8500-1:2023)' },
    { '@type': 'PropertyValue', name: 'Single-row size', value: '2280 × 1200 × 100 mm, 660 kg' },
    { '@type': 'PropertyValue', name: 'Double-row size', value: '4400 × 1200 × 100 mm, 1265 kg' },
    { '@type': 'PropertyValue', name: 'Integrated trough option', value: '180 L (single) / 360 L (double)' },
    { '@type': 'PropertyValue', name: 'Anchor', value: 'M16 cast-in sockets' },
    { '@type': 'PropertyValue', name: 'Lead time', value: '2–3 weeks catalogue, 3–4 weeks with trough' },
    { '@type': 'PropertyValue', name: 'Country of origin', value: 'United Kingdom (Devon)' },
  ],
  offers: { '@type': 'Offer', priceCurrency: 'GBP', availability: 'https://schema.org/InStock', seller: { '@type': 'Organization', name: site.name } },
};

const faqSchema = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) };
---

<BaseLayout
  title="Cubicle End Walls — single 2280×1200 + double 4400×1200"
  description="Precast cubicle row end walls. Single 2280×1200×100mm at 660kg, double 4400×1200×100mm at 1265kg. Integrated water trough option. Cast in North Devon."
  image="/images/products/cubicle-end-walls.jpg"
  schema="Product"
  schemaData={productSchema}
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)} slot="head" />
  <TrustStrip />

  <section class="bg-navy text-white">
    <div class="container-wccp py-16 md:py-20">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <p class="eyebrow text-yellow mb-4">Agricultural · dairy · cubicle housing</p>
          <h1 class="font-display text-display-xl text-white mb-4">Cubicle End Walls.</h1>
          <p class="text-lg text-white/90 leading-relaxed mb-6">
            Single-row (2280 × 1200 × 100mm, 660kg) and double-row (4400 × 1200 × 100mm, 1,265kg)
            end-wall panels for cubicle terminations. Optional integrated water trough (180L single,
            360L double) — cubicle-row cap and drink station in one unit.
          </p>
          <ul class="grid grid-cols-2 gap-3 text-sm mb-8 max-w-md">
            <li class="flex gap-2"><span class="text-yellow">·</span> Single 2280×1200</li>
            <li class="flex gap-2"><span class="text-yellow">·</span> Double 4400×1200</li>
            <li class="flex gap-2"><span class="text-yellow">·</span> 660 / 1,265 kg</li>
            <li class="flex gap-2"><span class="text-yellow">·</span> Trough option</li>
            <li class="flex gap-2"><span class="text-yellow">·</span> M16 anchors</li>
            <li class="flex gap-2"><span class="text-yellow">·</span> 2–3 week lead</li>
          </ul>
          <div class="flex flex-wrap gap-3">
            <a href="/quote?product=Cubicle+End+Walls" class="btn-primary">Configure a quote</a>
            <a href="/spec-sheets/cubicle-end-walls.pdf" class="btn-yellow">Download spec sheet</a>
            <a href={`tel:${site.contact.phoneIntl}`} class="btn-ghost border-white text-white hover:bg-white hover:text-navy">Call {site.contact.phone}</a>
          </div>
        </div>
        <div class="aspect-[4/3] bg-cast-100 rounded overflow-hidden"><div class="w-full h-full bg-gradient-to-br from-cast-300 via-cast to-navy"></div></div>
      </div>
    </div>
  </section>

  <section class="container-wccp py-20">
    <div class="max-w-2xl mb-10">
      <p class="eyebrow text-cast mb-3">Specification</p>
      <h2 class="font-display text-display-lg mb-4">Variants and integrated options.</h2>
      <p class="text-cast-700 text-lg">Catalogue panels at standard cubicle-row dimensions. Bespoke lengths cast to drawing.</p>
    </div>
    <div class="overflow-x-auto">
      <table class="spec-table w-full text-left border-collapse">
        <thead class="bg-navy text-white">
          <tr>
            <th class="px-4 py-3 font-display text-sm uppercase tracking-wide">Type</th>
            <th class="px-4 py-3 font-display text-sm uppercase tracking-wide">Size (L×H×T)</th>
            <th class="px-4 py-3 font-display text-sm uppercase tracking-wide">Weight</th>
            <th class="px-4 py-3 font-display text-sm uppercase tracking-wide">Water</th>
            <th class="px-4 py-3 font-display text-sm uppercase tracking-wide">Typical use</th>
          </tr>
        </thead>
        <tbody>
          {specs.map((s, i) => (
            <tr class={i % 2 === 0 ? 'bg-white' : 'bg-bone-200'}>
              <td class="px-4 py-3 font-bold text-navy">{s.type}</td>
              <td class="px-4 py-3">{s.size}</td>
              <td class="px-4 py-3">{s.weight}</td>
              <td class="px-4 py-3">{s.water}</td>
              <td class="px-4 py-3 text-cast">{s.use}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <section class="bg-bone-200 py-20">
    <div class="container-wccp">
      <div class="grid lg:grid-cols-2 gap-12">
        <div>
          <p class="eyebrow text-cast mb-3">Where they go</p>
          <h2 class="font-display text-display-lg mb-6">Common applications.</h2>
          <p class="text-cast-700 text-lg leading-relaxed mb-6">From a 60-cubicle single bank to a 240-cubicle robot shed — same panel range, with the integrated trough option for tighter cow flow.</p>
          <ul class="space-y-3">
            {applications.map((a) => (<li class="flex gap-3 text-cast-700 leading-relaxed"><span class="text-ember font-bold mt-1">·</span><span>{a}</span></li>))}
          </ul>
        </div>
        <div class="card p-8">
          <p class="eyebrow text-cast mb-3">Standards & references</p>
          <h3 class="font-display text-2xl font-bold text-navy mb-4">Cast and sized to current best practice.</h3>
          <dl class="space-y-4 text-sm">
            <div><dt class="font-bold text-navy">BS EN 13369</dt><dd class="text-cast">Common rules for precast concrete — factory production control.</dd></div>
            <div><dt class="font-bold text-navy">BS 5502-22:2003</dt><dd class="text-cast">Agricultural buildings — cattle housing layouts and loadings.</dd></div>
            <div><dt class="font-bold text-navy">BS 8500-1:2023</dt><dd class="text-cast">Concrete spec — C40/50 designed mix.</dd></div>
            <div><dt class="font-bold text-navy">AHDB Dairy</dt><dd class="text-cast">Cow-flow guidance for cubicle end-of-row layouts.</dd></div>
            <div><dt class="font-bold text-navy">BS EN 1992 (Eurocode 2)</dt><dd class="text-cast">Concrete structural design — anchor and lifting calculation.</dd></div>
          </dl>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-yellow text-navy py-16">
    <div class="container-wccp">
      <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6">
        <div>
          <p class="eyebrow text-navy mb-2">Configure your end-wall set</p>
          <h2 class="font-display text-display-md">Send row count, layout and trough preference — we will quote inside 24 hours.</h2>
        </div>
        <div class="flex flex-wrap gap-3 shrink-0">
          <a href="/quote?product=Cubicle+End+Walls" class="btn bg-navy text-white hover:bg-navy-700">Open the configurator</a>
          <a href={`mailto:${site.contact.quotesEmail}`} class="btn-secondary">Email quotes</a>
        </div>
      </div>
    </div>
  </section>

  <section class="container-wccp py-20">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between mb-10 gap-4">
      <div>
        <p class="eyebrow text-cast mb-3">Related products</p>
        <h2 class="font-display text-display-lg">Often ordered alongside.</h2>
      </div>
      <a href="/products" class="text-ember font-bold hover:text-ember-700 inline-flex items-center gap-2">View full range
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12" stroke-linecap="round" /><polyline points="12 5 19 12 12 19" stroke-linecap="round" stroke-linejoin="round" /></svg>
      </a>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
      {related.map((r) => (
        <a href={r.href} class="card p-5 group">
          <div class="aspect-[16/10] bg-cast-100 mb-4 rounded overflow-hidden"><div class="w-full h-full bg-gradient-to-br from-cast-200 to-cast-100"></div></div>
          <h3 class="font-display text-base font-bold text-navy mb-1 group-hover:text-ember">{r.label}</h3>
          <p class="text-cast text-xs">{r.meta}</p>
        </a>
      ))}
    </div>
  </section>

  <section class="bg-bone-200 py-20">
    <div class="container-wccp">
      <div class="max-w-2xl mb-12">
        <p class="eyebrow text-cast mb-3">Common questions</p>
        <h2 class="font-display text-display-lg mb-4">What people ask about cubicle end walls.</h2>
        <p class="text-cast-700 text-lg">Five questions we answer most weeks. If yours is not here, ring the yard.</p>
      </div>
      <div class="max-w-3xl space-y-4">
        {faqs.map((f) => (
          <details class="card p-6 group">
            <summary class="font-display text-lg font-bold text-navy cursor-pointer list-none flex justify-between items-start gap-4">
              <span>{f.q}</span>
              <span class="text-ember text-2xl leading-none group-open:rotate-45 transition-transform shrink-0">+</span>
            </summary>
            <p class="text-cast-700 leading-relaxed mt-4">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-navy text-white py-20">
    <div class="container-wccp text-center">
      <h2 class="font-display text-display-xl mb-4 text-white">Ready to spec it?</h2>
      <p class="text-white/90 text-lg max-w-xl mx-auto mb-8">Send the row layout and herd size. Quote and lead-time same day.</p>
      <div class="flex flex-wrap justify-center gap-3">
        <a href="/quote?product=Cubicle+End+Walls" class="btn-yellow">Configure a quote</a>
        <a href={`tel:${site.contact.phoneIntl}`} class="btn-secondary">Call {site.contact.phone}</a>
        <a href={`mailto:${site.contact.quotesEmail}`} class="btn-primary">Email quotes</a>
      </div>
    </div>
  </section>
</BaseLayout>
