---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ProductWarrantyLine from '@/components/ProductWarrantyLine.astro';
import TrustStrip from '@/components/TrustStrip.astro';
import FittedVsSupply from '@/components/FittedVsSupply.astro';
import SpecSheetButton from '@/components/SpecSheetButton.astro';
import { site } from '@/config/site';
import RelatedProductGrid from '@/components/RelatedProductGrid.astro';

const prestressedSpecs = [
  { thickness: '95mm', heights: '1.0m, 1.2m, 1.5m', lengths: 'Custom + 15\' & 20\' standard stocked', use: 'Lighter clamp side walls and bay divisions' },
  { thickness: '145mm', heights: '1.0m, 1.2m, 1.5m', lengths: 'Custom + 15\' & 20\' standard stocked', use: 'Mid-size clamps; cantilever heights reduced 0.3–0.4m vs 180mm' },
  { thickness: '180mm', heights: '1.0m, 1.2m, 1.5m', lengths: 'Custom + 15\' & 20\' standard stocked', use: 'Standard clamp panels; vertical cantilever rated' },
];

const cantileverSpecs = [
  { service: 'Slurry retention', height: '3.7m', notes: 'Maximum cantilever retained height' },
  { service: 'Silage with 10t vehicle surcharge', height: '3.2m', notes: 'Filling vehicle on top of stack' },
  { service: 'Earth retention', height: '3.4m', notes: 'No surcharge above retained level' },
];

const applications = [
  'Dairy farm grass and maize silage clamps',
  'Beef finishing-unit feed-stock clamps',
  'AD plant silage clamp feedstock storage',
  'Push walls — driven against during clamp filling',
  'Transition walls between filling bays',
  'Ramp returns and end walls',
  'Effluent collection channels and tank walls',
];

const related = [
  { href: '/products/prestressed-panels', label: 'Prestressed Panels', meta: '95 / 145 / 180mm thick' },
  { href: '/products/l-blocks', label: 'Free-Standing Walls & Blocks', meta: "'A' / 'L' / 'T' walls + Beton blocks" },
  { href: '/products/slurry-storage', label: 'Slurry Storage', meta: 'SSAFO 2018-compliant' },
  { href: '/products/cattle-cubicles', label: 'Cattle Cubicles', meta: 'AHDB 2024 sized' },
];

const faqs = [
  { q: 'What thicknesses do you stock?', a: 'Our prestressed panel range is 95mm, 145mm or 180mm thick, in heights of 1.0m, 1.2m and 1.5m. Custom lengths to order, plus 15\' and 20\' standard stocked lengths. We size each scheme on the run length, height and surcharge.' },
  { q: 'How tall can I retain with vertical cantilever?', a: 'The 180mm Vertical Cantilever Panels retain slurry to 3.7m, silage with a 10-tonne vehicle surcharge to 3.2m, and earth to 3.4m. The 145mm panels can be used in cantilever mode with retained heights reduced by 0.3–0.4m. No supporting posts are required for these cantilever panels.' },
  { q: 'Why sulphate-resisting cement?', a: 'Silage effluent is around pH 3.8–4.2 and rich in lactic and acetic acids. Standard Portland cement reacts and the panel face deteriorates. CEM III/A (ground-granulated blast-furnace slag blend) is far more resistant — it is what gives the wall a 30+ year service life in clamp service.' },
  { q: 'Can the panels take a tractor pushing against them?', a: 'Yes — the structural design accounts for vehicle impact during filling. The 180mm Vertical Cantilever spec assumes a 10-tonne surcharge during filling. Push-wall details with thickened upstands available where you want extra protection.' },
  { q: 'Lead time?', a: 'Catalogue panels run 3 to 5 weeks. The 15\' and 20\' standard lengths often despatch from stock. Spring is the busy clamp season; get the order in by mid-winter if you are commissioning for the May silage cut.' },
];

const productSchema = {
  name: 'Silage Clamp Wall Panels',
  description: 'WCCP prestressed panel range for silage clamps. Heights 1.0m, 1.2m and 1.5m at thicknesses of 95mm, 145mm or 180mm. Custom lengths plus 15\' and 20\' standard stocked. Vertical Cantilever Panels (180mm) retain slurry to 3.7m, silage with 10t vehicle surcharge to 3.2m, earth to 3.4m. No supporting posts required for cantilever panels.',
  brand: { '@type': 'Brand', name: site.name },
  manufacturer: { '@type': 'Organization', name: site.name },
  category: 'Precast silage clamp wall',
  material: 'Prestressed reinforced concrete, C40/50 sulphate-resisting CEM III/A (BS 8500-1:2023, XA3)',
  weight: { '@type': 'QuantitativeValue', minValue: 200, maxValue: 1100, unitCode: 'KGM', unitText: 'kilogram per linear metre' },
  additionalProperty: [
    { '@type': 'PropertyValue', name: 'Standard', value: 'BS EN 14992 / SSAFO 2018' },
    { '@type': 'PropertyValue', name: 'Concrete grade', value: 'C40/50 sulphate-resisting' },
    { '@type': 'PropertyValue', name: 'Cement type', value: 'CEM III/A (GGBS blend)' },
    { '@type': 'PropertyValue', name: 'Exposure class', value: 'XA3 (BS EN 206)' },
    { '@type': 'PropertyValue', name: 'Panel heights', value: '1.0 m, 1.2 m, 1.5 m' },
    { '@type': 'PropertyValue', name: 'Panel thicknesses', value: '95 mm, 145 mm, 180 mm' },
    { '@type': 'PropertyValue', name: 'Standard stocked lengths', value: "15' & 20' (custom lengths available)" },
    { '@type': 'PropertyValue', name: 'Vertical Cantilever — slurry', value: '3.7 m retained height (180mm)' },
    { '@type': 'PropertyValue', name: 'Vertical Cantilever — silage + 10t surcharge', value: '3.2 m retained height (180mm)' },
    { '@type': 'PropertyValue', name: 'Vertical Cantilever — earth', value: '3.4 m retained height (180mm)' },
    { '@type': 'PropertyValue', name: 'Cantilever supporting posts', value: 'None required' },
    { '@type': 'PropertyValue', name: '145mm cantilever', value: 'Reduce retained heights by 0.3–0.4m' },
    { '@type': 'PropertyValue', name: 'Lead time', value: '3–5 weeks catalogue' },
    { '@type': 'PropertyValue', name: 'Country of origin', value: 'United Kingdom (Devon)' },
  ],
  offers: { '@type': 'Offer', availability: 'https://schema.org/InStock', areaServed: 'GB', seller: { '@type': 'Organization', name: site.name } },
};

const faqSchema = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) };
---

<BaseLayout
  title="Silage Clamp Walls — 95/145/180mm prestressed · vertical cantilever to 3.7m"
  description="WCCP prestressed silage clamp panels. Heights 1.0m, 1.2m, 1.5m in 95mm, 145mm or 180mm. Vertical Cantilever Panels retain slurry to 3.7m, silage to 3.2m, earth to 3.4m — no supporting posts required. Cast in North Devon."
  image="/og/silage-clamp-walls.png"
  schema="Product"
  schemaData={productSchema}
  whatsappContext="Silage Clamp Walls"
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)} slot="head" />
  <TrustStrip />

  <section class="bg-navy text-white">
    <div class="container-wccp py-16 md:py-20">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <p class="eyebrow text-yellow mb-4">Agricultural · silage · push walls</p>
          <h1 class="font-display text-display-xl text-white mb-4">Silage Clamp Walls.</h1>
          <p class="font-display italic text-xl md:text-2xl text-yellow leading-tight mb-5">Acid-tight. Push-rated. Stack and seal.</p>
          <blockquote class="font-display italic text-base md:text-lg text-white/95 leading-relaxed mb-6 pl-4 border-l-2 border-yellow max-w-xl">
            UK silage clamp walls should be cast in C40/50 concrete with sulphate-resisting cement
            (CEM&nbsp;III/A) to resist silage effluent (pH&nbsp;3.8&ndash;4.2), per BS&nbsp;8500-1:2023
            exposure class XA3. Minimum cover to reinforcement is 50&nbsp;mm.
          </blockquote>
          <p class="text-base text-white/85 leading-relaxed mb-6 max-w-xl">
            WCCP prestressed clamp panels. Heights of <strong class="text-white">1.0m, 1.2m and 1.5m</strong>
            at thicknesses of <strong class="text-white">95mm, 145mm or 180mm</strong>. Custom lengths to
            order plus 15' and 20' standard stocked lengths. The 180mm Vertical Cantilever Panels
            retain slurry to 3.7m, silage with a 10-tonne vehicle surcharge to 3.2m and earth to 3.4m
            — with no supporting posts required.
          </p>
          <ul class="grid grid-cols-2 gap-3 text-sm mb-8 max-w-md">
            <li class="flex gap-2"><span class="text-yellow">·</span> 1.0 / 1.2 / 1.5m high</li>
            <li class="flex gap-2"><span class="text-yellow">·</span> 95 / 145 / 180mm thick</li>
            <li class="flex gap-2"><span class="text-yellow">·</span> 15' & 20' stocked</li>
            <li class="flex gap-2"><span class="text-yellow">·</span> Vertical cantilever</li>
            <li class="flex gap-2"><span class="text-yellow">·</span> No supporting posts</li>
            <li class="flex gap-2"><span class="text-yellow">·</span> 3–5 week lead</li>
          </ul>
          <div class="flex flex-wrap gap-3">
            <a href="/quote?product=Silage%20Clamp%20Walls" class="btn-primary">Configure a quote</a>
            <a href="mailto:engineering@wccp.co.uk?subject=Spec%20sheet%20request%20%E2%80%94%20Silage%20Clamp%20Walls&amp;body=Hi%20WCCP%20engineering%2C%0A%0APlease%20send%20the%20spec%20sheet%20for%20Silage%20Clamp%20Walls.%0A%0AProject%20details%3A%0A%E2%80%A2%20Project%20name%3A%0A%E2%80%A2%20Site%20location%3A%0A%E2%80%A2%20Required%20spec%20%2F%20standard%3A%0A%0AThanks" class="btn-yellow">Request spec sheet</a>
            <a href={`tel:${site.contact.phoneIntl}`} class="btn-ghost border-white text-white hover:bg-white hover:text-navy">Call {site.contact.phone}</a>
          </div>
        </div>
        <div class="aspect-[4/3] bg-cast-100 rounded overflow-hidden">
          <img src="/images/products/concrete-panels/wccp-concrete-panels-prestressed-concrete-panels.jpg" alt="Prestressed concrete silage clamp wall panels — West Country Concrete Products, Devon" class="w-full h-full object-cover" loading="eager" decoding="async" />
        </div>
      </div>
    </div>
  </section>

  <!-- Prestressed panels -->
  <section class="container-wccp py-20">
    <div class="max-w-2xl mb-10">
      <p class="eyebrow text-cast mb-3">Prestressed Panels</p>
      <h2 class="font-display text-display-lg mb-4">Three thicknesses, three heights.</h2>
      <p class="text-cast-700 text-lg">95mm, 145mm or 180mm thick at 1.0m, 1.2m and 1.5m heights. Custom lengths to order, plus 15' and 20' standard stocked lengths.</p>
    </div>
    <div class="overflow-x-auto">
      <table class="spec-table w-full text-left border-collapse">
        <thead class="bg-navy text-white">
          <tr>
            <th class="px-4 py-3 font-display text-sm uppercase tracking-wide">Thickness</th>
            <th class="px-4 py-3 font-display text-sm uppercase tracking-wide">Heights available</th>
            <th class="px-4 py-3 font-display text-sm uppercase tracking-wide">Lengths</th>
            <th class="px-4 py-3 font-display text-sm uppercase tracking-wide">Typical use</th>
          </tr>
        </thead>
        <tbody>
          {prestressedSpecs.map((s, i) => (
            <tr class={i % 2 === 0 ? 'bg-white' : 'bg-bone-200'}>
              <td class="px-4 py-3 font-bold text-navy">{s.thickness}</td>
              <td class="px-4 py-3">{s.heights}</td>
              <td class="px-4 py-3">{s.lengths}</td>
              <td class="px-4 py-3 text-cast">{s.use}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <!-- Vertical Cantilever Panels -->
  <section class="bg-bone-200 py-20">
    <div class="container-wccp">
      <div class="max-w-2xl mb-10">
        <p class="eyebrow text-cast mb-3">Vertical Cantilever Panels</p>
        <h2 class="font-display text-display-lg mb-4">No supporting posts required.</h2>
        <p class="text-cast-700 text-lg">The 180mm panels retain to the heights below in cantilever — no supporting posts in the wall run. 145mm panels can be used in cantilever with retained heights reduced by 0.3–0.4m.</p>
      </div>
      <div class="overflow-x-auto">
        <table class="spec-table w-full text-left border-collapse">
          <thead class="bg-navy text-white">
            <tr>
              <th class="px-4 py-3 font-display text-sm uppercase tracking-wide">Service</th>
              <th class="px-4 py-3 font-display text-sm uppercase tracking-wide">Retained height (180mm)</th>
              <th class="px-4 py-3 font-display text-sm uppercase tracking-wide">Notes</th>
            </tr>
          </thead>
          <tbody>
            {cantileverSpecs.map((s, i) => (
              <tr class={i % 2 === 0 ? 'bg-white' : 'bg-bone-200'}>
                <td class="px-4 py-3 font-bold text-navy">{s.service}</td>
                <td class="px-4 py-3">{s.height}</td>
                <td class="px-4 py-3 text-cast">{s.notes}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <section class="container-wccp py-20">
    <div class="grid lg:grid-cols-2 gap-12">
      <div>
        <p class="eyebrow text-cast mb-3">Where they go</p>
        <h2 class="font-display text-display-lg mb-6">Common applications.</h2>
        <p class="text-cast-700 text-lg leading-relaxed mb-6">From a 60-cow grass clamp to a maize clamp at an AD plant — same panel system, same paperwork.</p>
        <ul class="space-y-3">
          {applications.map((a) => (<li class="flex gap-3 text-cast-700 leading-relaxed"><span class="text-ember font-bold mt-1">·</span><span>{a}</span></li>))}
        </ul>
      </div>
      <div class="card p-8">
        <p class="eyebrow text-cast mb-3">Standards & certification</p>
        <h3 class="font-display text-2xl font-bold text-navy mb-4">Cast for the silage environment.</h3>
        <dl class="space-y-4 text-sm">
          <div><dt class="font-bold text-navy">SSAFO 2018</dt><dd class="text-cast">Silage, Slurry and Agricultural Fuel Oil regulations — clamp design and capacity.</dd></div>
          <div><dt class="font-bold text-navy">BS EN 14992</dt><dd class="text-cast">Precast wall elements — UKCA marked.</dd></div>
          <div><dt class="font-bold text-navy">BS 8500-1:2023</dt><dd class="text-cast">Concrete spec — DC-3/DC-4 designations for aggressive ground.</dd></div>
          <div><dt class="font-bold text-navy">BS EN 206</dt><dd class="text-cast">Concrete exposure classes — XA3 for chemical aggressive environments.</dd></div>
          <div><dt class="font-bold text-navy">BS EN 1992 (Eurocode 2)</dt><dd class="text-cast">Concrete structural design — surcharge and vehicle-loading checks.</dd></div>
        </dl>
      </div>
    </div>
  </section>

  <section class="bg-yellow text-navy py-16">
    <div class="container-wccp">
      <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6">
        <div>
          <p class="eyebrow text-navy mb-2">Configure your clamp</p>
          <h2 class="font-display text-display-md">Send wall heights and run length — we will quote inside 24 hours.</h2>
        </div>
        <div class="flex flex-wrap gap-3 shrink-0">
          <a href="/quote?product=Silage%20Clamp%20Walls" class="btn bg-navy text-white hover:bg-navy-700">Open the configurator</a>
          <a href={`mailto:${site.contact.quotesEmail}`} class="btn-secondary">Email quotes</a>
        </div>
      </div>
    </div>
  </section>

  <section class="container-wccp py-20">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between mb-10 gap-4">
      <div>
        <p class="eyebrow text-cast mb-3">Related products</p>
        <h2 class="font-display text-display-lg">Often ordered alongside.</h2>
      </div>
      <a href="/products" class="text-ember font-bold hover:text-ember-700 inline-flex items-center gap-2">View full range
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12" stroke-linecap="round" /><polyline points="12 5 19 12 12 19" stroke-linecap="round" stroke-linejoin="round" /></svg>
      </a>
    </div>
    <RelatedProductGrid items={related} />
  </section>

  <section class="bg-bone-200 py-20">
    <div class="container-wccp">
      <div class="max-w-2xl mb-12">
        <p class="eyebrow text-cast mb-3">Common questions</p>
        <h2 class="font-display text-display-lg mb-4">What people ask about clamp walls.</h2>
        <p class="text-cast-700 text-lg">Five questions we answer most weeks. If yours is not here, ring the yard.</p>
      </div>
      <div class="max-w-3xl space-y-4">
        {faqs.map((f) => (
          <details class="card p-6 group">
            <summary class="font-display text-lg font-bold text-navy cursor-pointer list-none flex justify-between items-start gap-4">
              <span>{f.q}</span>
              <span class="text-ember text-2xl leading-none group-open:rotate-45 transition-transform shrink-0">+</span>
            </summary>
            <p class="text-cast-700 leading-relaxed mt-4">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Supply-only vs Fitted -->
  <section class="container-wccp section-rhythm border-t border-cast-100">
    <FittedVsSupply
      productName="Silage Clamp Walls"
      defaultMode="supply"
      supply={{
        price: 'from £210 per m² of panel',
        leadTime: '3–5 weeks',
        includes: [
          'Prestressed panels in 95 / 145 / 180mm thicknesses',
          'Heights 1.0m, 1.2m or 1.5m; custom or 15\' / 20\' lengths',
          'C40/50 sulphate-resisting (XA3) for pH 3.8–4.2 service',
          'Delivery on our HIAB to your slab',
        ],
        excludes: [
          'Strip-footing groundworks and cast-in pockets',
          'On-site setting / fixing labour',
          'Effluent collection channel ducting',
        ],
      }}
      fitted={{
        price: 'from £320 per m² installed',
        leadTime: '6–8 weeks (incl. site slot)',
        includes: [
          'Everything in supply only',
          'Two-man install crew with HIAB and 35t crane',
          'Setting-out, levelling and joint sealing',
          '12-month workmanship warranty',
        ],
        excludes: [
          'Strip-footing concrete and reinforcement',
          'Effluent tank and pipework fit-out',
        ],
      }}
      note="Indicative 2026 pricing per m² of wall face on standard panels. Vertical Cantilever Panels (no supporting posts), bespoke push-wall thickenings and ramp returns priced individually — bookings for the May silage cut close mid-winter."
    />
  </section>

  <section class="bg-navy text-white py-20">
    <div class="container-wccp text-center">
      <h2 class="font-display text-display-xl mb-4 text-white">Ready to spec it?</h2>
      <p class="text-white/90 text-lg max-w-xl mx-auto mb-8">Send heights, run length and the silage type. Quote and lead-time same day.</p>
      <div class="flex flex-wrap justify-center gap-3">
        <a href="/quote?product=Silage%20Clamp%20Walls" class="btn-yellow">Configure a quote</a>
        <a href={`tel:${site.contact.phoneIntl}`} class="btn-secondary">Call {site.contact.phone}</a>
        <a href={`mailto:${site.contact.quotesEmail}`} class="btn-primary">Email quotes</a>
      </div>
    </div>
  </section>

  <SpecSheetButton productSlug="silage-clamp-walls" productName="Silage Clamp Walls" />
  <ProductWarrantyLine />
</BaseLayout>
