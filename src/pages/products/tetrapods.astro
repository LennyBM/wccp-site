---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ProductWarrantyLine from '@/components/ProductWarrantyLine.astro';
import TrustStrip from '@/components/TrustStrip.astro';
import CADDownloads from '@/components/CADDownloads.astro';
import SpecSheetButton from '@/components/SpecSheetButton.astro';
import { site } from '@/config/site';
import RelatedProductGrid from '@/components/RelatedProductGrid.astro';

const tocSections = [
  { id: 'overview', label: 'Overview' },
  { id: 'specifications', label: 'Specifications' },
  { id: 'applications', label: 'Applications' },
  { id: 'related', label: 'Related' },
  { id: 'faq', label: 'FAQ' },
  { id: 'downloads', label: 'Downloads' },
];

const tetrapodSpecs = [
  { weight: '3 tonne', dimensions: '1950 × 1950 × 1720 mm (1.95 × 1.95 × 1.72 m)', density: 'C40/50 concrete', application: 'Coastal defence, sea-wall armour, wave-energy reduction' },
  { weight: '5 tonne', dimensions: '2340 × 2340 × 2080 mm (2.34 × 2.34 × 2.08 m)', density: 'C40/50 concrete', application: 'Heavy breakwater armour and exposed foreshore protection' },
];

const applications = [
  'Coastal defence and erosion control',
  'Breakwater and revetment protection',
  'Wave attenuation on exposed foreshores',
  'Marine engineering and harbour protection',
  'Environmental revetments and habitat structures',
];

const related = [
  { href: '/products/culverts', label: 'Culverts & Box Sections', meta: 'BS 5911 / EN 14844' },
  { href: '/products/padstones', label: 'Padstones & Bearings', meta: 'Cast to schedule' },
  { href: '/products/l-blocks', label: 'L-Block Retaining', meta: 'Interlocking units' },
];

const faqs = [
  { q: 'What are tetrapods used for?', a: 'Tetrapods are four-legged concrete armour units designed to dissipate wave energy and protect coastlines from erosion and storm surge. They lock together when placed on a slope, creating an effective breakwater or revetment protection layer.' },
  { q: 'What size are WCCP tetrapods?', a: 'Two sizes — 3-tonne units at 1950 × 1950 × 1720 mm and 5-tonne units at 2340 × 2340 × 2080 mm. Both are cast in C40/50 concrete and ideal for sea defence, reducing erosion and reducing wave energy. Suitable for Environment Agency coastal works.' },
  { q: 'How are they installed?', a: 'Tetrapods are typically placed on prepared slopes (usually 1.5:1 or 2:1) using a crane with a spreader beam or lifting sling. They interlock naturally as they settle, creating a stable mass that resists wave action.' },
  { q: 'What concrete specification do you use?', a: 'C40/50 concrete ensures durability in harsh marine environments. We can specify marine-grade mixes or sulphate-resisting cement if required for specific site conditions.' },
  { q: 'Can you provide design and engineering?', a: 'Yes. We work with coastal engineers and contractors on sizing calculations, placement plans and site-specific specifications. Contact the office for a detailed quotation.' },
  { q: 'Lead time and delivery?', a: 'Tetrapods typically ship in 4–6 weeks. Delivery is on a heavy breakbulk service due to weight. We handle all logistics coordination.' },
];

const productSchema = {
  name: 'Tetrapods — 3-tonne and 5-tonne Coastal Armour Units',
  description: 'WCCP precast concrete tetrapods for coastal defence, breakwater protection and wave attenuation. 3-tonne units at 1950×1950×1720mm and 5-tonne units at 2340×2340×2080mm. C40/50 concrete. Suitable for Environment Agency coastal works.',
  brand: { '@type': 'Brand', name: site.name },
  manufacturer: { '@type': 'Organization', name: site.name },
  category: 'Precast concrete coastal armour unit (tetrapod)',
  material: 'Reinforced concrete, C40/50 (BS 8500-1:2023)',
  weight: { '@type': 'QuantitativeValue', minValue: 3000, maxValue: 5000, unitCode: 'KGM', unitText: 'kilogram per unit' },
  additionalProperty: [
    { '@type': 'PropertyValue', name: '3-tonne unit', value: '1950 × 1950 × 1720 mm' },
    { '@type': 'PropertyValue', name: '5-tonne unit', value: '2340 × 2340 × 2080 mm' },
    { '@type': 'PropertyValue', name: 'Concrete grade', value: 'C40/50 (BS 8500-1:2023)' },
    { '@type': 'PropertyValue', name: 'Use', value: 'Sea defence, erosion reduction, wave energy reduction — Environment Agency coastal works' },
    { '@type': 'PropertyValue', name: 'Country of origin', value: 'United Kingdom (Devon)' },
  ],
};
---

<BaseLayout
  title="Tetrapods — 3-tonne and 5-tonne coastal armour units"
  description="Precast concrete tetrapods for coastal defence, breakwaters and revetments. 3-tonne (1.95 × 1.95 × 1.72 m) and 5-tonne (2.34 × 2.34 × 2.08 m) units for sea defence, erosion reduction and wave energy reduction. Made in Devon."
  schema="Product"
  productSchema={productSchema}
>
  <TrustStrip />

  <!-- Hero -->
  <section id="overview" class="relative bg-navy text-white overflow-hidden">
    <div class="relative container-wccp py-20 md:py-28">
      <div class="grid lg:grid-cols-[1.2fr_1fr] gap-10 lg:gap-14 items-center">
        <div>
          <p class="eyebrow text-yellow mb-6">Coastal Protection</p>
          <h1 class="font-display text-display-2xl text-white mb-6">
            Tetrapods.<br />
            <span class="text-yellow">3 and 5-tonne wave armour.</span>
          </h1>
          <p class="text-lg md:text-xl text-white/90 max-w-2xl mb-10 leading-relaxed">
            Ideal for sea defence — reduce erosion, reduce wave energy. Suitable for
            Environment Agency coastal works. Two sizes — 3-tonne (1.95 × 1.95 × 1.72 m)
            and 5-tonne (2.34 × 2.34 × 2.08 m) — cast in C40/50 marine-grade concrete.
          </p>
          <div class="flex flex-wrap gap-3">
            <SpecSheetButton product="Tetrapods" />
            <a href="/quote?product=Tetrapods" class="btn-ghost border-white text-white hover:bg-white hover:text-navy">Enquire</a>
          </div>
        </div>
        <div class="rounded-lg overflow-hidden shadow-lifted ring-1 ring-yellow-400/30">
          <picture>
            <source srcset="/images/products/home/wccp-home-img-20260414-162319990-comp-1024x1024.webp" type="image/webp" />
            <img
              src="/images/products/home/wccp-home-img-20260414-162319990-comp-1024x1024.jpg"
              alt="WCCP tetrapods in the yard"
              class="w-full h-auto block"
              loading="eager"
              decoding="async"
            />
          </picture>
        </div>
      </div>
    </div>
  </section>

  <ProductWarrantyLine />

  <!-- Specifications -->
  <section id="specifications" class="container-wccp py-20">
    <div class="max-w-2xl mb-12">
      <p class="eyebrow text-cast mb-3">Specification</p>
      <h2 class="font-display text-display-lg mb-6">Marine armour — engineered sizing.</h2>
    </div>

    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b-2 border-navy">
            <th class="text-left py-3 px-4 font-semibold text-navy">Unit Weight</th>
            <th class="text-left py-3 px-4 font-semibold text-navy">Arm Length</th>
            <th class="text-left py-3 px-4 font-semibold text-navy">Concrete Spec</th>
            <th class="text-left py-3 px-4 font-semibold text-navy">Application</th>
          </tr>
        </thead>
        <tbody>
          {tetrapodSpecs.map((spec) => (
            <tr class="border-b border-cast-200 hover:bg-bone-100">
              <td class="py-4 px-4 text-cast-700">{spec.weight}</td>
              <td class="py-4 px-4 text-cast-700">{spec.dimensions}</td>
              <td class="py-4 px-4 text-cast-700">{spec.density}</td>
              <td class="py-4 px-4 text-cast-700">{spec.application}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <div class="mt-12 grid md:grid-cols-2 gap-8">
      <div>
        <p class="eyebrow text-cast mb-3">Key Features</p>
        <ul class="space-y-2 text-cast-700">
          <li class="flex gap-3">
            <span class="text-ember font-bold">·</span>
            <span>3.5-tonne weight for optimal interlocking and stability</span>
          </li>
          <li class="flex gap-3">
            <span class="text-ember font-bold">·</span>
            <span>Four-leg design for natural matrix formation on slopes</span>
          </li>
          <li class="flex gap-3">
            <span class="text-ember font-bold">·</span>
            <span>C40/50 concrete for marine durability and long service life</span>
          </li>
          <li class="flex gap-3">
            <span class="text-ember font-bold">·</span>
            <span>Integrated lifting points for safe placement</span>
          </li>
          <li class="flex gap-3">
            <span class="text-ember font-bold">·</span>
            <span>BS-compliant design and marine engineering certification</span>
          </li>
        </ul>
      </div>

      <div class="card p-6 bg-bone-200">
        <p class="eyebrow text-ember mb-3">Design Standards</p>
        <ul class="space-y-2 text-cast">
          <li>· BS 6349-1-1 (Maritime works)</li>
          <li>· EN 14844 (Precast concrete products)</li>
          <li>· Coastal engineering best practice</li>
          <li>· Wave energy dissipation modelling</li>
          <li>· Site-specific slope analysis available</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Applications -->
  <section id="applications" class="bg-bone-200 py-20">
    <div class="container-wccp">
      <div class="max-w-2xl mb-10">
        <p class="eyebrow text-cast mb-3">Where They Go</p>
        <h2 class="font-display text-display-lg">Breakwaters, revetments, coastal armour.</h2>
      </div>

      <div class="grid md:grid-cols-2 gap-6">
        {applications.map((app) => (
          <div class="flex gap-4">
            <div class="w-12 h-12 rounded-full bg-navy text-white flex items-center justify-center shrink-0 font-bold text-lg">
              ✓
            </div>
            <div>
              <p class="text-cast-700 leading-relaxed">{app}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section id="faq" class="container-wccp py-20">
    <div class="max-w-2xl mb-12">
      <p class="eyebrow text-cast mb-3">Common Questions</p>
      <h2 class="font-display text-display-lg">Asked and answered.</h2>
    </div>

    <div class="max-w-3xl space-y-6">
      {faqs.map((faq) => (
        <details class="card p-6 group cursor-pointer">
          <summary class="flex items-start justify-between gap-4 font-semibold text-navy hover:text-ember transition-colors">
            <span>{faq.q}</span>
            <span class="text-ember text-xl shrink-0 group-open:rotate-180 transition-transform">+</span>
          </summary>
          <p class="mt-4 text-cast-700 leading-relaxed">{faq.a}</p>
        </details>
      ))}
    </div>
  </section>

  <!-- Related Products -->
  <section id="related" class="bg-bone-200 py-20">
    <div class="container-wccp">
      <div class="max-w-2xl mb-10">
        <p class="eyebrow text-cast mb-3">Related Products</p>
        <h2 class="font-display text-display-lg">Other civils and marine units.</h2>
      </div>
      <RelatedProductGrid items={related} />
    </div>
  </section>

  <!-- Downloads -->
  <section id="downloads" class="container-wccp py-20">
    <div class="max-w-2xl mb-10">
      <p class="eyebrow text-cast mb-3">Downloads</p>
      <h2 class="font-display text-display-lg">Datasheet, CAD and BIM files.</h2>
    </div>

    <div class="grid md:grid-cols-3 gap-6">
      <SpecSheetButton product="Tetrapods" variant="card" />
      <CADDownloads product="Tetrapods" />
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-navy text-white py-16">
    <div class="container-wccp text-center">
      <h2 class="font-display text-display-lg mb-4">Need a quotation?</h2>
      <p class="text-white/85 text-lg max-w-xl mx-auto mb-8">
        Provide your site conditions, slope gradient and wave data — we'll design the armour specification and lead time.
      </p>
      <div class="flex flex-wrap justify-center gap-3">
        <a href="/quote?product=Tetrapods" class="btn-primary">Request a quote</a>
        <a href={`tel:${site.contact.phoneIntl}`} class="btn-yellow">Call {site.contact.phone}</a>
      </div>
    </div>
  </section>
</BaseLayout>
