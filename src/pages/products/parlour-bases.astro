---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ProductWarrantyLine from '@/components/ProductWarrantyLine.astro';
import TrustStrip from '@/components/TrustStrip.astro';
import FittedVsSupply from '@/components/FittedVsSupply.astro';
import SpecSheetButton from '@/components/SpecSheetButton.astro';
import { site } from '@/config/site';
import RelatedProductGrid from '@/components/RelatedProductGrid.astro';
import ProductPageTOC from '@/components/ProductPageTOC.astro';

const tocSections = [
  { id: 'overview', label: 'Overview' },
  { id: 'specifications', label: 'Specifications' },
  { id: 'gallery', label: 'Gallery' },
  { id: 'related', label: 'Related' },
  { id: 'faq', label: 'FAQ' },
  { id: 'downloads', label: 'Downloads' },
];

const specs = [
  { variant: 'DeLaval VMS V300 base', size: '3.6m × 2.4m × 250mm', tolerance: '±2mm level across base', use: 'Single-box VMS V300 robotic milking installation' },
  { variant: 'Lely Astronaut A5 base', size: '3.5m × 2.4m × 250mm', tolerance: '±2mm level across base', use: 'Lely A5 robotic milking installation' },
  { variant: 'GEA DairyRobot R9500 base', size: '3.4m × 2.4m × 250mm', tolerance: '±2mm level across base', use: 'GEA box-style robotic milking' },
  { variant: 'Herringbone parlour base', size: 'To pit length — typically 12-24m', tolerance: '±3mm level along pit', use: 'Conventional 8/16 to 24/48 herringbone parlours' },
  { variant: 'Rotary parlour ring base', size: '12m to 28m external diameter', tolerance: '±3mm level around ring', use: 'External rotary platforms — Waikato, GEA, DeLaval' },
  { variant: 'Collecting yard slab', size: 'To shed dimensions', tolerance: 'Falls 1:60 to channel', use: 'Pre-milking holding yard with grooved finish' },
  { variant: 'Parlour pit precast', size: '900mm wide × pit length', tolerance: '±2mm to operator floor', use: 'Operator pit with cable / vacuum / wash channels cast in' },
];

const applications = [
  'New-build robot dairies — DeLaval, Lely, GEA installations',
  'Conventional herringbone parlour replacements (8/16 to 32/64)',
  'External rotary parlours up to 80-point platforms',
  'Retro-fits where a robot replaces an old herringbone',
  'Conversion of straw-yard barns to robotic milking',
  'Calf-rearing automatic feeders on precast bases',
  'Mixed installations — robot-led with herringbone backup',
];

const related = [
  { href: '/products/cattle-cubicles', label: 'Cattle Cubicles', meta: 'Fixed + portable · AHDB sized' },
  { href: '/products/water-troughs', label: 'Water Troughs', meta: 'Single + double row' },
  { href: '/products/slurry-storage', label: 'Slurry Storage', meta: 'SSAFO 2018-compliant' },
  { href: '/products/feed-troughs', label: 'Feed Troughs', meta: 'Precast slabs · grooved' },
];

const faqs = [
  { q: 'How tight is the level tolerance for a robot?', a: 'Robot manufacturers specify ±2mm level across the base — Lely, DeLaval and GEA all give the same number. We cast our parlour bases to a steel-trowelled finish on a benched mould and check level with a rotating laser before lifting. Slabs out of tolerance are remade at our cost.' },
  { q: 'Which manufacturer schedules do you cast to?', a: 'We have shop drawings on file for DeLaval VMS V300 / V310, Lely Astronaut A5 and A4, GEA DairyRobot R9500 and DairyProQ rotaries. For conventional parlours we cast to Fullwood, Boumatic, GEA, DeLaval, Pearson and Dairymaster pit and platform schedules. Send us the model and we will return a confirmed drawing.' },
  { q: 'Do you cast the pit and the rotary ring as one piece or in segments?', a: 'Pits up to 6m we cast as a single piece. Longer pits and rotary rings we cast in segments with grout-injected dowel joints — six segments around an 18m diameter rotary is typical. Joints are detailed below the operator floor and finished flush.' },
  { q: 'What about cable, vacuum and wash penetrations?', a: 'All cast in to the parlour-installer schedule before the slab leaves our yard. Late penetrations on site mean diamond drilling — we strongly prefer to do them at the yard where we can keep them out of reinforcement. Send us the parlour drawings before we cut the mould.' },
  { q: 'What is the lead time?', a: 'Robot bases ship in 2-3 weeks if the manufacturer drawing is signed off. Bespoke herringbone pits and rotary rings run 4-6 weeks. Spring and autumn book up early — drop us the parlour install date as soon as you have it from the dealer and we will hold a casting slot.' },
];

const productSchema = {
  name: 'Precast Parlour & Dairy Bases',
  description: 'Precast concrete bases and pits for robotic and conventional milking systems. DeLaval VMS, Lely Astronaut, GEA DairyRobot box-style; herringbone and rotary platforms. Cast in C40/50 to ±2mm level tolerance at our Holsworthy yard.',
  brand: { '@type': 'Brand', name: site.name },
  manufacturer: { '@type': 'Organization', name: site.name },
  category: 'Precast concrete dairy parlour base',
  material: 'Reinforced concrete, C40/50 (BS 8500-1:2023)',
  additionalProperty: [
    { '@type': 'PropertyValue', name: 'Standard', value: 'BS 5502-22:2003 (agricultural buildings)' },
    { '@type': 'PropertyValue', name: 'Concrete grade', value: 'C40/50 (BS 8500-1:2023)' },
    { '@type': 'PropertyValue', name: 'Level tolerance', value: '±2mm across robot base' },
    { '@type': 'PropertyValue', name: 'Compatible robots', value: 'DeLaval VMS V300/V310, Lely A4/A5, GEA R9500' },
    { '@type': 'PropertyValue', name: 'Conventional parlours', value: 'Herringbone 8/16 to 32/64, rotary up to 80-point' },
    { '@type': 'PropertyValue', name: 'Lead time', value: '2-3 weeks robot, 4-6 weeks bespoke pits' },
    { '@type': 'PropertyValue', name: 'Country of origin', value: 'United Kingdom (Devon)' },
  ],
  offers: { '@type': 'Offer', availability: 'https://schema.org/InStock', areaServed: 'GB', seller: { '@type': 'Organization', name: site.name } },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<BaseLayout
  title="Parlour & Dairy Bases — Robotic & Conventional Milking · ±2mm tolerance"
  description="Precast parlour bases for DeLaval VMS, Lely Astronaut, GEA DairyRobot and conventional herringbone / rotary parlours. ±2mm level tolerance, C40/50 to BS 8500-1. Cast in North Devon."
  image="/og-default.png"
  schema="Product"
  schemaData={productSchema}
  whatsappContext="Parlour Bases"
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)} slot="head" />
  <TrustStrip />
  <ProductPageTOC sections={tocSections} />

  <!-- Hero -->
  <section id="overview" class="bg-navy text-white">
    <div class="container-wccp py-16 md:py-20">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <p class="eyebrow text-yellow mb-4">Agricultural · dairy · robotic</p>
          <h1 class="font-display text-display-xl text-white mb-4">Parlour Bases.</h1>
          <p class="font-display italic text-xl md:text-2xl text-yellow leading-tight mb-5">±2mm. Every time. Or we re-cast.</p>
          <p class="text-lg lg:text-xl text-cast leading-relaxed font-medium text-white/95 mb-6 max-w-xl">
            Precast bases and pits for robotic and conventional milking systems. DeLaval VMS,
            Lely Astronaut, GEA DairyRobot box-style; herringbone parlours up to 32/64 and
            external rotaries up to 80-point. Cast to the manufacturer's schedule, level to
            ±2mm, ready to bolt the robot down.
          </p>
          <blockquote class="font-display italic text-base md:text-lg text-white/95 leading-relaxed mb-6 pl-4 border-l-2 border-yellow max-w-xl">
            A milking robot is a precision instrument bolted to a slab. Get the slab wrong and
            the dealer cannot commission. We cast the slab right — to the robot manufacturer's
            tolerance — so commissioning happens on the day it should.
          </blockquote>
          <p class="text-base text-white/85 leading-relaxed mb-6 max-w-xl">
            We have shop drawings on file for every major UK robot brand and most conventional
            parlour pit schedules. Send us the dealer drawing and the install date and we will
            hold a casting slot.
          </p>
          <ul class="grid grid-cols-2 gap-3 text-sm mb-8 max-w-md">
            <li class="flex gap-2"><span class="text-yellow">·</span> ±2mm tolerance</li>
            <li class="flex gap-2"><span class="text-yellow">·</span> C40/50 concrete</li>
            <li class="flex gap-2"><span class="text-yellow">·</span> Robot + conventional</li>
            <li class="flex gap-2"><span class="text-yellow">·</span> All cast-ins coordinated</li>
            <li class="flex gap-2"><span class="text-yellow">·</span> 2-3 week robot lead</li>
            <li class="flex gap-2"><span class="text-yellow">·</span> BS 5502-22</li>
          </ul>
          <div class="flex flex-wrap gap-3">
            <a href="/quote?product=Parlour%20Bases" class="btn-primary">Configure a quote</a>
            <a href="mailto:engineering@wccp.co.uk?subject=Spec%20sheet%20request%20%E2%80%94%20Parlour%20Bases&amp;body=Hi%20WCCP%20engineering%2C%0A%0APlease%20send%20the%20spec%20sheet%20for%20Parlour%20Bases.%0A%0AProject%20details%3A%0A%E2%80%A2%20Project%20name%3A%0A%E2%80%A2%20Site%20location%3A%0A%E2%80%A2%20Required%20spec%20%2F%20standard%3A%0A%0AThanks" class="btn-yellow">Request spec sheet</a>
            <a href={`tel:${site.contact.phoneIntl}`} class="btn-ghost border-white text-white hover:bg-white hover:text-navy">
              Call {site.contact.phone}
            </a>
          </div>
        </div>
        <div class="aspect-[4/3] bg-cast-100 rounded overflow-hidden flex items-center justify-center border-2 border-dashed border-cast-300 p-8 text-center">
          <div>
            <p class="text-cast-600 text-sm font-mono">Photo needed</p>
            <p class="text-cast text-xs mt-2">Hero — installed robot base with VMS or Astronaut bolted down, finished concrete and cast-in conduits visible</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Spec table -->
  <section id="specifications" class="container-wccp py-20">
    <div class="max-w-2xl mb-10">
      <p class="eyebrow text-cast mb-3">Specification</p>
      <h2 class="font-display text-display-lg mb-4">Robot, herringbone and rotary bases.</h2>
      <p class="text-cast-700 text-lg">
        Sizes shown are robot-manufacturer standard. Pit lengths and rotary ring diameters are
        cast to the parlour-installer schedule with all cable, vacuum and wash penetrations
        coordinated before the mould is cut.
      </p>
    </div>

    <div class="overflow-x-auto">
      <table class="spec-table w-full text-left border-collapse">
        <thead class="bg-navy text-white">
          <tr>
            <th class="px-4 py-3 font-display text-sm uppercase tracking-wide">Variant</th>
            <th class="px-4 py-3 font-display text-sm uppercase tracking-wide">Size</th>
            <th class="px-4 py-3 font-display text-sm uppercase tracking-wide">Tolerance</th>
            <th class="px-4 py-3 font-display text-sm uppercase tracking-wide">Typical use</th>
          </tr>
        </thead>
        <tbody>
          {specs.map((s, i) => (
            <tr class={i % 2 === 0 ? 'bg-white' : 'bg-bone-200'}>
              <td class="px-4 py-3 font-bold text-navy">{s.variant}</td>
              <td class="px-4 py-3">{s.size}</td>
              <td class="px-4 py-3">{s.tolerance}</td>
              <td class="px-4 py-3 text-cast">{s.use}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    <p class="text-cast text-sm mt-4">
      We confirm robot model, pit dimensions and cable / vacuum / wash penetrations on a shop
      drawing before mould cut. Late changes after mould cut are chargeable.
    </p>

    <p class="text-cast text-sm mt-4">
      All bases supplied with mix design, cube-test data and a level survey to confirm the
      ±2mm tolerance has been achieved before despatch.
    </p>
  </section>

  <!-- Gallery -->
  <section id="gallery" class="bg-bone-200 py-20">
    <div class="container-wccp">
      <div class="max-w-2xl mb-10">
        <p class="eyebrow text-cast mb-3">Parlour & robot bases</p>
        <h2 class="font-display text-display-lg mb-4 text-navy">Recent dairy installations.</h2>
        <p class="text-cast-700 text-lg">Photo plates being commissioned — placeholder shot briefs below.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {[
          { caption: 'DeLaval VMS V300 · landed and bolted', shot: 'VMS V300 robot bolted down on precast base, conduits coming up through cast-in penetrations' },
          { caption: 'Lely Astronaut A5 · ready for commissioning', shot: 'Lely A5 on precast base, all services connected, parlour ready for first milk' },
          { caption: 'Herringbone pit precast · 16/32', shot: 'Long herringbone parlour pit cast as single segment, operator side, cable channels' },
          { caption: 'External rotary ring · 60-point', shot: 'External rotary platform precast ring base on site, multiple segments joined' },
          { caption: 'Robot base in mould · steel-trowelled', shot: 'Robot base in mould at Holsworthy with steel-trowelled finish, mid-cure' },
          { caption: 'Level survey · ±2mm verified', shot: 'Operator with rotating laser level checking finished base before despatch' },
          { caption: 'HIAB delivery · 12 t single piece', shot: 'WCCP HIAB lorry offloading robot base onto prepared sub-base on dairy farm' },
          { caption: 'Cable / vacuum penetrations cast in', shot: 'Close-up of cast-in penetrations on base — sleeves grouped to manufacturer schedule' },
        ].map((img) => (
          <figure>
            <div class="aspect-[4/3] bg-cast-100 rounded overflow-hidden flex items-center justify-center border-2 border-dashed border-cast-300 p-4 text-center">
              <div>
                <p class="text-cast-600 text-xs font-mono">Photo needed</p>
                <p class="text-cast text-xs mt-2">{img.shot}</p>
              </div>
            </div>
            <figcaption class="mt-3 text-sm font-medium text-cast">{img.caption}</figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- Applications -->
  <section class="bg-white py-20">
    <div class="container-wccp">
      <div class="grid lg:grid-cols-2 gap-12">
        <div>
          <p class="eyebrow text-cast mb-3">Where they go</p>
          <h2 class="font-display text-display-lg mb-6">Common applications.</h2>
          <p class="text-cast-700 text-lg leading-relaxed mb-6">
            From a single-robot conversion of a 60-cow Devon dairy to a four-robot 240-cow
            new build in Wales, we cast the base to the dealer's drawing and to the
            manufacturer's tolerance.
          </p>
          <ul class="space-y-3">
            {applications.map((a) => (
              <li class="flex gap-3 text-cast-700 leading-relaxed">
                <span class="text-ember font-bold mt-1">·</span>
                <span>{a}</span>
              </li>
            ))}
          </ul>
        </div>

        <div class="card p-8">
          <p class="eyebrow text-cast mb-3">Standards & references</p>
          <h3 class="font-display text-2xl font-bold text-navy mb-4">Cast and certified to current code.</h3>
          <dl class="space-y-4 text-sm">
            <div>
              <dt class="font-bold text-navy">BS 5502-22:2003</dt>
              <dd class="text-cast">Buildings and structures for agriculture — cattle housing and milking parlours.</dd>
            </div>
            <div>
              <dt class="font-bold text-navy">BS 8500-1:2023</dt>
              <dd class="text-cast">Concrete specification — C40/50, exposure XC4 / XF1 for the dairy environment.</dd>
            </div>
            <div>
              <dt class="font-bold text-navy">BS EN 13369</dt>
              <dd class="text-cast">Common rules for precast concrete products — Factory Production Control.</dd>
            </div>
            <div>
              <dt class="font-bold text-navy">Robot-manufacturer schedules</dt>
              <dd class="text-cast">DeLaval VMS V300/V310, Lely Astronaut A5, GEA DairyRobot R9500 — drawings on file.</dd>
            </div>
            <div>
              <dt class="font-bold text-navy">Red Tractor Dairy Standards</dt>
              <dd class="text-cast">Hygiene and surface-finish requirements for milking-area concrete.</dd>
            </div>
          </dl>
        </div>
      </div>
    </div>
  </section>

  <!-- Configurator CTA -->
  <section class="bg-yellow text-navy py-16">
    <div class="container-wccp">
      <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6">
        <div>
          <p class="eyebrow text-navy mb-2">Configure your parlour base</p>
          <h2 class="font-display text-display-md">Tell us robot make, pit length and install date — we will quote and hold a slot inside 24 hours.</h2>
        </div>
        <div class="flex flex-wrap gap-3 shrink-0">
          <a href="/quote?product=Parlour%20Bases" class="btn bg-navy text-white hover:bg-navy-700">Open the configurator</a>
          <a href={`mailto:${site.contact.quotesEmail}`} class="btn-secondary">Email quotes</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Related -->
  <section id="related" class="container-wccp py-20">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between mb-10 gap-4">
      <div>
        <p class="eyebrow text-cast mb-3">Related products</p>
        <h2 class="font-display text-display-lg">Often ordered alongside.</h2>
      </div>
      <a href="/products" class="text-ember font-bold hover:text-ember-700 inline-flex items-center gap-2">
        View full range
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <line x1="5" y1="12" x2="19" y2="12" stroke-linecap="round" />
          <polyline points="12 5 19 12 12 19" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </a>
    </div>
    <RelatedProductGrid items={related} />
  </section>

  <!-- FAQ -->
  <section id="faq" class="bg-bone-200 py-20">
    <div class="container-wccp">
      <div class="max-w-2xl mb-12">
        <p class="eyebrow text-cast mb-3">Common questions</p>
        <h2 class="font-display text-display-lg mb-4">What dairy farmers ask.</h2>
        <p class="text-cast-700 text-lg">
          Five questions we answer most weeks. If yours is not here, ring the yard.
        </p>
      </div>
      <div class="max-w-3xl space-y-4">
        {faqs.map((f) => (
          <details class="card p-6 group">
            <summary class="font-display text-lg font-bold text-navy cursor-pointer list-none flex justify-between items-start gap-4">
              <span>{f.q}</span>
              <span class="text-ember text-2xl leading-none group-open:rotate-45 transition-transform shrink-0">+</span>
            </summary>
            <p class="text-cast-700 leading-relaxed mt-4">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Supply-only vs Fitted -->
  <section class="container-wccp section-rhythm border-t border-cast-100">
    <FittedVsSupply
      productName="Parlour Bases"
      defaultMode="fitted"
      supply={{
        price: 'Bespoke quote',
        leadTime: '2–3 weeks robot · 4–6 weeks bespoke',
        includes: [
          'Cast base to robot / parlour-installer schedule',
          'All cast-in penetrations coordinated',
          'Level survey to ±2mm at despatch',
          'Delivery on flatbed or HIAB',
        ],
        excludes: [
          'On-site lifting beyond 12 t (mobile crane separate)',
          'Sub-base and grout-bedding',
        ],
      }}
      fitted={{
        price: 'Bespoke quote (incl. set & grout)',
        leadTime: '4–6 weeks (incl. site slot)',
        includes: [
          'Everything in supply only',
          'WCCP HIAB offload and set on prepared sub-base',
          'Survey, setting-out, levelling, grout-bedding',
          '12-month workmanship warranty',
        ],
        excludes: [
          'Robot or parlour commissioning (dealer scope)',
          'M&E first-fix (electrical, water, vacuum)',
        ],
      }}
      note=". We coordinate timing with the robot dealer so the slab is cured and signed off in time for commissioning day."
    />
  </section>

  <!-- Final CTA -->
  <section class="bg-navy text-white py-20">
    <div class="container-wccp text-center">
      <h2 class="font-display text-display-xl mb-4 text-white">Ready to spec it?</h2>
      <p class="text-white/90 text-lg max-w-xl mx-auto mb-8">
        Send the dealer drawing and the install date — we will quote and hold a slot.
      </p>
      <div class="flex flex-wrap justify-center gap-3">
        <a href="/quote?product=Parlour%20Bases" class="btn-yellow">Configure a quote</a>
        <a href={`tel:${site.contact.phoneIntl}`} class="btn-secondary">Call {site.contact.phone}</a>
        <a href={`mailto:${site.contact.quotesEmail}`} class="btn-primary">Email quotes</a>
      </div>
    </div>
  </section>

  <SpecSheetButton productSlug="parlour-bases" productName="Parlour Bases" />
  <ProductWarrantyLine />
</BaseLayout>
