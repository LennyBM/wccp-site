---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TrustStrip from '@/components/TrustStrip.astro';
import { site } from '@/config/site';

const specs = [
  { height: '1.5m', stem: '180mm', toe: '0.9m', heel: '0.6m', weight: '1,650 kg/m', surcharge: '20 kN/m²' },
  { height: '2.5m', stem: '200mm', toe: '1.2m', heel: '0.9m', weight: '2,750 kg/m', surcharge: '25 kN/m²' },
  { height: '3.5m', stem: '220mm', toe: '1.5m', heel: '1.2m', weight: '4,200 kg/m', surcharge: '30 kN/m²' },
  { height: '4.5m', stem: '250mm', toe: '1.8m', heel: '1.5m', weight: '6,150 kg/m', surcharge: '40 kN/m²' },
  { height: '5.5m', stem: '280mm', toe: '2.2m', heel: '1.8m', weight: '8,800 kg/m', surcharge: '45 kN/m²' },
  { height: '6.0m', stem: '300mm', toe: '2.4m', heel: '2.0m', weight: '10,400 kg/m', surcharge: '50 kN/m²' },
];

const applications = [
  'Highway and rail civils retention up to 6m',
  'Free-standing boundary and basement walls',
  'Industrial yard level-change retention',
  'Reservoir and flood-defence walls',
  'Petrol-station forecourt level changes',
  'Commercial development boundary retention',
  'Reinforced earth wall facing on embankments',
];

const related = [
  { href: '/products/retaining-walls', label: 'All Retaining Walls', meta: 'Family hub · four systems' },
  { href: '/products/king-post-walls', label: 'King Post Walls', meta: 'Steel post + panel infill' },
  { href: '/products/l-blocks', label: 'L-Block Retaining', meta: '1m–6m · interlocking' },
  { href: '/products/prestressed-panels', label: 'Prestressed Panels', meta: 'BS EN 14992 · UKCA' },
];

const faqs = [
  { q: 'How is a cantilever wall different from an L-block?', a: 'A cantilever wall has a continuous engineered heel — it is designed as a single structure with cast-in-situ joints. L-blocks are individual units sitting on hardcore. Cantilever takes a heavier engineered loading and a longer design life; L-blocks are quicker, cheaper and re-locatable.' },
  { q: 'Do you cast in situ or precast?', a: 'Both options. We will precast the stem and ship to site with a cast-in-situ heel for fast install on heavy schemes. For smaller jobs, full precast units with a bolted heel are quicker still. Talk to the design team about which suits your programme.' },
  { q: 'Engineered to what code?', a: 'Every cantilever wall we deliver is calculated to BS EN 1992-1-1 (Eurocode 2) and BS EN 1997 (Eurocode 7) for the geotechnical bearing and sliding checks. 50-year design life as standard, 120-year available on civils-grade specs.' },
  { q: 'What surcharge can I run?', a: 'Up to 50 kN/m² at 6m height — that covers HA traffic loading (LM1) plus a margin. Higher surcharges or seismic detailing on bespoke designs.' },
  { q: 'Lead time?', a: '4 to 6 weeks for the standard cantilever range. Bespoke heel details, exposed-aggregate facing or curved alignments run 6 to 10 weeks. Send the section drawing first — we can usually shave a fortnight off if you order early.' },
];

const productSchema = {
  name: 'Precast Cantilever Retaining Walls',
  description: 'Free-standing precast cantilever retaining walls. Engineered to BS EN 1992-1-1 (Eurocode 2). Heights 1.5m to 6.0m, surcharge ratings to 50 kN/m². 50-year design life as standard.',
  brand: { '@type': 'Brand', name: site.name },
  manufacturer: { '@type': 'Organization', name: site.name },
  category: 'Precast cantilever retaining wall',
  material: 'Reinforced concrete, C40/50 (BS 8500-1:2023)',
  weight: { '@type': 'QuantitativeValue', minValue: 1650, maxValue: 10400, unitCode: 'KGM', unitText: 'kilogram per linear metre' },
  additionalProperty: [
    { '@type': 'PropertyValue', name: 'Standard', value: 'BS EN 14992 / BS EN 13369' },
    { '@type': 'PropertyValue', name: 'Structural design', value: 'BS EN 1992-1-1 / BS EN 1997 (Eurocode 7)' },
    { '@type': 'PropertyValue', name: 'Concrete grade', value: 'C40/50 (BS 8500-1:2023)' },
    { '@type': 'PropertyValue', name: 'Height range', value: '1.5 m – 6.0 m' },
    { '@type': 'PropertyValue', name: 'Maximum surcharge', value: '50 kN/m² (incl. LM1)' },
    { '@type': 'PropertyValue', name: 'Design life', value: '50 years (120-year option)' },
    { '@type': 'PropertyValue', name: 'Lead time', value: '4–6 weeks catalogue' },
    { '@type': 'PropertyValue', name: 'Country of origin', value: 'United Kingdom (Devon)' },
  ],
  offers: { '@type': 'Offer', priceCurrency: 'GBP', availability: 'https://schema.org/InStock', seller: { '@type': 'Organization', name: site.name } },
};

const faqSchema = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) };
---

<BaseLayout
  title="Cantilever Retaining Walls — engineered to BS EN 1992-1-1"
  description="Free-standing precast cantilever retaining walls. Heights 1.5m to 6.0m, surcharge to 50 kN/m². BS EN 1992-1-1, 50-year design life. Cast in North Devon."
  image="/images/products/cantilever-walls.jpg"
  schema="Product"
  schemaData={productSchema}
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)} slot="head" />
  <TrustStrip />

  <section class="bg-navy text-white">
    <div class="container-wccp py-16 md:py-20">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <p class="eyebrow text-yellow mb-4">Civils · infrastructure · highways</p>
          <h1 class="font-display text-display-xl text-white mb-4">Cantilever Walls.</h1>
          <p class="text-lg text-white/90 leading-relaxed mb-6">
            Free-standing precast cantilever retaining walls engineered to BS EN 1992-1-1.
            Heights 1.5m to 6.0m, surcharge ratings to 50 kN/m² including HA traffic loading.
            50-year design life as standard, 120-year on civils-grade specs.
          </p>
          <ul class="grid grid-cols-2 gap-3 text-sm mb-8 max-w-md">
            <li class="flex gap-2"><span class="text-yellow">·</span> Heights 1.5–6.0m</li>
            <li class="flex gap-2"><span class="text-yellow">·</span> Up to 50 kN/m²</li>
            <li class="flex gap-2"><span class="text-yellow">·</span> Eurocode 2 + 7</li>
            <li class="flex gap-2"><span class="text-yellow">·</span> 50-year life</li>
            <li class="flex gap-2"><span class="text-yellow">·</span> LM1 traffic load</li>
            <li class="flex gap-2"><span class="text-yellow">·</span> 4–6 week lead</li>
          </ul>
          <div class="flex flex-wrap gap-3">
            <a href="/quote?product=Cantilever+Walls" class="btn-primary">Configure a quote</a>
            <a href="/spec-sheets/cantilever-walls.pdf" class="btn-yellow">Download spec sheet</a>
            <a href={`tel:${site.contact.phoneIntl}`} class="btn-ghost border-white text-white hover:bg-white hover:text-navy">Call {site.contact.phone}</a>
          </div>
        </div>
        <div class="aspect-[4/3] bg-cast-100 rounded overflow-hidden"><div class="w-full h-full bg-gradient-to-br from-cast-300 via-cast to-navy"></div></div>
      </div>
    </div>
  </section>

  <section class="container-wccp py-20">
    <div class="max-w-2xl mb-10">
      <p class="eyebrow text-cast mb-3">Specification</p>
      <h2 class="font-display text-display-lg mb-4">Heights, stem thickness and footings.</h2>
      <p class="text-cast-700 text-lg">Catalogue dimensions for typical loadings. Site-specific design always to BS EN 1992-1-1 and BS EN 1997.</p>
    </div>
    <div class="overflow-x-auto">
      <table class="spec-table w-full text-left border-collapse">
        <thead class="bg-navy text-white">
          <tr>
            <th class="px-4 py-3 font-display text-sm uppercase tracking-wide">Height</th>
            <th class="px-4 py-3 font-display text-sm uppercase tracking-wide">Stem</th>
            <th class="px-4 py-3 font-display text-sm uppercase tracking-wide">Toe</th>
            <th class="px-4 py-3 font-display text-sm uppercase tracking-wide">Heel</th>
            <th class="px-4 py-3 font-display text-sm uppercase tracking-wide">Weight</th>
            <th class="px-4 py-3 font-display text-sm uppercase tracking-wide">Surcharge</th>
          </tr>
        </thead>
        <tbody>
          {specs.map((s, i) => (
            <tr class={i % 2 === 0 ? 'bg-white' : 'bg-bone-200'}>
              <td class="px-4 py-3 font-bold text-navy">{s.height}</td>
              <td class="px-4 py-3">{s.stem}</td>
              <td class="px-4 py-3">{s.toe}</td>
              <td class="px-4 py-3">{s.heel}</td>
              <td class="px-4 py-3">{s.weight}</td>
              <td class="px-4 py-3">{s.surcharge}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <section class="bg-bone-200 py-20">
    <div class="container-wccp">
      <div class="grid lg:grid-cols-2 gap-12">
        <div>
          <p class="eyebrow text-cast mb-3">Where they go</p>
          <h2 class="font-display text-display-lg mb-6">Common applications.</h2>
          <p class="text-cast-700 text-lg leading-relaxed mb-6">From a 1.5m level change at a forecourt to a 6m highway retention scheme — engineered for the long term.</p>
          <ul class="space-y-3">
            {applications.map((a) => (<li class="flex gap-3 text-cast-700 leading-relaxed"><span class="text-ember font-bold mt-1">·</span><span>{a}</span></li>))}
          </ul>
        </div>
        <div class="card p-8">
          <p class="eyebrow text-cast mb-3">Standards & certification</p>
          <h3 class="font-display text-2xl font-bold text-navy mb-4">Engineered, marked, certified.</h3>
          <dl class="space-y-4 text-sm">
            <div><dt class="font-bold text-navy">BS EN 1992-1-1 (Eurocode 2)</dt><dd class="text-cast">Concrete structural design — stem, heel and toe calculations.</dd></div>
            <div><dt class="font-bold text-navy">BS EN 1997 (Eurocode 7)</dt><dd class="text-cast">Geotechnical design — bearing, sliding and overturning checks.</dd></div>
            <div><dt class="font-bold text-navy">BS EN 14992</dt><dd class="text-cast">Precast wall elements — UKCA marking.</dd></div>
            <div><dt class="font-bold text-navy">BS EN 13369</dt><dd class="text-cast">Common rules for precast — factory production control.</dd></div>
            <div><dt class="font-bold text-navy">BS 8500-1:2023</dt><dd class="text-cast">Concrete spec — designated mixes for the exposure class.</dd></div>
          </dl>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-yellow text-navy py-16">
    <div class="container-wccp">
      <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6">
        <div>
          <p class="eyebrow text-navy mb-2">Configure your cantilever wall</p>
          <h2 class="font-display text-display-md">Send section, height and surcharge — we will quote inside 24 hours.</h2>
        </div>
        <div class="flex flex-wrap gap-3 shrink-0">
          <a href="/quote?product=Cantilever+Walls" class="btn bg-navy text-white hover:bg-navy-700">Open the configurator</a>
          <a href={`mailto:${site.contact.quotesEmail}`} class="btn-secondary">Email quotes</a>
        </div>
      </div>
    </div>
  </section>

  <section class="container-wccp py-20">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between mb-10 gap-4">
      <div>
        <p class="eyebrow text-cast mb-3">Related products</p>
        <h2 class="font-display text-display-lg">Often ordered alongside.</h2>
      </div>
      <a href="/products" class="text-ember font-bold hover:text-ember-700 inline-flex items-center gap-2">View full range
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12" stroke-linecap="round" /><polyline points="12 5 19 12 12 19" stroke-linecap="round" stroke-linejoin="round" /></svg>
      </a>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
      {related.map((r) => (
        <a href={r.href} class="card p-5 group">
          <div class="aspect-[16/10] bg-cast-100 mb-4 rounded overflow-hidden"><div class="w-full h-full bg-gradient-to-br from-cast-200 to-cast-100"></div></div>
          <h3 class="font-display text-base font-bold text-navy mb-1 group-hover:text-ember">{r.label}</h3>
          <p class="text-cast text-xs">{r.meta}</p>
        </a>
      ))}
    </div>
  </section>

  <section class="bg-bone-200 py-20">
    <div class="container-wccp">
      <div class="max-w-2xl mb-12">
        <p class="eyebrow text-cast mb-3">Common questions</p>
        <h2 class="font-display text-display-lg mb-4">What people ask about cantilever walls.</h2>
        <p class="text-cast-700 text-lg">Five questions we answer most weeks. If yours is not here, ring the yard.</p>
      </div>
      <div class="max-w-3xl space-y-4">
        {faqs.map((f) => (
          <details class="card p-6 group">
            <summary class="font-display text-lg font-bold text-navy cursor-pointer list-none flex justify-between items-start gap-4">
              <span>{f.q}</span>
              <span class="text-ember text-2xl leading-none group-open:rotate-45 transition-transform shrink-0">+</span>
            </summary>
            <p class="text-cast-700 leading-relaxed mt-4">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-navy text-white py-20">
    <div class="container-wccp text-center">
      <h2 class="font-display text-display-xl mb-4 text-white">Ready to spec it?</h2>
      <p class="text-white/90 text-lg max-w-xl mx-auto mb-8">Send the section, height and surcharge. Quote and lead-time same day.</p>
      <div class="flex flex-wrap justify-center gap-3">
        <a href="/quote?product=Cantilever+Walls" class="btn-yellow">Configure a quote</a>
        <a href={`tel:${site.contact.phoneIntl}`} class="btn-secondary">Call {site.contact.phone}</a>
        <a href={`mailto:${site.contact.quotesEmail}`} class="btn-primary">Email quotes</a>
      </div>
    </div>
  </section>
</BaseLayout>
