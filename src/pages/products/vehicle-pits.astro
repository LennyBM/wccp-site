---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ProductWarrantyLine from '@/components/ProductWarrantyLine.astro';
import TrustStrip from '@/components/TrustStrip.astro';
import FittedVsSupply from '@/components/FittedVsSupply.astro';
import SpecSheetButton from '@/components/SpecSheetButton.astro';
import ProductGallery from '@/components/ProductGallery.astro';
import { site } from '@/config/site';
import RelatedProductGrid from '@/components/RelatedProductGrid.astro';

const specs = [
  { spec: 'Deep pit (low-loader / 7.5t)', value: '1.5 m internal depth · 6.4 t main unit' },
  { spec: 'Shallow pit (standard artic)', value: '1.3 m internal depth · 5.5 t main unit' },
  { spec: 'Side recesses', value: 'Cast in for cables, airlines and lighting — keeps services flush' },
  { spec: 'End walls', value: 'Available with cast-in galvanised steel steps to one end' },
  { spec: 'Lifting points', value: 'Cast-in eyes on every main section' },
  { spec: 'Installation', value: 'Crane-lorry delivery — sections drop straight into the prepared excavation' },
];

const features = [
  'Two depths — 1.5m (low-loaders / 7.5 tonne lorries) and 1.3m (standard artics)',
  'Main section weights — 6.4 t (deep) and 5.5 t (shallow)',
  'Side recesses cast in for cables, airlines and lighting — services run flush',
  'Cast-in galvanised steel steps to one end available',
  'Crane-lorry delivery for fast install — sections drop straight in',
  'Far less expensive than steel-formed pits, very quick and easy to install',
  'Cast-in lifting eyes on every section',
];

const applications = [
  'Lorry workshop pits and HGV servicing bays',
  'Agricultural-engineer servicing pits',
  'MOT class IV (cars / light vans) inspection bays',
  'MOT class VII (3.5–7.5t goods vehicles) bays',
  'Bus and coach maintenance depots',
  'Plant and earthmoving equipment workshops',
  'Local authority fleet maintenance pits',
];

const related = [
  { href: '/products/culverts', label: 'Box Culverts', meta: 'BS EN 1916 · 1.0–3.6m' },
  { href: '/products/clean-rooms', label: 'Clean Rooms', meta: 'Tanked floor · machine pit' },
  { href: '/products/bespoke', label: 'Bespoke Precast', meta: 'Custom moulds · 4–8 wk' },
  { href: '/products/padstones', label: 'Padstones', meta: '200×200 to 600×600' },
];

const faqs = [
  { q: 'What depths are available?', a: 'Two depths — 1.5m for low-loaders and 7.5 tonne lorries, or 1.3m for standard artics. The depth is the internal depth of the pit. The deep main unit weighs 6.4 tonnes; the shallow main unit weighs 5.5 tonnes.' },
  { q: 'Why precast over a fabricated steel pit?', a: 'We believe our precast concrete workshop pits are far less expensive than steel-formed ones, and very quick and easy to install. Drop the section into the prepared excavation, level it, grout the joint, and you are running the workshop again very quickly.' },
  { q: 'How are the pits installed?', a: 'Typical installation is to excavate the pit, lay a blinding base, drop the precast sections in by crane lorry, then grout the joints. We can arrange delivery of the complete kit by crane lorry to fit the units straight into position.' },
  { q: 'Lighting, cables and air services?', a: 'The sides of the main sections have cast-in recesses you can use to run cables, airlines, and accommodate lighting — keeping them neatly out of the way. Pits can be supplied with cast-in galvanised steel steps to one end.' },
  { q: 'Lead time?', a: 'Catalogue pit sections run 4 to 6 weeks. Bespoke depths or layouts run 8 to 10 weeks. Send the workshop drawing first — most details are resolvable in a 30-minute call with our team.' },
];

const productSchema = {
  name: 'Precast Concrete Lorry Workshop Pits',
  description: 'Precast concrete lorry workshop and inspection pits in two depths — 1.5m (low-loaders / 7.5 tonne lorries) and 1.3m (standard artics). Main units 6.4t (deep) and 5.5t (shallow). Side recesses cast-in for cables, airlines and lighting; cast-in galvanised steps optional. Crane-lorry delivery.',
  brand: { '@type': 'Brand', name: site.name },
  manufacturer: { '@type': 'Organization', name: site.name },
  category: 'Precast vehicle inspection pit',
  material: 'Reinforced concrete, C40/50 (BS 8500-1:2023)',
  weight: { '@type': 'QuantitativeValue', minValue: 5500, maxValue: 6400, unitCode: 'KGM', unitText: 'kilogram per main unit' },
  additionalProperty: [
    { '@type': 'PropertyValue', name: 'Standard', value: 'BS EN 13369' },
    { '@type': 'PropertyValue', name: 'Concrete grade', value: 'C40/50 (BS 8500-1:2023)' },
    { '@type': 'PropertyValue', name: 'Deep pit', value: '1.5 m internal depth — for low-loaders / 7.5t lorries' },
    { '@type': 'PropertyValue', name: 'Shallow pit', value: '1.3 m internal depth — for standard artics' },
    { '@type': 'PropertyValue', name: 'Main unit weight', value: '6.4 t (deep), 5.5 t (shallow)' },
    { '@type': 'PropertyValue', name: 'Side recesses', value: 'Cast-in for cables, airlines and lighting' },
    { '@type': 'PropertyValue', name: 'End wall option', value: 'Cast-in galvanised steel steps available' },
    { '@type': 'PropertyValue', name: 'Installation', value: 'Crane-lorry delivery — sections drop into prepared excavation' },
    { '@type': 'PropertyValue', name: 'Lead time', value: '4–6 weeks catalogue, 8–10 weeks bespoke' },
    { '@type': 'PropertyValue', name: 'Country of origin', value: 'United Kingdom (Devon)' },
  ],
  offers: { '@type': 'Offer', availability: 'https://schema.org/InStock', areaServed: 'GB', seller: { '@type': 'Organization', name: site.name } },
};

const faqSchema = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) };
---

<BaseLayout
  title="Lorry Workshop Pits — 1.5m and 1.3m precast concrete inspection pits"
  description="Precast concrete lorry workshop pits in two depths: 1.5m for low-loaders / 7.5t lorries (6.4t main unit) and 1.3m for standard artics (5.5t main unit). Side recesses for cables, airlines and lighting. Crane-lorry install. Cast in North Devon."
  image="/og/vehicle-pits.png"
  schema="Product"
  schemaData={productSchema}
  whatsappContext="Lorry Workshop Pits"
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)} slot="head" />
  <TrustStrip />

  <section class="bg-navy text-white">
    <div class="container-wccp py-16 md:py-20">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <p class="eyebrow text-yellow mb-4">Civils · workshop · MOT</p>
          <h1 class="font-display text-display-xl text-white mb-4">Lorry Workshop Pits.</h1>
          <p class="font-display italic text-xl md:text-2xl text-yellow leading-tight mb-5">
            Sub-base to top deck. One pour. One delivery.
          </p>
          <h2 class="sr-only">How deep should a lorry workshop pit be?</h2>
          <blockquote class="font-display italic text-base md:text-lg text-white/95 leading-relaxed mb-6 pl-4 border-l-2 border-yellow max-w-xl">
            <strong class="not-italic text-white">How deep should a lorry workshop pit be?</strong>
            We supply two depths — <strong class="text-white">1.5&nbsp;m</strong> for low-loaders
            and 7.5 tonne lorries, and <strong class="text-white">1.3&nbsp;m</strong> for standard
            artics. The depth is the internal depth of the precast pit. Working depth always to PUWER 1998.
          </blockquote>
          <p class="text-base text-white/85 leading-relaxed mb-6 max-w-xl">
            Main units are <strong class="text-white">6.4&nbsp;t</strong> (deep) and
            <strong class="text-white">5.5&nbsp;t</strong> (shallow). Side recesses cast-in for
            cables, airlines and lighting. Cast-in galvanised steel steps optional.
          </p>
          <ul class="grid grid-cols-2 gap-3 text-sm mb-8 max-w-md">
            <li class="flex gap-2"><span class="text-yellow">·</span> 1.5m or 1.3m deep</li>
            <li class="flex gap-2"><span class="text-yellow">·</span> 6.4t / 5.5t main units</li>
            <li class="flex gap-2"><span class="text-yellow">·</span> Side service recesses</li>
            <li class="flex gap-2"><span class="text-yellow">·</span> Galv steel steps option</li>
            <li class="flex gap-2"><span class="text-yellow">·</span> Crane-lorry delivery</li>
            <li class="flex gap-2"><span class="text-yellow">·</span> Far cheaper than steel</li>
          </ul>
          <div class="flex flex-wrap gap-3">
            <a href="/quote?product=Vehicle%20Pits" class="btn-primary">Configure a quote</a>
            <a href="mailto:engineering@wccp.co.uk?subject=Spec%20sheet%20request%20%E2%80%94%20Vehicle%20Pits&amp;body=Hi%20WCCP%20engineering%2C%0A%0APlease%20send%20the%20spec%20sheet%20for%20Vehicle%20Pits.%0A%0AProject%20details%3A%0A%E2%80%A2%20Project%20name%3A%0A%E2%80%A2%20Site%20location%3A%0A%E2%80%A2%20Required%20spec%20%2F%20standard%3A%0A%0AThanks" class="btn-yellow">Request spec sheet</a>
            <a href={`tel:${site.contact.phoneIntl}`} class="btn-ghost border-white text-white hover:bg-white hover:text-navy">Call {site.contact.phone}</a>
          </div>
        </div>
        <div class="aspect-[4/3] bg-cast-100 rounded overflow-hidden">
          <img src="/images/products/automotive-work-pit/wccp-automotive-work-pit-auto-pit-1-sqr-1-1024x1024.jpg" alt="Precast concrete lorry workshop inspection pit — West Country Concrete Products, Devon" class="w-full h-full object-cover" loading="eager" decoding="async" />
        </div>
      </div>
    </div>
  </section>

  <section class="container-wccp py-20">
    <div class="max-w-2xl mb-10">
      <p class="eyebrow text-cast mb-3">Specification</p>
      <h2 class="font-display text-display-lg mb-4">Dimensions, sections and weights.</h2>
      <p class="text-cast-700 text-lg">Two standard section lengths combine to build a pit of any workshop dimension. Bespoke widths and depths cast on application.</p>
    </div>
    <div class="overflow-x-auto">
      <table class="spec-table w-full text-left border-collapse">
        <thead class="bg-navy text-white">
          <tr>
            <th class="px-4 py-3 font-display text-sm uppercase tracking-wide">Specification</th>
            <th class="px-4 py-3 font-display text-sm uppercase tracking-wide">Value</th>
          </tr>
        </thead>
        <tbody>
          {specs.map((s, i) => (
            <tr class={i % 2 === 0 ? 'bg-white' : 'bg-bone-200'}>
              <td class="px-4 py-3 font-bold text-navy">{s.spec}</td>
              <td class="px-4 py-3">{s.value}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <ProductGallery
    eyebrow="On-farm + workshop"
    heading="Inspection pits in service."
    background="bone"
    cols={3}
    images={[
      { src: '/images/products/lorry-workshop-pit/wccp-lorry-workshop-pit-an-installation-of-west-country-concrete-products-precast-concrete-vehicle-inspe.jpg', alt: 'Installation of a WCCP precast concrete vehicle inspection pit in a commercial workshop, Devon', caption: 'Pit installation' },
      { src: '/images/products/lorry-workshop-pit/wccp-lorry-workshop-pit-photo-showing-korry-mounted-crane-installation-of-west-country-concrete-products.jpg', alt: 'Lorry-mounted crane lifting a WCCP precast concrete inspection-pit section into a prepared excavation, Devon', caption: 'Crane-lorry install' },
      { src: '/images/products/lorry-workshop-pit/wccp-lorry-workshop-pit-photo-showing-end-wall-and-lifting-points-on-west-country-concrete-products-prec.jpg', alt: 'Close-up of cast-in lifting points and end wall on a WCCP precast concrete vehicle inspection pit, Devon', caption: 'Cast-in lifting points + end wall' },
      { src: '/images/products/lorry-workshop-pit/wccp-lorry-workshop-pit-image-of-precast-concrete-workshop-pit-showing-galvanised-steel-steps-to-one-end.jpg', alt: 'WCCP precast concrete workshop pit showing optional cast-in galvanised steel steps to one end, Devon', caption: 'Optional galvanised steps' },
      { src: '/images/products/lorry-workshop-pit/wccp-lorry-workshop-pit-drawing-showing-dimensioned-profiles-of-west-country-concrete-products-precast-c.png', alt: 'Dimensioned profile drawing of WCCP precast concrete workshop pit deep and shallow variants, Devon', caption: '1.5m and 1.3m profiles · drawing' },
      { src: '/images/products/lorry-workshop-pit/wccp-lorry-workshop-pit-20180705-133122.jpg', alt: 'WCCP precast concrete workshop pit on the lorry leaving the Holsworthy yard for delivery, Devon', caption: 'On the lorry from Holsworthy' },
    ]}
  />

  <section class="bg-white py-20">
    <div class="container-wccp">
      <div class="grid lg:grid-cols-2 gap-12">
        <div>
          <p class="eyebrow text-cast mb-3">Why precast</p>
          <h2 class="font-display text-display-lg mb-6">Faster, cheaper, ready for service.</h2>
          <p class="text-cast-700 text-lg leading-relaxed mb-6">From a single MOT bay at a village garage to a four-pit HGV workshop — same precast section family, scaled to length.</p>
          <ul class="space-y-3">
            {features.map((f) => (<li class="flex gap-3 text-cast-700 leading-relaxed"><span class="text-ember font-bold mt-1">·</span><span>{f}</span></li>))}
          </ul>
        </div>
        <div class="card p-8">
          <p class="eyebrow text-cast mb-3">Where they go</p>
          <h3 class="font-display text-2xl font-bold text-navy mb-4">Common applications.</h3>
          <ul class="space-y-3">
            {applications.map((a) => (<li class="flex gap-3 text-cast-700 leading-relaxed"><span class="text-ember font-bold mt-1">·</span><span>{a}</span></li>))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-yellow text-navy py-16">
    <div class="container-wccp">
      <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6">
        <div>
          <p class="eyebrow text-navy mb-2">Configure your inspection pit</p>
          <h2 class="font-display text-display-md">Send workshop length, vehicle type and any sleeves required — we will quote inside 24 hours.</h2>
        </div>
        <div class="flex flex-wrap gap-3 shrink-0">
          <a href="/quote?product=Vehicle%20Pits" class="btn bg-navy text-white hover:bg-navy-700">Open the configurator</a>
          <a href={`mailto:${site.contact.quotesEmail}`} class="btn-secondary">Email quotes</a>
        </div>
      </div>
    </div>
  </section>

  <section class="container-wccp py-20">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between mb-10 gap-4">
      <div>
        <p class="eyebrow text-cast mb-3">Related products</p>
        <h2 class="font-display text-display-lg">Often ordered alongside.</h2>
      </div>
      <a href="/products" class="text-ember font-bold hover:text-ember-700 inline-flex items-center gap-2">View full range
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12" stroke-linecap="round" /><polyline points="12 5 19 12 12 19" stroke-linecap="round" stroke-linejoin="round" /></svg>
      </a>
    </div>
    <RelatedProductGrid items={related} />
  </section>

  <section class="bg-bone-200 py-20">
    <div class="container-wccp">
      <div class="max-w-2xl mb-12">
        <p class="eyebrow text-cast mb-3">Common questions</p>
        <h2 class="font-display text-display-lg mb-4">What people ask about workshop pits.</h2>
        <p class="text-cast-700 text-lg">Five questions we answer most weeks. If yours is not here, ring the yard.</p>
      </div>
      <div class="max-w-3xl space-y-4">
        {faqs.map((f) => (
          <details class="card p-6 group">
            <summary class="font-display text-lg font-bold text-navy cursor-pointer list-none flex justify-between items-start gap-4">
              <span>{f.q}</span>
              <span class="text-ember text-2xl leading-none group-open:rotate-45 transition-transform shrink-0">+</span>
            </summary>
            <p class="text-cast-700 leading-relaxed mt-4">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Supply-only vs Fitted -->
  <section class="container-wccp section-rhythm border-t border-cast-100">
    <FittedVsSupply
      productName="Vehicle Inspection Pits"
      defaultMode="fitted"
      supply={{
        price: 'Bespoke quote',
        leadTime: '4–6 weeks',
        includes: [
          'Precast pit main unit (1.5m deep 6.4t or 1.3m deep 5.5t)',
          'Side recesses cast-in for cables, airlines, lighting',
          'Cast-in lifting eyes and LOLER lifting cert',
          'Delivery on our low-loader / crane-lorry to site',
        ],
        excludes: [
          'Excavation, blinding and grouting',
          'On-site crane and section setting',
          'Lighting, power, compressed-air fit-out',
        ],
      }}
      fitted={{
        price: 'Bespoke quote (incl. install)',
        leadTime: '8–10 weeks (incl. site slot)',
        includes: [
          'Everything in supply only',
          'Crane-lorry installation service',
          'Section setting, levelling, joint grouting',
          '12-month workmanship warranty',
        ],
        excludes: [
          'Excavation, dewatering and breakout',
          'MOT testing-lane equipment and lighting',
        ],
      }}
      note="Send the workshop drawing and we will spec the depth, section count and any cast-in sleeves. Crane-lorry delivery means same-day install."
    />
  </section>

  <section class="bg-navy text-white py-20">
    <div class="container-wccp text-center">
      <h2 class="font-display text-display-xl mb-4 text-white">Ready to spec it?</h2>
      <p class="text-white/90 text-lg max-w-xl mx-auto mb-8">Send the workshop drawing and the vehicle types. Quote and lead-time same day.</p>
      <div class="flex flex-wrap justify-center gap-3">
        <a href="/quote?product=Vehicle%20Pits" class="btn-yellow">Configure a quote</a>
        <a href={`tel:${site.contact.phoneIntl}`} class="btn-secondary">Call {site.contact.phone}</a>
        <a href={`mailto:${site.contact.quotesEmail}`} class="btn-primary">Email quotes</a>
      </div>
    </div>
  </section>

  <SpecSheetButton productSlug="vehicle-pits" productName="Vehicle Inspection Pits" />
  <ProductWarrantyLine />
</BaseLayout>
