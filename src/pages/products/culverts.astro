---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ProductWarrantyLine from '@/components/ProductWarrantyLine.astro';
import TrustStrip from '@/components/TrustStrip.astro';
import CADDownloads from '@/components/CADDownloads.astro';
import FittedVsSupply from '@/components/FittedVsSupply.astro';
import SpecSheetButton from '@/components/SpecSheetButton.astro';
import ProductGallery from '@/components/ProductGallery.astro';
import { site } from '@/config/site';
import RelatedProductGrid from '@/components/RelatedProductGrid.astro';

// WCCP cast culverts to bespoke sizes up to 3630mm × 2630mm overall in 1000mm
// section widths. Wall thicknesses and reinforcement to suit the application,
// designed to BS EN 14844:2006+A2:2011.
const specs = [
  { spec: 'Maximum overall size', value: '3630 mm × 2630 mm' },
  { spec: 'Section width', value: '1000 mm (units sit side-by-side along the run)' },
  { spec: 'Standard', value: 'BS EN 14844:2006+A2:2011 (precast box culverts)' },
  { spec: 'Wall thicknesses', value: 'To suit application — designed for the loading and reinforced accordingly' },
  { spec: 'Concrete grade', value: 'C40/50 (BS 8500-1:2023)' },
  { spec: 'Bespoke detailing', value: 'Outer faces can be sawn or finished to spec — e.g. for visible bridge applications' },
];

const applications = [
  'Watercourse and stream crossings under farm tracks',
  'Highway and rail drainage culverts',
  'Livestock and stock-grazing underpasses',
  'Pedestrian and cycle underpasses',
  'Bridge deck sections on accommodation crossings',
  'Service tunnels for utilities and cable runs',
  'Surface-water attenuation tank sections',
];

const related = [
  { href: '/products/cantilever-walls', label: 'Cantilever Walls', meta: 'Free-standing precast' },
  { href: '/products/king-post-walls', label: 'King Post Walls', meta: 'Steel post + panel infill' },
  { href: '/products/padstones', label: 'Padstones', meta: '200×200 to 600×600' },
  { href: '/products/vehicle-pits', label: 'Vehicle Pits', meta: '6.5m / 8m · MOT-compliant' },
];

const faqs = [
  { q: 'What is the maximum culvert size you can cast?', a: 'Up to 3630mm × 2630mm overall dimensions in 1000mm section widths. Wall thicknesses and reinforcement are designed to suit the loading, in accordance with BS EN 14844:2006+A2:2011 (precast box culverts). Larger spans on application.' },
  { q: 'What are culverts used for?', a: 'Underpasses, stream crossings, vertical chambers, attenuation and storage tanks. In early 2024 we manufactured and supplied two units forming a waterway beneath a footbridge for the railway station at Henley-on-Thames — built to the customer\'s requirements with the outer faces finished to spec.' },
  { q: 'How are wall thickness and reinforcement determined?', a: 'Each culvert is engineered to the loading and section. We work to BS EN 14844:2006+A2:2011 with structural design to BS EN 1992 (Eurocode 2). Send us the section, the fill height and the live load and we will return a culvert design including wall thickness and rebar schedule.' },
  { q: 'Can the outer faces be finished?', a: 'Yes — outer faces can be sawn or finished to specification. We did exactly that on the Henley-on-Thames railway station job for visible faces under a footbridge. Tell us the architectural finish required when you brief the job.' },
  { q: 'Lead time?', a: 'Box culverts run 6 to 10 weeks depending on size, reinforcement complexity and current bookings. Talk to us early on a programmed scheme — culverts that need rebar drawings approved can be on the critical path.' },
];

const productSchema = {
  name: 'Precast Concrete Box Culverts',
  description: 'Precast concrete box culverts to BS EN 14844:2006+A2:2011. Manufactured up to 3630mm × 2630mm overall in 1000mm section widths, with wall thicknesses and reinforcement designed to suit the application. Used for underpasses, stream crossings, vertical chambers, attenuation and storage tanks. Network Rail proven (Henley-on-Thames footbridge).',
  brand: { '@type': 'Brand', name: site.name },
  manufacturer: { '@type': 'Organization', name: site.name },
  category: 'Precast concrete box culvert',
  material: 'Reinforced concrete, C40/50 (BS 8500-1:2023)',
  additionalProperty: [
    { '@type': 'PropertyValue', name: 'Standard', value: 'BS EN 14844:2006+A2:2011 / BS EN 13369' },
    { '@type': 'PropertyValue', name: 'Concrete grade', value: 'C40/50 (BS 8500-1:2023)' },
    { '@type': 'PropertyValue', name: 'Maximum overall dimensions', value: '3630 mm × 2630 mm' },
    { '@type': 'PropertyValue', name: 'Section width', value: '1000 mm (units sit side-by-side)' },
    { '@type': 'PropertyValue', name: 'Wall and rebar', value: 'Designed to suit application loading' },
    { '@type': 'PropertyValue', name: 'Outer face finish', value: 'Sawn or finished to specification (e.g. visible bridge applications)' },
    { '@type': 'PropertyValue', name: 'Notable project', value: 'Henley-on-Thames railway station footbridge waterway (2024)' },
    { '@type': 'PropertyValue', name: 'Lead time', value: '6–10 weeks bespoke' },
    { '@type': 'PropertyValue', name: 'Country of origin', value: 'United Kingdom (Devon)' },
  ],
  offers: { '@type': 'Offer', availability: 'https://schema.org/InStock', areaServed: 'GB', seller: { '@type': 'Organization', name: site.name } },
};

const faqSchema = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) };
---

<BaseLayout
  title="Box Culverts — BS EN 14844 · up to 3630 × 2630mm"
  description="Precast concrete box culverts to BS EN 14844:2006+A2:2011. Up to 3630mm × 2630mm overall in 1000mm section widths, walls and reinforcement designed to suit. Underpasses, stream crossings, attenuation. Cast in North Devon."
  image="/og/culverts.png"
  schema="Product"
  schemaData={productSchema}
  whatsappContext="Box Culverts"
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)} slot="head" />
  <TrustStrip />

  <section class="bg-navy text-white">
    <div class="container-wccp py-16 md:py-20">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <p class="eyebrow text-yellow mb-4">Civils · drainage · highways</p>
          <h1 class="font-display text-display-xl text-white mb-4">Box Culverts.</h1>
          <p class="font-display italic text-xl md:text-2xl text-yellow leading-tight mb-5">Up to 3630 × 2630mm. Bespoke walls and reinforcement to BS EN 14844.</p>
          <h2 class="sr-only">What size box culvert can WCCP cast?</h2>
          <blockquote class="font-display italic text-base md:text-lg text-white/95 leading-relaxed mb-6 pl-4 border-l-2 border-yellow max-w-xl">
            <strong class="not-italic text-white">What size box culvert can WCCP cast?</strong>
            We have the capability to manufacture precast concrete culverts up to
            <strong class="text-white">3630&nbsp;mm × 2630&nbsp;mm</strong> overall dimensions in
            1000&nbsp;mm section widths. Wall thicknesses and reinforcement to suit the application,
            designed to <strong class="text-white">BS&nbsp;EN&nbsp;14844:2006+A2:2011</strong>.
          </blockquote>
          <p class="text-base text-white/85 leading-relaxed mb-6 max-w-xl">
            Used for underpasses, stream crossings, vertical chambers, attenuation and
            storage tanks. In early 2024 we manufactured two units forming a waterway
            beneath a footbridge for Henley-on-Thames railway station — outer faces
            sawn to the customer's spec.
          </p>
          <ul class="grid grid-cols-2 gap-3 text-sm mb-8 max-w-md">
            <li class="flex gap-2"><span class="text-yellow">·</span> BS EN 14844</li>
            <li class="flex gap-2"><span class="text-yellow">·</span> Up to 3630 × 2630mm</li>
            <li class="flex gap-2"><span class="text-yellow">·</span> 1000mm section widths</li>
            <li class="flex gap-2"><span class="text-yellow">·</span> Bespoke walls / rebar</li>
            <li class="flex gap-2"><span class="text-yellow">·</span> Sawn outer faces option</li>
            <li class="flex gap-2"><span class="text-yellow">·</span> Network Rail proven</li>
          </ul>
          <div class="flex flex-wrap gap-3">
            <a href="/quote?product=Culverts" class="btn-primary">Configure a quote</a>
            <a href={`tel:${site.contact.phoneIntl}`} class="btn-ghost border-white text-white hover:bg-white hover:text-navy">Call {site.contact.phone}</a>
          </div>
        </div>
        <div class="aspect-[4/3] bg-cast-100 rounded overflow-hidden">
          <img src="/images/products/culverts/wccp-culverts-20240308-121028-reduced-1024x768.jpg" alt="Precast concrete box culverts being placed on site — West Country Concrete Products, Devon" class="w-full h-full object-cover" loading="eager" decoding="async" />
        </div>
      </div>
    </div>
  </section>

  <section class="container-wccp py-20">
    <div class="max-w-2xl mb-10">
      <p class="eyebrow text-cast mb-3">Specification</p>
      <h2 class="font-display text-display-lg mb-4">Sizes, walls and loadings.</h2>
      <p class="text-cast-700 text-lg">Catalogue box culvert sizes for typical schemes. Bespoke spans, skews and loadings on application.</p>
    </div>
    <div class="overflow-x-auto">
      <table class="spec-table w-full text-left border-collapse">
        <thead class="bg-navy text-white">
          <tr>
            <th class="px-4 py-3 font-display text-sm uppercase tracking-wide">Specification</th>
            <th class="px-4 py-3 font-display text-sm uppercase tracking-wide">Value</th>
          </tr>
        </thead>
        <tbody>
          {specs.map((s, i) => (
            <tr class={i % 2 === 0 ? 'bg-white' : 'bg-bone-200'}>
              <td class="px-4 py-3 font-bold text-navy">{s.spec}</td>
              <td class="px-4 py-3 text-cast">{s.value}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    <p class="text-cast text-sm mt-4">
      Each culvert is engineered to the application — send the section, fill height, loading and crossing layout
      and we will return a culvert design with wall thicknesses, reinforcement schedule and weight calculations.
    </p>
  </section>

  <ProductGallery
    eyebrow="On site"
    heading="On-site installation."
    background="bone"
    cols={2}
    images={[
      { src: '/images/products/home/wccp-home-20130306-1249271-1024x768.jpg', alt: 'Stacked precast concrete box culvert sections in the WCCP yard at Holsworthy, Devon', caption: 'Box culverts in the yard' },
      { src: '/images/products/culverts/wccp-culverts-whatsapp-image-2024-03-08-at-22-06-30-5b94be08-1024x768.jpg', alt: 'Two large precast concrete box culverts strapped to a flatbed lorry leaving the WCCP yard for delivery, Devon', caption: 'Box culverts on the lorry' },
      { src: '/images/products/culverts/wccp-culverts-img-20240325-wa0013-768x1024.jpg', alt: 'Site team lowering a precast concrete box culvert section into a stream excavation by West Country Concrete Products, Devon', caption: 'Lowering into excavation' },
      { src: '/images/products/culverts/wccp-culverts-img-20240325-wa0010-1024x497.jpg', alt: 'Installed precast concrete culvert with stone abutments and galvanised handrails forming a small footbridge by WCCP Devon', caption: 'Culvert with stone abutments' },
      { src: '/images/products/culverts/wccp-culverts-img-20240325-wa0009-1024x497.jpg', alt: 'Finished precast concrete culvert deck with resin-bound surface and galvanised handrail crossing by WCCP Devon', caption: 'Finished culvert deck' },
    ]}
  />

  <section class="bg-white py-20">
    <div class="container-wccp">
      <div class="grid lg:grid-cols-2 gap-12">
        <div>
          <p class="eyebrow text-cast mb-3">Where they go</p>
          <h2 class="font-display text-display-lg mb-6">Common applications.</h2>
          <p class="text-cast-700 text-lg leading-relaxed mb-6">From a 1m drainage culvert under a farm track to a 3.6m bridge section on a road scheme — same yard, same paperwork.</p>
          <ul class="space-y-3">
            {applications.map((a) => (<li class="flex gap-3 text-cast-700 leading-relaxed"><span class="text-ember font-bold mt-1">·</span><span>{a}</span></li>))}
          </ul>
        </div>
        <div class="card p-8">
          <p class="eyebrow text-cast mb-3">Standards & certification</p>
          <h3 class="font-display text-2xl font-bold text-navy mb-4">Engineered, marked, certified.</h3>
          <dl class="space-y-4 text-sm">
            <div><dt class="font-bold text-navy">BS EN 14844:2006+A2:2011</dt><dd class="text-cast">Precast concrete box culverts — the live product standard for our range.</dd></div>
            <div><dt class="font-bold text-navy">BS EN 13369</dt><dd class="text-cast">Common rules for precast — factory production control.</dd></div>
            <div><dt class="font-bold text-navy">BS EN 1992 (Eurocode 2)</dt><dd class="text-cast">Concrete structural design — section, joint and bearing checks.</dd></div>
            <div><dt class="font-bold text-navy">BS 5400 / BS EN 1991-2</dt><dd class="text-cast">Highway loadings — HA, HB30, HB45 traffic loads.</dd></div>
            <div><dt class="font-bold text-navy">BS 8500-1:2023</dt><dd class="text-cast">Concrete spec — designated mixes for the exposure class.</dd></div>
          </dl>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-yellow text-navy py-16">
    <div class="container-wccp">
      <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6">
        <div>
          <p class="eyebrow text-navy mb-2">Configure your culvert</p>
          <h2 class="font-display text-display-md">Send section, fill height and loading — we will quote inside 24 hours.</h2>
        </div>
        <div class="flex flex-wrap gap-3 shrink-0">
          <a href="/quote?product=Culverts" class="btn bg-navy text-white hover:bg-navy-700">Open the configurator</a>
          <a href={`mailto:${site.contact.quotesEmail}`} class="btn-secondary">Email quotes</a>
        </div>
      </div>
    </div>
  </section>

  <section class="container-wccp py-20">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between mb-10 gap-4">
      <div>
        <p class="eyebrow text-cast mb-3">Related products</p>
        <h2 class="font-display text-display-lg">Often ordered alongside.</h2>
      </div>
      <a href="/products" class="text-ember font-bold hover:text-ember-700 inline-flex items-center gap-2">View full range
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12" stroke-linecap="round" /><polyline points="12 5 19 12 12 19" stroke-linecap="round" stroke-linejoin="round" /></svg>
      </a>
    </div>
    <RelatedProductGrid items={related} />
  </section>

  <section class="bg-bone-200 py-20">
    <div class="container-wccp">
      <div class="max-w-2xl mb-12">
        <p class="eyebrow text-cast mb-3">Common questions</p>
        <h2 class="font-display text-display-lg mb-4">What people ask about culverts.</h2>
        <p class="text-cast-700 text-lg">Five questions we answer most weeks. If yours is not here, ring the yard.</p>
      </div>
      <div class="max-w-3xl space-y-4">
        {faqs.map((f) => (
          <details class="card p-6 group">
            <summary class="font-display text-lg font-bold text-navy cursor-pointer list-none flex justify-between items-start gap-4">
              <span>{f.q}</span>
              <span class="text-ember text-2xl leading-none group-open:rotate-45 transition-transform shrink-0">+</span>
            </summary>
            <p class="text-cast-700 leading-relaxed mt-4">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Supply-only vs Fitted -->
  <section class="container-wccp section-rhythm border-t border-cast-100">
    <FittedVsSupply
      productName="Box Culverts"
      defaultMode="supply"
      supply={{
        price: 'Bespoke quote',
        leadTime: '6–10 weeks',
        includes: [
          'Box-culvert sections to BS EN 14844:2006+A2:2011',
          'Wall thicknesses and reinforcement designed to your loading',
          'Designer-stamped Eurocode 2 calcs',
          'Delivery on our HIAB / low-loader',
        ],
        excludes: [
          'Excavation, blinding and bedding',
          'On-site crane and setting labour',
          'Headwall, wingwall and apron units',
        ],
      }}
      fitted={{
        price: 'Bespoke quote (incl. install)',
        leadTime: '10–14 weeks (incl. site slot)',
        includes: [
          'Everything in supply only',
          'Four-man install crew with 50t crane',
          'Joint sealing and section levelling',
          '12-month workmanship warranty',
        ],
        excludes: [
          'Excavation, dewatering and bedding stone',
          'Reinstatement, traffic management and surfacing',
        ],
      }}
      note="Every culvert is engineered to its loading and section. Send the section drawing, fill height and live load and we will return a culvert design with rebar schedule and weight calcs."
    />
  </section>

  <CADDownloads productSlug="culverts" productName="Box culverts" />

  <section class="bg-navy text-white py-20">
    <div class="container-wccp text-center">
      <h2 class="font-display text-display-xl mb-4 text-white">Ready to spec it?</h2>
      <p class="text-white/90 text-lg max-w-xl mx-auto mb-8">Send section, fill height, loading and headwall details. Quote and lead-time same day.</p>
      <div class="flex flex-wrap justify-center gap-3">
        <a href="/quote?product=Culverts" class="btn-yellow">Configure a quote</a>
        <a href={`tel:${site.contact.phoneIntl}`} class="btn-secondary">Call {site.contact.phone}</a>
        <a href={`mailto:${site.contact.quotesEmail}`} class="btn-primary">Email quotes</a>
      </div>
    </div>
  </section>

  <SpecSheetButton productSlug="culverts" productName="Box Culverts" />
  <ProductWarrantyLine />
</BaseLayout>
