---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ProductWarrantyLine from '@/components/ProductWarrantyLine.astro';
import TrustStrip from '@/components/TrustStrip.astro';
import CADDownloads from '@/components/CADDownloads.astro';
import FittedVsSupply from '@/components/FittedVsSupply.astro';
import SpecSheetButton from '@/components/SpecSheetButton.astro';
import SpecDownloads from '@/components/SpecDownloads.astro';
import ProductGallery from '@/components/ProductGallery.astro';
import { site } from '@/config/site';
import RelatedProductGrid from '@/components/RelatedProductGrid.astro';

// Stocked range — three thicknesses (95 / 145 / 180mm) × three heights (1.0 / 1.2 / 1.5m)
// × two stocked lengths (15ft = 4572mm, 20ft = 6096mm). Custom lengths to order.
// Weights from WCCP published spec table.
const specs15 = [
  { panel: '1000 × 95mm',  weight: '1,042 kg', height: '1.0m', thickness: '95mm' },
  { panel: '1200 × 95mm',  weight: '1,251 kg', height: '1.2m', thickness: '95mm' },
  { panel: '1500 × 95mm',  weight: '1,564 kg', height: '1.5m', thickness: '95mm' },
  { panel: '1000 × 145mm', weight: '1,591 kg', height: '1.0m', thickness: '145mm' },
  { panel: '1200 × 145mm', weight: '1,909 kg', height: '1.2m', thickness: '145mm' },
  { panel: '1500 × 145mm', weight: '2,387 kg', height: '1.5m', thickness: '145mm' },
  { panel: '1000 × 180mm', weight: '1,975 kg', height: '1.0m', thickness: '180mm' },
  { panel: '1200 × 180mm', weight: '2,370 kg', height: '1.2m', thickness: '180mm' },
  { panel: '1500 × 180mm', weight: '2,963 kg', height: '1.5m', thickness: '180mm' },
];

const specs20 = [
  { panel: '1000 × 95mm',  weight: '1,390 kg', height: '1.0m', thickness: '95mm' },
  { panel: '1200 × 95mm',  weight: '1,668 kg', height: '1.2m', thickness: '95mm' },
  { panel: '1500 × 95mm',  weight: '2,085 kg', height: '1.5m', thickness: '95mm' },
  { panel: '1000 × 145mm', weight: '2,121 kg', height: '1.0m', thickness: '145mm' },
  { panel: '1200 × 145mm', weight: '2,546 kg', height: '1.2m', thickness: '145mm' },
  { panel: '1500 × 145mm', weight: '3,182 kg', height: '1.5m', thickness: '145mm' },
  { panel: '1000 × 180mm', weight: '2,633 kg', height: '1.0m', thickness: '180mm' },
  { panel: '1200 × 180mm', weight: '3,160 kg', height: '1.2m', thickness: '180mm' },
  { panel: '1500 × 180mm', weight: '3,950 kg', height: '1.5m', thickness: '180mm' },
];

// Optional extras — direct from the old WCCP product page
const extras = [
  'Double stressed to accept loading from both sides',
  'Bolts and brackets to fix panels to steel posts',
  'Mastic for sealing panels',
  'Panel rebates (to allow flush fitting)',
  'Lifting clutch that fits the cast-in panel rebate',
];

// Vertical Cantilever Panels — 180mm thick prestressed panels stood vertically
// with no king post support. Spec from brochure page 2.
const cantileverSpecs = [
  { thickness: '180mm', material: 'Slurry',                            retained: 'up to 3.7 m' },
  { thickness: '180mm', material: 'Silage (with 10 t vehicle surcharge)', retained: 'up to 3.2 m' },
  { thickness: '180mm', material: 'Earth',                             retained: 'up to 3.4 m' },
  { thickness: '145mm', material: 'Slurry / silage / earth (reduced)', retained: '0.3–0.4 m less than 180mm equivalent' },
];

const applications = [
  'SSAFO 2018-compliant slurry stores up to 6.0m wall height',
  'Silage clamp walls — push-off ends, transition bays, ramp returns',
  'Grain stores and bulk-aggregate bay divisions',
  'L-block alternative on cantilever retaining walls',
  'Bunds for fuel tanks, transformers and process plant',
  'Push walls for waste-transfer and recycling sites',
  'Boundary and security walls — exposed-aggregate finishes available',
];

const related = [
  { href: '/products/king-post-walls', label: 'King Post Walls', meta: 'Steel posts · panel infill' },
  { href: '/products/l-blocks', label: 'L-Block Retaining', meta: '600mm to 4.0m · interlocking' },
  { href: '/products/slurry-storage', label: 'Slurry Storage', meta: 'SSAFO · 250–5000m³' },
  { href: '/products/silage-clamp-walls', label: 'Silage Clamp Walls', meta: 'C40/50 · sulphate-resisting' },
];

const faqs = [
  {
    q: 'What standard do your prestressed panels meet?',
    a: 'Every panel we cast is manufactured to BS EN 14992 (precast concrete wall element specification) under factory production control to BS EN 13369. Concrete is BS 8500-1:2023 designated, structural design follows BS EN 1992 (Eurocode 2), and every consignment ships with its UKCA-marked declaration of performance.',
  },
  {
    q: 'How are the panels installed?',
    a: 'Panels are typically lifted into pre-cast pockets in a strip footing or bolted to a steel king-post system. We supply the lifting points cast in, the install drawing and the recommended bedding mortar. A two-man crew with a 35-tonne crane will set 30–40 panels a day on a level pad.',
  },
  {
    q: 'Are panels suitable for slurry contact?',
    a: 'Yes — for slurry use we cast in C40/50 with sulphate-resisting CEM II/B-V or CEM III/A binder and an aggressive-chemical (DC-3 or DC-4) designation under BS 8500. We supply the SSAFO 2018 capacity statement, the structural calcs and the mix certificate as one PDF pack.',
  },
  {
    q: 'What is the lead time on a typical order?',
    a: 'Catalogue thicknesses (100, 150, 180, 280mm) at standard heights are usually 2 to 4 weeks from order. Bespoke heights, finishes and pocket details run 6 to 8 weeks. Spring and autumn are the busy seasons — talk to us early if you have a programme date.',
  },
  {
    q: 'Can I get exposed-aggregate or board-marked finishes?',
    a: 'Yes. We cast feature finishes for architectural projects — board-marked timber pattern, exposed local aggregate, acid-etched and polished. We sample finishes before commit so you sign off the look before we cast the panel.',
  },
];

const productSchema = {
  name: 'Prestressed Wall Panels',
  description:
    'Factory-cast prestressed concrete wall panels to BS EN 14992. Stocked in 95, 145 and 180mm thicknesses; standard heights 1.0m, 1.2m and 1.5m. Custom lengths plus 15ft and 20ft stocked lengths. Vertical cantilever panels in 180mm retain slurry to 3.7m with no supporting posts. Cast in C40/50 sulphate-resisting concrete at our Holsworthy yard.',
  brand: { '@type': 'Brand', name: site.name },
  manufacturer: { '@type': 'Organization', name: site.name },
  category: 'Precast prestressed concrete wall panel',
  material: 'Prestressed reinforced concrete, C40/50 sulphate-resisting (BS 8500-1:2023)',
  additionalProperty: [
    { '@type': 'PropertyValue', name: 'Standard', value: 'BS EN 14992 / UKCA marked' },
    { '@type': 'PropertyValue', name: 'Concrete grade', value: 'C40/50 sulphate-resisting' },
    { '@type': 'PropertyValue', name: 'Concrete specification', value: 'BS 8500-1:2023' },
    { '@type': 'PropertyValue', name: 'Structural design', value: 'BS EN 1992 (Eurocode 2)' },
    { '@type': 'PropertyValue', name: 'Available thicknesses', value: '95mm, 145mm, 180mm' },
    { '@type': 'PropertyValue', name: 'Standard heights', value: '1.0m, 1.2m, 1.5m' },
    { '@type': 'PropertyValue', name: 'Stocked lengths', value: '15ft and 20ft (custom lengths to order)' },
    { '@type': 'PropertyValue', name: 'Vertical cantilever — slurry retention', value: 'up to 3.7m with 180mm panel, no posts' },
    { '@type': 'PropertyValue', name: 'Vertical cantilever — silage', value: 'up to 3.2m with 180mm panel and 10t vehicle surcharge' },
    { '@type': 'PropertyValue', name: 'Vertical cantilever — earth', value: 'up to 3.4m with 180mm panel' },
    { '@type': 'PropertyValue', name: 'Country of origin', value: 'United Kingdom (Devon)' },
    { '@type': 'PropertyValue', name: 'Lead time', value: '2–4 weeks catalogue, 6–8 weeks bespoke' },
  ],
  offers: { '@type': 'Offer', availability: 'https://schema.org/InStock', areaServed: 'GB', seller: { '@type': 'Organization', name: site.name } },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<BaseLayout
  title="Prestressed Wall Panels — BS EN 14992 · 95/145/180mm"
  description="Factory-cast prestressed concrete wall panels: 95mm, 145mm and 180mm thicknesses, standard heights 1.0m / 1.2m / 1.5m, custom and stocked lengths. Vertical cantilever option retains slurry to 3.7m with no posts. CE/UKCA-marked to BS EN 14992."
  image="/og/prestressed-panels.png"
  schema="Product"
  schemaData={productSchema}
  whatsappContext="Prestressed Wall Panels"
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)} slot="head" />
  <TrustStrip />

  <!-- Hero -->
  <section class="bg-navy text-white">
    <div class="container-wccp py-16 md:py-20">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <p class="eyebrow text-yellow mb-4">Civils · agricultural · slurry</p>
          <h1 class="font-display text-display-xl text-white mb-4">
            Prestressed Wall Panels.
          </h1>
          <p class="font-display italic text-xl md:text-2xl text-yellow leading-tight mb-5">10-metre spans. Zero formwork on site.</p>
          <blockquote class="font-display italic text-base md:text-lg text-white/95 leading-relaxed mb-6 pl-4 border-l-2 border-yellow max-w-xl">
            Prestressed precast wall panels are cast to BS&nbsp;EN&nbsp;14992, CE/UKCA marked, in
            100&nbsp;mm, 150&nbsp;mm, 180&nbsp;mm and 280&nbsp;mm thicknesses with cast-in lifting
            anchors. WCCP panels span up to 10&nbsp;m unsupported and arrive ready to lift on the
            same lorry.
          </blockquote>
          <p class="text-base text-white/85 leading-relaxed mb-6 max-w-xl">
            Factory-cast prestressed panels in 95mm, 145mm and 180mm thicknesses;
            standard heights 1.0m, 1.2m and 1.5m. Custom lengths to order, plus 15ft
            and 20ft stocked. Stand 180mm panels vertically and cantilever to 3.7m of
            slurry with no posts. Cast in C40/50 sulphate-resisting concrete.
          </p>
          <ul class="grid grid-cols-2 gap-3 text-sm mb-8 max-w-md">
            <li class="flex gap-2"><span class="text-yellow">·</span> BS EN 14992 / UKCA</li>
            <li class="flex gap-2"><span class="text-yellow">·</span> BS 8500-1:2023 mix</li>
            <li class="flex gap-2"><span class="text-yellow">·</span> Eurocode 2 design</li>
            <li class="flex gap-2"><span class="text-yellow">·</span> Heights 1.0–1.5m</li>
            <li class="flex gap-2"><span class="text-yellow">·</span> 95 / 145 / 180mm</li>
            <li class="flex gap-2"><span class="text-yellow">·</span> 2–4 week lead time</li>
          </ul>
          <div class="flex flex-wrap gap-3">
            <a href="/quote?product=Prestressed+Wall+Panels" class="btn-primary">Configure a quote</a>
            <a href={`tel:${site.contact.phoneIntl}`} class="btn-ghost border-white text-white hover:bg-white hover:text-navy">
              Call {site.contact.phone}
            </a>
          </div>
        </div>

        <div class="aspect-[4/3] bg-cast-100 rounded overflow-hidden">
          <img src="/images/products/concrete-panels/wccp-concrete-panels-prestressed-concrete-panels.jpg" alt="Prestressed precast concrete wall panels — West Country Concrete Products, Holsworthy Devon" class="w-full h-full object-cover" loading="eager" decoding="async" />
        </div>
      </div>
    </div>
  </section>

  <!-- Spec table -->
  <section class="container-wccp py-20">
    <div class="max-w-2xl mb-10">
      <p class="eyebrow text-cast mb-3">Specification</p>
      <h2 class="font-display text-display-lg mb-4">Sizes, weights and ratings.</h2>
      <p class="text-cast-700 text-lg">
        Catalogue thicknesses and heights below. Bespoke combinations — cut-outs, pockets, kicker
        details, exposed-aggregate finishes — quoted on application.
      </p>
    </div>

    <h3 class="font-display text-2xl font-bold text-navy mb-4">15ft (4572mm) panels</h3>
    <div class="overflow-x-auto mb-10">
      <table class="spec-table w-full text-left border-collapse">
        <thead class="bg-navy text-white">
          <tr>
            <th class="px-4 py-3 font-display text-sm uppercase tracking-wide">Panel (height × thickness)</th>
            <th class="px-4 py-3 font-display text-sm uppercase tracking-wide">Length</th>
            <th class="px-4 py-3 font-display text-sm uppercase tracking-wide">Height</th>
            <th class="px-4 py-3 font-display text-sm uppercase tracking-wide">Thickness</th>
            <th class="px-4 py-3 font-display text-sm uppercase tracking-wide">Weight</th>
          </tr>
        </thead>
        <tbody>
          {specs15.map((s, i) => (
            <tr class={i % 2 === 0 ? 'bg-white' : 'bg-bone-200'}>
              <td class="px-4 py-3 font-bold text-navy">{s.panel}</td>
              <td class="px-4 py-3">4572mm</td>
              <td class="px-4 py-3">{s.height}</td>
              <td class="px-4 py-3">{s.thickness}</td>
              <td class="px-4 py-3 text-cast">{s.weight}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <h3 class="font-display text-2xl font-bold text-navy mb-4">20ft (6096mm) panels</h3>
    <div class="overflow-x-auto">
      <table class="spec-table w-full text-left border-collapse">
        <thead class="bg-navy text-white">
          <tr>
            <th class="px-4 py-3 font-display text-sm uppercase tracking-wide">Panel (height × thickness)</th>
            <th class="px-4 py-3 font-display text-sm uppercase tracking-wide">Length</th>
            <th class="px-4 py-3 font-display text-sm uppercase tracking-wide">Height</th>
            <th class="px-4 py-3 font-display text-sm uppercase tracking-wide">Thickness</th>
            <th class="px-4 py-3 font-display text-sm uppercase tracking-wide">Weight</th>
          </tr>
        </thead>
        <tbody>
          {specs20.map((s, i) => (
            <tr class={i % 2 === 0 ? 'bg-white' : 'bg-bone-200'}>
              <td class="px-4 py-3 font-bold text-navy">{s.panel}</td>
              <td class="px-4 py-3">6096mm</td>
              <td class="px-4 py-3">{s.height}</td>
              <td class="px-4 py-3">{s.thickness}</td>
              <td class="px-4 py-3 text-cast">{s.weight}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <p class="text-cast text-sm mt-4">
      <strong class="text-navy">15ft and 20ft</strong> are standard stocked lengths. Custom lengths to order —
      site-specific design carried out to BS EN 1992 / Eurocode 2.
    </p>

    <div class="mt-10 card p-6 bg-bone-200">
      <p class="eyebrow text-cast mb-3">Optional extras</p>
      <ul class="grid sm:grid-cols-2 gap-2 text-sm text-cast-700">
        {extras.map((e) => (<li class="flex gap-2"><span class="text-ember font-bold">·</span><span>{e}</span></li>))}
      </ul>
    </div>

    <!-- ====== Vertical Cantilever Panels — flagship use of the 180mm panel ====== -->
    <div class="mt-16 card p-6 md:p-8 border-l-4 border-yellow">
      <p class="eyebrow text-cast mb-3">Named system</p>
      <h3 class="font-display text-display-md text-navy mb-3">Vertical Cantilever Panels.</h3>
      <p class="text-cast-700 leading-relaxed mb-6 max-w-3xl">
        Stand a 180mm prestressed panel vertically and cantilever it from the slab — no king
        post, no tie-back, no rear bracing. We design, supply and install the cantilever
        run; the panel does the work.
      </p>

      <div class="overflow-x-auto">
        <table class="spec-table w-full text-left border-collapse">
          <thead class="bg-navy text-white">
            <tr>
              <th class="px-4 py-3 font-display text-sm uppercase tracking-wide">Panel</th>
              <th class="px-4 py-3 font-display text-sm uppercase tracking-wide">Retained material</th>
              <th class="px-4 py-3 font-display text-sm uppercase tracking-wide">Maximum retained height</th>
            </tr>
          </thead>
          <tbody>
            {cantileverSpecs.map((s, i) => (
              <tr class={i % 2 === 0 ? 'bg-white' : 'bg-bone-200'}>
                <td class="px-4 py-3 font-bold text-navy">{s.thickness}</td>
                <td class="px-4 py-3">{s.material}</td>
                <td class="px-4 py-3 text-cast">{s.retained}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <p class="text-cast text-sm mt-4">
        No supporting posts required. Site-specific structural calc supplied with every job.
      </p>
    </div>
  </section>

  <ProductGallery
    eyebrow="Handling"
    heading="Handling & install detail."
    background="bone"
    cols={2}
    images={[
      { src: '/images/products/concrete-panels/wccp-concrete-panels-lifting-clutch-1024x488.jpg', alt: 'Wire-rope lifting clutch and 2.5T sling used to handle prestressed precast concrete wall panels by West Country Concrete Products, Devon', caption: 'Lifting clutch & sling' },
    ]}
  />

  <!-- Applications -->
  <section class="bg-white py-20">
    <div class="container-wccp">
      <div class="grid lg:grid-cols-2 gap-12">
        <div>
          <p class="eyebrow text-cast mb-3">Where they go</p>
          <h2 class="font-display text-display-lg mb-6">Common applications.</h2>
          <p class="text-cast-700 text-lg leading-relaxed mb-6">
            One panel system, many jobs. From the dairy slurry store to the civils retaining wall on
            a road scheme — same factory, same paperwork, same yard.
          </p>
          <ul class="space-y-3">
            {applications.map((a) => (
              <li class="flex gap-3 text-cast-700 leading-relaxed">
                <span class="text-ember font-bold mt-1">·</span>
                <span>{a}</span>
              </li>
            ))}
          </ul>
        </div>

        <!-- Standards block -->
        <div class="card p-8">
          <p class="eyebrow text-cast mb-3">Standards & certification</p>
          <h3 class="font-display text-2xl font-bold text-navy mb-4">Cast to current British and European standards.</h3>
          <dl class="space-y-4 text-sm">
            <div>
              <dt class="font-bold text-navy">BS EN 14992</dt>
              <dd class="text-cast">Precast concrete products — wall elements. Factory production control and CE/UKCA marking.</dd>
            </div>
            <div>
              <dt class="font-bold text-navy">BS 8500-1:2023</dt>
              <dd class="text-cast">Concrete specification. We cast to designated and designed mixes including DC-3 / DC-4 for aggressive ground.</dd>
            </div>
            <div>
              <dt class="font-bold text-navy">BS EN 1992 (Eurocode 2)</dt>
              <dd class="text-cast">Design of concrete structures. All structural calculations carried out by our in-house design team.</dd>
            </div>
            <div>
              <dt class="font-bold text-navy">BS EN 13369</dt>
              <dd class="text-cast">Common rules for precast concrete products — factory production control framework.</dd>
            </div>
            <div>
              <dt class="font-bold text-navy">SSAFO 2018</dt>
              <dd class="text-cast">For agricultural slurry use — capacity statement and structural calcs supplied with every store.</dd>
            </div>
          </dl>
        </div>
      </div>
    </div>
  </section>

  <!-- Configurator CTA -->
  <section class="bg-yellow text-navy py-16">
    <div class="container-wccp">
      <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6">
        <div>
          <p class="eyebrow text-navy mb-2">Configure your panel run</p>
          <h2 class="font-display text-display-md">Tell us thickness, height and run length — we will quote inside 24 hours.</h2>
        </div>
        <div class="flex flex-wrap gap-3 shrink-0">
          <a href="/quote?product=Prestressed+Wall+Panels" class="btn bg-navy text-white hover:bg-navy-700">Open the configurator</a>
          <a href={`mailto:${site.contact.quotesEmail}`} class="btn-secondary">Email quotes</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Related -->
  <section class="container-wccp py-20">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between mb-10 gap-4">
      <div>
        <p class="eyebrow text-cast mb-3">Related products</p>
        <h2 class="font-display text-display-lg">Often ordered alongside.</h2>
      </div>
      <a href="/products" class="text-ember font-bold hover:text-ember-700 inline-flex items-center gap-2">
        View full range
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <line x1="5" y1="12" x2="19" y2="12" stroke-linecap="round" />
          <polyline points="12 5 19 12 12 19" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </a>
    </div>

    <RelatedProductGrid items={related} />
  </section>

  <!-- FAQ -->
  <section class="bg-bone-200 py-20">
    <div class="container-wccp">
      <div class="max-w-2xl mb-12">
        <p class="eyebrow text-cast mb-3">Common questions</p>
        <h2 class="font-display text-display-lg mb-4">What people ask about panels.</h2>
        <p class="text-cast-700 text-lg">
          Five questions we answer most weeks. If yours is not here, ring the yard.
        </p>
      </div>

      <div class="max-w-3xl space-y-4">
        {faqs.map((f) => (
          <details class="card p-6 group">
            <summary class="font-display text-lg font-bold text-navy cursor-pointer list-none flex justify-between items-start gap-4">
              <span>{f.q}</span>
              <span class="text-ember text-2xl leading-none group-open:rotate-45 transition-transform shrink-0">+</span>
            </summary>
            <p class="text-cast-700 leading-relaxed mt-4">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <SpecDownloads
    intro="Panel range overview plus the on-site handling, lifting and storage guidelines."
    downloads={[
      { href: '/downloads/specs/concrete-panels/wccp-concrete-panels-handling-guidelines.pdf', title: 'Concrete panels — handling guidelines', meta: 'PDF · 386 KB' },
    ]}
  />

  <!-- Supply-only vs Fitted -->
  <section class="container-wccp section-rhythm border-t border-cast-100">
    <FittedVsSupply
      productName="Prestressed Wall Panels"
      defaultMode="supply"
      supply={{
        price: 'Bespoke quote',
        leadTime: '3–4 weeks',
        includes: [
          'Factory-cast prestressed panels (95 / 145 / 180mm)',
          'BS EN 14992 UKCA declaration of performance',
          'Lifting points and install drawing',
          'Delivery on our HIAB to your site',
        ],
        excludes: [
          'On-site fixing labour and crane hire',
          'Footings, pockets and cast-in king posts',
          'Bedding mortar and joint sealant',
        ],
      }}
      note="Bespoke pocket details, exposed-aggregate finishes and sulphate-resisting variants all priced individually. Install handled by our partner contractors — ask the yard for a referral."
    />
  </section>

  <CADDownloads productSlug="prestressed-panels" productName="Prestressed wall panels" />

  <!-- Final CTA -->
  <section class="bg-navy text-white py-20">
    <div class="container-wccp text-center">
      <h2 class="font-display text-display-xl mb-4 text-white">Ready to spec it?</h2>
      <p class="text-white/90 text-lg max-w-xl mx-auto mb-8">
        Send us heights, run length and the surcharge. Quote and lead-time same day.
      </p>
      <div class="flex flex-wrap justify-center gap-3">
        <a href="/quote?product=Prestressed+Wall+Panels" class="btn-yellow">Configure a quote</a>
        <a href={`tel:${site.contact.phoneIntl}`} class="btn-secondary">
          Call {site.contact.phone}
        </a>
        <a href={`mailto:${site.contact.quotesEmail}`} class="btn-primary">Email quotes</a>
      </div>
    </div>
  </section>

  <SpecSheetButton productSlug="prestressed-panels" productName="Prestressed Wall Panels" />
  <ProductWarrantyLine />
</BaseLayout>
