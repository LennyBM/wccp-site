---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TrustStrip from '@/components/TrustStrip.astro';
import { site } from '@/config/site';

const specs = [
  { thickness: '100mm', height: '1.0m', weight: '240 kg/m', surcharge: '5 kN/m²', use: 'Bay divisions, light retention' },
  { thickness: '150mm', height: '1.2m', weight: '432 kg/m', surcharge: '10 kN/m²', use: 'Grain walls, light agricultural' },
  { thickness: '180mm', height: '1.5m', weight: '648 kg/m', surcharge: '20 kN/m²', use: 'Silage clamps, push walls' },
  { thickness: '180mm', height: '3.0m', weight: '1,296 kg/m', surcharge: '30 kN/m²', use: 'Slurry storage, retaining' },
  { thickness: '280mm', height: '4.5m', weight: '3,024 kg/m', surcharge: '50 kN/m²', use: 'Heavy retention, deep slurry' },
  { thickness: '280mm', height: '6.0m', weight: '4,032 kg/m', surcharge: '60 kN/m²', use: 'Deep slurry, civils retention' },
];

const applications = [
  'SSAFO 2018-compliant slurry stores up to 6.0m wall height',
  'Silage clamp walls — push-off ends, transition bays, ramp returns',
  'Grain stores and bulk-aggregate bay divisions',
  'L-block alternative on cantilever retaining walls',
  'Bunds for fuel tanks, transformers and process plant',
  'Push walls for waste-transfer and recycling sites',
  'Boundary and security walls — exposed-aggregate finishes available',
];

const related = [
  { href: '/products/king-post-walls', label: 'King Post Walls', meta: 'Steel posts · panel infill' },
  { href: '/products/l-blocks', label: 'L-Block Retaining', meta: '600mm to 4.0m · interlocking' },
  { href: '/products/slurry-storage', label: 'Slurry Storage', meta: 'SSAFO · 250–5000m³' },
  { href: '/products/silage-clamp-walls', label: 'Silage Clamp Walls', meta: 'C40/50 · sulphate-resisting' },
];

const faqs = [
  {
    q: 'What standard do your prestressed panels meet?',
    a: 'Every panel we cast is manufactured to BS EN 14992 (precast concrete wall element specification) under factory production control to BS EN 13369. Concrete is BS 8500-1:2023 designated, structural design follows BS EN 1992 (Eurocode 2), and every consignment ships with its UKCA-marked declaration of performance.',
  },
  {
    q: 'How are the panels installed?',
    a: 'Panels are typically lifted into pre-cast pockets in a strip footing or bolted to a steel king-post system. We supply the lifting points cast in, the install drawing and the recommended bedding mortar. A two-man crew with a 35-tonne crane will set 30–40 panels a day on a level pad.',
  },
  {
    q: 'Are panels suitable for slurry contact?',
    a: 'Yes — for slurry use we cast in C40/50 with sulphate-resisting CEM II/B-V or CEM III/A binder and an aggressive-chemical (DC-3 or DC-4) designation under BS 8500. We supply the SSAFO 2018 capacity statement, the structural calcs and the mix certificate as one PDF pack.',
  },
  {
    q: 'What is the lead time on a typical order?',
    a: 'Catalogue thicknesses (100, 150, 180, 280mm) at standard heights are usually 2 to 4 weeks from order. Bespoke heights, finishes and pocket details run 6 to 8 weeks. Spring and autumn are the busy seasons — talk to us early if you have a programme date.',
  },
  {
    q: 'Can I get exposed-aggregate or board-marked finishes?',
    a: 'Yes. We cast feature finishes for architectural projects — board-marked timber pattern, exposed local aggregate, acid-etched and polished. We sample finishes before commit so you sign off the look before we cast the panel.',
  },
];

const productSchema = {
  name: 'Prestressed Wall Panels',
  description:
    'Factory-cast prestressed concrete wall panels to BS EN 14992. Available in 100, 150, 180 and 280mm thickness, heights to 6.0m, suitable for slurry storage, silage clamps, retaining walls and civils retention. Cast at our Holsworthy yard in C40/50 sulphate-resisting concrete.',
  brand: { '@type': 'Brand', name: site.name },
  manufacturer: { '@type': 'Organization', name: site.name },
  category: 'Precast prestressed concrete wall panel',
  material: 'Prestressed reinforced concrete, C40/50 sulphate-resisting (BS 8500-1:2023)',
  weight: {
    '@type': 'QuantitativeValue',
    minValue: 240,
    maxValue: 4032,
    unitCode: 'KGM',
    unitText: 'kilogram per linear metre',
  },
  additionalProperty: [
    { '@type': 'PropertyValue', name: 'Standard', value: 'BS EN 14992 / UKCA marked' },
    { '@type': 'PropertyValue', name: 'Concrete grade', value: 'C40/50 sulphate-resisting' },
    { '@type': 'PropertyValue', name: 'Concrete specification', value: 'BS 8500-1:2023' },
    { '@type': 'PropertyValue', name: 'Structural design', value: 'BS EN 1992 (Eurocode 2)' },
    { '@type': 'PropertyValue', name: 'Available thicknesses', value: '100mm, 150mm, 180mm, 280mm' },
    { '@type': 'PropertyValue', name: 'Maximum height', value: '6.0 m' },
    { '@type': 'PropertyValue', name: 'Maximum surcharge', value: '60 kN/m²' },
    { '@type': 'PropertyValue', name: 'Country of origin', value: 'United Kingdom (Devon)' },
    { '@type': 'PropertyValue', name: 'Lead time', value: '2–4 weeks catalogue, 6–8 weeks bespoke' },
  ],
  offers: {
    '@type': 'Offer',
    priceCurrency: 'GBP',
    availability: 'https://schema.org/InStock',
    seller: { '@type': 'Organization', name: site.name },
  },
};
---

<BaseLayout
  title="Prestressed Wall Panels — BS EN 14992 · 100/150/180/280mm"
  description="Factory-cast prestressed concrete wall panels: 100/150/180/280mm thicknesses, heights to 6.0m, surcharges to 60 kN/m². CE/UKCA-marked to BS EN 14992. Slurry, silage, civils retention."
  image="/images/products/prestressed-panels.jpg"
  schema="Product"
  schemaData={productSchema}
>
  <TrustStrip />

  <!-- Hero -->
  <section class="bg-navy text-white">
    <div class="container-wccp py-16 md:py-20">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <p class="eyebrow text-yellow mb-4">Civils · agricultural · slurry</p>
          <h1 class="font-display text-display-xl text-white mb-4">
            Prestressed Wall Panels.
          </h1>
          <p class="text-lg text-white/90 leading-relaxed mb-6">
            Factory-cast prestressed panels in 100, 150, 180 and 280mm thicknesses,
            heights to 6.0m, surcharges to 60 kN/m². CE/UKCA-marked to BS EN 14992.
            Cast in C40/50 sulphate-resisting concrete in our Holsworthy yard.
          </p>
          <ul class="grid grid-cols-2 gap-3 text-sm mb-8 max-w-md">
            <li class="flex gap-2"><span class="text-yellow">·</span> BS EN 14992 / UKCA</li>
            <li class="flex gap-2"><span class="text-yellow">·</span> BS 8500-1:2023 mix</li>
            <li class="flex gap-2"><span class="text-yellow">·</span> Eurocode 2 design</li>
            <li class="flex gap-2"><span class="text-yellow">·</span> Heights to 6.0m</li>
            <li class="flex gap-2"><span class="text-yellow">·</span> Up to 60 kN/m²</li>
            <li class="flex gap-2"><span class="text-yellow">·</span> 2–4 week lead time</li>
          </ul>
          <div class="flex flex-wrap gap-3">
            <a href="/quote?product=Prestressed+Wall+Panels" class="btn-primary">Configure a quote</a>
            <a href="/spec-sheets/prestressed-panels.pdf" class="btn-yellow">Download spec sheet</a>
            <a href={`tel:${site.contact.phoneIntl}`} class="btn-ghost border-white text-white hover:bg-white hover:text-navy">
              Call {site.contact.phone}
            </a>
          </div>
        </div>

        <div class="aspect-[4/3] bg-cast-100 rounded overflow-hidden">
          <div class="w-full h-full bg-gradient-to-br from-cast-300 via-cast to-navy"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Spec table -->
  <section class="container-wccp py-20">
    <div class="max-w-2xl mb-10">
      <p class="eyebrow text-cast mb-3">Specification</p>
      <h2 class="font-display text-display-lg mb-4">Sizes, weights and ratings.</h2>
      <p class="text-cast-700 text-lg">
        Catalogue thicknesses and heights below. Bespoke combinations — cut-outs, pockets, kicker
        details, exposed-aggregate finishes — quoted on application.
      </p>
    </div>

    <div class="overflow-x-auto">
      <table class="spec-table w-full text-left border-collapse">
        <thead class="bg-navy text-white">
          <tr>
            <th class="px-4 py-3 font-display text-sm uppercase tracking-wide">Thickness</th>
            <th class="px-4 py-3 font-display text-sm uppercase tracking-wide">Height</th>
            <th class="px-4 py-3 font-display text-sm uppercase tracking-wide">Weight</th>
            <th class="px-4 py-3 font-display text-sm uppercase tracking-wide">Max surcharge</th>
            <th class="px-4 py-3 font-display text-sm uppercase tracking-wide">Typical use</th>
          </tr>
        </thead>
        <tbody>
          {specs.map((s, i) => (
            <tr class={i % 2 === 0 ? 'bg-white' : 'bg-bone-200'}>
              <td class="px-4 py-3 font-bold text-navy">{s.thickness}</td>
              <td class="px-4 py-3">{s.height}</td>
              <td class="px-4 py-3">{s.weight}</td>
              <td class="px-4 py-3">{s.surcharge}</td>
              <td class="px-4 py-3 text-cast">{s.use}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <p class="text-cast text-sm mt-4">
      Surcharge values are indicative for a free-standing wall on a 1.5 × wall-height strip footing.
      Site-specific design always carried out to BS EN 1992. Talk to us before ordering.
    </p>
  </section>

  <!-- Applications -->
  <section class="bg-bone-200 py-20">
    <div class="container-wccp">
      <div class="grid lg:grid-cols-2 gap-12">
        <div>
          <p class="eyebrow text-cast mb-3">Where they go</p>
          <h2 class="font-display text-display-lg mb-6">Common applications.</h2>
          <p class="text-cast-700 text-lg leading-relaxed mb-6">
            One panel system, many jobs. From the dairy slurry store to the civils retaining wall on
            a road scheme — same factory, same paperwork, same yard.
          </p>
          <ul class="space-y-3">
            {applications.map((a) => (
              <li class="flex gap-3 text-cast-700 leading-relaxed">
                <span class="text-ember font-bold mt-1">·</span>
                <span>{a}</span>
              </li>
            ))}
          </ul>
        </div>

        <!-- Standards block -->
        <div class="card p-8">
          <p class="eyebrow text-cast mb-3">Standards & certification</p>
          <h3 class="font-display text-2xl font-bold text-navy mb-4">Cast to current British and European standards.</h3>
          <dl class="space-y-4 text-sm">
            <div>
              <dt class="font-bold text-navy">BS EN 14992</dt>
              <dd class="text-cast">Precast concrete products — wall elements. Factory production control and CE/UKCA marking.</dd>
            </div>
            <div>
              <dt class="font-bold text-navy">BS 8500-1:2023</dt>
              <dd class="text-cast">Concrete specification. We cast to designated and designed mixes including DC-3 / DC-4 for aggressive ground.</dd>
            </div>
            <div>
              <dt class="font-bold text-navy">BS EN 1992 (Eurocode 2)</dt>
              <dd class="text-cast">Design of concrete structures. All structural calculations carried out by our in-house design team.</dd>
            </div>
            <div>
              <dt class="font-bold text-navy">BS EN 13369</dt>
              <dd class="text-cast">Common rules for precast concrete products — factory production control framework.</dd>
            </div>
            <div>
              <dt class="font-bold text-navy">SSAFO 2018</dt>
              <dd class="text-cast">For agricultural slurry use — capacity statement and structural calcs supplied with every store.</dd>
            </div>
          </dl>
        </div>
      </div>
    </div>
  </section>

  <!-- Configurator CTA -->
  <section class="bg-yellow text-navy py-16">
    <div class="container-wccp">
      <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6">
        <div>
          <p class="eyebrow text-navy mb-2">Configure your panel run</p>
          <h2 class="font-display text-display-md">Tell us thickness, height and run length — we will quote inside 24 hours.</h2>
        </div>
        <div class="flex flex-wrap gap-3 shrink-0">
          <a href="/quote?product=Prestressed+Wall+Panels" class="btn bg-navy text-white hover:bg-navy-700">Open the configurator</a>
          <a href={`mailto:${site.contact.quotesEmail}`} class="btn-secondary">Email quotes</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Related -->
  <section class="container-wccp py-20">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between mb-10 gap-4">
      <div>
        <p class="eyebrow text-cast mb-3">Related products</p>
        <h2 class="font-display text-display-lg">Often ordered alongside.</h2>
      </div>
      <a href="/products" class="text-ember font-bold hover:text-ember-700 inline-flex items-center gap-2">
        View full range
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <line x1="5" y1="12" x2="19" y2="12" stroke-linecap="round" />
          <polyline points="12 5 19 12 12 19" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </a>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
      {related.map((r) => (
        <a href={r.href} class="card p-5 group">
          <div class="aspect-[16/10] bg-cast-100 mb-4 rounded overflow-hidden">
            <div class="w-full h-full bg-gradient-to-br from-cast-200 to-cast-100"></div>
          </div>
          <h3 class="font-display text-base font-bold text-navy mb-1 group-hover:text-ember">{r.label}</h3>
          <p class="text-cast text-xs">{r.meta}</p>
        </a>
      ))}
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-bone-200 py-20">
    <div class="container-wccp">
      <div class="max-w-2xl mb-12">
        <p class="eyebrow text-cast mb-3">Common questions</p>
        <h2 class="font-display text-display-lg mb-4">What people ask about panels.</h2>
        <p class="text-cast-700 text-lg">
          Five questions we answer most weeks. If yours is not here, ring the yard.
        </p>
      </div>

      <div class="max-w-3xl space-y-4">
        {faqs.map((f) => (
          <details class="card p-6 group">
            <summary class="font-display text-lg font-bold text-navy cursor-pointer list-none flex justify-between items-start gap-4">
              <span>{f.q}</span>
              <span class="text-ember text-2xl leading-none group-open:rotate-45 transition-transform shrink-0">+</span>
            </summary>
            <p class="text-cast-700 leading-relaxed mt-4">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="bg-navy text-white py-20">
    <div class="container-wccp text-center">
      <h2 class="font-display text-display-xl mb-4 text-white">Ready to spec it?</h2>
      <p class="text-white/90 text-lg max-w-xl mx-auto mb-8">
        Send us heights, run length and the surcharge. Quote and lead-time same day.
      </p>
      <div class="flex flex-wrap justify-center gap-3">
        <a href="/quote?product=Prestressed+Wall+Panels" class="btn-yellow">Configure a quote</a>
        <a href={`tel:${site.contact.phoneIntl}`} class="btn-secondary">
          Call {site.contact.phone}
        </a>
        <a href={`mailto:${site.contact.quotesEmail}`} class="btn-primary">Email quotes</a>
      </div>
    </div>
  </section>
</BaseLayout>
