              <span class="text-ember text-2xl leading-none group-open:rotate-45 transition-transform shrink-0">+</span>
            </summary>
            <p class="text-cast-700 leading-relaxed mt-4">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Supply-only vs Fitted -->
  <section class="container-wccp section-rhythm border-t border-cast-100">
    <FittedVsSupply
      productName="Free-Standing Walls & Blocks"
      defaultMode="supply"
      supply={{
        price: 'Bespoke quote',
        leadTime: '2–4 weeks',
        includes: [
          "Cast 'A', 'L', 'T' Wall or Interlocking Beton Block to spec",
          'Integrated anchoring points / holes',
          'Lifting brackets where applicable (L Walls)',
          'Delivery on our HIAB to your site',
