          '12-month workmanship warranty',
        ],
        excludes: [
          'Hardcore base preparation and compaction',
          'Backfill or stored-material handling',
        ],
      }}
      note="'A', 'L', 'T' Walls and bespoke face finishes all priced individually — unit count drives the rate. Send the bay layout for an inside-a-day quote."
    />
  </section>

  <CADDownloads productSlug="l-blocks" productName="Free-standing walls" />

  <section class="bg-navy text-white py-20">
    <div class="container-wccp text-center">
