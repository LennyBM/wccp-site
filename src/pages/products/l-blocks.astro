---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ProductWarrantyLine from '@/components/ProductWarrantyLine.astro';
import TrustStrip from '@/components/TrustStrip.astro';
import CADDownloads from '@/components/CADDownloads.astro';
import FittedVsSupply from '@/components/FittedVsSupply.astro';
import SpecSheetButton from '@/components/SpecSheetButton.astro';
import { site } from '@/config/site';
import RelatedProductGrid from '@/components/RelatedProductGrid.astro';

const aWallSpecs = [
  { height: '2500mm', weight: '2,300 kg', notes: '1200mm wide × 1300mm deep base' },
  { height: '3000mm', weight: '2,500 kg', notes: '1200mm wide × 1300mm deep base' },
  { height: '3500mm', weight: '2,700 kg', notes: '1200mm wide × 1300mm deep base' },
];

const aWallFeatures = [
  '2.5m, 3m or 3.5m high · 1200mm wide × 1300mm deep base',
  'Optional fork slots on the front',
  'Raised base on the sides — placement from any side',
  'Integrated anchoring points',
  'Free-standing push-walls / bay walls — drive against during filling',
];

const lWallSpecs = [
  { height: '2500mm', base: '1400mm deep · 1200mm wide', weight: '2,000 kg' },
  { height: '3000mm', base: '1605mm deep · 1200mm wide', weight: '2,230 kg' },
  { height: '4000mm', base: '2155mm deep · 1000mm wide', weight: '2,660 kg' },
];

const lWallFeatures = [
  '2.5m, 3m or 4m high',
  '1400 / 1605 / 2155mm deep base',
  'Integrated anchoring holes',
  'Very heavy-duty reinforcement for high-load applications',
  'Lifting brackets available for level positioning',
];

const tWallSpecs = [
  { height: '2500mm', base: '2390mm wide base · 1200mm wide', weight: '2,400 kg' },
  { height: '3000mm', base: '2600mm wide base · 1200mm wide', weight: '2,700 kg' },
];

const tWallFeatures = [
  '2.5m or 3m high',
  '2390mm wide base at 2.5m, 2600mm wide base at 3m',
  '1200mm wide units throughout',
  'Integrated anchoring holes',
  'Very heavy-duty reinforcement',
];

const betonSpecs = [
  { type: 'Single 800', size: '800 × 800 × 800mm', weight: '1,200 kg' },
  { type: 'Double 1600', size: '1600 × 800 × 800mm', weight: '2,400 kg' },
  { type: 'Triple 1800', size: '1800 × 600 × 600mm', weight: '1,550 kg' },
  { type: 'Double 1200', size: '1200 × 600 × 600mm', weight: '1,033 kg' },
  { type: 'Single 600', size: '600 × 600 × 600mm', weight: '517 kg' },
];

const betonFeatures = [
  '800×800×800mm singles (1,200kg) and 1600mm doubles (2,400kg)',
  '1800×600×600mm triples (1,550kg), 1200mm doubles (1,033kg), 600mm singles (517kg)',
  'Smooth or stepped sloping end blocks',
  'Ridged & flat-top capping blocks available',
  'Lift in / lift out, rearrange — true modular bay storage',
];

const applications = [
  'Free-standing push-walls and bay walls (A walls)',
  'Heavy-duty retaining for high-load applications (L walls)',
  'Tall retention with vehicle loadings (T walls)',
  'Modular bay storage for grain, woodchip, aggregate (Beton blocks)',
  'Silage clamp side and end walls',
  'Bulk-aggregate yards at quarries and recycling sites',
  'Temporary site-separation and security walls',
  'Cattle yard divisions and feed-passage walls',
];

const related = [
  { href: '/products/retaining-walls', label: 'Retaining Walls (family hub)', meta: 'Includes Rapid Fit Retaining Wall System' },
  { href: '/products/silage-clamp-walls', label: 'Silage Clamp Walls', meta: '95 / 145 / 180mm panels' },
  { href: '/products/interlocking-blocks', label: 'Interlocking Blocks', meta: 'Beton-style modular' },
  { href: '/products/king-post-walls', label: 'King Post Walls', meta: 'Steel post + panel infill' },
];

const faqs = [
  { q: "What's the difference between A, L and T walls?", a: "All three are named WCCP Free-Standing Wall Sections. 'A' Walls are push-walls and bay walls — 2.5m, 3m or 3.5m high, 1200mm wide × 1300mm deep base, with optional fork slots and raised side bases for placement from any direction. 'L' Walls are heavier-duty retention units at 2.5m or 3m, 1200mm wide on a 1400mm or 1600mm deep base. 'T' Walls go higher — 2.5m, 3m, 3.5m or 4m high — with very heavy-duty reinforcement on a wider base." },
  { q: 'Do they need a foundation?', a: 'A, L and T Walls are free-standing — no concrete strip footing required. They sit on a compacted hardcore base. L and T Walls have integrated anchoring holes if you need to tie them down for high-load or high-wind situations. A Walls have integrated anchoring points for the same reason.' },
  { q: 'How are the blocks lifted and re-positioned?', a: "All units have integrated lifting eyes or brackets. The 'L' Walls offer lifting brackets for level positioning. The Interlocking Beton Blocks are designed to lift in, lift out and rearrange — that's the whole point of the system. A 25-tonne crane or 20-tonne teleporter handles the largest singles." },
  { q: 'What sizes do the Interlocking Beton Blocks come in?', a: 'Singles at 800×800×800mm and 1,200kg, doubles at 1,600mm and 2,400kg. Triples at 1,800×600×600mm (1,550kg), doubles at 1,200×600×600mm (1,033kg) and singles at 600×600×600mm (517kg). Smooth or stepped sloping end blocks plus ridged and flat-top capping blocks available for finishing the run.' },
  { q: 'Lead time and delivery?', a: 'Catalogue heights ship in 2 to 4 weeks. Delivery is on a HIAB lorry that can offload itself. The taller T Walls travel as wide loads — we will book the haulage and notify the police where required.' },
];

const productSchema = {
  name: "Free-Standing Walls & Interlocking Blocks — 'A' / 'L' / 'T' Walls & Beton Blocks",
  description: "WCCP named Free-Standing Wall Sections range. 'A' Walls (2.5m / 3m / 3.5m high, 1200mm wide × 1300mm deep base, 2,300 / 2,500 / 2,680kg, optional fork slots, integrated anchoring points). 'L' Walls (2.5m / 3m, 1200mm wide × 1400 or 1600mm deep base, 2,000 / 2,240kg, very heavy-duty reinforcement, lifting brackets). 'T' Walls (2.5m / 3m / 3.5m / 4m, 1200mm wide, 2,360 / 2,660 / 3,180 / 3,340kg). Plus Interlocking Beton Blocks (singles, doubles and triples, 517kg up to 2,400kg).",
  brand: { '@type': 'Brand', name: site.name },
  manufacturer: { '@type': 'Organization', name: site.name },
  category: 'Precast free-standing walls & interlocking blocks',
  material: 'Reinforced concrete, C40/50 (BS 8500-1:2023)',
  weight: { '@type': 'QuantitativeValue', minValue: 517, maxValue: 3340, unitCode: 'KGM', unitText: 'kilogram per unit' },
  additionalProperty: [
    { '@type': 'PropertyValue', name: 'Standard', value: 'BS EN 13369 / BS EN 14992' },
    { '@type': 'PropertyValue', name: 'Concrete grade', value: 'C40/50 (BS 8500-1:2023)' },
    { '@type': 'PropertyValue', name: "Named: 'A' Walls", value: '2.5m / 3m / 3.5m high, 1200mm wide × 1300mm deep base, 2,300 / 2,500 / 2,680 kg' },
    { '@type': 'PropertyValue', name: "'A' Wall features", value: 'Optional fork slots; raised base on sides; integrated anchoring points' },
    { '@type': 'PropertyValue', name: "Named: 'L' Walls", value: '2.5m / 3m high, 1200mm wide on 1400 / 1600mm deep base, 2,000 / 2,240 kg' },
    { '@type': 'PropertyValue', name: "'L' Wall features", value: 'Integrated anchoring holes; very heavy-duty reinforcement; lifting brackets available' },
    { '@type': 'PropertyValue', name: "Named: 'T' Walls", value: '2.5m / 3m (2200/2600mm base) and 3.5m / 4m (2000mm base) high, 1200mm wide, 2,360 / 2,660 / 3,180 / 3,340 kg' },
    { '@type': 'PropertyValue', name: "'T' Wall features", value: 'Integrated anchoring holes; very heavy-duty reinforcement' },
    { '@type': 'PropertyValue', name: 'Interlocking Beton Blocks', value: '800×800×800mm singles (1,200kg) & 1600mm doubles (2,400kg); 1800×600×600 triples (1,550kg), 1200mm doubles (1,033kg), 600mm singles (517kg)' },
    { '@type': 'PropertyValue', name: 'Beton end / capping options', value: 'Smooth or stepped sloping end blocks; ridged & flat-top capping blocks' },
    { '@type': 'PropertyValue', name: 'Foundation', value: 'Compacted hardcore base (no concrete strip required for free-standing units)' },
    { '@type': 'PropertyValue', name: 'Lead time', value: '2–4 weeks' },
    { '@type': 'PropertyValue', name: 'Country of origin', value: 'United Kingdom (Devon)' },
  ],
  offers: { '@type': 'Offer', availability: 'https://schema.org/InStock', areaServed: 'GB', seller: { '@type': 'Organization', name: site.name } },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })),
};
---

<BaseLayout
  title="Free-Standing Walls & Blocks — 'A', 'L', 'T' & Interlocking Beton"
  description="WCCP named Free-Standing Wall Sections range. 'A' Walls 2.5–3.5m, 'L' Walls 2.5–3m, 'T' Walls 2.5–4m, plus Interlocking Beton Blocks (800×800 singles, 1600 doubles, 1800 triples). Heavy-duty reinforcement, integrated anchoring. Cast in North Devon."
  image="/og/l-blocks.png"
  schema="Product"
  schemaData={productSchema}
  whatsappContext="Free-Standing Walls"
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)} slot="head" />
  <TrustStrip />

  <section class="bg-navy text-white">
    <div class="container-wccp py-16 md:py-20">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <p class="eyebrow text-yellow mb-4">Civils · agricultural · bulk storage</p>
          <h1 class="font-display text-display-xl text-white mb-4">Free-standing walls &amp; blocks &mdash; A, L, T and Interlocking Beton.</h1>
          <p class="font-display italic text-xl md:text-2xl text-yellow leading-tight mb-5">
            Bay walls, push-walls, bunds. Move them when the job moves.
          </p>
          <h2 class="sr-only">What's the holding capacity of an L-block retaining wall?</h2>
          <blockquote class="font-display italic text-base md:text-lg text-white/95 leading-relaxed mb-6 pl-4 border-l-2 border-yellow max-w-xl">
            <strong class="not-italic text-white">What's the holding capacity of an L-block retaining wall?</strong>
            WCCP standard L-blocks retain to about 3&nbsp;m height in dry granular fill with no
            surcharge. Surcharge from a tractor or stockpile within 1.5&nbsp;m of the wall steps
            the design down. Above 3&nbsp;m retained, switch to king-post or cantilever.
          </blockquote>
          <p class="text-base text-white/85 leading-relaxed mb-6 max-w-xl">
            <strong class="text-white">'A' Walls</strong> 2.5–3.5m for push-walls and bay walls.
            <strong class="text-white">'L' Walls</strong> 2.5–3m, heavy-duty retention.
            <strong class="text-white">'T' Walls</strong> 2.5–4m for tall retention.
            <strong class="text-white">Interlocking Beton Blocks</strong> for modular bay storage.
            All free-standing on compacted hardcore.
          </p>
          <ul class="grid grid-cols-2 gap-3 text-sm mb-8 max-w-md">
            <li class="flex gap-2"><span class="text-yellow">·</span> 'A' Walls 2.5–3.5m</li>
            <li class="flex gap-2"><span class="text-yellow">·</span> 'L' Walls 2.5–3m</li>
            <li class="flex gap-2"><span class="text-yellow">·</span> 'T' Walls 2.5–4m</li>
            <li class="flex gap-2"><span class="text-yellow">·</span> Beton blocks</li>
            <li class="flex gap-2"><span class="text-yellow">·</span> Heavy-duty reinforcement</li>
            <li class="flex gap-2"><span class="text-yellow">·</span> 2–4 week lead</li>
          </ul>
          <div class="flex flex-wrap gap-3">
            <a href="/quote?product=Free-Standing+Walls" class="btn-primary">Configure a quote</a>
            <a href={`tel:${site.contact.phoneIntl}`} class="btn-ghost border-white text-white hover:bg-white hover:text-navy">Call {site.contact.phone}</a>
          </div>
        </div>
        <div class="aspect-[4/3] bg-cast-100 rounded overflow-hidden">
          <img src="/images/products/home/wccp-home-free-standing-wall-section.jpg" alt="Free-standing precast concrete wall section — West Country Concrete Products, Devon" class="w-full h-full object-cover" loading="eager" decoding="async" />
        </div>
      </div>
    </div>
  </section>

  <!-- A Walls -->
  <section class="container-wccp py-20">
    <div class="card p-8 md:p-12 border-2 border-ember/20">
      <div class="grid lg:grid-cols-2 gap-10 items-start">
        <div>
          <p class="eyebrow text-ember mb-3">Named system · push-walls / bay walls</p>
          <h2 class="font-display text-display-lg text-navy mb-4">'A' Walls.</h2>
          <p class="text-cast-700 text-lg leading-relaxed mb-4">
            Free-standing push-walls and bay walls. 1200mm wide on a 1300mm deep base. Heights of
            2.5m, 3m and 3.5m at 2,300, 2,500 and 2,680kg respectively. Optional fork slots on the
            front; raised base on the sides allowing placement from any direction. Integrated
            anchoring points.
          </p>
          <ul class="space-y-2 text-sm">
            {aWallFeatures.map((f) => (<li class="flex gap-2 text-cast-700"><span class="text-ember font-bold">·</span><span>{f}</span></li>))}
          </ul>
        </div>
        <div>
          <p class="eyebrow text-cast mb-3">Specification</p>
          <div class="overflow-x-auto">
            <table class="spec-table w-full text-left border-collapse">
              <thead class="bg-navy text-white">
                <tr>
                  <th class="px-3 py-2 font-display text-xs uppercase">Height</th>
                  <th class="px-3 py-2 font-display text-xs uppercase">Weight</th>
                  <th class="px-3 py-2 font-display text-xs uppercase">Base</th>
                </tr>
              </thead>
              <tbody>
                {aWallSpecs.map((s, i) => (
                  <tr class={i % 2 === 0 ? 'bg-white' : 'bg-bone-200'}>
                    <td class="px-3 py-2 font-bold text-navy text-sm">{s.height}</td>
                    <td class="px-3 py-2 text-sm">{s.weight}</td>
                    <td class="px-3 py-2 text-sm text-cast">{s.notes}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- L Walls -->
  <section class="bg-bone-200 py-20">
    <div class="container-wccp">
      <div class="card p-8 md:p-12 border-2 border-ember/20">
        <div class="grid lg:grid-cols-2 gap-10 items-start">
          <div>
            <p class="eyebrow text-ember mb-3">Named system · heavy-duty retention</p>
            <h2 class="font-display text-display-lg text-navy mb-4">'L' Walls.</h2>
            <p class="text-cast-700 text-lg leading-relaxed mb-4">
              Free-standing 'L' shaped retaining walls. 2.5m or 3m high, 1200mm wide, on a 1400mm
              or 1600mm deep base. 2,000kg and 2,240kg. Made with very heavy-duty reinforcement
              for high-load applications. Integrated anchoring holes. Lifting brackets available
              for level positioning.
            </p>
            <ul class="space-y-2 text-sm">
              {lWallFeatures.map((f) => (<li class="flex gap-2 text-cast-700"><span class="text-ember font-bold">·</span><span>{f}</span></li>))}
            </ul>
          </div>
          <div>
            <p class="eyebrow text-cast mb-3">Specification</p>
            <div class="overflow-x-auto">
              <table class="spec-table w-full text-left border-collapse">
                <thead class="bg-navy text-white">
                  <tr>
                    <th class="px-3 py-2 font-display text-xs uppercase">Height</th>
                    <th class="px-3 py-2 font-display text-xs uppercase">Base</th>
                    <th class="px-3 py-2 font-display text-xs uppercase">Weight</th>
                  </tr>
                </thead>
                <tbody>
                  {lWallSpecs.map((s, i) => (
                    <tr class={i % 2 === 0 ? 'bg-white' : 'bg-bone-200'}>
                      <td class="px-3 py-2 font-bold text-navy text-sm">{s.height}</td>
                      <td class="px-3 py-2 text-sm">{s.base}</td>
                      <td class="px-3 py-2 text-sm">{s.weight}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- T Walls -->
  <section class="container-wccp py-20">
    <div class="card p-8 md:p-12 border-2 border-ember/20">
      <div class="grid lg:grid-cols-2 gap-10 items-start">
        <div>
          <p class="eyebrow text-ember mb-3">Named system · tall retention</p>
          <h2 class="font-display text-display-lg text-navy mb-4">'T' Walls.</h2>
          <p class="text-cast-700 text-lg leading-relaxed mb-4">
            Free-standing 'T' shaped walls for taller free-standing retention. 2.5m, 3m, 3.5m and
            4m high. 2200/2600mm width base for the 2.5m and 3m heights; 2000mm wide base for 3.5m
            and 4m. 1200mm wide units throughout. 2,360 / 2,660 / 3,180 / 3,340kg. Integrated
            anchoring holes; very heavy-duty reinforcement.
          </p>
          <ul class="space-y-2 text-sm">
            {tWallFeatures.map((f) => (<li class="flex gap-2 text-cast-700"><span class="text-ember font-bold">·</span><span>{f}</span></li>))}
          </ul>
        </div>
        <div>
          <p class="eyebrow text-cast mb-3">Specification</p>
          <div class="overflow-x-auto">
            <table class="spec-table w-full text-left border-collapse">
              <thead class="bg-navy text-white">
                <tr>
                  <th class="px-3 py-2 font-display text-xs uppercase">Height</th>
                  <th class="px-3 py-2 font-display text-xs uppercase">Base</th>
                  <th class="px-3 py-2 font-display text-xs uppercase">Weight</th>
                </tr>
              </thead>
              <tbody>
                {tWallSpecs.map((s, i) => (
                  <tr class={i % 2 === 0 ? 'bg-white' : 'bg-bone-200'}>
                    <td class="px-3 py-2 font-bold text-navy text-sm">{s.height}</td>
                    <td class="px-3 py-2 text-sm">{s.base}</td>
                    <td class="px-3 py-2 text-sm">{s.weight}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Interlocking Beton Blocks -->
  <section class="bg-bone-200 py-20">
    <div class="container-wccp">
      <div class="card p-8 md:p-12 border-2 border-ember/20">
        <div class="grid lg:grid-cols-2 gap-10 items-start">
          <div>
            <p class="eyebrow text-ember mb-3">Modular system</p>
            <h2 class="font-display text-display-lg text-navy mb-4">Interlocking Beton Blocks.</h2>
            <p class="text-cast-700 text-lg leading-relaxed mb-4">
              Modular bay-storage blocks. 800×800×800mm singles (1,200kg) and 1600mm doubles
              (2,400kg). Plus 1800×600×600mm triples (1,550kg), 1200mm doubles (1,033kg) and 600mm
              singles (517kg). Smooth or stepped sloping end blocks. Ridged and flat-top capping
              blocks available to finish the run. Lift in, lift out, rearrange next year.
            </p>
            <ul class="space-y-2 text-sm">
              {betonFeatures.map((f) => (<li class="flex gap-2 text-cast-700"><span class="text-ember font-bold">·</span><span>{f}</span></li>))}
            </ul>
          </div>
          <div>
            <p class="eyebrow text-cast mb-3">Specification</p>
            <div class="overflow-x-auto">
              <table class="spec-table w-full text-left border-collapse">
                <thead class="bg-navy text-white">
                  <tr>
                    <th class="px-3 py-2 font-display text-xs uppercase">Type</th>
                    <th class="px-3 py-2 font-display text-xs uppercase">Size</th>
                    <th class="px-3 py-2 font-display text-xs uppercase">Weight</th>
                  </tr>
                </thead>
                <tbody>
                  {betonSpecs.map((s, i) => (
                    <tr class={i % 2 === 0 ? 'bg-white' : 'bg-bone-200'}>
                      <td class="px-3 py-2 font-bold text-navy text-sm">{s.type}</td>
                      <td class="px-3 py-2 text-sm">{s.size}</td>
                      <td class="px-3 py-2 text-sm">{s.weight}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="container-wccp py-20">
    <div class="grid lg:grid-cols-2 gap-12">
      <div>
        <p class="eyebrow text-cast mb-3">Where they go</p>
        <h2 class="font-display text-display-lg mb-6">Common applications.</h2>
        <p class="text-cast-700 text-lg leading-relaxed mb-6">From a 60-cow Devon silage clamp to a 4m T-wall woodchip bay at an AD plant — pick the family that fits the loading.</p>
        <ul class="space-y-3">
          {applications.map((a) => (<li class="flex gap-3 text-cast-700 leading-relaxed"><span class="text-ember font-bold mt-1">·</span><span>{a}</span></li>))}
        </ul>
      </div>
      <div class="card p-8">
        <p class="eyebrow text-cast mb-3">Standards & certification</p>
        <h3 class="font-display text-2xl font-bold text-navy mb-4">Cast and certified for free-standing retention.</h3>
        <dl class="space-y-4 text-sm">
          <div><dt class="font-bold text-navy">BS EN 13369</dt><dd class="text-cast">Common rules for precast concrete — factory production control.</dd></div>
          <div><dt class="font-bold text-navy">BS EN 14992</dt><dd class="text-cast">Precast wall elements — UKCA marking.</dd></div>
          <div><dt class="font-bold text-navy">BS EN 1992-1-1 (Eurocode 2)</dt><dd class="text-cast">Concrete structural design — overturning and bearing checks.</dd></div>
          <div><dt class="font-bold text-navy">BS 8500-1:2023</dt><dd class="text-cast">Concrete spec — designated mixes for the storage environment.</dd></div>
          <div><dt class="font-bold text-navy">BS 5502-22:2003</dt><dd class="text-cast">Agricultural buildings — silage and bulk-storage loadings.</dd></div>
        </dl>
      </div>
    </div>
  </section>

  <section class="bg-yellow text-navy py-16">
    <div class="container-wccp">
      <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6">
        <div>
          <p class="eyebrow text-navy mb-2">Configure your bay or wall</p>
          <h2 class="font-display text-display-md">Send the loading and run length — we will spec A, L, T or Beton.</h2>
        </div>
        <div class="flex flex-wrap gap-3 shrink-0">
          <a href="/quote?product=Free-Standing+Walls" class="btn bg-navy text-white hover:bg-navy-700">Open the configurator</a>
          <a href={`mailto:${site.contact.quotesEmail}`} class="btn-secondary">Email quotes</a>
        </div>
      </div>
    </div>
  </section>

  <section class="container-wccp py-20">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between mb-10 gap-4">
      <div>
        <p class="eyebrow text-cast mb-3">Related products</p>
        <h2 class="font-display text-display-lg">Often ordered alongside.</h2>
      </div>
      <a href="/products" class="text-ember font-bold hover:text-ember-700 inline-flex items-center gap-2">View full range
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12" stroke-linecap="round" /><polyline points="12 5 19 12 12 19" stroke-linecap="round" stroke-linejoin="round" /></svg>
      </a>
    </div>
    <RelatedProductGrid items={related} />
  </section>

  <section class="bg-bone-200 py-20">
    <div class="container-wccp">
      <div class="max-w-2xl mb-12">
        <p class="eyebrow text-cast mb-3">Common questions</p>
        <h2 class="font-display text-display-lg mb-4">What people ask about free-standing walls.</h2>
        <p class="text-cast-700 text-lg">Five questions we answer most weeks. If yours is not here, ring the yard.</p>
      </div>
      <div class="max-w-3xl space-y-4">
        {faqs.map((f) => (
