          <dl class="space-y-4 text-sm">
            <div>
              <dt class="font-bold text-navy">SSAFO Regulations 2018</dt>
              <dd class="text-cast">Silage, Slurry & Agricultural Fuel Oil â€” clamp construction and effluent containment.</dd>
            </div>
            <div>
              <dt class="font-bold text-navy">BS 5502-22:2003</dt>
              <dd class="text-cast">Buildings and structures for agriculture â€” silage and feed storage.</dd>
            </div>
            <div>
              <dt class="font-bold text-navy">BS 8500-1:2023</dt>
              <dd class="text-cast">Concrete specification â€” sulphate-resisting C40/50 mix for silage effluent.</dd>
            </div>
            <div>
              <dt class="font-bold text-navy">BS EN 14992</dt>
              <dd class="text-cast">Precast concrete wall elements â€” structural performance and CE marking.</dd>
            </div>
            <div>
              <dt class="font-bold text-navy">BS EN ISO 1461</dt>
              <dd class="text-cast">Hot-dip galvanising â€” coating thickness on the steel wear lip.</dd>
            </div>
          </dl>
        </div>
      </div>
    </div>
  </section>

  <!-- Configurator CTA -->
  <section class="bg-yellow text-navy py-16">
    <div class="container-wccp">
      <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6">
        <div>
          <p class="eyebrow text-navy mb-2">Configure your clamp face</p>
          <h2 class="font-display text-display-md">Send clamp dimensions and silage type â€” we will quote inside 24 hours.</h2>
        </div>
        <div class="flex flex-wrap gap-3 shrink-0">
          <a href="/quote?product=Feed-Stop%20Walling" class="btn bg-navy text-white hover:bg-navy-700">Open the configurator</a>
          <a href={`mailto:${site.contact.quotesEmail}`} class="btn-secondary">Email quotes</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Related -->
  <section id="related" class="container-wccp py-20">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between mb-10 gap-4">
      <div>
        <p class="eyebrow text-cast mb-3">Related products</p>
        <h2 class="font-display text-display-lg">Often ordered alongside.</h2>
      </div>
      <a href="/products" class="text-ember font-bold hover:text-ember-700 inline-flex items-center gap-2">
        View full range
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <line x1="5" y1="12" x2="19" y2="12" stroke-linecap="round" />
          <polyline points="12 5 19 12 12 19" stroke-linecap="round" stroke-linejoin="round" />
