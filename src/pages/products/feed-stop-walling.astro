---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ProductWarrantyLine from '@/components/ProductWarrantyLine.astro';
import TrustStrip from '@/components/TrustStrip.astro';
import FittedVsSupply from '@/components/FittedVsSupply.astro';
import SpecSheetButton from '@/components/SpecSheetButton.astro';
import ProductGallery from '@/components/ProductGallery.astro';
import { site } from '@/config/site';
import RelatedProductGrid from '@/components/RelatedProductGrid.astro';
import ProductPageTOC from '@/components/ProductPageTOC.astro';

const tocSections = [
  { id: 'overview', label: 'Overview' },
  { id: 'specifications', label: 'Specifications' },
  { id: 'gallery', label: 'Gallery' },
  { id: 'related', label: 'Related' },
  { id: 'faq', label: 'FAQ' },
  { id: 'downloads', label: 'Downloads' },
];

// Feed-stop walling â€” 3m precast units with galvanised steel lip for silage clamps.
const specs = [
  { variant: 'Standard Feed-Stop 3m Ã— 1.2m', bed: '3000 Ã— 1200 Ã— 200mm', style: 'Galvanised steel lip cast in', use: 'Silage clamp face â€” dairy and beef' },
  { variant: 'Tall Feed-Stop 3m Ã— 1.5m', bed: '3000 Ã— 1500 Ã— 200mm', style: 'Galvanised steel lip cast in', use: 'Deep clamp face / maize silage' },
  { variant: 'Short Feed-Stop 3m Ã— 0.9m', bed: '3000 Ã— 900 Ã— 200mm', style: 'Galvanised steel lip cast in', use: 'Smaller clamps / wholecrop' },
  { variant: 'Corner Feed-Stop', bed: 'Bespoke L-profile', style: 'Mitred junction Â· steel lip continuous', use: 'Clamp ends and L-junctions' },
  { variant: 'Tractor-Bucket Wear Plate', bed: 'Galv. lip section only', style: 'Bolted-on retrofit lip', use: 'Refurbishing existing concrete walls' },
];

const applications = [
  'New silage clamps on dairy and beef holdings',
  'SSAFO 2018 refurb work where existing walls have failed',
  'Maize and wholecrop clamps with heavy roll-off pressure',
  'Anaerobic digester feedstock storage clamps',
  'Drive-over silage pads with low retaining walls',
  'Effluent channel kerb where the loader scrapes',
  'Any clamp face where a tractor bucket meets concrete daily',
];

const related = [
  { href: '/products/retaining-walls', label: 'Retaining Walls', meta: 'L-shape & T-shape Â· to 6m' },
  { href: '/products/cantilever-walls', label: 'Cantilever Walls', meta: 'Free-standing Â· clamp & bay' },
  { href: '/products/silage-clamp-walls', label: 'Silage Clamp Walls', meta: 'A-panel Â· sulphate-resisting' },
  { href: '/products/slurry-storage', label: 'Slurry Storage', meta: 'SSAFO 2018-compliant' },
];

const faqs = [
  { q: 'What is the steel lip for?', a: 'Silage clamp faces are abused. Every day a tractor bucket scrapes the top of the wall taking the next feed cut. Without a steel lip the concrete chips, then crumbles, and within five years you have a half-rotten wall. The galvanised lip â€” typically 6mm thick, 100mm tall â€” takes the wear and saves the concrete underneath. WCCP feed-stop walls last 25+ years where bare concrete walls last 8.' },
  { q: 'What concrete spec do you use?', a: 'Sulphate-resisting C40/50 to BS 8500-1:2023. Silage effluent is acidic â€” pH 3.5 to 4.5 â€” and standard concrete dissolves in it. The sulphate-resisting mix plus a 50mm cover to the steel gives a design life of 50+ years for the buried portion.' },
  { q: 'Free-standing or anchored?', a: 'Both. Standard 3m units are free-standing on a 600mm Ã— 200mm reinforced strip foundation, locked together with cast-in dowel bars. For taller clamps and AD feedstock walls we anchor to a continuous toe slab. Either way the design is signed off by our consulting engineer.' },
  { q: 'How are they delivered?', a: 'On our HIAB lorry â€” a 3m Ã— 1.2m unit weighs about 1.7 tonnes, so we lift straight off onto the prepared base. We deliver UK-wide; site access for an articulated HIAB needs about 4m clear width and a hard standing within 12m of the wall line.' },
  { q: 'What is the lead time?', a: 'Catalogue 3m feed-stop units run 2 to 4 weeks. Bespoke heights and corner pieces 4 to 6 weeks. Major SSAFO 2018 refurbs with engineering design run 6 to 10 weeks for the design-and-cast cycle.' },
];

const productSchema = {
  name: 'Precast Feed-Stop Walling',
  description: '3m precast feed-stop wall units with galvanised steel lip for silage clamp faces. Sulphate-resisting C40/50 concrete to BS 8500-1:2023. Cast at our Holsworthy yard.',
  brand: { '@type': 'Brand', name: site.name },
  manufacturer: { '@type': 'Organization', name: site.name },
  category: 'Precast concrete silage clamp walling',
  material: 'Sulphate-resisting reinforced concrete, C40/50 (BS 8500-1:2023)',
  weight: {
    '@type': 'QuantitativeValue',
    minValue: 1300,
    maxValue: 2200,
    unitCode: 'KGM',
    unitText: 'kilogram per unit',
  },
  additionalProperty: [
    { '@type': 'PropertyValue', name: 'Standard', value: 'BS EN 14992 (precast concrete wall elements)' },
    { '@type': 'PropertyValue', name: 'Concrete grade', value: 'Sulphate-resisting C40/50 (BS 8500-1:2023)' },
    { '@type': 'PropertyValue', name: 'Wear lip', value: 'Galvanised steel â€” 6mm Ã— 100mm cast in' },
    { '@type': 'PropertyValue', name: 'Standard length', value: '3000mm' },
    { '@type': 'PropertyValue', name: 'Height range', value: '900â€“1500mm catalogue, taller bespoke' },
    { '@type': 'PropertyValue', name: 'Compliance', value: 'SSAFO Regulations 2018' },
    { '@type': 'PropertyValue', name: 'Lead time', value: '2â€“4 weeks catalogue, 4â€“6 weeks bespoke' },
    { '@type': 'PropertyValue', name: 'Country of origin', value: 'United Kingdom (Devon)' },
  ],
  offers: { '@type': 'Offer', availability: 'https://schema.org/InStock', areaServed: 'GB', seller: { '@type': 'Organization', name: site.name } },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<BaseLayout
  title="Feed-Stop Walling â€” Silage clamp face with steel lip Â· 3m precast"
  description="3m precast feed-stop wall units with galvanised steel lip for silage clamps. Sulphate-resisting C40/50 concrete. SSAFO 2018-compliant. Cast in North Devon."
  image="/og/home.png"
  schema="Product"
  schemaData={productSchema}
  whatsappContext="Feed-Stop Walling"
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)} slot="head" />
  <TrustStrip />
  <ProductPageTOC sections={tocSections} />

  <!-- Hero -->
  <section id="overview" class="bg-navy text-white">
    <div class="container-wccp py-16 md:py-20">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <p class="eyebrow text-yellow mb-4">Agricultural Â· silage Â· SSAFO</p>
          <h1 class="font-display text-display-xl text-white mb-4">Feed-Stop Walling.</h1>
          <p class="font-display italic text-xl md:text-2xl text-yellow leading-tight mb-5">Steel where it scrapes. Concrete where it sits.</p>
          <p class="text-lg lg:text-xl text-cast leading-relaxed font-medium text-white/95 mb-6 max-w-xl">
            3m precast feed-stop wall units with a galvanised steel lip cast into the top
            edge â€” the part the tractor bucket scrapes against every feeding round. Cast in
            sulphate-resisting C40/50 concrete to BS 8500-1:2023. SSAFO 2018-compliant.
            Catalogue lead time 2-4 weeks.
          </p>
          <blockquote class="font-display italic text-base md:text-lg text-white/95 leading-relaxed mb-6 pl-4 border-l-2 border-yellow max-w-xl">
            A feed-stop wall is the upright concrete face of a silage clamp â€” the part the
            loader bucket scrapes when taking the next feed cut. WCCP feed-stops cast a
            6&nbsp;mm Ã— 100&nbsp;mm galvanised steel lip into the top edge so the wear hits
            the steel, not the concrete. Design life 25+ years versus 8 for bare concrete.
          </blockquote>
          <p class="text-base text-white/85 leading-relaxed mb-6 max-w-xl">
            We cast, deliver and install across England and Wales â€” the right answer for
            new silage clamps, AD feedstock storage, and SSAFO 2018 refurb work.
          </p>
          <ul class="grid grid-cols-2 gap-3 text-sm mb-8 max-w-md">
            <li class="flex gap-2"><span class="text-yellow">Â·</span> Galvanised steel lip</li>
            <li class="flex gap-2"><span class="text-yellow">Â·</span> Sulphate-resisting C40/50</li>
            <li class="flex gap-2"><span class="text-yellow">Â·</span> 3m standard length</li>
            <li class="flex gap-2"><span class="text-yellow">Â·</span> SSAFO 2018-compliant</li>
            <li class="flex gap-2"><span class="text-yellow">Â·</span> 25+ year design life</li>
            <li class="flex gap-2"><span class="text-yellow">Â·</span> 2â€“4 week lead</li>
          </ul>
          <div class="flex flex-wrap gap-3">
            <a href="/quote?product=Feed-Stop%20Walling" class="btn-primary">Configure a quote</a>
            <a href="mailto:engineering@wccp.co.uk?subject=Spec%20sheet%20request%20%E2%80%94%20Feed-Stop%20Walling&amp;body=Hi%20WCCP%20engineering%2C%0A%0APlease%20send%20the%20spec%20sheet%20for%20Feed-Stop%20Walling.%0A%0AProject%20details%3A%0A%E2%80%A2%20Project%20name%3A%0A%E2%80%A2%20Site%20location%3A%0A%E2%80%A2%20Required%20spec%20%2F%20standard%3A%0A%0AThanks" class="btn-yellow">Request spec sheet</a>
            <a href={`tel:${site.contact.phoneIntl}`} class="btn-ghost border-white text-white hover:bg-white hover:text-navy">
              Call {site.contact.phone}
            </a>
          </div>
        </div>
        <div class="aspect-[4/3] bg-cast-100 rounded overflow-hidden flex items-center justify-center border-2 border-dashed border-cast-300 p-8 text-center">
          <div>
            <p class="text-cast-600 text-sm font-mono">ðŸ“· Photo needed</p>
            <p class="text-cast text-xs mt-2">Hero shot â€” feed-stop wall on a working silage clamp showing the galvanised steel lip across the top, ideally with a tractor bucket in shot</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Spec table -->
  <section id="specifications" class="container-wccp py-20">
