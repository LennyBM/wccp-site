        excludes: [
          'Strip foundation construction',
          'On-site setting / fixing labour',
        ],
      }}
      fitted={{
        price: 'Bespoke quote (incl. install)',
        leadTime: '4â€“6 weeks (incl. site slot)',
        includes: [
          'Everything in supply only',
          'Two-man install crew with HIAB',
          'Dowel-bar joint setting and bedding-mortar',
          '12-month workmanship warranty',
        ],
        excludes: [
          'Strip foundation and reinforced toe slab',
          'Effluent channel and drainage works',
        ],
      }}
      note=". Bespoke heights, AD feedstock walls and full SSAFO 2018 refurb packages priced individually â€” send clamp dimensions and we'll come back within a working day."
    />
  </section>

  <!-- Final CTA -->
  <section class="bg-navy text-white py-20">
    <div class="container-wccp text-center">
      <h2 class="font-display text-display-xl mb-4 text-white">Ready to spec it?</h2>
      <p class="text-white/90 text-lg max-w-xl mx-auto mb-8">
        Send us clamp dimensions, silage type and a sketch. Quote and lead-time same day.
      </p>
      <div class="flex flex-wrap justify-center gap-3">
        <a href="/quote?product=Feed-Stop%20Walling" class="btn-yellow">Configure a quote</a>
        <a href={`tel:${site.contact.phoneIntl}`} class="btn-secondary">Call {site.contact.phone}</a>
        <a href={`mailto:${site.contact.quotesEmail}`} class="btn-primary">Email quotes</a>
      </div>
    </div>
  </section>

  <SpecSheetButton productSlug="feed-stop-walling" productName="Feed-Stop Walling" />
  <ProductWarrantyLine />
</BaseLayout>
