---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ProductWarrantyLine from '@/components/ProductWarrantyLine.astro';
import TrustStrip from '@/components/TrustStrip.astro';
import FittedVsSupply from '@/components/FittedVsSupply.astro';
import SpecSheetButton from '@/components/SpecSheetButton.astro';
import SpecDownloads from '@/components/SpecDownloads.astro';
import { site } from '@/config/site';
import RelatedProductGrid from '@/components/RelatedProductGrid.astro';

const specs = [
  { spec: 'Overall width', value: '1300 mm' },
  { spec: 'Overall height', value: '875 mm' },
  { spec: 'Length options', value: '2.5m, 3m, 3.5m or 4m total' },
  { spec: 'Configuration', value: 'Two-part kit (joins at centre)' },
  { spec: 'Internal base width', value: '600 mm (saves chemical usage)' },
  { spec: 'Stepover walls', value: '300 mm entry & exit' },
  { spec: 'Drain holes', value: '4 fast-draining holes (one in each corner)' },
  { spec: 'Kit contents', value: 'Lifting loops, sealant cartridge & applicator gun' },
];

const features = [
  'Two-part kit format with total length options of 2.5m, 3m, 3.5m or 4m',
  '1300mm overall width and 875mm overall height',
  'Narrower 600mm internal base — saves chemical usage on every fill',
  '300mm entry and exit stepover walls keep cows committed to the bath',
  'Four fast-draining holes — one in each corner — for rapid emptying',
  'Complete kit with lifting loops, sealant and applicator gun',
];

const applications = [
  'Routine herd-walk-through hoof treatment',
  'Targeted high-mastitis or digital-dermatitis groups',
  'Robotic milking herd post-robot exit lane',
  'Beef finishing units treating digital dermatitis',
  'Sheep dipping (formalin / zinc sulphate solution)',
  'AI / fertility yard cow-flow treatment',
  'Show preparation and pre-export hoof care',
];

const related = [
  { href: '/products/cattle-cubicles', label: 'Cattle Cubicles', meta: 'AHDB 2024 sized' },
  { href: '/products/water-troughs', label: 'Drinking Troughs', meta: '40 to 500 Gallon range' },
  { href: '/products/cubicle-end-walls', label: 'Cubicle End Walls', meta: 'Trough + panel variants' },
  { href: '/products/feed-troughs', label: 'Feed Troughs', meta: "'J' Trough · Quad Run · Round Top" },
];

const faqs = [
  { q: 'What lengths can I order?', a: 'The kit comes in four total lengths — 2.5m, 3m, 3.5m or 4m — so you can match cow-flow to the exit race or robot drop-off zone. All four are 1300mm wide and 875mm overall high. Two precast sections that join at the centre.' },
  { q: 'Why the 600mm internal base?', a: 'A narrower 600mm internal base saves chemical on every fill — less formalin or copper sulphate used per pass for the same treatment depth. Pays back fast when you are running a programme through the herd weekly.' },
  { q: 'How fast does it drain?', a: 'Four fast-draining holes — one in each corner — empty the bath rapidly when it is time to refresh chemical. The 300mm entry and exit stepover walls keep cows committed to the bath without splash-out.' },
  { q: "What's in the kit?", a: 'Two precast sections, lifting loops cast in for offload, plus the sealant cartridge and applicator gun for the centre joint. Lift each half off the lorry, butt them together, run the bead, you are done.' },
  { q: 'Lead time and delivery?', a: 'Stock often available — usually 1 to 2 weeks. Delivered on a HIAB lorry that offloads itself onto your prepared base. Talk to the yard for current availability and a delivered price for your address.' },
];

const productSchema = {
  name: 'Precast Cattle Footbath — Two-Part Kit',
  description: "Precast cattle footbath two-part kit. Total length 2.5m, 3m, 3.5m or 4m. 1300mm wide × 875mm overall height with a narrower 600mm internal base that saves chemical usage. 300mm entry & exit stepover walls. Four fast-draining corner holes. Complete kit with lifting loops, sealant and applicator gun.",
  brand: { '@type': 'Brand', name: site.name },
  manufacturer: { '@type': 'Organization', name: site.name },
  category: 'Precast cattle footbath',
  material: 'Reinforced concrete, C40/50 sulphate-resisting (BS 8500-1:2023)',
  weight: { '@type': 'QuantitativeValue', value: 2300, unitCode: 'KGM', unitText: 'kilogram per kit (two halves)' },
  additionalProperty: [
    { '@type': 'PropertyValue', name: 'Standard', value: 'BS EN 13369' },
    { '@type': 'PropertyValue', name: 'Concrete grade', value: 'C40/50 sulphate-resisting' },
    { '@type': 'PropertyValue', name: 'Overall width', value: '1300 mm' },
    { '@type': 'PropertyValue', name: 'Overall height', value: '875 mm' },
    { '@type': 'PropertyValue', name: 'Total length options', value: '2.5m, 3m, 3.5m or 4m (two-part kit)' },
    { '@type': 'PropertyValue', name: 'Internal base width', value: '600 mm (saves chemical)' },
    { '@type': 'PropertyValue', name: 'Stepover walls', value: '300 mm entry & exit' },
    { '@type': 'PropertyValue', name: 'Drainage', value: '4 fast-draining holes (one per corner)' },
    { '@type': 'PropertyValue', name: 'Kit contents', value: 'Lifting loops, sealant cartridge & applicator gun' },
    { '@type': 'PropertyValue', name: 'Lead time', value: '1–2 weeks (stock dependent)' },
    { '@type': 'PropertyValue', name: 'Country of origin', value: 'United Kingdom (Devon)' },
  ],
  offers: { '@type': 'Offer', availability: 'https://schema.org/InStock', areaServed: 'GB', seller: { '@type': 'Organization', name: site.name } },
};

const faqSchema = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) };
---

<BaseLayout
  title="Footbaths — 2.5m, 3m, 3.5m or 4m two-part kit · 600mm chemical-saving base"
  description="Precast cattle footbath kit. 1300mm wide × 875mm high, total length 2.5m / 3m / 3.5m / 4m. Narrower 600mm internal base saves chemical. 300mm stepover walls, 4 corner drains. Lifting loops, sealant + applicator gun supplied. Cast in North Devon."
  image="/og/footbaths.png"
  schema="Product"
  schemaData={productSchema}
  whatsappContext="Footbaths"
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)} slot="head" />
  <TrustStrip />

  <section class="bg-navy text-white">
    <div class="container-wccp py-16 md:py-20">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <p class="eyebrow text-yellow mb-4">Agricultural · cattle health · hoof care</p>
          <h1 class="font-display text-display-xl text-white mb-4">Footbaths.</h1>
          <p class="font-display italic text-xl md:text-2xl text-yellow leading-tight mb-5">One pour. Two parts. Healthy hooves.</p>
          <h2 class="sr-only">How long should a cattle footbath be?</h2>
          <blockquote class="font-display italic text-base md:text-lg text-white/95 leading-relaxed mb-6 pl-4 border-l-2 border-yellow max-w-xl">
            <strong class="not-italic text-white">How long should a cattle footbath be?</strong>
            AHDB recommends a minimum 3&nbsp;m bath length to ensure both feet of every cow get
            two immersions. WCCP precast kits come in 2.5, 3, 3.5 and 4&nbsp;m, with 300&nbsp;mm
            stepover walls each end and four corner drains for fast emptying.
          </blockquote>
          <p class="text-base text-white/85 leading-relaxed mb-6 max-w-xl">
            Two-part precast footbath kit. <strong class="text-white">1300mm wide × 875mm high</strong>, total
            length <strong class="text-white">2.5m, 3m, 3.5m or 4m</strong>. The narrower 600mm internal base saves
            chemical usage on every fill; 300mm entry and exit stepover walls keep cows committed to
            the bath; four fast-draining holes (one in each corner) empty it quickly. Complete kit
            with lifting loops, sealant cartridge and applicator gun supplied.
          </p>
          <ul class="grid grid-cols-2 gap-3 text-sm mb-8 max-w-md">
            <li class="flex gap-2"><span class="text-yellow">·</span> 2.5m / 3m / 3.5m / 4m</li>
            <li class="flex gap-2"><span class="text-yellow">·</span> 1300mm wide</li>
            <li class="flex gap-2"><span class="text-yellow">·</span> 875mm high</li>
            <li class="flex gap-2"><span class="text-yellow">·</span> 600mm chemical-saving base</li>
            <li class="flex gap-2"><span class="text-yellow">·</span> 4 corner drains</li>
            <li class="flex gap-2"><span class="text-yellow">·</span> Lifting loops + sealant kit</li>
          </ul>
          <div class="flex flex-wrap gap-3">
            <a href="/quote?product=Footbaths" class="btn-primary">Order a kit</a>
            <a href="/downloads/specs/footbaths/wccp-footbaths-west-country-concrete-products-footbath-data-sheet.pdf" class="btn-yellow">Download spec sheet</a>
            <a href={`tel:${site.contact.phoneIntl}`} class="btn-ghost border-white text-white hover:bg-white hover:text-navy">Call {site.contact.phone}</a>
          </div>
        </div>
        <div class="aspect-[4/3] bg-cast-100 rounded overflow-hidden">
          <img src="/images/products/footbaths/wccp-footbaths-precast-concrete-cattle-footbath.jpg" alt="WCCP precast concrete cattle footbath — two-part kit with 600mm chemical-saving base, Devon" class="w-full h-full object-cover" loading="eager" decoding="async" />
        </div>
      </div>
    </div>
  </section>

  <section class="container-wccp py-20">
    <div class="max-w-2xl mb-10">
      <p class="eyebrow text-cast mb-3">Specification</p>
      <h2 class="font-display text-display-lg mb-4">Dimensions and kit contents.</h2>
      <p class="text-cast-700 text-lg">Pick a total length to suit your exit race; everything else is fixed. Sealant and applicator gun supplied so you can run treatment within the hour of unloading.</p>
    </div>
    <div class="overflow-x-auto">
      <table class="spec-table w-full text-left border-collapse">
        <thead class="bg-navy text-white">
          <tr>
            <th class="px-4 py-3 font-display text-sm uppercase tracking-wide">Specification</th>
            <th class="px-4 py-3 font-display text-sm uppercase tracking-wide">Value</th>
          </tr>
        </thead>
        <tbody>
          {specs.map((s, i) => (
            <tr class={i % 2 === 0 ? 'bg-white' : 'bg-bone-200'}>
              <td class="px-4 py-3 font-bold text-navy">{s.spec}</td>
              <td class="px-4 py-3">{s.value}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <section class="bg-bone-200 py-20">
    <div class="container-wccp">
      <div class="grid lg:grid-cols-2 gap-12">
        <div>
          <p class="eyebrow text-cast mb-3">Why this kit</p>
          <h2 class="font-display text-display-lg mb-6">Engineered to save chemical and clean fast.</h2>
          <p class="text-cast-700 text-lg leading-relaxed mb-6">Hundreds of UK herds run our footbath. Every detail comes from feedback over years of weekly walk-throughs.</p>
          <ul class="space-y-3">
            {features.map((f) => (<li class="flex gap-3 text-cast-700 leading-relaxed"><span class="text-ember font-bold mt-1">·</span><span>{f}</span></li>))}
          </ul>
        </div>
        <div class="card p-8">
          <p class="eyebrow text-cast mb-3">Where they go</p>
          <h3 class="font-display text-2xl font-bold text-navy mb-4">Common applications.</h3>
          <ul class="space-y-3">
            {applications.map((a) => (<li class="flex gap-3 text-cast-700 leading-relaxed"><span class="text-ember font-bold mt-1">·</span><span>{a}</span></li>))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-yellow text-navy py-16">
    <div class="container-wccp">
      <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6">
        <div>
          <p class="eyebrow text-navy mb-2">Order your footbath</p>
          <h2 class="font-display text-display-md">Pick a total length — 2.5m, 3m, 3.5m or 4m. Kits usually shipping from stock.</h2>
        </div>
        <div class="flex flex-wrap gap-3 shrink-0">
          <a href="/quote?product=Footbaths" class="btn bg-navy text-white hover:bg-navy-700">Order now</a>
          <a href={`mailto:${site.contact.quotesEmail}`} class="btn-secondary">Email quotes</a>
        </div>
      </div>
    </div>
  </section>

  <section class="container-wccp py-20">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between mb-10 gap-4">
      <div>
        <p class="eyebrow text-cast mb-3">Related products</p>
        <h2 class="font-display text-display-lg">Often ordered alongside.</h2>
      </div>
      <a href="/products" class="text-ember font-bold hover:text-ember-700 inline-flex items-center gap-2">View full range
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12" stroke-linecap="round" /><polyline points="12 5 19 12 12 19" stroke-linecap="round" stroke-linejoin="round" /></svg>
      </a>
    </div>
    <RelatedProductGrid items={related} />
  </section>

  <section class="bg-bone-200 py-20">
    <div class="container-wccp">
      <div class="max-w-2xl mb-12">
        <p class="eyebrow text-cast mb-3">Common questions</p>
        <h2 class="font-display text-display-lg mb-4">What people ask about footbaths.</h2>
        <p class="text-cast-700 text-lg">Five questions we answer most weeks. If yours is not here, ring the yard.</p>
      </div>
      <div class="max-w-3xl space-y-4">
        {faqs.map((f) => (
          <details class="card p-6 group">
            <summary class="font-display text-lg font-bold text-navy cursor-pointer list-none flex justify-between items-start gap-4">
              <span>{f.q}</span>
              <span class="text-ember text-2xl leading-none group-open:rotate-45 transition-transform shrink-0">+</span>
            </summary>
            <p class="text-cast-700 leading-relaxed mt-4">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <SpecDownloads
    intro="Two-part footbath kit — the full data sheet."
    downloads={[
      { href: '/downloads/specs/footbaths/wccp-footbaths-west-country-concrete-products-footbath-data-sheet.pdf', title: 'WCCP footbath — data sheet', meta: 'PDF · 357 KB' },
    ]}
  />

  <!-- Supply-only vs Fitted -->
  <section class="container-wccp section-rhythm border-t border-cast-100">
    <FittedVsSupply
      productName="Footbaths"
      defaultMode="supply"
      supply={{
        price: 'Bespoke quote',
        leadTime: '1–2 weeks (stock often available)',
        includes: [
          'Precast section in C40/50 sulphate-resisting',
          'Lifting loops cast in for HIAB offload',
          'Sealant cartridge and applicator gun (kit)',
          'Delivery on our HIAB to your yard',
        ],
        excludes: [
          'On-site setting and joint sealing',
          '100mm hardcore base preparation',
          'Resin anchors if bolt-down required',
        ],
      }}
      fitted={{
        price: 'Bespoke quote (incl. install)',
        leadTime: '3–4 weeks (incl. site slot)',
        includes: [
          'Everything in supply only',
          'Two-man crew with HIAB to set both halves',
          'Joint sealing and bedding finished on site',
          '12-month workmanship warranty',
        ],
        excludes: [
          'Hardcore base preparation and excavation',
          'Treatment chemical and chemical handling',
        ],
      }}
      note="Pick a total kit length of 2.5m, 3m, 3.5m or 4m — bespoke approach races priced individually. Talk to the yard for a delivered price."
    />
  </section>

  <section class="bg-navy text-white py-20">
    <div class="container-wccp text-center">
      <h2 class="font-display text-display-xl mb-4 text-white">Ready to order?</h2>
      <p class="text-white/90 text-lg max-w-xl mx-auto mb-8">Stock often available. Tell us the kit length and your address — ring the yard for a delivered price.</p>
      <div class="flex flex-wrap justify-center gap-3">
        <a href="/quote?product=Footbaths" class="btn-yellow">Order a kit</a>
        <a href={`tel:${site.contact.phoneIntl}`} class="btn-secondary">Call {site.contact.phone}</a>
        <a href={`mailto:${site.contact.quotesEmail}`} class="btn-primary">Email quotes</a>
      </div>
    </div>
  </section>

  <SpecSheetButton productSlug="footbaths" productName="Footbaths" href="/downloads/specs/footbaths/wccp-footbaths-west-country-concrete-products-footbath-data-sheet.pdf" />
  <ProductWarrantyLine />
</BaseLayout>
