---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TrustStrip from '@/components/TrustStrip.astro';
import { site } from '@/config/site';

const specs = [
  { type: 'L-trough (single side)', size: '2440 × 900 × 600mm', weight: '580 kg', anchor: 'Cast-in M16 sockets', use: 'Single-row feed-passage layout' },
  { type: 'Single-sided straight', size: '2440 × 600 × 600mm', weight: '440 kg', anchor: 'Cast-in M16 sockets', use: 'Wall-mounted single feed line' },
  { type: 'Double-sided straight', size: '2440 × 1200 × 600mm', weight: '760 kg', anchor: 'Cast-in M16 sockets', use: 'Centre-passage two-sided feeding' },
  { type: 'Tombstone barrier-top', size: '2440 × 900 × 1100mm', weight: '780 kg', anchor: 'Bolt-down to slab', use: 'Self-locking yoke front' },
  { type: 'Calf creep trough', size: '2000 × 600 × 450mm', weight: '320 kg', anchor: 'Free-standing', use: 'Calf creep and youngstock pens' },
  { type: 'Heavy-duty drive-along', size: '3000 × 900 × 700mm', weight: '850 kg', anchor: 'Cast-in M20 sockets', use: 'TMR drive-along feeding systems' },
];

const applications = [
  'Cubicle-housed dairy parlour feed passages',
  'Loose-housed beef and youngstock pens',
  'TMR (total mixed ration) feed-out systems',
  'Calf-rearing and creep-feeding pens',
  'Self-locking yoke barriers for AI and treatment',
  'Outdoor wintering pads with covered feed face',
  'Sheep handling and feed yards',
];

const related = [
  { href: '/products/water-troughs', label: 'Water Troughs', meta: 'Single + double row · 1300×600' },
  { href: '/products/cattle-cubicles', label: 'Cattle Cubicles', meta: 'AHDB 2024 sized' },
  { href: '/products/cubicle-end-walls', label: 'Cubicle End Walls', meta: 'Integrated trough option' },
  { href: '/products/interlocking-blocks', label: 'Interlocking Blocks', meta: 'Beton-style · 1485kg' },
];

const faqs = [
  { q: 'L-shape or straight — what do I need?', a: 'L-troughs sit at the end of a feed passage and turn the run — handy on most cubicle layouts. Straight troughs go between L-troughs in the middle of the passage. We supply both at 2440mm length so they line up. The L-trough at 2440 × 900 × 600mm weighs 580kg.' },
  { q: 'How are they anchored?', a: 'Standard troughs come with M16 cast-in sockets at 1.2m centres — bolt down through your slab. Drive-along units use M20. We supply the resin-anchor spec or stainless bolts. Heavy-duty TMR systems also need anti-slide cleats; we will cast those in too on request.' },
  { q: 'Will they last with TMR feed?', a: 'Yes — C40/50 mix with sulphate-resisting binder where the feed is acid-rich. The trough lip is the wear point on TMR systems, so we cast a thicker lip section as standard. Decades of service is normal.' },
  { q: 'Can I get a tombstone or yoke front?', a: 'Yes — tombstone barrier tops, self-locking yoke fronts and full headlock systems all bolt to the trough back. Sized to the breed in line with AHDB feed-passage guidance.' },
  { q: 'Lead time?', a: 'Catalogue sizes ship in 2 to 3 weeks. Bespoke trough lengths or integrated yoke-fronts run 4 to 6 weeks. Most farms want them in for the autumn housing — order by August.' },
];

const productSchema = {
  name: 'Precast Cattle Feed Troughs',
  description: 'L-shaped, single-sided and double-sided precast feed troughs. Standard 2440×900×600mm L-trough at 580kg. Cast-in M16 anchor sockets. C40/50 concrete. For TMR, single-line and yoke-front feeding systems.',
  brand: { '@type': 'Brand', name: site.name },
  manufacturer: { '@type': 'Organization', name: site.name },
  category: 'Precast feed trough',
  material: 'Reinforced concrete, C40/50 (BS 8500-1:2023)',
  weight: { '@type': 'QuantitativeValue', minValue: 320, maxValue: 850, unitCode: 'KGM', unitText: 'kilogram per trough' },
  additionalProperty: [
    { '@type': 'PropertyValue', name: 'Standard', value: 'BS EN 13369 / BS 5502-22:2003' },
    { '@type': 'PropertyValue', name: 'Concrete grade', value: 'C40/50 (BS 8500-1:2023)' },
    { '@type': 'PropertyValue', name: 'Standard L-trough', value: '2440 × 900 × 600mm, 580 kg' },
    { '@type': 'PropertyValue', name: 'Anchor', value: 'M16 cast-in sockets at 1.2m c/c' },
    { '@type': 'PropertyValue', name: 'Variants', value: 'L-shape / single-sided / double-sided / tombstone / drive-along' },
    { '@type': 'PropertyValue', name: 'Lead time', value: '2–3 weeks catalogue' },
    { '@type': 'PropertyValue', name: 'Country of origin', value: 'United Kingdom (Devon)' },
  ],
  offers: { '@type': 'Offer', priceCurrency: 'GBP', availability: 'https://schema.org/InStock', seller: { '@type': 'Organization', name: site.name } },
};

const faqSchema = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) };
---

<BaseLayout
  title="Feed Troughs — L-shape, single + double-sided · 2440×900×600"
  description="Precast cattle feed troughs. L-shape, single + double-sided. Standard 2440×900×600mm L-trough at 580kg. M16 cast-in anchors. Cast in North Devon."
  image="/images/products/feed-troughs.jpg"
  schema="Product"
  schemaData={productSchema}
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)} slot="head" />
  <TrustStrip />

  <section class="bg-navy text-white">
    <div class="container-wccp py-16 md:py-20">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <p class="eyebrow text-yellow mb-4">Agricultural · feeding · cattle</p>
          <h1 class="font-display text-display-xl text-white mb-4">Feed Troughs.</h1>
          <p class="text-lg text-white/90 leading-relaxed mb-6">
            L-shaped, single-sided and double-sided precast troughs for cattle feed passages.
            Standard 2440 × 900 × 600mm L-trough at 580kg with M16 cast-in anchor sockets.
            Tombstone tops, drive-along sizes and calf-creep variants on the catalogue.
          </p>
          <ul class="grid grid-cols-2 gap-3 text-sm mb-8 max-w-md">
            <li class="flex gap-2"><span class="text-yellow">·</span> L-trough 2440×900</li>
            <li class="flex gap-2"><span class="text-yellow">·</span> 580 kg standard</li>
            <li class="flex gap-2"><span class="text-yellow">·</span> M16 anchors</li>
            <li class="flex gap-2"><span class="text-yellow">·</span> TMR-rated</li>
            <li class="flex gap-2"><span class="text-yellow">·</span> Tombstone option</li>
            <li class="flex gap-2"><span class="text-yellow">·</span> 2–3 week lead</li>
          </ul>
          <div class="flex flex-wrap gap-3">
            <a href="/quote?product=Feed+Troughs" class="btn-primary">Configure a quote</a>
            <a href="/spec-sheets/feed-troughs.pdf" class="btn-yellow">Download spec sheet</a>
            <a href={`tel:${site.contact.phoneIntl}`} class="btn-ghost border-white text-white hover:bg-white hover:text-navy">Call {site.contact.phone}</a>
          </div>
        </div>
        <div class="aspect-[4/3] bg-cast-100 rounded overflow-hidden"><div class="w-full h-full bg-gradient-to-br from-cast-300 via-cast to-navy"></div></div>
      </div>
    </div>
  </section>

  <section class="container-wccp py-20">
    <div class="max-w-2xl mb-10">
      <p class="eyebrow text-cast mb-3">Specification</p>
      <h2 class="font-display text-display-lg mb-4">Variants, sizes and weights.</h2>
      <p class="text-cast-700 text-lg">Catalogue troughs at 2440mm length so units line up. Bespoke lengths and integrated yoke-fronts on application.</p>
    </div>
    <div class="overflow-x-auto">
      <table class="spec-table w-full text-left border-collapse">
        <thead class="bg-navy text-white">
          <tr>
            <th class="px-4 py-3 font-display text-sm uppercase tracking-wide">Type</th>
            <th class="px-4 py-3 font-display text-sm uppercase tracking-wide">Size (L×W×H)</th>
            <th class="px-4 py-3 font-display text-sm uppercase tracking-wide">Weight</th>
            <th class="px-4 py-3 font-display text-sm uppercase tracking-wide">Anchor</th>
            <th class="px-4 py-3 font-display text-sm uppercase tracking-wide">Typical use</th>
          </tr>
        </thead>
        <tbody>
          {specs.map((s, i) => (
            <tr class={i % 2 === 0 ? 'bg-white' : 'bg-bone-200'}>
              <td class="px-4 py-3 font-bold text-navy">{s.type}</td>
              <td class="px-4 py-3">{s.size}</td>
              <td class="px-4 py-3">{s.weight}</td>
              <td class="px-4 py-3">{s.anchor}</td>
              <td class="px-4 py-3 text-cast">{s.use}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <section class="bg-bone-200 py-20">
    <div class="container-wccp">
      <div class="grid lg:grid-cols-2 gap-12">
        <div>
          <p class="eyebrow text-cast mb-3">Where they go</p>
          <h2 class="font-display text-display-lg mb-6">Common applications.</h2>
          <p class="text-cast-700 text-lg leading-relaxed mb-6">From a 60-cow cubicle shed to a 400-cow TMR drive-along — same trough family, sized for the breed and feed system.</p>
          <ul class="space-y-3">
            {applications.map((a) => (<li class="flex gap-3 text-cast-700 leading-relaxed"><span class="text-ember font-bold mt-1">·</span><span>{a}</span></li>))}
          </ul>
        </div>
        <div class="card p-8">
          <p class="eyebrow text-cast mb-3">Standards & references</p>
          <h3 class="font-display text-2xl font-bold text-navy mb-4">Cast and sized to current best practice.</h3>
          <dl class="space-y-4 text-sm">
            <div><dt class="font-bold text-navy">BS EN 13369</dt><dd class="text-cast">Common rules for precast concrete — factory production control.</dd></div>
            <div><dt class="font-bold text-navy">BS 5502-22:2003</dt><dd class="text-cast">Agricultural buildings — feed-passage detailing and loadings.</dd></div>
            <div><dt class="font-bold text-navy">BS 8500-1:2023</dt><dd class="text-cast">Concrete spec — C40/50 designed mix for the feeding environment.</dd></div>
            <div><dt class="font-bold text-navy">AHDB Dairy</dt><dd class="text-cast">Feed-passage and trough-front sizing guidance for cattle.</dd></div>
            <div><dt class="font-bold text-navy">BS EN 1992 (Eurocode 2)</dt><dd class="text-cast">Concrete structural design — anchor and lifting calculation.</dd></div>
          </dl>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-yellow text-navy py-16">
    <div class="container-wccp">
      <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6">
        <div>
          <p class="eyebrow text-navy mb-2">Configure your feed run</p>
          <h2 class="font-display text-display-md">Send passage length, breed and feed system — we will quote inside 24 hours.</h2>
        </div>
        <div class="flex flex-wrap gap-3 shrink-0">
          <a href="/quote?product=Feed+Troughs" class="btn bg-navy text-white hover:bg-navy-700">Open the configurator</a>
          <a href={`mailto:${site.contact.quotesEmail}`} class="btn-secondary">Email quotes</a>
        </div>
      </div>
    </div>
  </section>

  <section class="container-wccp py-20">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between mb-10 gap-4">
      <div>
        <p class="eyebrow text-cast mb-3">Related products</p>
        <h2 class="font-display text-display-lg">Often ordered alongside.</h2>
      </div>
      <a href="/products" class="text-ember font-bold hover:text-ember-700 inline-flex items-center gap-2">View full range
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12" stroke-linecap="round" /><polyline points="12 5 19 12 12 19" stroke-linecap="round" stroke-linejoin="round" /></svg>
      </a>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
      {related.map((r) => (
        <a href={r.href} class="card p-5 group">
          <div class="aspect-[16/10] bg-cast-100 mb-4 rounded overflow-hidden"><div class="w-full h-full bg-gradient-to-br from-cast-200 to-cast-100"></div></div>
          <h3 class="font-display text-base font-bold text-navy mb-1 group-hover:text-ember">{r.label}</h3>
          <p class="text-cast text-xs">{r.meta}</p>
        </a>
      ))}
    </div>
  </section>

  <section class="bg-bone-200 py-20">
    <div class="container-wccp">
      <div class="max-w-2xl mb-12">
        <p class="eyebrow text-cast mb-3">Common questions</p>
        <h2 class="font-display text-display-lg mb-4">What people ask about feed troughs.</h2>
        <p class="text-cast-700 text-lg">Five questions we answer most weeks. If yours is not here, ring the yard.</p>
      </div>
      <div class="max-w-3xl space-y-4">
        {faqs.map((f) => (
          <details class="card p-6 group">
            <summary class="font-display text-lg font-bold text-navy cursor-pointer list-none flex justify-between items-start gap-4">
              <span>{f.q}</span>
              <span class="text-ember text-2xl leading-none group-open:rotate-45 transition-transform shrink-0">+</span>
            </summary>
            <p class="text-cast-700 leading-relaxed mt-4">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-navy text-white py-20">
    <div class="container-wccp text-center">
      <h2 class="font-display text-display-xl mb-4 text-white">Ready to spec it?</h2>
      <p class="text-white/90 text-lg max-w-xl mx-auto mb-8">Send the feed-passage length and herd type. Quote and lead-time same day.</p>
      <div class="flex flex-wrap justify-center gap-3">
        <a href="/quote?product=Feed+Troughs" class="btn-yellow">Configure a quote</a>
        <a href={`tel:${site.contact.phoneIntl}`} class="btn-secondary">Call {site.contact.phone}</a>
        <a href={`mailto:${site.contact.quotesEmail}`} class="btn-primary">Email quotes</a>
      </div>
    </div>
  </section>
</BaseLayout>
