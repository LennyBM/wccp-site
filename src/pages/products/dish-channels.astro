          'BS EN 1433 dish units to specified class',
          'Bends, junctions and falls units cast to GA',
          'UKCA mill certs and bedding spec',
          'Delivery to site by HIAB or flat-bed',
        ],
        excludes: [
          'Excavation and bedding works',
          'Mortar joint installation labour',
        ],
      }}
      fitted={{
        price: 'Bespoke quote (incl. install)',
        leadTime: '6â€“10 weeks (incl. site slot)',
        includes: [
          'Everything in supply only',
          'Civils crew with setting-out',
          'Mortar bedding and joint sealing',
          '12-month workmanship warranty',
        ],
        excludes: [
          'Carriageway construction works',
          'Traffic-management costs',
        ],
      }}
      note=". Bespoke widths, falls and SuDS-integrated runs priced individually â€” send the drainage GA and outfall invert and we'll come back within a working day."
    />
  </section>

  <!-- Final CTA -->
  <section class="bg-navy text-white py-20">
    <div class="container-wccp text-center">
      <h2 class="font-display text-display-xl mb-4 text-white">Ready to spec it?</h2>
      <p class="text-white/90 text-lg max-w-xl mx-auto mb-8">
        Send us run length, loading class and outfall. Quote and lead-time same day.
      </p>
      <div class="flex flex-wrap justify-center gap-3">
        <a href="/quote?product=Dish%20Channels" class="btn-yellow">Configure a quote</a>
        <a href={`tel:${site.contact.phoneIntl}`} class="btn-secondary">Call {site.contact.phone}</a>
        <a href={`mailto:${site.contact.quotesEmail}`} class="btn-primary">Email quotes</a>
      </div>
    </div>
  </section>

  <SpecSheetButton productSlug="dish-channels" productName="Dish Channels" />
  <ProductWarrantyLine />
</BaseLayout>
