---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ProductWarrantyLine from '@/components/ProductWarrantyLine.astro';
import TrustStrip from '@/components/TrustStrip.astro';
import FittedVsSupply from '@/components/FittedVsSupply.astro';
import SpecSheetButton from '@/components/SpecSheetButton.astro';
import ProductGallery from '@/components/ProductGallery.astro';
import { site } from '@/config/site';
import RelatedProductGrid from '@/components/RelatedProductGrid.astro';
import ProductPageTOC from '@/components/ProductPageTOC.astro';

const tocSections = [
  { id: 'overview', label: 'Overview' },
  { id: 'specifications', label: 'Specifications' },
  { id: 'gallery', label: 'Gallery' },
  { id: 'related', label: 'Related' },
  { id: 'faq', label: 'FAQ' },
  { id: 'downloads', label: 'Downloads' },
];

// WCCP precast dish channels â€” surface drainage runs, BS EN 1433, SuDS-compatible.
const specs = [
  { variant: 'Standard 305mm dish', bed: '305mm wide Ã— 915mm long Ã— 125mm deep', style: 'Class C250 â€” light traffic', use: 'Yards, footpaths, light-vehicle areas' },
  { variant: 'Heavy 450mm dish', bed: '450mm wide Ã— 915mm long Ã— 150mm deep', style: 'Class D400 â€” full traffic', use: 'Adoptable carriageways, estate roads' },
  { variant: 'Industrial 600mm dish', bed: '600mm wide Ã— 915mm long Ã— 175mm deep', style: 'Class E600 â€” HGV areas', use: 'Industrial yards, lorry parks, ports' },
  { variant: 'Half-batter dish', bed: '305mm Ã— 915mm â€” kerb-aligned profile', style: 'Class D400 â€” kerbline runs', use: 'Highway kerb gulley alternatives' },
  { variant: 'Falls dish (graded)', bed: '305mm Ã— 915mm â€” 1:80 cast fall', style: 'Class D400 with built-in fall', use: 'Flat-area falls, slow-flow channels' },
  { variant: 'Bend / junction units', bed: 'To suit run geometry', style: 'Class to match adjacent run', use: 'Direction changes, side-entry junctions' },
];

const applications = [
  'Adoptable carriageway and estate-road surface drainage',
  'Industrial and logistics yards â€” HGV-loaded surfaces',
  'Farm and agricultural concrete-yard runoff control',
  'Public realm and footpath drainage',
  'SuDS source-control conveyance to soakaways',
  'Car-park and retail-park surface water capture',
  'Forecourt and fuel-station bunded drainage',
];

const related = [
  { href: '/products/sand-channels', label: 'Sand Channels', meta: 'Forecourt and yard drainage' },
  { href: '/products/kerbs', label: 'Kerbs', meta: 'BS EN 1340 Â· half-batter, bullnose' },
  { href: '/products/soakaways-chambers', label: 'Soakaways & Chambers', meta: 'BS 5911-3 Â· SuDS systems' },
  { href: '/products/pipe-culverts', label: 'Pipe Culverts', meta: 'BS 5911-1 Â· 300â€“1800mm' },
];

const faqs = [
  { q: 'What standard do your dish channels meet?', a: 'BS EN 1433:2002+A1:2005 â€” drainage channels for vehicular and pedestrian areas. We supply Classes C250 (light), D400 (carriageway) and E600 (HGV areas) depending on your loading. Cast in C40/50 concrete to BS 8500-1:2023, factory-production-controlled to BS EN 13369 and UKCA marked.' },
  { q: 'Are they SuDS-compatible?', a: 'Yes â€” dish channels are commonly used as conveyance components in SuDS source-control systems, feeding from impermeable surfaces into soakaways, swales or attenuation tanks. They satisfy CIRIA C753 SuDS Manual conveyance criteria and integrate with our BS 5911-3 soakaway chambers. Specify the falls and outfall on your drainage layout and we will batch the run accordingly.' },
  { q: 'Do you cast bends and junctions?', a: 'Yes â€” 90-degree and 45-degree bends, T-junctions and graded falls units are all cast in-house at Holsworthy. Send the drainage GA and we will set out the run with named pieces â€” straight runs, bends, end-stops and outfall connections â€” so the gangs install kit-of-parts on site.' },
  { q: 'How are they bedded?', a: 'Standard bedding is a Class S granular bed on a 100mm C20 lean-mix base, with cement-mortar joints between units to BS EN 1433 watertightness. For trafficked carriageway use we recommend a 150mm C32/40 surround â€” full bedding detail supplied with the spec sheet.' },
  { q: 'What is the lead time?', a: 'Catalogue 305mm and 450mm dish ship in 2 to 3 weeks. Bespoke widths, falls runs and graded units run 4 to 6 weeks. We schedule highways orders around your possession dates â€” give us the works programme early.' },
];

const productSchema = {
  name: 'Precast Dish Channels',
  description: 'Precast concrete dish channels for surface drainage to BS EN 1433. Class C250, D400 and E600 loading. SuDS-compatible. Cast in C40/50 concrete at our Holsworthy yard.',
  brand: { '@type': 'Brand', name: site.name },
  manufacturer: { '@type': 'Organization', name: site.name },
  category: 'Precast concrete drainage channel',
  material: 'Reinforced concrete, C40/50 (BS 8500-1:2023)',
  additionalProperty: [
    { '@type': 'PropertyValue', name: 'Standard', value: 'BS EN 1433:2002+A1:2005' },
    { '@type': 'PropertyValue', name: 'Concrete grade', value: 'C40/50 (BS 8500-1:2023)' },
    { '@type': 'PropertyValue', name: 'Loading classes', value: 'C250 / D400 / E600' },
    { '@type': 'PropertyValue', name: 'Width range', value: '305mm to 600mm' },
    { '@type': 'PropertyValue', name: 'Effective length', value: '915mm standard' },
    { '@type': 'PropertyValue', name: 'SuDS compatibility', value: 'CIRIA C753 conveyance' },
    { '@type': 'PropertyValue', name: 'Factory production control', value: 'BS EN 13369 Â· UKCA marked' },
    { '@type': 'PropertyValue', name: 'Lead time', value: '2â€“3 weeks catalogue, 4â€“6 weeks bespoke' },
    { '@type': 'PropertyValue', name: 'Country of origin', value: 'United Kingdom (Devon)' },
  ],
  offers: { '@type': 'Offer', availability: 'https://schema.org/InStock', areaServed: 'GB', seller: { '@type': 'Organization', name: site.name } },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<BaseLayout
  title="Dish Channels â€” BS EN 1433 Â· D400 / E600 Â· SuDS-compatible"
  description="Precast dish channels to BS EN 1433. Surface drainage for adoptable roads, industrial yards and SuDS systems. Class C250, D400 and E600. Cast in North Devon."
  image="/og/home.png"
  schema="Product"
  schemaData={productSchema}
  whatsappContext="Dish Channels"
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)} slot="head" />
  <TrustStrip />
  <ProductPageTOC sections={tocSections} />

  <!-- Hero -->
  <section id="overview" class="bg-navy text-white">
    <div class="container-wccp py-16 md:py-20">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <p class="eyebrow text-yellow mb-4">Civils Â· drainage Â· SuDS</p>
          <h1 class="font-display text-display-xl text-white mb-4">Dish Channels.</h1>
          <p class="font-display italic text-xl md:text-2xl text-yellow leading-tight mb-5">Surface water captured. Carriageway dry.</p>
          <p class="text-lg lg:text-xl text-cast leading-relaxed font-medium text-white/95 mb-6 max-w-xl">
            Precast dish channels to BS EN 1433 for surface drainage on roads, industrial
            yards and SuDS systems. Cast in 305mm, 450mm and 600mm widths in 915mm units,
            Classes C250, D400 and E600 to suit loading. C40/50 concrete to BS 8500-1:2023,
            UKCA marked. Catalogue lead time 2â€“3 weeks.
          </p>
          <blockquote class="font-display italic text-base md:text-lg text-white/95 leading-relaxed mb-6 pl-4 border-l-2 border-yellow max-w-xl">
            A 450&nbsp;mm dish channel cast to BS EN 1433 Class D400 carries the full
            adoptable-highway wheel load, joints up watertight with a cement-mortar seal
            and feeds straight into a BS 5911-3 soakaway chamber as part of a SuDS train.
          </blockquote>
          <p class="text-base text-white/85 leading-relaxed mb-6 max-w-xl">
            We cast straights, bends, T-junctions and falls units in matching profiles â€”
            kit-of-parts delivered to your drainage layout. Cast at Holsworthy, delivered
            UK-wide.
          </p>
          <ul class="grid grid-cols-2 gap-3 text-sm mb-8 max-w-md">
            <li class="flex gap-2"><span class="text-yellow">Â·</span> BS EN 1433</li>
            <li class="flex gap-2"><span class="text-yellow">Â·</span> C250â€“E600</li>
            <li class="flex gap-2"><span class="text-yellow">Â·</span> 305â€“600mm wide</li>
            <li class="flex gap-2"><span class="text-yellow">Â·</span> SuDS-compatible</li>
            <li class="flex gap-2"><span class="text-yellow">Â·</span> UKCA marked</li>
            <li class="flex gap-2"><span class="text-yellow">Â·</span> 2â€“6 week lead</li>
          </ul>
          <div class="flex flex-wrap gap-3">
            <a href="/quote?product=Dish%20Channels" class="btn-primary">Configure a quote</a>
            <a href="mailto:engineering@wccp.co.uk?subject=Spec%20sheet%20request%20%E2%80%94%20Dish%20Channels&amp;body=Hi%20WCCP%20engineering%2C%0A%0APlease%20send%20the%20spec%20sheet%20for%20Dish%20Channels.%0A%0AProject%20details%3A%0A%E2%80%A2%20Project%20name%3A%0A%E2%80%A2%20Site%20location%3A%0A%E2%80%A2%20Required%20spec%20%2F%20standard%3A%0A%0AThanks" class="btn-yellow">Request spec sheet</a>
            <a href={`tel:${site.contact.phoneIntl}`} class="btn-ghost border-white text-white hover:bg-white hover:text-navy">
              Call {site.contact.phone}
            </a>
          </div>
        </div>
        <div class="aspect-[4/3] bg-cast-100 rounded overflow-hidden flex items-center justify-center border-2 border-dashed border-cast-300 p-8 text-center">
          <div>
            <p class="text-cast-600 text-sm font-mono">ðŸ“· Photo needed</p>
            <p class="text-cast text-xs mt-2">Hero shot: 450mm dish channel run laid into adoptable estate road, with kerbline behind, taken from low angle showing the dish profile</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Spec table -->
  <section class="container-wccp py-20">
    <div class="max-w-2xl mb-10">
      <p class="eyebrow text-cast mb-3">Specification</p>
      <h2 class="font-display text-display-lg mb-4">Widths, classes and formats.</h2>
      <p class="text-cast-700 text-lg">
        Six catalogue formats covering footpath to HGV-yard duty. Bends, T-junctions and
        graded fall units cast to suit your drainage layout â€” send the GA, we will set out
        the run.
      </p>
    </div>

    <div class="overflow-x-auto">
      <table class="spec-table w-full text-left border-collapse">
        <thead class="bg-navy text-white">
          <tr>
            <th class="px-4 py-3 font-display text-sm uppercase tracking-wide">Variant</th>
            <th class="px-4 py-3 font-display text-sm uppercase tracking-wide">Size</th>
            <th class="px-4 py-3 font-display text-sm uppercase tracking-wide">Class / style</th>
            <th class="px-4 py-3 font-display text-sm uppercase tracking-wide">Typical use</th>
          </tr>
        </thead>
        <tbody>
          {specs.map((s, i) => (
            <tr class={i % 2 === 0 ? 'bg-white' : 'bg-bone-200'}>
              <td class="px-4 py-3 font-bold text-navy">{s.variant}</td>
              <td class="px-4 py-3">{s.bed}</td>
              <td class="px-4 py-3">{s.style}</td>
              <td class="px-4 py-3 text-cast">{s.use}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    <p class="text-cast text-sm mt-4">
      All units UKCA marked, factory production controlled to BS EN 13369. Mortar-joint and
      bedding details supplied with the spec sheet â€” Class S granular on 100mm C20 lean-mix base.
    </p>

    <p class="text-cast text-sm mt-4">
      Bespoke widths and inverted-fall units are cast on order â€” talk to engineering with
      the drainage GA and outfall invert and we will work the falls back through the run.
    </p>
  </section>

  <ProductGallery
    eyebrow="The range"
    heading="Dish channels in service."
    background="bone"
    cols={4}
    images={[
      { src: '', alt: 'Dish channel yard stockpile', caption: 'Stockpile Â· 450mm dish units stacked in Holsworthy yard, freshly cast' },
      { src: '', alt: 'Dish channel install', caption: 'Install Â· gang setting 305mm dish channel into mortar bed on estate road' },
      { src: '', alt: 'Dish channel profile', caption: 'Profile Â· close-up of the dish cross-section showing 1:8 batter' },
      { src: '', alt: 'Dish channel D400 highway', caption: 'D400 carriageway run Â· adoptable road, kerbline visible' },
      { src: '', alt: 'Dish channel bend unit', caption: '90-degree bend unit Â· cast in matching profile to straight run' },
      { src: '', alt: 'Dish channel SuDS connection', caption: 'SuDS outfall Â· dish channel running into precast soakaway chamber' },
      { src: '', alt: 'Dish channel yard HGV', caption: 'E600 industrial yard Â· 600mm dish carrying HGV runoff' },
      { src: '', alt: 'Dish channel falls run', caption: 'Falls unit Â· graded 1:80 dish handling slow-flow capture' },
    ]}
  />

  <!-- Applications -->
  <section class="bg-white py-20">
    <div class="container-wccp">
      <div class="grid lg:grid-cols-2 gap-12">
        <div>
          <p class="eyebrow text-cast mb-3">Where they go</p>
          <h2 class="font-display text-display-lg mb-6">Common applications.</h2>
          <p class="text-cast-700 text-lg leading-relaxed mb-6">
            From a 305mm dairy-yard runoff capture to a 600mm port-side HGV apron, dish
            channels handle the full range of vehicular and pedestrian surface drainage.
          </p>
          <ul class="space-y-3">
            {applications.map((a) => (
              <li class="flex gap-3 text-cast-700 leading-relaxed">
                <span class="text-ember font-bold mt-1">Â·</span>
                <span>{a}</span>
