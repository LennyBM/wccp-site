---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ProductWarrantyLine from '@/components/ProductWarrantyLine.astro';
import TrustStrip from '@/components/TrustStrip.astro';
import FittedVsSupply from '@/components/FittedVsSupply.astro';
import SpecSheetButton from '@/components/SpecSheetButton.astro';
import ProductGallery from '@/components/ProductGallery.astro';
import { site } from '@/config/site';
import RelatedProductGrid from '@/components/RelatedProductGrid.astro';
import ProductPageTOC from '@/components/ProductPageTOC.astro';

const tocSections = [
  { id: 'overview', label: 'Overview' },
  { id: 'specifications', label: 'Specifications' },
  { id: 'gallery', label: 'Gallery' },
  { id: 'related', label: 'Related' },
  { id: 'faq', label: 'FAQ' },
  { id: 'downloads', label: 'Downloads' },
];

// WCCP precast weighbridge bases â€” trade and agriculture, NMI-compliant tolerances, BS EN 1992.
const specs = [
  { variant: '6m Ã— 3m base', bed: '6000 Ã— 3000 Ã— 350mm deck', style: '30t SWL Â· trade-approved tolerances', use: 'Light commercial, agricultural feed mills' },
  { variant: '12m Ã— 3m base', bed: '12000 Ã— 3000 Ã— 400mm deck', style: '50t SWL Â· NMI Class III', use: 'Standard HGV agricultural weighbridge' },
  { variant: '14m Ã— 3m base', bed: '14000 Ã— 3000 Ã— 400mm deck', style: '60t SWL Â· NMI Class III', use: 'Six-axle HGV trade weighbridge' },
  { variant: '18m Ã— 3m base', bed: '18000 Ã— 3000 Ã— 450mm deck', style: '80t SWL Â· NMI Class III', use: 'Drawbar trailer + tractor unit' },
  { variant: '22m Ã— 3.5m base', bed: '22000 Ã— 3500 Ã— 500mm deck', style: '100t SWL Â· heavy industrial', use: 'Quarry, port, heavy-haul yards' },
  { variant: 'Pit-type base', bed: 'To suit deck (flush surface)', style: 'Sealed pit Â· sump and drainage', use: 'Flush-deck installations, restricted sites' },
];

const applications = [
  'Agricultural feed mills and grain stores',
  'Slurry-haulage and AD-plant feedstock weighing',
  'Quarry and aggregate yard trade weighbridges',
  'Waste-transfer and recycling facility weigh-ins',
  'Port-side and harbour bulk-cargo weighing',
  'Livestock-haulage farm weighbridges',
  'Industrial estate and logistics-yard installations',
];

const related = [
  { href: '/products/vehicle-pits', label: 'Vehicle Pits', meta: 'Inspection and service pits' },
  { href: '/products/retaining-walls', label: 'Retaining Walls', meta: 'L-shape and counterfort civils' },
  { href: '/products/l-blocks', label: 'L-Blocks', meta: 'Modular bay walls and divisions' },
  { href: '/products/ad-plant-components', label: 'AD Plant Components', meta: 'Anaerobic digester precast' },
];

const faqs = [
  { q: 'Are your bases NMI-approved?', a: 'Our weighbridge bases are cast to tolerances that satisfy NMI (National Measurement and Regulation Office) Class III requirements for trade-approved weighbridges. The deck is cast flat to within Â±2mm over the run length, with load-cell mounting plates set to Â±1mm verticality. The actual trade approval is granted to the complete weighbridge by the load-cell supplier (Avery, Bilanciai, etc) â€” we cast the structural base to receive their kit.' },
  { q: 'What concrete grade and reinforcement?', a: 'C40/50 concrete to BS 8500-1:2023, with B500B reinforcement designed to BS EN 1992 (Eurocode 2). Decks are cast 350mm to 500mm thick depending on SWL, with twin-layer reinforcement and cast-in load-cell pockets. Mill certs and concrete cube records supplied with delivery.' },
  { q: 'Surface or pit-type?', a: 'Both. Surface-mount bases sit 350mm proud of the yard and use approach ramps â€” the standard for greenfield sites. Pit-type bases sit flush with the surrounding yard surface, with a sealed sump and drainage to a controlled outfall â€” better for tight sites and where flush vehicle access is needed. Pit type costs more in civils but saves yard length.' },
  { q: 'How is it delivered and installed?', a: 'Decks up to 18m are cast in a single piece and delivered on a low-loader, then craned into position by 50t mobile crane. Larger 22m bases are cast in two sections with a cast-in-situ joint poured on site. We supply the rebar drawing for the joint and the concrete spec â€” the on-site civils contractor pours under our oversight if required.' },
  { q: 'What is the lead time?', a: 'Catalogue 12m and 14m bases ship in 4 to 6 weeks. Larger 18m and 22m bespoke runs sit at 6 to 8 weeks given the deck-cure programme. Pit-type bases run 6 to 8 weeks. We schedule around your weighbridge installer\'s commissioning slot â€” talk to engineering early.' },
];

const productSchema = {
  name: 'Precast Weighbridge Bases',
  description: 'Precast concrete weighbridge bases for trade and agricultural use. NMI Class III tolerances, 30t to 100t SWL, surface and pit-type variants. Cast in C40/50 concrete to BS EN 1992 at our Holsworthy yard.',
  brand: { '@type': 'Brand', name: site.name },
  manufacturer: { '@type': 'Organization', name: site.name },
  category: 'Precast concrete weighbridge base',
  material: 'Reinforced concrete, C40/50 (BS 8500-1:2023)',
  additionalProperty: [
    { '@type': 'PropertyValue', name: 'Standard', value: 'BS EN 1992 (Eurocode 2)' },
    { '@type': 'PropertyValue', name: 'Concrete grade', value: 'C40/50 (BS 8500-1:2023)' },
    { '@type': 'PropertyValue', name: 'Reinforcement', value: 'B500B twin-layer (BS 4449)' },
    { '@type': 'PropertyValue', name: 'Tolerance', value: 'NMI Class III Â· Â±2mm flatness' },
    { '@type': 'PropertyValue', name: 'Load capacity', value: '30t to 100t SWL' },
    { '@type': 'PropertyValue', name: 'Length range', value: '6m to 22m standard' },
    { '@type': 'PropertyValue', name: 'Variants', value: 'Surface-mount / pit-type' },
    { '@type': 'PropertyValue', name: 'Factory production control', value: 'BS EN 13369 Â· UKCA marked' },
    { '@type': 'PropertyValue', name: 'Lead time', value: '4â€“6 weeks catalogue, 6â€“8 weeks bespoke' },
    { '@type': 'PropertyValue', name: 'Country of origin', value: 'United Kingdom (Devon)' },
  ],
  offers: { '@type': 'Offer', availability: 'https://schema.org/InStock', areaServed: 'GB', seller: { '@type': 'Organization', name: site.name } },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<BaseLayout
  title="Weighbridge Bases â€” NMI Class III Â· 30tâ€“100t Â· Trade Approved"
  description="Precast weighbridge bases for trade and agriculture. NMI Class III tolerances, 30t to 100t SWL, surface and pit-type variants. BS EN 1992. Cast in North Devon."
  image="/og/home.png"
  schema="Product"
  schemaData={productSchema}
  whatsappContext="Weighbridge Bases"
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)} slot="head" />
  <TrustStrip />
  <ProductPageTOC sections={tocSections} />

  <!-- Hero -->
  <section id="overview" class="bg-navy text-white">
    <div class="container-wccp py-16 md:py-20">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <p class="eyebrow text-yellow mb-4">Civils Â· trade Â· agriculture</p>
          <h1 class="font-display text-display-xl text-white mb-4">Weighbridge Bases.</h1>
          <p class="font-display italic text-xl md:text-2xl text-yellow leading-tight mb-5">Flat to Â±2mm. Approved for trade.</p>
          <p class="text-lg lg:text-xl text-cast leading-relaxed font-medium text-white/95 mb-6 max-w-xl">
            Precast concrete weighbridge bases cast to NMI Class III tolerances for trade-approved
            HGV weighing. 6m to 22m deck lengths, 30t to 100t SWL, surface-mount or pit-type
            variants. C40/50 concrete to BS 8500-1:2023 with twin-layer B500B reinforcement
            designed to BS EN 1992 (Eurocode 2). Lead time 4â€“6 weeks.
          </p>
          <blockquote class="font-display italic text-base md:text-lg text-white/95 leading-relaxed mb-6 pl-4 border-l-2 border-yellow max-w-xl">
            A trade-approved 14&nbsp;m Ã— 3&nbsp;m weighbridge base for a six-axle HGV is cast to
            NMI Class III flatness â€” the deck reads flat to Â±2&nbsp;mm over the run, with load-cell
            mounting plates set to Â±1&nbsp;mm verticality so the load-cell supplier can sign off
            trade approval first time.
          </blockquote>
          <p class="text-base text-white/85 leading-relaxed mb-6 max-w-xl">
            We cast for Avery, Bilanciai, Pfister and farm-installer brands UK-wide. Single-piece
            decks up to 18m, two-piece for 22m. Cast at Holsworthy, delivered on low-loader.
          </p>
          <ul class="grid grid-cols-2 gap-3 text-sm mb-8 max-w-md">
            <li class="flex gap-2"><span class="text-yellow">Â·</span> NMI Class III</li>
            <li class="flex gap-2"><span class="text-yellow">Â·</span> 6â€“22m decks</li>
            <li class="flex gap-2"><span class="text-yellow">Â·</span> 30â€“100t SWL</li>
            <li class="flex gap-2"><span class="text-yellow">Â·</span> Surface + pit type</li>
            <li class="flex gap-2"><span class="text-yellow">Â·</span> Â±2mm flatness</li>
            <li class="flex gap-2"><span class="text-yellow">Â·</span> 4â€“6 week lead</li>
          </ul>
          <div class="flex flex-wrap gap-3">
            <a href="/quote?product=Weighbridge%20Bases" class="btn-primary">Configure a quote</a>
            <a href="mailto:engineering@wccp.co.uk?subject=Spec%20sheet%20request%20%E2%80%94%20Weighbridge%20Bases&amp;body=Hi%20WCCP%20engineering%2C%0A%0APlease%20send%20the%20spec%20sheet%20for%20Weighbridge%20Bases.%0A%0AProject%20details%3A%0A%E2%80%A2%20Project%20name%3A%0A%E2%80%A2%20Site%20location%3A%0A%E2%80%A2%20Required%20spec%20%2F%20standard%3A%0A%0AThanks" class="btn-yellow">Request spec sheet</a>
            <a href={`tel:${site.contact.phoneIntl}`} class="btn-ghost border-white text-white hover:bg-white hover:text-navy">
              Call {site.contact.phone}
            </a>
          </div>
        </div>
        <div class="aspect-[4/3] bg-cast-100 rounded overflow-hidden flex items-center justify-center border-2 border-dashed border-cast-300 p-8 text-center">
          <div>
            <p class="text-cast-600 text-sm font-mono">ðŸ“· Photo needed</p>
            <p class="text-cast text-xs mt-2">Hero shot: 14m weighbridge deck on low-loader leaving the Holsworthy yard, with banner straps visible</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Spec table -->
  <section class="container-wccp py-20">
    <div class="max-w-2xl mb-10">
      <p class="eyebrow text-cast mb-3">Specification</p>
      <h2 class="font-display text-display-lg mb-4">Deck sizes and load capacities.</h2>
      <p class="text-cast-700 text-lg">
        Six catalogue formats from 30t agricultural to 100t industrial. Bespoke widths,
        deck depths and pit configurations cast on order â€” send the load-cell supplier's
        installation drawing and we will work to it.
      </p>
    </div>

    <div class="overflow-x-auto">
      <table class="spec-table w-full text-left border-collapse">
        <thead class="bg-navy text-white">
          <tr>
            <th class="px-4 py-3 font-display text-sm uppercase tracking-wide">Variant</th>
            <th class="px-4 py-3 font-display text-sm uppercase tracking-wide">Size</th>
            <th class="px-4 py-3 font-display text-sm uppercase tracking-wide">SWL / class</th>
            <th class="px-4 py-3 font-display text-sm uppercase tracking-wide">Typical use</th>
          </tr>
        </thead>
        <tbody>
          {specs.map((s, i) => (
            <tr class={i % 2 === 0 ? 'bg-white' : 'bg-bone-200'}>
              <td class="px-4 py-3 font-bold text-navy">{s.variant}</td>
              <td class="px-4 py-3">{s.bed}</td>
              <td class="px-4 py-3">{s.style}</td>
              <td class="px-4 py-3 text-cast">{s.use}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    <p class="text-cast text-sm mt-4">
      Cast in C40/50 concrete to BS 8500-1:2023 with twin-layer B500B reinforcement designed
      to BS EN 1992. UKCA marked, factory production controlled to BS EN 13369. Mill certs
      supplied with delivery.
    </p>

    <p class="text-cast text-sm mt-4">
      We cast load-cell pockets to your supplier's setting-out (Avery, Bilanciai, Pfister
      and others) â€” send their install drawing at order and we will work the rebar around
      the cell positions.
    </p>
  </section>

  <ProductGallery
    eyebrow="The range"
    heading="Weighbridge bases on site and in the yard."
    background="bone"
    cols={4}
    images={[
      { src: '', alt: 'Weighbridge deck cast', caption: 'Deck cast Â· 14m base in formwork at Holsworthy, top steel placed' },
      { src: '', alt: 'Weighbridge deck delivery', caption: 'Delivery Â· 12m deck on low-loader leaving yard for Cornwall site' },
      { src: '', alt: 'Weighbridge deck install', caption: 'Install Â· 50t crane lifting deck onto load-cell mounting plates' },
      { src: '', alt: 'Load cell pocket detail', caption: 'Load-cell pocket Â· cast-in mounting plate detail' },
      { src: '', alt: 'Pit-type base', caption: 'Pit type Â· sealed sump base with sump pump location visible' },
      { src: '', alt: 'Surface mount finished', caption: 'Surface mount Â· finished installation with approach ramps' },
      { src: '', alt: 'Agricultural feed mill', caption: 'Feed mill Â· 12m base on Devon agricultural site' },
      { src: '', alt: 'AD plant weighbridge', caption: 'AD plant Â· slurry-haulage weighbridge with vehicle on deck' },
    ]}
  />

  <!-- Applications -->
  <section class="bg-white py-20">
    <div class="container-wccp">
      <div class="grid lg:grid-cols-2 gap-12">
        <div>
          <p class="eyebrow text-cast mb-3">Where they go</p>
          <h2 class="font-display text-display-lg mb-6">Common applications.</h2>
          <p class="text-cast-700 text-lg leading-relaxed mb-6">
            From a 6m agricultural feed-mill base in Devon to a 22m quarry base in Cornwall,
            we cast and deliver the same engineered standard â€” sized to your load-cell
            supplier's drawing, delivered to their commissioning slot.
          </p>
          <ul class="space-y-3">
            {applications.map((a) => (
              <li class="flex gap-3 text-cast-700 leading-relaxed">
                <span class="text-ember font-bold mt-1">Â·</span>
                <span>{a}</span>
              </li>
            ))}
          </ul>
        </div>

        <div class="card p-8">
          <p class="eyebrow text-cast mb-3">Standards & references</p>
          <h3 class="font-display text-2xl font-bold text-navy mb-4">Cast and certified to current code.</h3>
          <dl class="space-y-4 text-sm">
            <div>
              <dt class="font-bold text-navy">BS EN 1992 / Eurocode 2</dt>
              <dd class="text-cast">Design of concrete structures â€” reinforcement detailing for the deck slab.</dd>
            </div>
            <div>
              <dt class="font-bold text-navy">NMI / OIML R76</dt>
              <dd class="text-cast">National Measurement and Regulation Office â€” Class III non-automatic weighing instrument tolerances.</dd>
            </div>
            <div>
              <dt class="font-bold text-navy">BS 8500-1:2023</dt>
              <dd class="text-cast">Concrete specification â€” C40/50 mix designed for exposure class XF3/XD3.</dd>
            </div>
            <div>
              <dt class="font-bold text-navy">BS 4449</dt>
              <dd class="text-cast">B500B reinforcement steel â€” twin-layer mat to load-cell supplier drawing.</dd>
            </div>
            <div>
              <dt class="font-bold text-navy">BS EN 13369</dt>
              <dd class="text-cast">Common rules for precast concrete products â€” factory production control.</dd>
            </div>
            <div>
              <dt class="font-bold text-navy">Weights and Measures Act 1985</dt>
              <dd class="text-cast">Statutory framework for trade-approved weighing in Great Britain.</dd>
            </div>
          </dl>
        </div>
      </div>
    </div>
  </section>

  <!-- Configurator CTA -->
  <section class="bg-yellow text-navy py-16">
    <div class="container-wccp">
      <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6">
        <div>
          <p class="eyebrow text-navy mb-2">Configure your weighbridge base</p>
          <h2 class="font-display text-display-md">Send us deck length, SWL and load-cell supplier â€” we will quote inside 24 hours.</h2>
        </div>
        <div class="flex flex-wrap gap-3 shrink-0">
          <a href="/quote?product=Weighbridge%20Bases" class="btn bg-navy text-white hover:bg-navy-700">Open the configurator</a>
          <a href={`mailto:${site.contact.quotesEmail}`} class="btn-secondary">Email quotes</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Related -->
  <section class="container-wccp py-20">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between mb-10 gap-4">
      <div>
        <p class="eyebrow text-cast mb-3">Related products</p>
        <h2 class="font-display text-display-lg">Often ordered alongside.</h2>
      </div>
      <a href="/products" class="text-ember font-bold hover:text-ember-700 inline-flex items-center gap-2">
        View full range
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <line x1="5" y1="12" x2="19" y2="12" stroke-linecap="round" />
          <polyline points="12 5 19 12 12 19" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </a>
    </div>
    <RelatedProductGrid items={related} />
  </section>

  <!-- FAQ -->
  <section id="faq" class="bg-bone-200 py-20">
    <div class="container-wccp">
      <div class="max-w-2xl mb-12">
        <p class="eyebrow text-cast mb-3">Common questions</p>
        <h2 class="font-display text-display-lg mb-4">What people ask about weighbridge bases.</h2>
        <p class="text-cast-700 text-lg">
          Five questions we answer most weeks. If yours is not here, ring the yard.
        </p>
      </div>
      <div class="max-w-3xl space-y-4">
        {faqs.map((f) => (
          <details class="card p-6 group">
            <summary class="font-display text-lg font-bold text-navy cursor-pointer list-none flex justify-between items-start gap-4">
              <span>{f.q}</span>
              <span class="text-ember text-2xl leading-none group-open:rotate-45 transition-transform shrink-0">+</span>
            </summary>
            <p class="text-cast-700 leading-relaxed mt-4">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Supply-only vs Fitted -->
  <section class="container-wccp section-rhythm border-t border-cast-100">
    <FittedVsSupply
      productName="Weighbridge Bases"
      defaultMode="supply"
      supply={{
        price: 'Bespoke quote',
        leadTime: '4â€“6 weeks',
        includes: [
          'Cast deck to NMI Class III tolerances',
          'Cast-in load-cell pockets to supplier drawing',
          'Mill certs and concrete cube records',
          'Delivery on low-loader to site',
        ],
        excludes: [
          'Foundation pad and approach ramps',
          'Load cells, electronics and trade approval',
        ],
      }}
      fitted={{
        price: 'Bespoke quote (incl. install)',
        leadTime: '6â€“10 weeks (incl. site slot)',
        includes: [
          'Everything in supply only',
          '50t mobile crane lift onto pad',
          'Setting and grouting to load-cell supplier sign-off',
          '12-month workmanship warranty',
        ],
        excludes: [
          'Foundation pad civils',
          'Trade-approval testing and certification',
        ],
      }}
      note=". Bespoke deck sizes, pit-type bases and load-cell-supplier coordination priced individually â€” send the install drawing and we'll come back within a working day."
    />
  </section>

  <!-- Final CTA -->
  <section class="bg-navy text-white py-20">
    <div class="container-wccp text-center">
      <h2 class="font-display text-display-xl mb-4 text-white">Ready to spec it?</h2>
      <p class="text-white/90 text-lg max-w-xl mx-auto mb-8">
        Send us deck length, SWL, surface or pit type, and the load-cell supplier. Quote and lead-time same day.
      </p>
      <div class="flex flex-wrap justify-center gap-3">
        <a href="/quote?product=Weighbridge%20Bases" class="btn-yellow">Configure a quote</a>
        <a href={`tel:${site.contact.phoneIntl}`} class="btn-secondary">Call {site.contact.phone}</a>
        <a href={`mailto:${site.contact.quotesEmail}`} class="btn-primary">Email quotes</a>
      </div>
    </div>
  </section>

  <SpecSheetButton productSlug="weighbridge-bases" productName="Weighbridge Bases" />
  <ProductWarrantyLine />
</BaseLayout>
