---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ProductWarrantyLine from '@/components/ProductWarrantyLine.astro';
import TrustStrip from '@/components/TrustStrip.astro';
import FittedVsSupply from '@/components/FittedVsSupply.astro';
import SpecSheetButton from '@/components/SpecSheetButton.astro';
import { site } from '@/config/site';
import RelatedProductGrid from '@/components/RelatedProductGrid.astro';

// Cleanroom kits are configured to the customer's drawing — no two layouts are the same.
// What we publish is the kit components and the way they fit together.
const kit = [
  { component: 'Vertical wall panel', detail: 'Cast vertical, smooth on both inside and outside faces — durable, easy to clean' },
  { component: '90° corner panel', detail: 'Cast as a single corner unit so panels stand unsupported around the box' },
  { component: 'Straight run panels', detail: 'Slot between supporting galvanised steel posts on long straight sections' },
  { component: 'Galvanised steel posts', detail: 'Supplied with the panels for straight runs' },
  { component: 'DeLaval / Lely sumps + bases', detail: 'Robot-specific sumps and pit bases supplied alongside the cleanroom kit' },
];

const applications = [
  'New robotic milking parlour fit-outs',
  'Conversions from rotary or herringbone to robot',
  'Multi-box dairy expansion projects',
  'Milk-tanker collection room enclosures',
  'Vacuum and chiller plant-room slabs',
  'Hygiene-critical handling and treatment rooms',
  'AI / fertility lab adjuncts to the dairy',
];

const related = [
  { href: '/products/milking-robot-bases', label: 'Robot Bases', meta: 'DeLaval · Lely · GEA · BouMatic' },
  { href: '/products/cattle-cubicles', label: 'Cattle Cubicles', meta: 'AHDB 2024 sized' },
  { href: '/products/water-troughs', label: 'Water Troughs', meta: 'Single + double row' },
  { href: '/products/slurry-storage', label: 'Slurry Storage', meta: 'SSAFO 2018-compliant' },
];

const faqs = [
  { q: 'How are the clean rooms supplied?', a: 'In kit form, sized to suit the layout you want. Send us your plans and we will quote the supply of a kit to suit your requirements. The wall panels are vertically cast and smooth on both the inside and the outside — durable and easy to clean.' },
  { q: 'Do the panels need supporting posts?', a: 'It depends on the run. The wall panels can be cast with 90° corners which lets them stand unsupported. Straight sections of wall we supply with supporting galvanised steel posts.' },
  { q: 'Can you also supply the milking-equipment bases?', a: 'Yes — we can also supply sumps and bases for DeLaval and Lely milking equipment alongside the clean-room kit so it all arrives together.' },
  { q: 'What concrete grade?', a: 'C40/50 to BS 8500-1:2023, factory production control to BS EN 13369. Smooth-cast finish on both faces of the panel.' },
  { q: 'Lead time?', a: 'Once we have your plans we can quote within a working day and ship the kit on our typical agricultural lead time. Ring the yard for current capacity.' },
];

const productSchema = {
  name: 'Precast Concrete Clean Room Enclosures',
  description: 'Precast concrete clean rooms supplied in kit form to suit your layout. Vertically-cast wall panels are smooth on both inside and outside making them durable and easy to clean. 90° corner panels can stand unsupported; straight runs use galvanised supporting steel posts. Sumps and bases for DeLaval and Lely milking equipment available alongside.',
  brand: { '@type': 'Brand', name: site.name },
  manufacturer: { '@type': 'Organization', name: site.name },
  category: 'Precast concrete clean-room enclosure (kit form)',
  material: 'Reinforced concrete, C40/50 (BS 8500-1:2023)',
  additionalProperty: [
    { '@type': 'PropertyValue', name: 'Supply form', value: 'Kit — bespoke to layout' },
    { '@type': 'PropertyValue', name: 'Standard', value: 'BS EN 13369 / BS 8500-1:2023' },
    { '@type': 'PropertyValue', name: 'Wall panel', value: 'Vertically cast, smooth both faces' },
    { '@type': 'PropertyValue', name: '90° corner panels', value: 'Cast as single unit — can stand unsupported' },
    { '@type': 'PropertyValue', name: 'Straight runs', value: 'Galvanised steel posts supplied' },
    { '@type': 'PropertyValue', name: 'Robot equipment', value: 'Sumps and bases for DeLaval and Lely milking equipment available' },
    { '@type': 'PropertyValue', name: 'Country of origin', value: 'United Kingdom (Devon)' },
  ],
  offers: { '@type': 'Offer', availability: 'https://schema.org/InStock', areaServed: 'GB', seller: { '@type': 'Organization', name: site.name } },
};

const faqSchema = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) };
---

<BaseLayout
  title="Clean Rooms — robot fit-out · DeLaval · Lely · GEA · BouMatic"
  description="Cleanroom slabs and machine-pit bases for robotic milking. Tanked floor gully, integrated drainage. Compatible with DeLaval, Lely, GEA and BouMatic. Cast in North Devon."
  image="/og/clean-rooms.png"
  schema="Product"
  schemaData={productSchema}
  whatsappContext="Clean Rooms"
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)} slot="head" />
  <TrustStrip />

  <section class="bg-navy text-white">
    <div class="container-wccp py-16 md:py-20">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <p class="eyebrow text-yellow mb-4">Agricultural · robotic dairy · parlour fit-out</p>
          <h1 class="font-display text-display-xl text-white mb-4">Clean Rooms.</h1>
          <p class="font-display italic text-xl md:text-2xl text-yellow leading-tight mb-5">
            Kit form. Smooth both faces. Cast to your layout.
          </p>
          <h2 class="sr-only">What's a precast clean-room enclosure?</h2>
          <blockquote class="font-display italic text-base md:text-lg text-white/95 leading-relaxed mb-6 pl-4 border-l-2 border-yellow max-w-xl">
            <strong class="not-italic text-white">What's a precast clean-room enclosure?</strong>
            Vertically-cast wall panels supplied in kit form to suit the layout you want.
            Smooth on both inside and outside — durable and easy to clean. 90° corner panels
            stand unsupported; straight runs use galvanised steel posts.
          </blockquote>
          <p class="text-base text-white/85 leading-relaxed mb-6 max-w-xl">
            Send us the plans for your robot box and we will quote a kit of vertical wall
            panels and corner units to suit. Sumps and bases for DeLaval and Lely milking
            equipment available alongside.
          </p>
          <ul class="grid grid-cols-2 gap-3 text-sm mb-8 max-w-md">
            <li class="flex gap-2"><span class="text-yellow">·</span> Kit form</li>
            <li class="flex gap-2"><span class="text-yellow">·</span> Smooth both faces</li>
            <li class="flex gap-2"><span class="text-yellow">·</span> 90° corner panels</li>
            <li class="flex gap-2"><span class="text-yellow">·</span> Galvanised posts</li>
            <li class="flex gap-2"><span class="text-yellow">·</span> DeLaval / Lely sumps</li>
            <li class="flex gap-2"><span class="text-yellow">·</span> Cast to your drawing</li>
          </ul>
          <div class="flex flex-wrap gap-3">
            <a href="/quote?product=Clean%20Rooms" class="btn-primary">Configure a quote</a>
            <a href="mailto:engineering@wccp.co.uk?subject=Spec%20sheet%20request%20%E2%80%94%20Clean%20Rooms&amp;body=Hi%20WCCP%20engineering%2C%0A%0APlease%20send%20the%20spec%20sheet%20for%20Clean%20Rooms.%0A%0AProject%20details%3A%0A%E2%80%A2%20Project%20name%3A%0A%E2%80%A2%20Site%20location%3A%0A%E2%80%A2%20Required%20spec%20%2F%20standard%3A%0A%0AThanks" class="btn-yellow">Request spec sheet</a>
            <a href={`tel:${site.contact.phoneIntl}`} class="btn-ghost border-white text-white hover:bg-white hover:text-navy">Call {site.contact.phone}</a>
          </div>
        </div>
        <div class="aspect-[4/3] bg-cast-100 rounded overflow-hidden"><img src="/images/products/clean-rooms.jpg" alt="Precast concrete clean room slab for robotic milking parlour" class="w-full h-full object-cover" loading="eager" decoding="async" /></div>
      </div>
    </div>
  </section>

  <section class="container-wccp py-20">
    <div class="max-w-2xl mb-10">
      <p class="eyebrow text-cast mb-3">What's in the kit</p>
      <h2 class="font-display text-display-lg mb-4">Kit components.</h2>
      <p class="text-cast-700 text-lg">Each clean-room kit is configured to your drawing — no two layouts are the same. These are the components we cast and supply.</p>
    </div>
    <div class="overflow-x-auto">
      <table class="spec-table w-full text-left border-collapse">
        <thead class="bg-navy text-white">
          <tr>
            <th class="px-4 py-3 font-display text-sm uppercase tracking-wide">Component</th>
            <th class="px-4 py-3 font-display text-sm uppercase tracking-wide">Detail</th>
          </tr>
        </thead>
        <tbody>
          {kit.map((s, i) => (
            <tr class={i % 2 === 0 ? 'bg-white' : 'bg-bone-200'}>
              <td class="px-4 py-3 font-bold text-navy">{s.component}</td>
              <td class="px-4 py-3 text-cast">{s.detail}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    <p class="text-cast text-sm mt-4">Send us your robot-box and parlour layout drawing and we will quote a complete kit. We can also supply DeLaval and Lely sumps and bases alongside.</p>
  </section>

  <section class="bg-bone-200 py-12">
    <div class="container-wccp">
      <p class="eyebrow text-cast mb-3">On-farm</p>
      <h2 class="font-display text-display-md mb-6">Clean rooms in service.</h2>
      <div class="grid md:grid-cols-2 gap-4">
        <img src="/images/products/clean-rooms/wccp-clean-room-enclosures-20120831-084144-1024x768.jpg" alt="WCCP precast concrete clean room enclosure installed on a Devon dairy with smooth-cast vertical wall panels" class="w-full h-auto rounded" loading="lazy" decoding="async" />
        <img src="/images/products/clean-rooms/wccp-clean-room-enclosures-20130626-160926-1024x768.jpg" alt="Precast concrete clean room kit assembled on-farm by WCCP, vertical panels with galvanised supporting posts on the straight run" class="w-full h-auto rounded" loading="lazy" decoding="async" />
      </div>
    </div>
  </section>

  <section class="bg-bone-200 py-20">
    <div class="container-wccp">
      <div class="grid lg:grid-cols-2 gap-12">
        <div>
          <p class="eyebrow text-cast mb-3">Where they go</p>
          <h2 class="font-display text-display-lg mb-6">Common applications.</h2>
          <p class="text-cast-700 text-lg leading-relaxed mb-6">From a single-box first install to a six-box expansion — the cleanroom slab and machine pit cast as matched sets with the robot base.</p>
          <ul class="space-y-3">
            {applications.map((a) => (<li class="flex gap-3 text-cast-700 leading-relaxed"><span class="text-ember font-bold mt-1">·</span><span>{a}</span></li>))}
          </ul>
        </div>
        <div class="card p-8">
          <p class="eyebrow text-cast mb-3">Standards & references</p>
          <h3 class="font-display text-2xl font-bold text-navy mb-4">Cast for the parlour environment.</h3>
          <dl class="space-y-4 text-sm">
            <div><dt class="font-bold text-navy">BS EN 13369</dt><dd class="text-cast">Common rules for precast concrete — factory production control.</dd></div>
            <div><dt class="font-bold text-navy">BS 8500-1:2023</dt><dd class="text-cast">Concrete spec — C40/50 designed mix for the wash-down environment.</dd></div>
            <div><dt class="font-bold text-navy">BS 5502-22:2003</dt><dd class="text-cast">Agricultural buildings — milking parlour design and detailing.</dd></div>
            <div><dt class="font-bold text-navy">Manufacturer install packs</dt><dd class="text-cast">DeLaval, Lely, GEA, BouMatic — published pour tolerances followed exactly.</dd></div>
            <div><dt class="font-bold text-navy">BS EN 1992 (Eurocode 2)</dt><dd class="text-cast">Concrete structural design — slab, gully and pit calculation.</dd></div>
          </dl>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-yellow text-navy py-16">
    <div class="container-wccp">
      <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6">
        <div>
          <p class="eyebrow text-navy mb-2">Configure your cleanroom</p>
          <h2 class="font-display text-display-md">Send robot brand, box count and shed drawing — we will quote inside 24 hours.</h2>
        </div>
        <div class="flex flex-wrap gap-3 shrink-0">
          <a href="/quote?product=Clean%20Rooms" class="btn bg-navy text-white hover:bg-navy-700">Open the configurator</a>
          <a href={`mailto:${site.contact.quotesEmail}`} class="btn-secondary">Email quotes</a>
        </div>
      </div>
    </div>
  </section>

  <section class="container-wccp py-20">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between mb-10 gap-4">
      <div>
        <p class="eyebrow text-cast mb-3">Related products</p>
        <h2 class="font-display text-display-lg">Often ordered alongside.</h2>
      </div>
      <a href="/products" class="text-ember font-bold hover:text-ember-700 inline-flex items-center gap-2">View full range
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12" stroke-linecap="round" /><polyline points="12 5 19 12 12 19" stroke-linecap="round" stroke-linejoin="round" /></svg>
      </a>
    </div>
    <RelatedProductGrid items={related} />
  </section>

  <section class="bg-bone-200 py-20">
    <div class="container-wccp">
      <div class="max-w-2xl mb-12">
        <p class="eyebrow text-cast mb-3">Common questions</p>
        <h2 class="font-display text-display-lg mb-4">What people ask about cleanrooms.</h2>
        <p class="text-cast-700 text-lg">Five questions we answer most weeks. If yours is not here, ring the yard.</p>
      </div>
      <div class="max-w-3xl space-y-4">
        {faqs.map((f) => (
          <details class="card p-6 group">
            <summary class="font-display text-lg font-bold text-navy cursor-pointer list-none flex justify-between items-start gap-4">
              <span>{f.q}</span>
              <span class="text-ember text-2xl leading-none group-open:rotate-45 transition-transform shrink-0">+</span>
            </summary>
            <p class="text-cast-700 leading-relaxed mt-4">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Supply-only vs Fitted -->
  <section class="container-wccp section-rhythm border-t border-cast-100">
    <FittedVsSupply
      productName="Clean Rooms"
      defaultMode="fitted"
      supply={{
        price: 'Bespoke quote',
        leadTime: 'Quoted with kit',
        includes: [
          'Vertically-cast wall panels (smooth both faces)',
          '90° corner panels for unsupported corners',
          'Galvanised supporting steel posts for straight runs',
          'Delivery on our HIAB to your shed',
        ],
        excludes: [
          'On-site setting and bedding mortar',
          'Robot supply, plumbing and electrical fit-out',
          'Sumps and milking-equipment bases (priced separately)',
        ],
      }}
      fitted={{
        price: 'Bespoke quote (incl. install)',
        leadTime: 'Quoted with kit',
        includes: [
          'Everything in supply only',
          'Install crew with HIAB to set the kit',
          'Setting to drawing tolerance',
          '12-month workmanship warranty',
        ],
        excludes: [
          'Excavation and sub-base preparation',
          'Mechanical, electrical and chiller plant',
        ],
      }}
      note="Every clean-room kit is sized to your robot-box layout. Send the drawing — we will quote inside a working day."
    />
  </section>

  <section class="bg-navy text-white py-20">
    <div class="container-wccp text-center">
      <h2 class="font-display text-display-xl mb-4 text-white">Ready to spec it?</h2>
      <p class="text-white/90 text-lg max-w-xl mx-auto mb-8">Send the robot brand and box count and the shed drawing. Quote and lead-time same day.</p>
      <div class="flex flex-wrap justify-center gap-3">
        <a href="/quote?product=Clean%20Rooms" class="btn-yellow">Configure a quote</a>
        <a href={`tel:${site.contact.phoneIntl}`} class="btn-secondary">Call {site.contact.phone}</a>
        <a href={`mailto:${site.contact.quotesEmail}`} class="btn-primary">Email quotes</a>
      </div>
    </div>
  </section>

  <SpecSheetButton productSlug="clean-rooms" productName="Clean Rooms" />
  <ProductWarrantyLine />
</BaseLayout>
