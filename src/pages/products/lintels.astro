---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ProductWarrantyLine from '@/components/ProductWarrantyLine.astro';
import TrustStrip from '@/components/TrustStrip.astro';
import FittedVsSupply from '@/components/FittedVsSupply.astro';
import SpecSheetButton from '@/components/SpecSheetButton.astro';
import ProductGallery from '@/components/ProductGallery.astro';
import { site } from '@/config/site';
import RelatedProductGrid from '@/components/RelatedProductGrid.astro';
import ProductPageTOC from '@/components/ProductPageTOC.astro';

const tocSections = [
  { id: 'overview', label: 'Overview' },
  { id: 'specifications', label: 'Specifications' },
  { id: 'gallery', label: 'Gallery' },
  { id: 'related', label: 'Related' },
  { id: 'faq', label: 'FAQ' },
  { id: 'downloads', label: 'Downloads' },
];

// WCCP precast concrete lintels — heritage, architectural, BS 5977.
const specs = [
  { variant: 'Standard prestressed lintel', bed: '100 × 65mm to 215 × 145mm × spans to 4m', style: 'BS 5977-1 prestressed · 7-wire strand', use: 'Domestic openings, internal partitions' },
  { variant: 'Reinforced architectural lintel', bed: '215 × 100mm to 325 × 215mm × spans to 6m', style: 'BS 5977-1 reinforced · B500B steel', use: 'Heritage windows, conservation rebuilds' },
  { variant: 'Boot lintel (composite)', bed: 'L-section · spans to 5m', style: 'BS 5977-2 cavity wall · weather check', use: 'Cavity-wall openings with brick reveal' },
  { variant: 'Bullnose moulded lintel', bed: 'To architect\'s drawing · spans to 4m', style: 'Cast-stone effect · bullnose nosing', use: 'Period properties, listed-building work' },
  { variant: 'Splay-stop architectural', bed: 'To drawing · spans to 4m', style: 'Splay end-stops · matched to opening', use: 'Georgian / Victorian sash windows' },
  { variant: 'Bespoke heritage profile', bed: 'To stonemason\'s drawing', style: 'Reinforced + cast-finish · matched stone', use: 'Listed buildings, conservation areas' },
];

const applications = [
  'Domestic and commercial window and door openings',
  'Heritage and conservation rebuilds — listed buildings',
  'Period property restoration and matching',
  'Cavity-wall construction with weather-check boot lintels',
  'Architectural-finish openings on premium housing',
  'Self-build and bespoke architect-specified projects',
  'Stable-block and agricultural-building openings',
];

const related = [
  { href: '/products/padstones', label: 'Padstones', meta: 'Cast bearing pads · steel beam supports' },
  { href: '/products/l-blocks', label: 'L-Blocks', meta: 'Modular bay walls and divisions' },
  { href: '/products/retaining-walls', label: 'Retaining Walls', meta: 'L-shape and counterfort civils' },
  { href: '/products/interlocking-blocks', label: 'Interlocking Blocks', meta: 'Lego-style temporary walls' },
];

const faqs = [
  { q: 'What standard do your lintels meet?', a: 'BS 5977-1:1981 — code of practice for design of lintels — and BS EN 845-2:2013 (specification for ancillary components for masonry — lintels). Cast in C40/50 concrete to BS 8500-1:2023, with B500B reinforcement designed to BS EN 1992 (Eurocode 2) or 7-wire prestressing strand to BS EN 10138-3 for prestressed types. UKCA marked, factory-production-controlled to BS EN 13369.' },
  { q: 'Heritage and listed-building work — can you match existing?', a: 'Yes — heritage and listed-building lintels are a core part of what we cast at Holsworthy. Send us the stonemason\'s drawing or a photo with measurements and we will match the bullnose, splay or moulded profile in cast concrete with a stone-effect finish. We work with conservation officers across the South West regularly. Pigments, exposed-aggregate finishes and bespoke moulds all available.' },
  { q: 'Boot lintels for cavity walls — how do they work?', a: 'A boot lintel is an L-section composite cast that supports the inner blockwork on the horizontal leg, while the vertical leg forms the brick reveal of the cavity wall and integrates with the DPC tray. We supply the boot to BS 5977-2 with the weather-check detail cast in. Typical use is on cavity-wall openings up to 5m where steel lintels would be too deep or where a clean cast finish is wanted.' },
  { q: 'How are they sized?', a: 'For domestic openings up to 1.8m our standard 100 × 65mm prestressed lintel takes most loads. For larger openings, masonry above and openings carrying steelwork, send us the load take-down and we will size against BS 5977-1. The catalogue covers 100mm wide for 100mm cavities up to 215mm wide for solid-wall heritage work — bespoke widths cast to drawing.' },
  { q: 'What is the lead time?', a: 'Catalogue prestressed and reinforced lintels ship in 2 to 3 weeks. Heritage and bespoke architectural profiles run 4 to 6 weeks given the bespoke mould. Listed-building rebuilds with multiple matched lintels typically run 6 to 8 weeks — engage us at the planning consent stage.' },
];

const productSchema = {
  name: 'Precast Concrete Lintels',
  description: 'Precast concrete lintels for heritage, architectural and standard openings to BS 5977. Prestressed, reinforced, boot and bespoke heritage profiles. Cast in C40/50 concrete at our Holsworthy yard.',
  brand: { '@type': 'Brand', name: site.name },
  manufacturer: { '@type': 'Organization', name: site.name },
  category: 'Precast concrete lintel',
  material: 'Reinforced or prestressed concrete, C40/50 (BS 8500-1:2023)',
  additionalProperty: [
    { '@type': 'PropertyValue', name: 'Standard', value: 'BS 5977-1:1981 · BS EN 845-2:2013' },
    { '@type': 'PropertyValue', name: 'Concrete grade', value: 'C40/50 (BS 8500-1:2023)' },
    { '@type': 'PropertyValue', name: 'Reinforcement', value: 'B500B (BS 4449) or 7-wire strand (BS EN 10138-3)' },
    { '@type': 'PropertyValue', name: 'Variants', value: 'Prestressed / reinforced / boot / heritage / bespoke' },
    { '@type': 'PropertyValue', name: 'Span range', value: 'Up to 6m standard, larger on request' },
    { '@type': 'PropertyValue', name: 'Width range', value: '100mm to 325mm' },
    { '@type': 'PropertyValue', name: 'Heritage finishes', value: 'Bullnose, splay, moulded, cast-stone effect' },
    { '@type': 'PropertyValue', name: 'Factory production control', value: 'BS EN 13369 · UKCA marked' },
    { '@type': 'PropertyValue', name: 'Lead time', value: '2–3 weeks catalogue, 4–6 weeks bespoke' },
    { '@type': 'PropertyValue', name: 'Country of origin', value: 'United Kingdom (Devon)' },
  ],
  offers: { '@type': 'Offer', availability: 'https://schema.org/InStock', areaServed: 'GB', seller: { '@type': 'Organization', name: site.name } },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<BaseLayout
  title="Lintels — BS 5977 · Heritage, Architectural, Prestressed"
  description="Precast concrete lintels to BS 5977. Heritage, architectural and standard prestressed types. Bullnose, splay and moulded profiles for listed buildings. Cast in North Devon."
  image="/og-default.png"
  schema="Product"
  schemaData={productSchema}
  whatsappContext="Lintels"
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)} slot="head" />
  <TrustStrip />
  <ProductPageTOC sections={tocSections} />

  <!-- Hero -->
  <section id="overview" class="bg-navy text-white">
    <div class="container-wccp py-16 md:py-20">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <p class="eyebrow text-yellow mb-4">Civils · heritage · architectural</p>
          <h1 class="font-display text-display-xl text-white mb-4">Lintels.</h1>
          <p class="font-display italic text-xl md:text-2xl text-yellow leading-tight mb-5">Cast for the opening. Matched to the stone.</p>
          <p class="text-lg lg:text-xl text-cast leading-relaxed font-medium text-white/95 mb-6 max-w-xl">
            Precast concrete lintels to BS 5977 — prestressed, reinforced, boot and bespoke
            heritage profiles. Bullnose, splay and moulded finishes for listed-building rebuilds
            and conservation work. C40/50 concrete to BS 8500-1:2023, designed to BS EN 1992
            (Eurocode 2). UKCA marked. Catalogue lead time 2–3 weeks.
          </p>
          <blockquote class="font-display italic text-base md:text-lg text-white/95 leading-relaxed mb-6 pl-4 border-l-2 border-yellow max-w-xl">
            A heritage bullnose lintel cast to BS 5977-1 with a matched stone-effect finish
            satisfies the listed-building consent for like-for-like replacement on a Grade
            II rebuild — designed to BS EN 1992, sized to the opening and the load take-down.
          </blockquote>
          <p class="text-base text-white/85 leading-relaxed mb-6 max-w-xl">
            Standard prestressed for the housebuilder. Bespoke heritage and architectural
            profiles for the conservation specialist. Cast at Holsworthy, delivered UK-wide.
          </p>
          <ul class="grid grid-cols-2 gap-3 text-sm mb-8 max-w-md">
            <li class="flex gap-2"><span class="text-yellow">·</span> BS 5977</li>
            <li class="flex gap-2"><span class="text-yellow">·</span> Up to 6m span</li>
            <li class="flex gap-2"><span class="text-yellow">·</span> Heritage profiles</li>
            <li class="flex gap-2"><span class="text-yellow">·</span> Boot + standard</li>
            <li class="flex gap-2"><span class="text-yellow">·</span> UKCA marked</li>
            <li class="flex gap-2"><span class="text-yellow">·</span> 2–6 week lead</li>
          </ul>
          <div class="flex flex-wrap gap-3">
            <a href="/quote?product=Lintels" class="btn-primary">Configure a quote</a>
            <a href="mailto:engineering@wccp.co.uk?subject=Spec%20sheet%20request%20%E2%80%94%20Lintels&amp;body=Hi%20WCCP%20engineering%2C%0A%0APlease%20send%20the%20spec%20sheet%20for%20Lintels.%0A%0AProject%20details%3A%0A%E2%80%A2%20Project%20name%3A%0A%E2%80%A2%20Site%20location%3A%0A%E2%80%A2%20Required%20spec%20%2F%20standard%3A%0A%0AThanks" class="btn-yellow">Request spec sheet</a>
            <a href={`tel:${site.contact.phoneIntl}`} class="btn-ghost border-white text-white hover:bg-white hover:text-navy">
              Call {site.contact.phone}
            </a>
          </div>
        </div>
        <div class="aspect-[4/3] bg-cast-100 rounded overflow-hidden flex items-center justify-center border-2 border-dashed border-cast-300 p-8 text-center">
          <div>
            <p class="text-cast-600 text-sm font-mono">📷 Photo needed</p>
            <p class="text-cast text-xs mt-2">Hero shot: bullnose heritage lintel on a heritage cottage rebuild in Devon, set above a sash window opening with stone surround</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Spec table -->
  <section class="container-wccp py-20">
    <div class="max-w-2xl mb-10">
      <p class="eyebrow text-cast mb-3">Specification</p>
      <h2 class="font-display text-display-lg mb-4">Profiles, sizes and uses.</h2>
      <p class="text-cast-700 text-lg">
        Six catalogue families covering domestic openings to listed-building heritage work.
        Bespoke moulds for matched conservation profiles cast on order — send the
        stonemason's drawing or a measured photo and we will match.
      </p>
    </div>

    <div class="overflow-x-auto">
      <table class="spec-table w-full text-left border-collapse">
        <thead class="bg-navy text-white">
          <tr>
            <th class="px-4 py-3 font-display text-sm uppercase tracking-wide">Variant</th>
            <th class="px-4 py-3 font-display text-sm uppercase tracking-wide">Size / span</th>
            <th class="px-4 py-3 font-display text-sm uppercase tracking-wide">Standard / style</th>
            <th class="px-4 py-3 font-display text-sm uppercase tracking-wide">Typical use</th>
          </tr>
        </thead>
        <tbody>
          {specs.map((s, i) => (
            <tr class={i % 2 === 0 ? 'bg-white' : 'bg-bone-200'}>
              <td class="px-4 py-3 font-bold text-navy">{s.variant}</td>
              <td class="px-4 py-3">{s.bed}</td>
              <td class="px-4 py-3">{s.style}</td>
              <td class="px-4 py-3 text-cast">{s.use}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    <p class="text-cast text-sm mt-4">
      All lintels UKCA marked, factory production controlled to BS EN 13369. Mill certs and
      load tables supplied with the spec sheet.
    </p>

    <p class="text-cast text-sm mt-4">
      For heritage and listed-building work we cast bespoke moulds in-house — send the
      stonemason's drawing or a measured photo and we will match bullnose, splay or moulded
      profile with a stone-effect finish.
    </p>
  </section>

  <ProductGallery
    eyebrow="The range"
    heading="Lintels in service."
    background="bone"
    cols={4}
    images={[
      { src: '', alt: 'Prestressed lintel stockpile', caption: 'Stockpile · standard prestressed lintels banded for delivery' },
      { src: '', alt: 'Heritage bullnose lintel', caption: 'Heritage · bullnose lintel above sash window on listed building' },
      { src: '', alt: 'Boot lintel cavity wall', caption: 'Boot lintel · L-section composite for cavity-wall opening' },
      { src: '', alt: 'Splay end-stop architectural', caption: 'Splay end-stop · architectural profile for Georgian opening' },
      { src: '', alt: 'Moulded heritage profile', caption: 'Moulded · cast-stone effect heritage profile, listed-building rebuild' },
      { src: '', alt: 'Bespoke heritage casting', caption: 'Bespoke mould · cast in-house at Holsworthy for matched profile' },
      { src: '', alt: 'Lintel install opening', caption: 'Install · lintel being set above brick opening on housing site' },
      { src: '', alt: 'Conservation cottage rebuild', caption: 'Conservation · matched lintels on Devon cottage rebuild' },
    ]}
  />

  <!-- Applications -->
  <section class="bg-white py-20">
    <div class="container-wccp">
      <div class="grid lg:grid-cols-2 gap-12">
        <div>
          <p class="eyebrow text-cast mb-3">Where they go</p>
          <h2 class="font-display text-display-lg mb-6">Common applications.</h2>
          <p class="text-cast-700 text-lg leading-relaxed mb-6">
            From a 1.2m prestressed lintel on a Devon new-build to a bespoke matched bullnose
            on a Grade II conservation rebuild in Cornwall, we cast and deliver to the same
            engineered standard — sized to the opening, finished to the spec.
          </p>
          <ul class="space-y-3">
            {applications.map((a) => (
              <li class="flex gap-3 text-cast-700 leading-relaxed">
                <span class="text-ember font-bold mt-1">·</span>
                <span>{a}</span>
              </li>
            ))}
          </ul>
        </div>

        <div class="card p-8">
          <p class="eyebrow text-cast mb-3">Standards & references</p>
          <h3 class="font-display text-2xl font-bold text-navy mb-4">Cast and certified to current code.</h3>
          <dl class="space-y-4 text-sm">
            <div>
              <dt class="font-bold text-navy">BS 5977-1:1981</dt>
              <dd class="text-cast">Code of practice for design of lintels — sizing, loading and detailing.</dd>
            </div>
            <div>
              <dt class="font-bold text-navy">BS EN 845-2:2013</dt>
              <dd class="text-cast">Specification for ancillary components for masonry — lintels and bed joint reinforcement.</dd>
            </div>
            <div>
              <dt class="font-bold text-navy">BS 8500-1:2023</dt>
              <dd class="text-cast">Concrete specification — C40/50 mix designed for exposure class XC3.</dd>
            </div>
            <div>
              <dt class="font-bold text-navy">BS EN 1992 / Eurocode 2</dt>
              <dd class="text-cast">Design of concrete structures — reinforcement detailing and durability.</dd>
            </div>
            <div>
              <dt class="font-bold text-navy">BS EN 10138-3</dt>
              <dd class="text-cast">Prestressing steels — 7-wire strand for prestressed lintels.</dd>
            </div>
            <div>
              <dt class="font-bold text-navy">BS EN 13369</dt>
              <dd class="text-cast">Common rules for precast concrete products — factory production control.</dd>
            </div>
          </dl>
        </div>
      </div>
    </div>
  </section>

  <!-- Configurator CTA -->
  <section class="bg-yellow text-navy py-16">
    <div class="container-wccp">
      <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6">
        <div>
          <p class="eyebrow text-navy mb-2">Configure your lintel order</p>
          <h2 class="font-display text-display-md">Send us the opening sizes, load take-down and finish — we will quote inside 24 hours.</h2>
        </div>
        <div class="flex flex-wrap gap-3 shrink-0">
          <a href="/quote?product=Lintels" class="btn bg-navy text-white hover:bg-navy-700">Open the configurator</a>
          <a href={`mailto:${site.contact.quotesEmail}`} class="btn-secondary">Email quotes</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Related -->
  <section class="container-wccp py-20">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between mb-10 gap-4">
      <div>
        <p class="eyebrow text-cast mb-3">Related products</p>
        <h2 class="font-display text-display-lg">Often ordered alongside.</h2>
      </div>
      <a href="/products" class="text-ember font-bold hover:text-ember-700 inline-flex items-center gap-2">
        View full range
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <line x1="5" y1="12" x2="19" y2="12" stroke-linecap="round" />
          <polyline points="12 5 19 12 12 19" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </a>
    </div>
    <RelatedProductGrid items={related} />
  </section>

  <!-- FAQ -->
  <section id="faq" class="bg-bone-200 py-20">
    <div class="container-wccp">
      <div class="max-w-2xl mb-12">
        <p class="eyebrow text-cast mb-3">Common questions</p>
        <h2 class="font-display text-display-lg mb-4">What people ask about lintels.</h2>
        <p class="text-cast-700 text-lg">
          Five questions we answer most weeks. If yours is not here, ring the yard.
        </p>
      </div>
      <div class="max-w-3xl space-y-4">
        {faqs.map((f) => (
          <details class="card p-6 group">
            <summary class="font-display text-lg font-bold text-navy cursor-pointer list-none flex justify-between items-start gap-4">
              <span>{f.q}</span>
              <span class="text-ember text-2xl leading-none group-open:rotate-45 transition-transform shrink-0">+</span>
            </summary>
            <p class="text-cast-700 leading-relaxed mt-4">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Supply-only vs Fitted -->
  <section class="container-wccp section-rhythm border-t border-cast-100">
    <FittedVsSupply
      productName="Lintels"
      defaultMode="supply"
      supply={{
        price: 'Bespoke quote',
        leadTime: '2–6 weeks',
        includes: [
          'BS 5977 lintels to specified profile',
          'Bespoke heritage moulds where specified',
          'UKCA mill certs and load tables',
          'Delivery to site by HIAB or flat-bed',
        ],
        excludes: [
          'Setting and bedding into masonry',
          'Wallwork above and below',
        ],
      }}
      fitted={{
        price: 'Available on bespoke heritage projects',
        leadTime: '6–10 weeks (incl. site slot)',
        includes: [
          'Everything in supply only',
          'Bedding into existing masonry',
          'Conservation-officer liaison if required',
          '12-month workmanship warranty',
        ],
        excludes: [
          'Surrounding structural and weatherproofing works',
          'Scaffolding and access',
        ],
      }}
      note=". Bespoke heritage profiles, listed-building rebuilds and architect-specified runs priced individually — send the drawing or measured photo and we'll come back within a working day."
    />
  </section>

  <!-- Final CTA -->
  <section class="bg-navy text-white py-20">
    <div class="container-wccp text-center">
      <h2 class="font-display text-display-xl mb-4 text-white">Ready to spec it?</h2>
      <p class="text-white/90 text-lg max-w-xl mx-auto mb-8">
        Send us opening sizes, load take-down and finish requirement. Quote and lead-time same day.
      </p>
      <div class="flex flex-wrap justify-center gap-3">
        <a href="/quote?product=Lintels" class="btn-yellow">Configure a quote</a>
        <a href={`tel:${site.contact.phoneIntl}`} class="btn-secondary">Call {site.contact.phone}</a>
        <a href={`mailto:${site.contact.quotesEmail}`} class="btn-primary">Email quotes</a>
      </div>
    </div>
  </section>

  <SpecSheetButton productSlug="lintels" productName="Lintels" />
  <ProductWarrantyLine />
</BaseLayout>
