---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TrustStrip from '@/components/TrustStrip.astro';
import { site } from '@/config/site';

const specs = [
  { type: 'Standard double', size: '1600 × 800 × 800mm', weight: '1,485 kg', interlock: 'Twin lug + recess', use: 'Standard storage bays, push walls' },
  { type: 'Standard single', size: '800 × 800 × 800mm', weight: '745 kg', interlock: 'Single lug + recess', use: 'Half-block infill, corners' },
  { type: 'Bottom (no lug)', size: '1600 × 800 × 800mm', weight: '1,485 kg', interlock: 'Recess only (top course)', use: 'Top of finished wall' },
  { type: 'Top (no recess)', size: '1600 × 800 × 800mm', weight: '1,485 kg', interlock: 'Lugs only (base course)', use: 'Bottom of stack' },
  { type: 'Half-height', size: '1600 × 800 × 400mm', weight: '745 kg', interlock: 'Twin lug + recess', use: 'Stepping down, course adjustment' },
  { type: 'Quarter-height', size: '1600 × 800 × 200mm', weight: '370 kg', interlock: 'Twin lug + recess', use: 'Final levelling course' },
];

const applications = [
  'Instant boundary walls and security screens',
  'Silage clamp side walls (stack to suit height)',
  'Bulk-aggregate, grain and biomass storage bays',
  'Push walls for waste-transfer and recycling',
  'Temporary site separation and counter-terror barriers',
  'Flood-defence barriers and bund walls',
  'Stack-and-go fertiliser, salt and gritter stores',
];

const related = [
  { href: '/products/l-blocks', label: 'L-Block Retaining', meta: '1m–6m heights' },
  { href: '/products/silage-clamp-walls', label: 'Silage Clamp Walls', meta: 'C40/50 sulphate-resisting' },
  { href: '/products/bespoke', label: 'Bespoke Precast', meta: 'Custom moulds' },
  { href: '/products/retaining-walls', label: 'All Retaining', meta: 'Family hub' },
];

const faqs = [
  { q: 'How tall can I stack them?', a: 'A free-standing wall of standard 1600×800×800mm blocks is good to 4 courses (3.2m) in most applications without a tieback. Higher stacks need engineering — we can supply a tied-back design or a wider footprint with two-row blocks below the third course.' },
  { q: 'How heavy are they?', a: 'The standard double block at 1600 × 800 × 800mm is 1,485kg. A 16-tonne teleporter handles them comfortably. Single 800 × 800 × 800 blocks at 745kg lift on a smaller machine.' },
  { q: 'Do they need a foundation?', a: 'Just a flat compacted MOT Type 1 base, 200mm thick. The blocks are heavy enough that overturning is not the issue at typical wall heights — it is the bearing. Soft ground gets a wider base.' },
  { q: 'Are they Beton-style?', a: 'Yes — twin-lug pattern compatible with the common European interlocking block. We can interlock with most other manufacturers\' blocks where the lug pitch matches; ring before mixing.' },
  { q: 'Lead time?', a: 'Catalogue blocks ship in 2 to 4 weeks. Stock often available for the standard double — ring the yard for current availability. Painted blocks (a popular ask for boundary walls) run 4 to 6 weeks.' },
];

const productSchema = {
  name: 'Interlocking Precast Concrete Blocks (Beton-style)',
  description: 'Stackable interlocking precast concrete blocks with twin-lug top and recess base. Standard 1600×800×800mm at 1485kg. Single, half-height and quarter-height variants. For instant walls, storage bays and barriers.',
  brand: { '@type': 'Brand', name: site.name },
  manufacturer: { '@type': 'Organization', name: site.name },
  category: 'Interlocking precast concrete block',
  material: 'Reinforced concrete, C40/50 (BS 8500-1:2023)',
  weight: { '@type': 'QuantitativeValue', minValue: 370, maxValue: 1485, unitCode: 'KGM', unitText: 'kilogram per block' },
  additionalProperty: [
    { '@type': 'PropertyValue', name: 'Standard', value: 'BS EN 13369' },
    { '@type': 'PropertyValue', name: 'Concrete grade', value: 'C40/50 (BS 8500-1:2023)' },
    { '@type': 'PropertyValue', name: 'Standard double size', value: '1600 × 800 × 800 mm, 1485 kg' },
    { '@type': 'PropertyValue', name: 'Interlock', value: 'Twin-lug top + recess base (Beton-style)' },
    { '@type': 'PropertyValue', name: 'Maximum unsupported height', value: '4 courses (3.2 m) typical' },
    { '@type': 'PropertyValue', name: 'Foundation', value: '200mm compacted MOT Type 1' },
    { '@type': 'PropertyValue', name: 'Lead time', value: '2–4 weeks (stock often available)' },
    { '@type': 'PropertyValue', name: 'Country of origin', value: 'United Kingdom (Devon)' },
  ],
  offers: { '@type': 'Offer', priceCurrency: 'GBP', availability: 'https://schema.org/InStock', seller: { '@type': 'Organization', name: site.name } },
};

const faqSchema = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) };
---

<BaseLayout
  title="Interlocking Blocks — Beton-style 1600×800×800mm"
  description="Stackable interlocking precast blocks. Standard 1600×800×800mm at 1485kg. Twin-lug Beton-style. Stack like Lego for instant walls, bays and barriers. Cast in North Devon."
  image="/images/products/interlocking-blocks.jpg"
  schema="Product"
  schemaData={productSchema}
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)} slot="head" />
  <TrustStrip />

  <section class="bg-navy text-white">
    <div class="container-wccp py-16 md:py-20">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <p class="eyebrow text-yellow mb-4">Civils · agricultural · storage</p>
          <h1 class="font-display text-display-xl text-white mb-4">Interlocking Blocks.</h1>
          <p class="text-lg text-white/90 leading-relaxed mb-6">
            Stackable Beton-style interlocking blocks. Standard 1600 × 800 × 800mm doubles at 1,485kg
            with twin-lug top and recessed base. Stack them like Lego for instant walls, storage bays
            or push walls — no mortar, no foundation strip, no design fee.
          </p>
          <ul class="grid grid-cols-2 gap-3 text-sm mb-8 max-w-md">
            <li class="flex gap-2"><span class="text-yellow">·</span> 1600×800×800mm</li>
            <li class="flex gap-2"><span class="text-yellow">·</span> 1,485 kg standard</li>
            <li class="flex gap-2"><span class="text-yellow">·</span> Twin-lug interlock</li>
            <li class="flex gap-2"><span class="text-yellow">·</span> Up to 4 courses</li>
            <li class="flex gap-2"><span class="text-yellow">·</span> No mortar needed</li>
            <li class="flex gap-2"><span class="text-yellow">·</span> 2–4 week lead</li>
          </ul>
          <div class="flex flex-wrap gap-3">
            <a href="/quote?product=Interlocking+Blocks" class="btn-primary">Configure a quote</a>
            <a href="/spec-sheets/interlocking-blocks.pdf" class="btn-yellow">Download spec sheet</a>
            <a href={`tel:${site.contact.phoneIntl}`} class="btn-ghost border-white text-white hover:bg-white hover:text-navy">Call {site.contact.phone}</a>
          </div>
        </div>
        <div class="aspect-[4/3] bg-cast-100 rounded overflow-hidden"><div class="w-full h-full bg-gradient-to-br from-cast-300 via-cast to-navy"></div></div>
      </div>
    </div>
  </section>

  <section class="container-wccp py-20">
    <div class="max-w-2xl mb-10">
      <p class="eyebrow text-cast mb-3">Specification</p>
      <h2 class="font-display text-display-lg mb-4">Variants, sizes and weights.</h2>
      <p class="text-cast-700 text-lg">Catalogue range covers full doubles, halves, top-of-wall, bottom-of-stack and levelling courses. All Beton-pattern compatible.</p>
    </div>
    <div class="overflow-x-auto">
      <table class="spec-table w-full text-left border-collapse">
        <thead class="bg-navy text-white">
          <tr>
            <th class="px-4 py-3 font-display text-sm uppercase tracking-wide">Type</th>
            <th class="px-4 py-3 font-display text-sm uppercase tracking-wide">Size (L×W×H)</th>
            <th class="px-4 py-3 font-display text-sm uppercase tracking-wide">Weight</th>
            <th class="px-4 py-3 font-display text-sm uppercase tracking-wide">Interlock</th>
            <th class="px-4 py-3 font-display text-sm uppercase tracking-wide">Typical use</th>
          </tr>
        </thead>
        <tbody>
          {specs.map((s, i) => (
            <tr class={i % 2 === 0 ? 'bg-white' : 'bg-bone-200'}>
              <td class="px-4 py-3 font-bold text-navy">{s.type}</td>
              <td class="px-4 py-3">{s.size}</td>
              <td class="px-4 py-3">{s.weight}</td>
              <td class="px-4 py-3">{s.interlock}</td>
              <td class="px-4 py-3 text-cast">{s.use}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <section class="bg-bone-200 py-20">
    <div class="container-wccp">
      <div class="grid lg:grid-cols-2 gap-12">
        <div>
          <p class="eyebrow text-cast mb-3">Where they go</p>
          <h2 class="font-display text-display-lg mb-6">Common applications.</h2>
          <p class="text-cast-700 text-lg leading-relaxed mb-6">From a temporary boundary on a building site to a permanent waste-transfer push wall — the blocks come, the wall goes up, the wall comes down again if you need it to.</p>
          <ul class="space-y-3">
            {applications.map((a) => (<li class="flex gap-3 text-cast-700 leading-relaxed"><span class="text-ember font-bold mt-1">·</span><span>{a}</span></li>))}
          </ul>
        </div>
        <div class="card p-8">
          <p class="eyebrow text-cast mb-3">Standards & references</p>
          <h3 class="font-display text-2xl font-bold text-navy mb-4">Cast and certified.</h3>
          <dl class="space-y-4 text-sm">
            <div><dt class="font-bold text-navy">BS EN 13369</dt><dd class="text-cast">Common rules for precast concrete — factory production control.</dd></div>
            <div><dt class="font-bold text-navy">BS 8500-1:2023</dt><dd class="text-cast">Concrete spec — C40/50 designed mix.</dd></div>
            <div><dt class="font-bold text-navy">BS EN 1992 (Eurocode 2)</dt><dd class="text-cast">Concrete structural design — overturning checks for stack heights.</dd></div>
            <div><dt class="font-bold text-navy">BS 5502-22:2003</dt><dd class="text-cast">Agricultural buildings — silage and bulk-storage loadings.</dd></div>
            <div><dt class="font-bold text-navy">Beton-block pattern</dt><dd class="text-cast">Twin-lug pitch compatible with most European interlocking-block manufacturers.</dd></div>
          </dl>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-yellow text-navy py-16">
    <div class="container-wccp">
      <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6">
        <div>
          <p class="eyebrow text-navy mb-2">Configure your wall</p>
          <h2 class="font-display text-display-md">Send length and height — we will quote inside 24 hours.</h2>
        </div>
        <div class="flex flex-wrap gap-3 shrink-0">
          <a href="/quote?product=Interlocking+Blocks" class="btn bg-navy text-white hover:bg-navy-700">Open the configurator</a>
          <a href={`mailto:${site.contact.quotesEmail}`} class="btn-secondary">Email quotes</a>
        </div>
      </div>
    </div>
  </section>

  <section class="container-wccp py-20">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between mb-10 gap-4">
      <div>
        <p class="eyebrow text-cast mb-3">Related products</p>
        <h2 class="font-display text-display-lg">Often ordered alongside.</h2>
      </div>
      <a href="/products" class="text-ember font-bold hover:text-ember-700 inline-flex items-center gap-2">View full range
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12" stroke-linecap="round" /><polyline points="12 5 19 12 12 19" stroke-linecap="round" stroke-linejoin="round" /></svg>
      </a>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
      {related.map((r) => (
        <a href={r.href} class="card p-5 group">
          <div class="aspect-[16/10] bg-cast-100 mb-4 rounded overflow-hidden"><div class="w-full h-full bg-gradient-to-br from-cast-200 to-cast-100"></div></div>
          <h3 class="font-display text-base font-bold text-navy mb-1 group-hover:text-ember">{r.label}</h3>
          <p class="text-cast text-xs">{r.meta}</p>
        </a>
      ))}
    </div>
  </section>

  <section class="bg-bone-200 py-20">
    <div class="container-wccp">
      <div class="max-w-2xl mb-12">
        <p class="eyebrow text-cast mb-3">Common questions</p>
        <h2 class="font-display text-display-lg mb-4">What people ask about interlocking blocks.</h2>
        <p class="text-cast-700 text-lg">Five questions we answer most weeks. If yours is not here, ring the yard.</p>
      </div>
      <div class="max-w-3xl space-y-4">
        {faqs.map((f) => (
          <details class="card p-6 group">
            <summary class="font-display text-lg font-bold text-navy cursor-pointer list-none flex justify-between items-start gap-4">
              <span>{f.q}</span>
              <span class="text-ember text-2xl leading-none group-open:rotate-45 transition-transform shrink-0">+</span>
            </summary>
            <p class="text-cast-700 leading-relaxed mt-4">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-navy text-white py-20">
    <div class="container-wccp text-center">
      <h2 class="font-display text-display-xl mb-4 text-white">Ready to spec it?</h2>
      <p class="text-white/90 text-lg max-w-xl mx-auto mb-8">Send wall length and stack height. Quote and lead-time same day.</p>
      <div class="flex flex-wrap justify-center gap-3">
        <a href="/quote?product=Interlocking+Blocks" class="btn-yellow">Configure a quote</a>
        <a href={`tel:${site.contact.phoneIntl}`} class="btn-secondary">Call {site.contact.phone}</a>
        <a href={`mailto:${site.contact.quotesEmail}`} class="btn-primary">Email quotes</a>
      </div>
    </div>
  </section>
</BaseLayout>
