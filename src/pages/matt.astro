            <label class="prod-pill yes"><input type="checkbox" name="products_keep" value="clean-rooms">Yes</label>
            <label class="prod-pill no"><input type="checkbox" name="products_remove" value="clean-rooms">No</label></div>
          <div class="prod-row"><div class="pname">Architectural Panels</div>
            <label class="prod-pill yes"><input type="checkbox" name="products_keep" value="architectural-panels">Yes</label>
            <label class="prod-pill no"><input type="checkbox" name="products_remove" value="architectural-panels">No</label></div>
