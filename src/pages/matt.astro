<!-- Sticky progress -->
<div class="progress">
  <span><strong id="progress-num">0</strong>/<strong id="progress-total">0</strong></span>
  <div class="progress-track"><div class="progress-fill" id="progress-fill"></div></div>
  <span id="progress-pct">0%</span>
</div>

<script>
  // File label
  function showFiles(input) {
    const list = input.parentElement.querySelector('.file-list');
    if (!list) return;
    if (input.files.length === 0) { list.textContent = ''; return; }
    list.textContent = [...input.files].map(f => '✓ ' + f.name).join(' · ');
  }

  // Handle product yes/no toggle to color the row
  function handleProdToggle(input) {
    const row = input.closest('.prod-row');
    if (!row) return;
    row.classList.remove('is-yes', 'is-no');
    if (input.value === 'yes') row.classList.add('is-yes');
    else if (input.value === 'no') row.classList.add('is-no');
  }

  // Bulk lead time setter
  function bulkLead() {
    const sel = document.getElementById('bulk-lead').value;
    if (!sel) return;
    document.querySelectorAll('.prod-row.is-yes .lead-select').forEach(s => { s.value = sel; });
    document.getElementById('lead_default_field').value = sel;
    updateProgress();
    saveState();
  }

  // localStorage save/restore
  const form = document.getElementById('mainform');
  const STORAGE_KEY = 'wccp-matt-form-v2';
  function saveState() {
    const data = {};
    new FormData(form).forEach((v, k) => {
      if (typeof v === 'string') data[k] = data[k] ? data[k] + ',' + v : v;
    });
    try { localStorage.setItem(STORAGE_KEY, JSON.stringify(data)); } catch (e) {}
  }
  function restoreState() {
    try {
      const data = JSON.parse(localStorage.getItem(STORAGE_KEY) || '{}');
      for (const [k, v] of Object.entries(data)) {
        const els = form.querySelectorAll('[name="' + k + '"]');
        els.forEach(el => {
          if (el.type === 'checkbox' || el.type === 'radio') {
            if (String(v).split(',').includes(el.value)) { el.checked = true; handleProdToggle(el); }
          } else if (el.type === 'file') { /* skip */ }
          else if (el.tagName === 'SELECT' || el.tagName === 'TEXTAREA' || el.type === 'text' || el.type === 'tel' || el.type === 'email' || el.type === 'number') {
            el.value = v;
          }
        });
      }
    } catch (e) {}
  }

  // Progress
  function updateProgress() {
    const groups = new Map();
    form.querySelectorAll('input[name]:not([type=hidden]):not([name=bot-field]), textarea[name], select[name]').forEach(el => {
      if (!groups.has(el.name)) groups.set(el.name, []);
      groups.get(el.name).push(el);
    });
    let total = 0, done = 0;
    for (const [name, els] of groups) {
      if (name === 'form-name' || name === 'bot-field' || name.startsWith('lead_')) continue;
      total++;
      const filled = els.some(el => {
        if (el.type === 'checkbox' || el.type === 'radio') return el.checked;
        if (el.type === 'file') return el.files && el.files.length > 0;
        return el.value && el.value.trim().length > 0;
      });
      if (filled) done++;
    }
    document.getElementById('progress-num').textContent = done;
    document.getElementById('progress-total').textContent = total;
    const pct = total ? Math.round((done / total) * 100) : 0;
    document.getElementById('progress-pct').textContent = pct + '%';
    document.getElementById('progress-fill').style.width = pct + '%';
  }

  restoreState();
  updateProgress();
  form.addEventListener('input', () => { saveState(); updateProgress(); });
  form.addEventListener('change', () => { saveState(); updateProgress(); });
  form.addEventListener('submit', () => { try { localStorage.removeItem(STORAGE_KEY); } catch (e) {} });
</script>

