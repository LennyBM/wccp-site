        </div>

        <div class="q" style="margin-top: 16px;">
          <label class="qlabel">Anything you make that's not on this list?</label>
          <div class="hint">Just type a few words — we'll add pages for them.</div>
          <textarea name="products_other" placeholder="e.g. specialist precast for..."></textarea>
        </div>
      </div>
    </div>

    <!-- SECTION 2: Your contact details -->
    <div class="section">
      <div class="section-head">
        <span class="num">2</span>
        <h2>Your contact details</h2>
        <span class="tag tag-must">MUST</span>
      </div>
      <div class="section-body">
        <p class="lead">What goes on the new site — exactly as you want it shown.</p>

        <div class="q">
          <label class="qlabel">Main phone number</label>
          <input type="tel" name="phone" placeholder="e.g. 01409 281437">
        </div>
        <div class="q">
          <label class="qlabel">Email address for enquiries</label>
          <input type="email" name="email_address" placeholder="e.g. info@wccp.co.uk">
        </div>
        <div class="q">
          <label class="qlabel">WhatsApp number (if different)</label>
          <div class="hint">Leave blank if it's the same as the phone above.</div>
          <input type="tel" name="whatsapp" placeholder="e.g. 07970 520123">
        </div>
        <div class="q">
          <label class="qlabel">Opening hours</label>
          <input type="text" name="hours" placeholder="e.g. Mon-Fri 7:30am-5:00pm">
        </div>
      </div>
    </div>

    <!-- SECTION 3: Accreditations -->
    <div class="section">
      <div class="section-head">
        <span class="num">3</span>
        <h2>Which of these accreditations do you actually have?</h2>
        <span class="tag tag-must">MUST</span>
      </div>
      <div class="section-body">
        <p class="lead">We've put loads on the site — let's only keep the ones you really hold (with current certificates). Tick the ones that are true:</p>

        <div class="opts row2">
          <label class="opt"><input type="checkbox" name="accreditations" value="iso-9001"><span class="opt-label">ISO 9001<small class="opt-sub">Quality management</small></span></label>
          <label class="opt"><input type="checkbox" name="accreditations" value="iso-14001"><span class="opt-label">ISO 14001<small class="opt-sub">Environmental</small></span></label>
          <label class="opt"><input type="checkbox" name="accreditations" value="iso-45001"><span class="opt-label">ISO 45001<small class="opt-sub">Health & safety</small></span></label>
          <label class="opt"><input type="checkbox" name="accreditations" value="ce-ukca"><span class="opt-label">CE / UKCA marking<small class="opt-sub">Factory Production Control</small></span></label>
          <label class="opt"><input type="checkbox" name="accreditations" value="chas"><span class="opt-label">CHAS<small class="opt-sub">Contractor health & safety</small></span></label>
          <label class="opt"><input type="checkbox" name="accreditations" value="constructionline"><span class="opt-label">Constructionline<small class="opt-sub">Bronze / Silver / Gold</small></span></label>
          <label class="opt"><input type="checkbox" name="accreditations" value="mpa-precast"><span class="opt-label">MPA Precast<small class="opt-sub">Trade body member</small></span></label>
          <label class="opt"><input type="checkbox" name="accreditations" value="fps"><span class="opt-label">FPS<small class="opt-sub">Federation of Piling Specialists</small></span></label>
          <label class="opt"><input type="checkbox" name="accreditations" value="made-in-britain"><span class="opt-label">Made in Britain<small class="opt-sub">Member</small></span></label>
          <label class="opt"><input type="checkbox" name="accreditations" value="nbs-source"><span class="opt-label">NBS Source<small class="opt-sub">Architect specification database</small></span></label>
        </div>

        <div class="q" style="margin-top:14px;">
          <label class="qlabel">Anything to note? Certificates expired, in progress, or other accreditations not listed?</label>
          <textarea name="accred_notes" placeholder="e.g. ISO 9001 expires Dec 2026, in process of getting ISO 45001..."></textarea>
        </div>
      </div>
    </div>

    <!-- SECTION 4: Quick decisions -->
    <div class="section">
      <div class="section-head">
        <span class="num">4</span>
        <h2>Three quick decisions</h2>
        <span class="tag tag-must">MUST</span>
      </div>
      <div class="section-body">

        <div class="q">
          <label class="qlabel">Do you want prices on the website?</label>
          <div class="opts row3">
            <label class="opt"><input type="radio" name="prices" value="hide"><span class="opt-label">No prices<small class="opt-sub">"Get a quote" only</small></span></label>
            <label class="opt"><input type="radio" name="prices" value="show"><span class="opt-label">Yes, show prices</span></label>
            <label class="opt"><input type="radio" name="prices" value="from"><span class="opt-label">"From £X" only<small class="opt-sub">Starting prices</small></span></label>
          </div>
        </div>

        <div class="q">
          <label class="qlabel">The logo — what do you want to do?</label>
          <div class="opts row3">
            <label class="opt"><input type="radio" name="logo_decision" value="keep"><span class="opt-label">Keep current<small class="opt-sub">As it is now</small></span></label>
            <label class="opt"><input type="radio" name="logo_decision" value="refresh"><span class="opt-label">Small refresh<small class="opt-sub">Tidy up</small></span></label>
            <label class="opt"><input type="radio" name="logo_decision" value="redesign"><span class="opt-label">Full redesign<small class="opt-sub">Brand new</small></span></label>
          </div>
        </div>

        <div class="q">
          <label class="qlabel">When do you want the site live?</label>
          <div class="hint">No pressure — just so we know what to aim for.</div>
          <div class="opts row3">
            <label class="opt"><input type="radio" name="launch_when" value="asap"><span class="opt-label">ASAP<small class="opt-sub">Next few weeks</small></span></label>
            <label class="opt"><input type="radio" name="launch_when" value="devon-show"><span class="opt-label">Devon Show<small class="opt-sub">21–23 May</small></span></label>
            <label class="opt"><input type="radio" name="launch_when" value="royal-cornwall"><span class="opt-label">Royal Cornwall<small class="opt-sub">4–6 June</small></span></label>
            <label class="opt"><input type="radio" name="launch_when" value="summer"><span class="opt-label">Summer 2026<small class="opt-sub">No rush</small></span></label>
            <label class="opt"><input type="radio" name="launch_when" value="autumn"><span class="opt-label">Autumn 2026</span></label>
            <label class="opt"><input type="radio" name="launch_when" value="flexible"><span class="opt-label">Whenever it's right</span></label>
          </div>
        </div>
      </div>
    </div>

    <!-- SECTION 5: Files -->
    <div class="section">
      <div class="section-head">
        <span class="num">5</span>
        <h2>Upload your logo &amp; photos</h2>
        <span class="tag tag-must">MUST</span>
      </div>
      <div class="section-body">
        <p class="lead">If you've got files to hand, drop them in here. If not, no worries — just leave it and we'll chase later.</p>

        <div class="q">
          <label class="qlabel">Logo files</label>
          <div class="hint">Best is an editable file (.ai, .eps, .svg or .pdf). A high-res PNG works too.</div>
          <label class="file-zone">
            <input type="file" name="logo_files" multiple accept=".ai,.eps,.svg,.pdf,.png,.jpg,.jpeg" onchange="showFiles(this)">
            <p><strong>📎 Tap to choose files</strong><br>or drop files here</p>
            <div class="file-list"></div>
          </label>
        </div>

        <div class="q">
          <label class="qlabel">Any photos you have (yard, products, team, customers)</label>
          <div class="hint">Phone photos are absolutely fine. Send anything you've got.</div>
          <label class="file-zone">
            <input type="file" name="photo_files" multiple accept="image/*,video/*" onchange="showFiles(this)">
            <p><strong>📎 Tap to choose photos</strong><br>or drop files here</p>
            <div class="file-list"></div>
          </label>
        </div>
      </div>
    </div>

    <!-- SECTION 6: Customer references -->
    <div class="section optional">
      <div class="section-head">
        <span class="num">6</span>
        <h2>2 or 3 happy customers</h2>
        <span class="tag tag-help">HELPFUL</span>
      </div>
      <div class="section-body">
        <p class="lead">Customers we could ring for a quick testimonial. Just names + phone numbers. We'll do the calling.</p>
        <div class="q">
          <textarea name="customer_references" rows="4" placeholder="e.g.&#10;1. John Smith — Trewartha Farm — 07000 000000&#10;2. Sarah Jones — Higgins Civils — 01234 567890"></textarea>
        </div>
      </div>
    </div>

    <!-- SECTION 7: Team & history (optional) -->
    <div class="section optional">
      <div class="section-head">
        <span class="num">7</span>
        <h2>Team &amp; history</h2>
        <span class="tag tag-skip">ONLY IF YOU HAVE TIME</span>
      </div>
      <div class="section-body">
        <p class="lead">This is for the "About" and "Team" pages. Skip if you're busy — we can come back to it after the site is live.</p>

        <div class="q">
          <label class="qlabel">Team list — who works there?</label>
          <div class="hint">Just names and job titles. Even rough — "Dave (yard manager, 15 years), Sarah (office), etc."</div>
          <textarea name="team_list" rows="3" placeholder="e.g. Kim Rumsam — MD..."></textarea>
        </div>

        <div class="q">
          <label class="qlabel">A few sentences about Kim</label>
          <div class="hint">How he came to WCCP, what he cares about. We'll polish it.</div>
          <textarea name="kim_bio" rows="3"></textarea>
        </div>

        <div class="q">
          <label class="qlabel">When did WCCP actually start trading?</label>
          <div class="hint">The year the business first started — under any name.</div>
          <input type="text" name="founded_year" placeholder="e.g. 1971">
        </div>
      </div>
    </div>

    <!-- SECTION 8: Anything else -->
    <div class="section optional">
      <div class="section-head">
        <span class="num">8</span>
        <h2>Anything else?</h2>
        <span class="tag tag-skip">OPTIONAL</span>
      </div>
      <div class="section-body">
        <div class="q">
          <textarea name="anything_else" rows="3" placeholder="Anything you want us to know, change, or ask about..."></textarea>
        </div>
      </div>
    </div>

    <!-- SUBMIT -->
    <div class="submit-bar">
      <p>Send what you've got — we'll chase anything missing.</p>
      <button type="submit" class="submit-btn">Send to WCCP team →</button>
      <div class="submit-status" id="status"></div>
    </div>

  </form>

  <!-- Progress -->
  <div class="progress">
    <span><strong id="progress-num">0</strong> of <strong id="progress-total">0</strong> answered</span>
    <div class="progress-track"><div class="progress-fill" id="progress-fill"></div></div>
    <span id="progress-pct">0%</span>
  </div>

</div>

<script>
  // Show selected filenames in the file-zone label
  function showFiles(input) {
    const list = input.parentElement.querySelector('.file-list');
    if (!list) return;
    if (input.files.length === 0) { list.textContent = ''; return; }
    const names = [...input.files].map(f => '✓ ' + f.name).join(' · ');
    list.textContent = names;
  }

  // Save form state to localStorage so progress isn't lost
  const form = document.getElementById('mainform');
  const STORAGE_KEY = 'wccp-matt-form';
  function saveState() {
    const data = {};
    new FormData(form).forEach((v, k) => {
      if (typeof v === 'string') {
        data[k] = data[k] ? data[k] + ',' + v : v;
      }
    });
    try { localStorage.setItem(STORAGE_KEY, JSON.stringify(data)); } catch (e) {}
  }
  function restoreState() {
    try {
      const data = JSON.parse(localStorage.getItem(STORAGE_KEY) || '{}');
      for (const [k, v] of Object.entries(data)) {
        const els = form.querySelectorAll('[name="' + k + '"]');
        els.forEach(el => {
          if (el.type === 'checkbox' || el.type === 'radio') {
            if (String(v).split(',').includes(el.value)) el.checked = true;
          } else if (el.type !== 'file') {
            el.value = v;
          }
        });
      }
    } catch (e) {}
  }

  // Progress tracker
  function updateProgress() {
    const fields = form.querySelectorAll('input[name]:not([type=hidden]):not([name=bot-field]), textarea[name], select[name]');
    const groups = new Map();
    fields.forEach(el => {
      const n = el.name;
      if (!groups.has(n)) groups.set(n, []);
      groups.get(n).push(el);
    });
    let total = 0, done = 0;
    for (const [name, els] of groups) {
      if (name === 'form-name' || name === 'bot-field') continue;
      total++;
      const filled = els.some(el => {
        if (el.type === 'checkbox' || el.type === 'radio') return el.checked;
        if (el.type === 'file') return el.files && el.files.length > 0;
        return el.value && el.value.trim().length > 0;
      });
      if (filled) done++;
    }
    document.getElementById('progress-num').textContent = done;
    document.getElementById('progress-total').textContent = total;
    document.getElementById('progress-pct').textContent = Math.round((done / total) * 100) + '%';
    document.getElementById('progress-fill').style.width = ((done / total) * 100) + '%';
  }

  restoreState();
  updateProgress();
  form.addEventListener('input', () => { saveState(); updateProgress(); });
  form.addEventListener('change', () => { saveState(); updateProgress(); });

  // Clear localStorage on successful submit (Netlify redirects, but if not, listener fires first)
  form.addEventListener('submit', () => {
    try { localStorage.removeItem(STORAGE_KEY); } catch (e) {}
  });
</script>

</body>
</html>
