---
// Internal — Matt's quick-fill form. Noindex, no nav. Submits via Netlify Forms.
// After first deploy: Netlify dashboard → Forms → wccp-matt → Notifications →
// add email notification to info@wccp.co.uk.
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="robots" content="noindex, nofollow">
<title>Quick form for Matt — WCCP</title>
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  :root {
    --navy: #131E44; --navy-mid: #3a5cb5; --yellow: #f5c13b;
    --red: #c0392b; --green: #27ae60; --bone: #f7f5f0;
    --cast: #6b7280; --border: #d1d5db; --soft: #f3f4f6;
  }
  body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: var(--bone); color: var(--navy); padding: 16px 12px 80px; line-height: 1.5; }
  .wrap { max-width: 720px; margin: 0 auto; }

  .hero { background: var(--navy); color: white; border-radius: 12px; padding: 22px 22px 20px; margin-bottom: 18px; }
  .hero h1 { font-size: 22px; font-weight: 800; line-height: 1.2; }
  .hero h1 span { color: var(--yellow); }
  .hero p { font-size: 14px; color: rgba(255,255,255,0.75); margin-top: 8px; }
  .hero .meta { margin-top: 12px; font-size: 12px; color: rgba(255,255,255,0.55); }

  .section { background: white; border-radius: 12px; border: 1px solid var(--border); margin-bottom: 14px; overflow: hidden; }
  .section-head { padding: 14px 18px; border-bottom: 1px solid var(--border); display: flex; align-items: center; gap: 10px; }
  .section-head .num { display: inline-flex; align-items: center; justify-content: center; width: 26px; height: 26px; border-radius: 50%; background: var(--navy); color: white; font-size: 13px; font-weight: 800; flex-shrink: 0; }
  .section-head h2 { font-size: 16px; font-weight: 700; flex: 1; }
  .section-head .tag { font-size: 10px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.06em; padding: 3px 8px; border-radius: 4px; }
  .tag-must { background: #fde8e8; color: var(--red); }
  .tag-help { background: #d1fae5; color: #065f46; }
  .tag-skip { background: var(--soft); color: var(--cast); }

  .section-body { padding: 16px 18px; }
  .section-body p.lead { font-size: 14px; color: var(--cast); margin-bottom: 14px; }

  .q { margin-bottom: 18px; }
  .q:last-child { margin-bottom: 0; }
  .q label.qlabel { display: block; font-size: 14px; font-weight: 700; margin-bottom: 6px; color: var(--navy); }
  .q .hint { font-size: 12.5px; color: var(--cast); margin-bottom: 8px; }

  input[type="text"], input[type="email"], input[type="tel"], input[type="date"], textarea {
    width: 100%; border: 1.5px solid var(--border); border-radius: 7px; padding: 10px 12px; font-family: inherit; font-size: 14px; color: var(--navy); background: white;
  }
  input:focus, textarea:focus { outline: none; border-color: var(--navy-mid); box-shadow: 0 0 0 3px rgba(58,92,181,0.12); }
  textarea { resize: vertical; min-height: 70px; }

  /* Radio + checkbox cards */
  .opts { display: grid; gap: 8px; }
  .opts.row2 { grid-template-columns: 1fr 1fr; }
  .opts.row3 { grid-template-columns: 1fr 1fr 1fr; }
  @media (max-width: 480px) { .opts.row2, .opts.row3 { grid-template-columns: 1fr; } }
  .opt { display: flex; align-items: flex-start; gap: 9px; padding: 10px 12px; border: 1.5px solid var(--border); border-radius: 7px; cursor: pointer; background: white; transition: all 0.15s; }
  .opt:hover { border-color: var(--navy-mid); background: #f8faff; }
  .opt input { margin-top: 2px; flex-shrink: 0; }
  .opt input:checked + .opt-label { color: var(--navy); font-weight: 700; }
  .opt:has(input:checked) { border-color: var(--navy); background: #f0f4ff; }
  .opt-label { font-size: 13.5px; line-height: 1.35; color: #374151; }
  .opt-sub { display: block; font-size: 11.5px; color: var(--cast); margin-top: 2px; font-weight: 400; }

  /* Product list — denser, scannable */
  .prods { display: grid; gap: 6px; }
  .prod-row { display: grid; grid-template-columns: 1fr auto auto; gap: 10px; align-items: center; padding: 8px 12px; border: 1px solid var(--border); border-radius: 6px; background: white; }
  .prod-row .pname { font-size: 13.5px; font-weight: 600; color: var(--navy); }
  .prod-row .pname small { display: block; font-size: 11px; color: var(--cast); font-weight: 400; margin-top: 1px; }
  .prod-pill { display: inline-flex; align-items: center; gap: 4px; font-size: 12px; padding: 4px 8px; border-radius: 4px; cursor: pointer; border: 1px solid var(--border); user-select: none; background: white; font-weight: 600; }
  .prod-pill input { display: none; }
  .prod-pill.yes:has(input:checked) { background: var(--green); border-color: var(--green); color: white; }
  .prod-pill.no:has(input:checked) { background: var(--red); border-color: var(--red); color: white; }
  .prod-pill:hover { border-color: var(--navy-mid); }

  /* File input */
  .file-zone { border: 2px dashed var(--border); border-radius: 8px; padding: 14px; text-align: center; background: var(--soft); cursor: pointer; transition: all 0.15s; }
  .file-zone:hover { border-color: var(--navy-mid); background: #f0f4ff; }
  .file-zone p { font-size: 13px; color: var(--cast); }
  .file-zone p strong { color: var(--navy); }
  .file-zone input[type="file"] { display: none; }
  .file-list { margin-top: 8px; font-size: 12px; color: var(--green); font-weight: 600; }

  /* Submit */
  .submit-bar { background: white; border: 1px solid var(--border); border-radius: 12px; padding: 18px; margin-top: 16px; text-align: center; }
  .submit-bar p { font-size: 13px; color: var(--cast); margin-bottom: 12px; }
  .submit-btn { background: var(--navy); color: white; font-family: inherit; font-size: 16px; font-weight: 700; padding: 14px 32px; border: none; border-radius: 8px; cursor: pointer; transition: all 0.15s; min-width: 200px; }
  .submit-btn:hover { background: var(--navy-mid); }
  .submit-btn:active { transform: scale(0.98); }
  .submit-status { font-size: 13px; margin-top: 10px; font-weight: 600; min-height: 18px; }
  .submit-status.ok { color: var(--green); }
  .submit-status.err { color: var(--red); }

  /* Optional section gentler */
  .section.optional .section-head { background: var(--soft); }
  .section.optional .section-head h2 { color: var(--cast); font-weight: 600; }

  .progress { position: sticky; bottom: 0; background: white; border-top: 2px solid var(--navy); padding: 10px 14px; margin: 16px -12px -80px; font-size: 12.5px; display: flex; align-items: center; justify-content: space-between; }
  .progress-track { flex: 1; height: 6px; background: var(--soft); border-radius: 3px; margin: 0 12px; overflow: hidden; }
  .progress-fill { height: 100%; background: var(--green); width: 0%; transition: width 0.3s; border-radius: 3px; }

  @media (max-width: 600px) {
    body { padding: 12px 8px 80px; }
    .hero { padding: 18px; }
    .hero h1 { font-size: 19px; }
    .section-body { padding: 14px; }
  }
</style>
</head>
<body>

<!-- Hidden static form so Netlify detects all fields at build time -->
<form name="wccp-matt" data-netlify="true" data-netlify-honeypot="bot-field" netlify hidden enctype="multipart/form-data">
  <input name="bot-field" />
  <input name="phone" /><input name="email_address" /><input name="hours" /><input name="whatsapp" />
  <input name="prices" /><input name="logo_decision" /><input name="launch_when" />
  <input name="products_keep" /><input name="products_remove" /><textarea name="products_other"></textarea>
  <input name="accreditations" /><textarea name="accred_notes"></textarea>
  <input type="file" name="logo_files" multiple /><input type="file" name="photo_files" multiple />
  <textarea name="customer_references"></textarea>
  <textarea name="team_list"></textarea><textarea name="kim_bio"></textarea><input name="founded_year" />
  <textarea name="anything_else"></textarea>
</form>

<div class="wrap">

  <!-- HERO -->
  <div class="hero">
    <h1>Hi Matt — quick form to get the <span>WCCP site live</span></h1>
    <p>Should take about 10 minutes. Skip anything you don't know — just hit Send at the bottom and we'll chase the rest. Replies come straight to info@wccp.co.uk.</p>
    <div class="meta">Top sections are the ones that unblock the launch. Bottom sections are optional — only fill them if you've got time.</div>
  </div>

  <form name="wccp-matt" method="POST" data-netlify="true" data-netlify-honeypot="bot-field" enctype="multipart/form-data" id="mainform">
    <input type="hidden" name="form-name" value="wccp-matt">
    <p style="display:none"><label>Don't fill this in: <input name="bot-field"></label></p>

    <!-- SECTION 1: Which products do you actually make? -->
    <div class="section">
      <div class="section-head">
        <span class="num">1</span>
        <h2>Which of these do you actually make?</h2>
        <span class="tag tag-must">MUST</span>
      </div>
      <div class="section-body">
        <p class="lead">We've built pages for everything we found on your current site. Tick "Yes" if you still make it, "No" if you don't (we'll remove the page). If you're not sure, leave it blank.</p>

        <div class="prods">
          <!-- Agricultural -->
          <div class="prod-row"><div class="pname">Cattle Cubicles <small>Front-leg mushroom, dairy + beef</small></div>
            <label class="prod-pill yes"><input type="checkbox" name="products_keep" value="cattle-cubicles">Yes</label>
            <label class="prod-pill no"><input type="checkbox" name="products_remove" value="cattle-cubicles">No</label></div>
          <div class="prod-row"><div class="pname">Portable Cubicles</div>
            <label class="prod-pill yes"><input type="checkbox" name="products_keep" value="portable-cubicles">Yes</label>
            <label class="prod-pill no"><input type="checkbox" name="products_remove" value="portable-cubicles">No</label></div>
          <div class="prod-row"><div class="pname">Cubicle End Walls</div>
            <label class="prod-pill yes"><input type="checkbox" name="products_keep" value="cubicle-end-walls">Yes</label>
            <label class="prod-pill no"><input type="checkbox" name="products_remove" value="cubicle-end-walls">No</label></div>
          <div class="prod-row"><div class="pname">Cattle Slats</div>
            <label class="prod-pill yes"><input type="checkbox" name="products_keep" value="cattle-slats">Yes</label>
            <label class="prod-pill no"><input type="checkbox" name="products_remove" value="cattle-slats">No</label></div>
          <div class="prod-row"><div class="pname">Slatted Lids</div>
            <label class="prod-pill yes"><input type="checkbox" name="products_keep" value="slatted-lids">Yes</label>
            <label class="prod-pill no"><input type="checkbox" name="products_remove" value="slatted-lids">No</label></div>
          <div class="prod-row"><div class="pname">Slurry Storage Panels</div>
            <label class="prod-pill yes"><input type="checkbox" name="products_keep" value="slurry-storage">Yes</label>
            <label class="prod-pill no"><input type="checkbox" name="products_remove" value="slurry-storage">No</label></div>
          <div class="prod-row"><div class="pname">Slurry Channels</div>
            <label class="prod-pill yes"><input type="checkbox" name="products_keep" value="slurry-channels">Yes</label>
            <label class="prod-pill no"><input type="checkbox" name="products_remove" value="slurry-channels">No</label></div>
          <div class="prod-row"><div class="pname">V-Section Sand Channels</div>
            <label class="prod-pill yes"><input type="checkbox" name="products_keep" value="sand-channels">Yes</label>
            <label class="prod-pill no"><input type="checkbox" name="products_remove" value="sand-channels">No</label></div>
          <div class="prod-row"><div class="pname">Dish Channels</div>
            <label class="prod-pill yes"><input type="checkbox" name="products_keep" value="dish-channels">Yes</label>
            <label class="prod-pill no"><input type="checkbox" name="products_remove" value="dish-channels">No</label></div>
          <div class="prod-row"><div class="pname">Feed Troughs</div>
            <label class="prod-pill yes"><input type="checkbox" name="products_keep" value="feed-troughs">Yes</label>
            <label class="prod-pill no"><input type="checkbox" name="products_remove" value="feed-troughs">No</label></div>
          <div class="prod-row"><div class="pname">Water Troughs / Drinkers</div>
            <label class="prod-pill yes"><input type="checkbox" name="products_keep" value="water-troughs">Yes</label>
            <label class="prod-pill no"><input type="checkbox" name="products_remove" value="water-troughs">No</label></div>
          <div class="prod-row"><div class="pname">Footbaths</div>
            <label class="prod-pill yes"><input type="checkbox" name="products_keep" value="footbaths">Yes</label>
            <label class="prod-pill no"><input type="checkbox" name="products_remove" value="footbaths">No</label></div>
          <div class="prod-row"><div class="pname">Silage Clamp Walls</div>
            <label class="prod-pill yes"><input type="checkbox" name="products_keep" value="silage-clamp-walls">Yes</label>
            <label class="prod-pill no"><input type="checkbox" name="products_remove" value="silage-clamp-walls">No</label></div>
          <div class="prod-row"><div class="pname">Grain Store Walls</div>
            <label class="prod-pill yes"><input type="checkbox" name="products_keep" value="grain-store-walls">Yes</label>
            <label class="prod-pill no"><input type="checkbox" name="products_remove" value="grain-store-walls">No</label></div>
          <div class="prod-row"><div class="pname">Milking Robot Bases</div>
            <label class="prod-pill yes"><input type="checkbox" name="products_keep" value="milking-robot-bases">Yes</label>
            <label class="prod-pill no"><input type="checkbox" name="products_remove" value="milking-robot-bases">No</label></div>
          <div class="prod-row"><div class="pname">Parlour Bases</div>
            <label class="prod-pill yes"><input type="checkbox" name="products_keep" value="parlour-bases">Yes</label>
            <label class="prod-pill no"><input type="checkbox" name="products_remove" value="parlour-bases">No</label></div>
          <div class="prod-row"><div class="pname">Heelstone Coping</div>
            <label class="prod-pill yes"><input type="checkbox" name="products_keep" value="heelstone-coping">Yes</label>
            <label class="prod-pill no"><input type="checkbox" name="products_remove" value="heelstone-coping">No</label></div>
          <div class="prod-row"><div class="pname">Feed Stop Walling</div>
            <label class="prod-pill yes"><input type="checkbox" name="products_keep" value="feed-stop-walling">Yes</label>
            <label class="prod-pill no"><input type="checkbox" name="products_remove" value="feed-stop-walling">No</label></div>
          <div class="prod-row"><div class="pname">Ventilated Floors</div>
            <label class="prod-pill yes"><input type="checkbox" name="products_keep" value="ventilated-floors">Yes</label>
            <label class="prod-pill no"><input type="checkbox" name="products_remove" value="ventilated-floors">No</label></div>
          <div class="prod-row"><div class="pname">Cattle Grids</div>
            <label class="prod-pill yes"><input type="checkbox" name="products_keep" value="cattle-grids">Yes</label>
            <label class="prod-pill no"><input type="checkbox" name="products_remove" value="cattle-grids">No</label></div>
          <div class="prod-row"><div class="pname">AD Plant Tanks</div>
            <label class="prod-pill yes"><input type="checkbox" name="products_keep" value="ad-plant-tanks">Yes</label>
            <label class="prod-pill no"><input type="checkbox" name="products_remove" value="ad-plant-tanks">No</label></div>

          <!-- Civils -->
          <div class="prod-row" style="margin-top:8px;"><div class="pname" style="color:var(--navy-mid);">— Civils & infrastructure —</div><div></div><div></div></div>
          <div class="prod-row"><div class="pname">Prestressed Wall Panels</div>
            <label class="prod-pill yes"><input type="checkbox" name="products_keep" value="prestressed-panels">Yes</label>
            <label class="prod-pill no"><input type="checkbox" name="products_remove" value="prestressed-panels">No</label></div>
          <div class="prod-row"><div class="pname">Retaining Walls</div>
            <label class="prod-pill yes"><input type="checkbox" name="products_keep" value="retaining-walls">Yes</label>
            <label class="prod-pill no"><input type="checkbox" name="products_remove" value="retaining-walls">No</label></div>
          <div class="prod-row"><div class="pname">King Post Walls</div>
            <label class="prod-pill yes"><input type="checkbox" name="products_keep" value="king-post-walls">Yes</label>
            <label class="prod-pill no"><input type="checkbox" name="products_remove" value="king-post-walls">No</label></div>
          <div class="prod-row"><div class="pname">Cantilever Walls</div>
            <label class="prod-pill yes"><input type="checkbox" name="products_keep" value="cantilever-walls">Yes</label>
            <label class="prod-pill no"><input type="checkbox" name="products_remove" value="cantilever-walls">No</label></div>
          <div class="prod-row"><div class="pname">L-Blocks</div>
            <label class="prod-pill yes"><input type="checkbox" name="products_keep" value="l-blocks">Yes</label>
            <label class="prod-pill no"><input type="checkbox" name="products_remove" value="l-blocks">No</label></div>
          <div class="prod-row"><div class="pname">Rapid-Fit Blocks (interlocking)</div>
            <label class="prod-pill yes"><input type="checkbox" name="products_keep" value="rapid-fit-blocks">Yes</label>
            <label class="prod-pill no"><input type="checkbox" name="products_remove" value="rapid-fit-blocks">No</label></div>
          <div class="prod-row"><div class="pname">Box Culverts</div>
            <label class="prod-pill yes"><input type="checkbox" name="products_keep" value="culverts">Yes</label>
            <label class="prod-pill no"><input type="checkbox" name="products_remove" value="culverts">No</label></div>
          <div class="prod-row"><div class="pname">Pipe Culverts</div>
            <label class="prod-pill yes"><input type="checkbox" name="products_keep" value="pipe-culverts">Yes</label>
            <label class="prod-pill no"><input type="checkbox" name="products_remove" value="pipe-culverts">No</label></div>
          <div class="prod-row"><div class="pname">Headwalls / Wing Walls</div>
            <label class="prod-pill yes"><input type="checkbox" name="products_keep" value="headwalls-wing-walls">Yes</label>
            <label class="prod-pill no"><input type="checkbox" name="products_remove" value="headwalls-wing-walls">No</label></div>
          <div class="prod-row"><div class="pname">Padstones</div>
            <label class="prod-pill yes"><input type="checkbox" name="products_keep" value="padstones">Yes</label>
            <label class="prod-pill no"><input type="checkbox" name="products_remove" value="padstones">No</label></div>
          <div class="prod-row"><div class="pname">Lintels</div>
            <label class="prod-pill yes"><input type="checkbox" name="products_keep" value="lintels">Yes</label>
            <label class="prod-pill no"><input type="checkbox" name="products_remove" value="lintels">No</label></div>
          <div class="prod-row"><div class="pname">Kerbs</div>
            <label class="prod-pill yes"><input type="checkbox" name="products_keep" value="kerbs">Yes</label>
            <label class="prod-pill no"><input type="checkbox" name="products_remove" value="kerbs">No</label></div>
          <div class="prod-row"><div class="pname">Bridge Beams</div>
            <label class="prod-pill yes"><input type="checkbox" name="products_keep" value="bridge-beams">Yes</label>
            <label class="prod-pill no"><input type="checkbox" name="products_remove" value="bridge-beams">No</label></div>
          <div class="prod-row"><div class="pname">Weighbridge Bases</div>
            <label class="prod-pill yes"><input type="checkbox" name="products_keep" value="weighbridge-bases">Yes</label>
            <label class="prod-pill no"><input type="checkbox" name="products_remove" value="weighbridge-bases">No</label></div>
          <div class="prod-row"><div class="pname">Soakaways / Chambers</div>
            <label class="prod-pill yes"><input type="checkbox" name="products_keep" value="soakaways-chambers">Yes</label>
            <label class="prod-pill no"><input type="checkbox" name="products_remove" value="soakaways-chambers">No</label></div>

          <!-- Bespoke -->
          <div class="prod-row" style="margin-top:8px;"><div class="pname" style="color:var(--navy-mid);">— Bespoke —</div><div></div><div></div></div>
          <div class="prod-row"><div class="pname">Vehicle Pits</div>
            <label class="prod-pill yes"><input type="checkbox" name="products_keep" value="vehicle-pits">Yes</label>
            <label class="prod-pill no"><input type="checkbox" name="products_remove" value="vehicle-pits">No</label></div>
