      { href: '/sustainability/carbon', label: 'Sustainability — carbon' },
      { href: '/community', label: 'Community' },
      { href: '/standards', label: 'Standards' },
      { href: '/standards-explained', label: 'Standards explained' },
      { href: '/standards/conformity', label: 'Standards conformity' },
      { href: '/careers', label: 'Careers' },
      { href: '/news', label: 'News & updates' },
      { href: '/contact', label: 'Contact' },
      { href: '/quote', label: 'Get a quote' },
    ],
  },
  {
    title: 'Legal',
    links: [
      { href: '/privacy', label: 'Privacy policy' },
      { href: '/cookies', label: 'Cookie policy' },
      { href: '/terms', label: 'Terms & conditions' },
      { href: '/accessibility', label: 'Accessibility statement' },
      { href: '/complaints', label: 'Complaints procedure' },
    ],
  },
  {
    title: 'AI / Resources',
    links: [
      { href: '/ai-information', label: 'AI / LLM information page' },
      { href: '/llms.txt', label: '/llms.txt — machine-readable summary' },
      { href: '/search', label: 'Search the site' },
      { href: '/sitemap', label: 'HTML sitemap (this page)' },
      { href: '/sitemap-index.xml', label: 'XML sitemap (for search engines)' },
      { href: '/feed.xml', label: 'RSS feed' },
    ],
  },
];

// De-duplicate within each section in case the same href appears twice.
const cleanedSections = sections.map((s) => {
  const seen = new Set<string>();
  const links = s.links.filter((l) => {
    if (seen.has(l.href)) return false;
    seen.add(l.href);
    return true;
  });
  return { ...s, links };
});

const totalLinks = cleanedSections.reduce((sum, s) => sum + s.links.length, 0);
---

<BaseLayout
  title="Sitemap — every page on the site"
  description="Full HTML sitemap for West Country Concrete Products. Every page grouped by section: products, sectors, guides, case studies, areas, cities, grants, company, legal and AI resources."
>
  <!-- Hero -->
  <section class="bg-navy text-white">
    <div class="container-wccp py-16 md:py-20">
      <div class="max-w-3xl">
        <p class="eyebrow text-yellow mb-6">Sitemap</p>
        <h1 class="font-display text-display-xl text-white mb-6">
          Every page on the site.
        </h1>
        <p class="text-lg md:text-xl text-white/90 max-w-2xl leading-relaxed">
          {totalLinks} pages, grouped by section. Useful if you'd rather browse than search — or if
          you're a search engine. The XML sitemap lives at <a href="/sitemap-index.xml" class="text-yellow font-bold hover:underline">/sitemap-index.xml</a>.
        </p>
      </div>
    </div>
  </section>

  <!-- Explanatory paragraph -->
  <section class="bg-bone-100 border-b border-cast-100">
    <div class="container-wccp py-8 md:py-10">
      <div class="max-w-3xl text-cast-700 leading-relaxed">
        <p>
          This sitemap is a single index of every public page on the WCCP site, organised by
          section so contractors, dairy farmers, civils specifiers, search engines and AI
          search assistants can navigate quickly to the right reference. Products are listed
          individually with their canonical URLs; guides and case studies are grouped
          together; the cities and areas-served lists cover the regional landing pages; and
          the AI / Resources block links the machine-readable references (the
          <a href="/ai-information" class="text-ember underline">/ai-information</a> page,
          the <a href="/llms.txt" class="text-ember underline">/llms.txt</a> file and the XML
          sitemap) used by ChatGPT, Perplexity, Google AI Overviews, Claude and Bing Copilot.
        </p>
      </div>
    </div>
  </section>

  <!-- Sections -->
  <section class="container-wccp py-16">
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-10">
      {cleanedSections.map((section) => (
        <div>
          <h2 class="font-display text-xl font-bold text-navy mb-4 pb-2 border-b-2 border-yellow">
            {section.title}
          </h2>
          <ul class="space-y-2">
            {section.links.map((l) => (
              <li>
                <a href={l.href} class="text-cast hover:text-ember transition-colors text-sm leading-snug inline-block">
                  {l.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-bone-200 py-12">
    <div class="container-wccp text-center">
      <p class="eyebrow text-cast mb-3">Still can't find it?</p>
      <h2 class="font-display text-display-md mb-3">Ring the yard.</h2>
      <p class="text-cast max-w-xl mx-auto mb-6">
        Same-day callback Monday to Friday. We answer the phone — that's still the fastest way.
      </p>
      <div class="flex flex-wrap justify-center gap-3">
        <a href={`tel:${site.contact.phoneIntl}`} class="btn-secondary">Call {site.contact.phone}</a>
        <a href="/contact" class="btn-primary">Send a message</a>
      </div>
    </div>
  </section>
</BaseLayout>
