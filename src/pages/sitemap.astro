      { href: '/guides/bespoke-precast-process', label: 'Bespoke precast process' },
      { href: '/guides/fetf-2026-eligible-products', label: 'FETF 2026 eligible products' },
      { href: '/downloads', label: 'Downloads (datasheets, CAD, BIM)' },
