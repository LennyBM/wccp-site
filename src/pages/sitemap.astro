    ],
  },
  {
    title: 'Case studies',
    links: [
      { href: '/case-studies', label: 'Case studies index' },
      { href: '/case-studies/trewartha-farm-dairy', label: 'Trewartha Farm dairy' },
      { href: '/case-studies/boscastle-beef-shed', label: 'Boscastle beef shed' },
