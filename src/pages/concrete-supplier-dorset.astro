---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TrustStrip from '@/components/TrustStrip.astro';
import RelatedProductGrid from '@/components/RelatedProductGrid.astro';
import { site } from '@/config/site';

const county = 'Dorset';
const town = 'Dorchester';
const distances = [
  { name: 'Dorchester', mi: 90 },
  { name: 'Bridport', mi: 80 },
  { name: 'Sherborne', mi: 80 },
];

const faqs = [
  { q: `Do you deliver across all of ${county}?`, a: `Yes — from Bridport along the Jurassic Coast to Bournemouth and inland to the Blackmore Vale. ${county} sits a ninety-minute artic run from Holsworthy.` },
  { q: 'Do you deliver to the Jurassic Coast and the Purbecks?', a: "Yes. Coastal lanes are tight — we'll do a recce on borderline access before the first load and switch to a rigid 8-wheeler instead of an artic where it's needed." },
  { q: 'Do you supply the AONB and heritage estates?', a: 'Yes. Heritage-style cast stone, copings and bespoke architectural panels are routine — colour-matched and finish-matched on samples before casting in volume.' },
  { q: `Lead time to ${town}?`, a: 'Catalogue items 2–3 weeks. Bespoke and engineered items quoted from drawings — typically four to six weeks from approved design.' },
];

const related = [
  { href: '/products/cattle-cubicles',     label: 'Cattle Cubicles',     meta: 'Holstein / Jersey / beef' },
  { href: '/products/retaining-walls',     label: 'Retaining Walls',     meta: 'L / King-post / Cantilever' },
  { href: '/products/silage-clamp-walls',  label: 'Silage Clamp Walls',  meta: 'C40/50 · sulphate-resisting' },
  { href: '/products/prestressed-panels',  label: 'Prestressed Panels',  meta: 'BS EN 14992 · 100–280mm' },
];

const serviceSchema = {
  name: `Precast concrete supplier in ${county}`,
  description: `Precast concrete delivered across ${county} from the WCCP yard in Holsworthy. Cubicles, retaining walls, heritage cast stone, civils.`,
  serviceType: 'Precast concrete manufacture and delivery',
  areaServed: [{ '@type': 'AdministrativeArea', name: county }, { '@type': 'City', name: town }],
  mainEntityOfPage: `${site.url}/concrete-supplier-dorset`,
};
---

<BaseLayout
  title={`Precast concrete supplier ${county} · WCCP`}
  description={`Precast concrete supplier delivering across ${county} from our Holsworthy yard. Cubicles, retaining walls, heritage cast stone, AONB civils. Family-led since 1971.`}
  schema="Service"
  schemaData={serviceSchema}
>
  <section class="bg-forest-700 text-cream">
    <div class="container-wccp py-20 md:py-28">
      <p class="eyebrow text-cream/70 mb-4">Areas served · {county}</p>
      <h1 class="font-display text-display-2xl text-cream mb-6 max-w-4xl">
        Precast concrete supplier in {county}.<br />
        <em class="text-terracotta not-italic font-display italic">Made in North Devon. Hauled to your slab.</em>
      </h1>
      <p class="text-cream/85 text-lg leading-relaxed max-w-3xl mb-8">
        WCCP delivers precast concrete across {county} from our Holsworthy yard, a ninety-minute
        artic run away. Common Dorset precast jobs: <a href="/products/cattle-cubicles" class="text-terracotta-300 underline-offset-4 hover:underline">cattle cubicles</a> for
        Blackmore Vale dairies, <a href="/products/retaining-walls" class="text-terracotta-300 underline-offset-4 hover:underline">retaining walls</a> and
        <a href="/products/heelstone-coping" class="text-terracotta-300 underline-offset-4 hover:underline"> heritage cast-stone copings</a>.
        Lead times: 2–3 weeks for catalogue items, 4–6 weeks bespoke. Recent deliveries:
        Bridport, Sherborne and the Jurassic Coast.
      </p>
      <div class="flex flex-wrap gap-3">
        <a href="/quote" class="btn-primary">Get a quote</a>
        <a href={`tel:${site.contact.phoneIntl}`} class="btn-yellow">Call {site.contact.phone}</a>
      </div>
    </div>
  </section>

  <TrustStrip />

  <section class="container-wccp py-16 md:py-20 section-reveal">
    <div class="grid lg:grid-cols-2 gap-10 items-start">
      <div>
        <p class="eyebrow text-cast mb-3">From the yard</p>
        <h2 class="font-display text-display-md text-forest-700 mb-4">
          Holsworthy to {town}: roughly {distances[0].mi} miles.
        </h2>
        <p class="text-cast-700 leading-relaxed">
          Typical delivery 2–3 days from order on catalogue items. Own HIAB lorries.
        </p>
      </div>
      <ul class="space-y-3">
        {distances.map((d) => (
          <li class="flex items-baseline justify-between border-b border-cast-100 pb-3">
            <span class="font-display text-lg font-semibold text-forest-700">{d.name}</span>
            <span class="text-cast tabular-nums">~{d.mi} mi</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="bg-cream-200 py-16 md:py-20 section-reveal">
    <div class="container-wccp">
      <div class="max-w-3xl mb-10">
        <p class="eyebrow text-cast mb-3">Why {county} farms, architects and contractors choose WCCP</p>
        <h2 class="font-display text-display-md text-forest-700 mb-4">Built for the Vale and the coast.</h2>
      </div>
      <div class="grid md:grid-cols-2 gap-6 max-w-4xl">
        <div class="card p-6">
          <h3 class="font-display text-lg font-bold text-forest-700 mb-2">Heritage and AONB-friendly finishes</h3>
          <p class="text-cast-700 leading-relaxed">Colour-matched <a href="/products/heelstone-coping" class="text-terracotta font-semibold hover:underline">cast stone copings</a> and architectural panels approved by Dorset planners on listed and AONB sites.</p>
        </div>
        <div class="card p-6">
          <h3 class="font-display text-lg font-bold text-forest-700 mb-2">Blackmore Vale dairy</h3>
          <p class="text-cast-700 leading-relaxed">High-yielding dairies across the Vale order our <a href="/products/cattle-cubicles" class="text-terracotta font-semibold hover:underline">cubicles</a> and <a href="/products/silage-clamp-walls" class="text-terracotta font-semibold hover:underline">silage clamp walls</a> for Holstein herds.</p>
        </div>
        <div class="card p-6">
          <h3 class="font-display text-lg font-bold text-forest-700 mb-2">Coastal and tight-lane access</h3>
          <p class="text-cast-700 leading-relaxed">Purbeck and Jurassic Coast lanes — we recce in advance and switch from artic to rigid 8-wheeler where the village or drive demands it.</p>
        </div>
        <div class="card p-6">
          <h3 class="font-display text-lg font-bold text-forest-700 mb-2">Engineered for civils</h3>
          <p class="text-cast-700 leading-relaxed">Engineered <a href="/products/retaining-walls" class="text-terracotta font-semibold hover:underline">retaining walls</a> and <a href="/products/padstones" class="text-terracotta font-semibold hover:underline">padstones</a> for Dorset main contractors and self-build architects.</p>
        </div>
      </div>
      <div class="mt-8">
        <a href="/quote" class="btn-primary">Get a quote</a>
      </div>
    </div>
  </section>

  <section class="container-wccp py-16 md:py-20 section-reveal">
    <div class="max-w-2xl mb-10">
      <p class="eyebrow text-cast mb-3">What we cast</p>
      <h2 class="font-display text-display-md text-forest-700 mb-4">Most ordered in {county}.</h2>
      <p class="text-cast-700">Dairy and beef sheds, AONB-friendly retaining walls, heritage cast stone.</p>
    </div>
    <RelatedProductGrid items={related} />
    <div class="mt-8">
      <a href="/products" class="text-terracotta font-bold hover:text-terracotta-700 inline-flex items-center gap-1.5">
        See the full catalogue
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <line x1="5" y1="12" x2="19" y2="12" stroke-linecap="round" />
          <polyline points="12 5 19 12 12 19" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </a>
    </div>
  </section>

  <section class="bg-cream-200 py-16 md:py-20 section-reveal">
    <div class="container-wccp">
      <div class="max-w-2xl mb-10">
        <p class="eyebrow text-cast mb-3">Common questions</p>
        <h2 class="font-display text-display-md text-forest-700">Delivering to {county}.</h2>
      </div>
      <div class="max-w-3xl space-y-4">
        {faqs.map((f) => (
          <details class="card p-6 group">
            <summary class="font-display text-lg font-bold text-forest-700 cursor-pointer list-none flex justify-between items-start gap-4">
              <span>{f.q}</span>
              <span class="text-terracotta text-2xl leading-none group-open:rotate-45 transition-transform shrink-0">+</span>
            </summary>
            <p class="text-cast-700 leading-relaxed mt-4">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-forest-700 text-cream py-16">
    <div class="container-wccp text-center max-w-2xl mx-auto">
      <h2 class="font-display text-display-md text-cream mb-3">Cast for {county} farms and contractors.</h2>
      <p class="text-cream/85 mb-8">Send a drawing or just describe the job. We'll quote inside a working day.</p>
      <div class="flex flex-wrap justify-center gap-3">
        <a href="/quote" class="btn-primary">Get a quote</a>
        <a href={`tel:${site.contact.phoneIntl}`} class="btn-yellow">Call {site.contact.phone}</a>
      </div>
    </div>
  </section>
</BaseLayout>
