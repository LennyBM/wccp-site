---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SpecTicker from '@/components/SpecTicker.astro';
import YardVideoBlock from '@/components/YardVideoBlock.astro';
import { site } from '@/config/site';

const stats = [
  { value: '2023', label: 'Yard built' },
  { value: '46', label: 'Jobs created' },
  { value: '12,000m²', label: 'Production footprint' },
  { value: '7-day', label: 'Standard lead' },
];

const capabilities = [
  {
    title: 'Heavy-duty casting beds',
    body: 'Long-line prestressing beds for wall panels up to 12m. Steel-fixed batters and moulds for cubicles, troughs and bespoke units.',
  },
  {
    title: 'In-house design team',
    body: 'Engineers and detailers working in CAD. Drawings to BS EN 1992 (Eurocode 2). Bespoke moulds turned around in days, not weeks.',
  },
  {
    title: 'Batching to BS 8500-1:2023',
    body: 'Mix designs from C32/40 through to C50/60 with sulphate-resisting and low-permeability variants for slurry, silage and marine work.',
  },
  {
    title: 'Own delivery fleet',
    body: 'HIAB-equipped lorries, articulated low-loaders and a yard team who load it right. Same drivers, same kit, every week.',
  },
  {
    title: 'QC laboratory',
    body: 'Cube testing on every pour. Records kept on file for 10 years. Available with delivery on request.',
  },
  {
    title: 'Circular-economy site',
    body: 'Heat and power links to the adjacent Severn Trent anaerobic digestion plant. Recycled aggregate streams in trial. More to come.',
  },
];
---

<BaseLayout
  title="The factory — purpose-built precast at Chilsworthy"
  description="West Country Concrete Products' new precast facility at Chilsworthy, Holsworthy. Built 2023, 46 jobs, in-house design, batching to BS 8500-1:2023, co-located with Severn Trent's biogas plant."
  schema="LocalBusiness"
>
  <!-- Hero -->
  <section class="relative bg-navy text-white overflow-hidden">
    <div class="relative container-wccp py-20 md:py-28">
      <div class="max-w-3xl">
        <p class="eyebrow text-yellow mb-6">Chilsworthy, Holsworthy · Built 2023</p>
        <h1 class="font-display text-display-2xl text-white mb-6">
          A new yard,<br />
          <span class="text-yellow">built for the next fifty years.</span>
        </h1>
        <p class="text-lg md:text-xl text-white/90 max-w-2xl mb-10 leading-relaxed">
          Our purpose-built precast facility opened in 2023 on the edge of Holsworthy. Bigger casting
          beds, in-house design, modern batching, a proper QC lab — and 46 jobs in a part of Devon
          that needed them.
        </p>
        <div class="flex flex-wrap gap-3">
          <a href="/contact" class="btn-yellow">Book a factory tour</a>
          <a href="/products" class="btn-ghost border-white text-white hover:bg-white hover:text-navy">See the range</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Concrete spec ticker — today's mix straight off the factory floor -->
  <SpecTicker />

  <!-- Walk the yard — video block -->
  <section class="container-wccp section-rhythm">
    <div class="max-w-2xl mb-10">
      <p class="eyebrow text-cast mb-3">Walk the yard</p>
      <h2 class="font-display text-display-lg">Ninety seconds inside Holsworthy.</h2>
    </div>
    <YardVideoBlock caption="A 90-second walk through the Holsworthy yard — pour to delivery." />
  </section>

  <!-- Live from the yard — webcam still placeholder -->
  <section class="container-wccp section-rhythm border-t border-cast-100">
    <div class="max-w-2xl mb-10">
      <p class="eyebrow text-cast mb-3">Live from the yard</p>
      <h2 class="font-display text-display-lg">A glance at panel bay 3.</h2>
    </div>

    <figure class="reveal">
      <div
        class="relative w-full aspect-video bg-navy-700 rounded-lg overflow-hidden shadow-soft ring-1 ring-cast-100"
        role="img"
        aria-label="Live still from the Holsworthy yard, panel bay 3"
      >
        <img
          src="/images/factory-hero.jpg"
          alt="Holsworthy yard, panel bay 3 — most recent still"
          class="absolute inset-0 w-full h-full object-cover"
          loading="lazy"
          decoding="async"
        />

        <!-- Timestamp badge -->
        <div class="absolute top-4 right-4 z-10">
          <span
            id="yard-cam-timestamp"
            class="inline-flex items-center gap-2 px-3 py-1.5 bg-navy-700/85 text-white text-xs font-bold uppercase tracking-wider rounded backdrop-blur-sm"
            aria-live="polite"
          >
            <span aria-hidden="true" class="w-1.5 h-1.5 rounded-full bg-yellow animate-pulse-soft"></span>
            <span class="sr-only">Last refreshed at </span>
            <span data-yard-cam-label>Last refreshed: --:--</span>
          </span>
        </div>

        <!-- Bottom navy gradient + caption overlay -->
        <div aria-hidden="true" class="absolute inset-x-0 bottom-0 h-1/3 bg-gradient-to-t from-navy-700/95 via-navy-700/55 to-transparent"></div>
        <figcaption class="absolute bottom-4 left-4 right-4 z-10 text-white">
          <p class="text-sm font-bold uppercase tracking-wider">
            Holsworthy yard <span aria-hidden="true">·</span> panel bay 3
          </p>
        </figcaption>
      </div>

      <p class="mt-4 text-sm text-cast">
        Refreshed every 5 minutes during yard hours. Pulled from the yard's network camera (planned 2026).
      </p>
    </figure>
  </section>

  <script is:inline>
    (function () {
      const labelEl = document.querySelector('[data-yard-cam-label]');
      if (!labelEl) return;

      const formatter = new Intl.DateTimeFormat('en-GB', {
        timeZone: 'Europe/London',
        hour: '2-digit',
        minute: '2-digit',
      });

      const render = function () {
        labelEl.textContent = 'Last refreshed: ' + formatter.format(new Date());
      };

      render();
      setInterval(render, 60000);
    })();
  </script>

  <!-- Stats strip -->
  <section class="bg-bone-200 py-12">
    <div class="container-wccp">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {stats.map((s) => (
          <div class="card p-6 text-center">
            <div class="font-display font-bold text-display-lg text-navy mb-1">{s.value}</div>
            <div class="text-cast text-sm font-medium uppercase tracking-wide">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Photo grid placeholder -->
  <section class="container-wccp py-20">
    <div class="max-w-2xl mb-12">
      <p class="eyebrow text-cast mb-3">The yard</p>
      <h2 class="font-display text-display-lg">Inside the factory.</h2>
    </div>

    <div class="grid grid-cols-2 lg:grid-cols-3 gap-3">
      <div class="aspect-[4/3] bg-cast-100 rounded overflow-hidden col-span-2 lg:col-span-2 lg:row-span-2">
        <picture>
          <source srcset="/images/products/home/wccp-home-20130306-1249271-1024x768.webp" type="image/webp" />
          <img src="/images/products/home/wccp-home-20130306-1249271-1024x768.jpg" alt="WCCP Holsworthy yard with stacked precast box culverts" class="w-full h-full object-cover" loading="lazy" decoding="async" />
        </picture>
      </div>
      <div class="aspect-[4/3] bg-cast-100 rounded overflow-hidden">
        <picture>
          <source srcset="/images/products/home/wccp-home-img-20260414-162247920-comp-1024x1024.webp" type="image/webp" />
          <img src="/images/products/home/wccp-home-img-20260414-162247920-comp-1024x1024.jpg" alt="WCCP slatted precast slurry covers in the Holsworthy yard" class="w-full h-full object-cover" loading="lazy" decoding="async" />
        </picture>
      </div>
      <div class="aspect-[4/3] bg-cast-100 rounded overflow-hidden">
        <picture>
          <source srcset="/images/products/home/wccp-home-img-20260414-162319990-comp-1024x1024.webp" type="image/webp" />
          <img src="/images/products/home/wccp-home-img-20260414-162319990-comp-1024x1024.jpg" alt="WCCP precast wall posts ready for dispatch from the Devon yard" class="w-full h-full object-cover" loading="lazy" decoding="async" />
        </picture>
      </div>
      <div class="aspect-[4/3] bg-cast-100 rounded overflow-hidden">
        <picture>
          <source srcset="/images/products/home/wccp-home-concrete-panels-copy.webp" type="image/webp" />
          <img src="/images/products/home/wccp-home-concrete-panels-copy.jpg" alt="WCCP precast concrete panels stacked at the Holsworthy yard" class="w-full h-full object-cover" loading="lazy" decoding="async" />
        </picture>
      </div>
      <div class="aspect-[4/3] bg-cast-100 rounded overflow-hidden">
        <picture>
          <source srcset="/images/products/home/wccp-home-free-standing-wall-section.webp" type="image/webp" />
          <img src="/images/products/home/wccp-home-free-standing-wall-section.jpg" alt="WCCP free-standing precast wall section in the yard" class="w-full h-full object-cover" loading="lazy" decoding="async" />
        </picture>
      </div>
      <div class="aspect-[4/3] bg-cast-100 rounded overflow-hidden">
        <picture>
          <source srcset="/images/products/home/wccp-home-20140615-193135-1024x768.webp" type="image/webp" />
          <img src="/images/products/home/wccp-home-20140615-193135-1024x768.jpg" alt="WCCP king-post precast retaining wall installed on a Devon site" class="w-full h-full object-cover" loading="lazy" decoding="async" />
        </picture>
      </div>
    </div>
  </section>

  <!-- Capabilities -->
  <section class="bg-bone-200 py-20">
    <div class="container-wccp">
      <div class="max-w-2xl mb-12">
        <p class="eyebrow text-cast mb-3">What's on site</p>
        <h2 class="font-display text-display-lg">Capability, plain and listed.</h2>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
        {capabilities.map((c) => (
          <div class="card p-6">
            <h3 class="font-display text-xl font-bold text-navy mb-3">{c.title}</h3>
            <p class="text-cast-700 leading-relaxed">{c.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Severn Trent / circular economy -->
  <section class="container-wccp py-20">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <div>
        <p class="eyebrow text-cast mb-3">Next door: Severn Trent biogas</p>
        <h2 class="font-display text-display-lg mb-6">Co-located with an anaerobic digestion plant.</h2>
        <p class="text-cast-700 text-lg leading-relaxed mb-5">
          The Chilsworthy yard sits adjacent to the Holsworthy Biogas Plant, owned by
          <strong class="text-navy-700">Severn Trent Green Power</strong> — the FTSE-100 utility's
          renewable arm, and one of the largest food-waste biogas plants in the UK. The neighbour
          relationship is a circular-economy story: food-waste digestate one side of the fence,
          precast concrete the other.
        </p>
        <p class="text-cast-700 text-lg leading-relaxed mb-8">
          Concrete is one of the most carbon-intensive materials in construction. Sitting next door
          to renewable energy isn't a fix on its own — but it's a real start, and a sensible one.
        </p>

        {/* CLIENT: confirm exact silo / water-tower / workshop counts and concrete batching capacity figures. */}
        <dl class="grid grid-cols-2 gap-4 mb-8 max-w-md">
          <div class="border-l-2 border-ember pl-3">
            <dt class="text-xs uppercase tracking-wider text-cast font-bold">Batching capacity</dt>
            <dd class="font-display text-display-sm text-navy-700">{/* CLIENT: confirm */}~ m³/hr</dd>
          </div>
          <div class="border-l-2 border-ember pl-3">
            <dt class="text-xs uppercase tracking-wider text-cast font-bold">Silos on site</dt>
            <dd class="font-display text-display-sm text-navy-700">{/* CLIENT: confirm */}n</dd>
          </div>
          <div class="border-l-2 border-ember pl-3">
            <dt class="text-xs uppercase tracking-wider text-cast font-bold">Water towers</dt>
            <dd class="font-display text-display-sm text-navy-700">{/* CLIENT: confirm */}n</dd>
          </div>
          <div class="border-l-2 border-ember pl-3">
            <dt class="text-xs uppercase tracking-wider text-cast font-bold">Workshops</dt>
            <dd class="font-display text-display-sm text-navy-700">{/* CLIENT: confirm */}n</dd>
          </div>
        </dl>
        <a href="/sustainability" class="btn-secondary">Sustainability & accreditations</a>
      </div>
      <div class="aspect-[4/3] bg-cast-100 rounded overflow-hidden">
        <picture>
          <source srcset="/images/products/home/wccp-home-20130306-1249271-1024x768.webp" type="image/webp" />
          <img src="/images/products/home/wccp-home-20130306-1249271-1024x768.jpg" alt="WCCP Holsworthy yard, beside the Severn Trent biogas plant" class="w-full h-full object-cover" loading="lazy" decoding="async" />
        </picture>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-yellow text-navy py-16">
    <div class="container-wccp text-center">
      <p class="eyebrow text-navy mb-3">Open to visitors by appointment</p>
      <h2 class="font-display text-display-xl mb-4">Book a factory tour.</h2>
      <p class="text-navy text-lg max-w-xl mx-auto mb-8">
        Bring your drawings, your engineer, or just yourself. We'll show you round, talk through your
        job, and stand the kettle on.
      </p>
      <div class="flex flex-wrap justify-center gap-3">
        <a href="/contact" class="btn-secondary">Request a tour</a>
        <a href={`tel:${site.contact.phoneIntl}`} class="btn bg-navy text-white hover:bg-navy-700">
          Call {site.contact.phone}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
