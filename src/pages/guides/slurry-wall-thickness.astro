        />
        <!-- Sticky TOC (desktop) -->
        <aside class="hidden lg:block">
          <p class="eyebrow text-cast mb-4">On this page</p>
          <ol class="space-y-3 text-sm border-l border-cast-100 pl-4">
            <li><a href="#ssafo" class="text-cast hover:text-ember">What SSAFO 2018 requires</a></li>
            <li><a href="#thickness-by-height" class="text-cast hover:text-ember">Thickness by retained height</a></li>
            <li><a href="#comparison" class="text-cast hover:text-ember">200mm vs 250mm vs 300mm</a></li>
            <li><a href="#concrete-grade" class="text-cast hover:text-ember">Concrete grade</a></li>
            <li><a href="#reinforcement" class="text-cast hover:text-ember">Reinforcement and cover</a></li>
            <li><a href="#mistakes" class="text-cast hover:text-ember">Common mistakes</a></li>
            <li><a href="#checklist" class="text-cast hover:text-ember">Compliance checklist</a></li>
            <li><a href="#faq" class="text-cast hover:text-ember">FAQ</a></li>
          </ol>

          <div class="mt-8 p-4 bg-yellow rounded-lg">
