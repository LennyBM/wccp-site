---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { site } from '@/config/site';

const faqs = [
  {
    q: 'What drives the cost of a king post retaining wall?',
    a: 'Five engineering inputs do most of the work: retained height (post size and panel thickness scale steeply), surcharge case (vehicle or stockpile loading), foundation conditions (cohesive clay vs sand vs rock), install method (supply-only vs installed) and site access (crane standing, gate widths, rural tracks). Get those five right at brief stage and the quote becomes precise.',
  },
  {
    q: 'What is included in supply-only?',
    a: 'Supply-only covers the steel UC posts cut to length, precast infill panels, joint sealant and ex-yard delivery within the South West. It excludes site survey, foundations, post sockets, excavation, backfill, drainage, geotextiles and labour for installation. The boundary between yard and site is the truck tail-lift.',
  },
  {
    q: 'How do post sockets affect cost?',
    a: 'Sockets are the wildcard input. Diameter and depth scale with retained height — typical sizes run 600mm × 1.5m for 2m walls up to 1,200mm × 3.0m at 5m walls. Hard ground (slate, granite) slows auger progress; very soft ground may force piling. We always note the soil assumption in the quote so any change can be priced cleanly.',
  },
  {
    q: 'Does soil type change the cost?',
    a: 'Yes. Cohesive clays are the cheapest to retain — sockets and foundations are easier and surcharge tolerance is higher. Granular sands and gravels need deeper sockets or longer toes. Made ground, peat and very wet sites can require piling or ground improvement, which significantly increases the foundation share of the build.',
  },
  {
    q: 'What about delivery?',
    a: 'Delivery within 50 miles of our Holsworthy yard is included on full-load orders. Beyond that we charge by the mile. Part-load deliveries or restricted access (rural farm tracks, urban sites with crane offload) are quoted individually — tell us about gate widths and standing area at brief.',
  },
  {
    q: 'Can I install the wall myself?',
    a: 'Yes for short, low walls (under 2m height, under 30m run) provided you have post-driving or auger access. Most farm contractors handle 2m–3m supply-only installs. Above 3m, or with significant surcharge, we recommend our installed price — the engineering and post embedment is unforgiving.',
  },
  {
    q: 'How is supply-only different from installed on cost?',
    a: 'Supply-only means our truck delivers panels, posts, sealant and design pack. Installed adds setting-out, augering, post embedment to tolerance, panel infill, joint sealing, crane time, and a defects liability period. Supply-only suits experienced groundworks crews; installed suits programme-critical or technically tall walls where re-work risk is unacceptable.',
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

const articleSchema = {
  headline: 'What drives the cost of a UK retaining wall?',
  datePublished: '2026-04-04',
  dateModified: '2026-04-28',
  author: {
    '@type': 'Organization',
    name: 'WCCP Engineering',
    url: 'https://wccp.co.uk',
  },
};
---

<BaseLayout
  title="What drives the cost of a UK retaining wall?"
  description="UK retaining wall cost drivers explained: retained height, surcharge case, foundation conditions, install method and site access. How engineering inputs shape king post and panel-and-post wall pricing — without the wild ranges."
  image="/images/case-studies/civils-retaining.jpg"
  schema="Article"
  schemaData={articleSchema}
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)} slot="head" />
  <section class="bg-navy text-white">
    <div class="container-wccp py-14 md:py-16">
      <nav class="text-sm text-white/90 mb-6" aria-label="Breadcrumb">
        <a href="/guides" class="hover:text-yellow">Guides</a>
        <span class="mx-2 text-cast">/</span>
        <span class="text-white/90">What drives retaining wall cost</span>
      </nav>
      <p class="eyebrow text-yellow mb-4">Engineering inputs · Pillar guide</p>
      <h1 class="font-display text-display-xl text-white mb-6 max-w-4xl">
        What drives the cost of a UK retaining wall?
      </h1>

      <div class="bg-navy-700 border-l-4 border-yellow p-6 max-w-3xl rounded-r">
        <p class="text-white/90 text-lg leading-relaxed">
          <strong class="text-white">Direct answer:</strong> Retaining wall cost is shaped by five
          engineering inputs — retained height, surcharge case (vehicle or stockpile loading),
          foundation conditions, install method (supply-only vs installed) and site access. Get
          those five right at brief stage and you stop paying the cost of unknowns. WCCP cast king
          post and panel-and-post systems to BS EN 1992-1-1 from 1.0m to 6.0m.
        </p>
      </div>

      <div class="mt-8 flex flex-wrap items-center gap-x-6 gap-y-2 text-sm text-white/90">
        <div>By <span class="text-white font-semibold">WCCP Engineering Team</span></div>
        <div>Published <time datetime="2026-04-04">4 April 2026</time></div>
        <div>Updated <time datetime="2026-04-28">28 April 2026</time></div>
      </div>
    </div>
  </section>

  <article class="container-wccp py-12 md:py-16">
    <div class="grid lg:grid-cols-[1fr_18rem] gap-10 lg:gap-16">
      <div class="max-w-3xl">

        <details class="lg:hidden mb-10 border border-cast-100 rounded-lg p-5">
          <summary class="font-display text-lg font-bold text-navy cursor-pointer">On this page</summary>
          <ol class="mt-4 space-y-2 text-cast list-decimal list-inside">
            <li><a href="#drivers" class="hover:text-ember">What drives cost</a></li>
            <li><a href="#height" class="hover:text-ember">Retained height</a></li>
            <li><a href="#surcharge" class="hover:text-ember">Surcharge and loading</a></li>
            <li><a href="#foundation" class="hover:text-ember">Foundation conditions</a></li>
            <li><a href="#supply-vs-install" class="hover:text-ember">Supply-only vs installed</a></li>
            <li><a href="#access" class="hover:text-ember">Site access</a></li>
            <li><a href="#checklist" class="hover:text-ember">Quote checklist</a></li>
            <li><a href="#faq" class="hover:text-ember">FAQ</a></li>
          </ol>
        </details>

        <section id="drivers" class="mb-12 scroll-mt-24">
          <h2 class="font-display text-3xl text-navy mb-4">What actually drives the cost of a retaining wall?</h2>
          <p class="text-cast-700 text-lg leading-relaxed mb-4">
            <strong class="text-navy">Five inputs do most of the work — retained height, surcharge,
            foundation conditions, install method and site access. Steel post weight, panel thickness,
            socket diameter and crane time all flow from those inputs. Engineering grade is set by the
            loads; you can't shortcut it without compromising design life.</strong>
          </p>
          <p class="text-cast-700 text-lg leading-relaxed mb-4">
            Material costs (steel and concrete) move with global commodity indices. Steel tracks the
            London Metal Exchange and varies year to year; concrete is more stable. On installed walls,
            post sockets are the largest variable — they swing heavily with ground conditions. Design
            and tolerance are a fixed share, regardless of length.
          </p>
          <p class="text-cast-700 text-lg leading-relaxed">
            What's typically not in our quote: drainage (perforated land drain at the wall heel,
            granular surround, geotextile), backfill material, excavation, top rail or fencing, and
            any haunching at top or base. These are quoted separately by us or your groundworks
            contractor. The systems compared in this guide are
            <a href="/products/king-post-walls" class="text-ember underline">king post walls</a>,
            <a href="/products/cantilever-walls" class="text-ember underline">cantilever walls</a>,
            <a href="/products/l-blocks" class="text-ember underline">L-blocks</a>
            and <a href="/products/interlocking-blocks" class="text-ember underline">interlocking blocks</a>
            across the WCCP <a href="/sectors/civils" class="text-ember underline">civils</a> range.
          </p>
        </section>

        <aside class="my-8 p-5 border-l-4 border-ember bg-ember/5 rounded-r-md">
          <p class="font-display font-bold text-navy text-base mb-1">Quote a retaining wall</p>
          <p class="text-sm text-cast mb-3">Five engineering inputs and we can size the design — tell us heights, lengths, surcharge and access.</p>
          <a href="/products/retaining-walls" class="inline-flex items-center gap-1.5 text-ember font-bold link-underline">Start a quote &rarr;</a>
        </aside>

        <section id="height" class="mb-12 scroll-mt-24">
          <h2 class="font-display text-3xl text-navy mb-4">How does retained height shape the build?</h2>
          <p class="text-cast-700 text-lg leading-relaxed mb-6">
            <strong class="text-navy">Cost per linear metre roughly doubles between 1m and 3m, and again
            between 3m and 5m. Posts get heavier (152×152 UC23 at 1m → 305×305 UC97 at 5m), panels
            get thicker, sockets get deeper, and crane time per post goes up. Above 5m the curve
            steepens further as design moves bespoke.</strong>
          </p>

          <div class="overflow-x-auto mb-4 -mx-4 sm:mx-0">
            <table class="spec-table min-w-full px-4 sm:px-0">
              <thead>
                <tr>
                  <th>Retained height</th>
                  <th>Typical post size</th>
                  <th>Panel thickness</th>
                  <th>Socket depth</th>
                </tr>
              </thead>
              <tbody class="text-cast">
                <tr>
                  <td>1.0m</td>
                  <td>152×152 UC23</td>
                  <td>150mm</td>
                  <td>1.0m</td>
                </tr>
                <tr>
                  <td>2.0m</td>
                  <td>203×203 UC46</td>
                  <td>180mm</td>
                  <td>1.5m</td>
                </tr>
                <tr>
                  <td>3.0m</td>
                  <td>254×254 UC73</td>
                  <td>200mm</td>
                  <td>2.0m</td>
                </tr>
                <tr>
                  <td>4.0m</td>
                  <td>305×305 UC97</td>
                  <td>225mm</td>
                  <td>2.5m</td>
                </tr>
                <tr>
                  <td>5.0m</td>
                  <td>305×305 UC137</td>
                  <td>250mm</td>
                  <td>3.0m</td>
                </tr>
              </tbody>
            </table>
          </div>
          <p class="text-sm text-cast italic">
            Indicative South West UK schedule for cohesive clay sub-base, surcharge 10 kN/m², posts at 2.0m centres,
            infill panels C40/50. Sockets at 600mm diameter to 4m retained height, 900mm at 5m.
          </p>
        </section>

        <section id="surcharge" class="mb-12 scroll-mt-24">
          <h2 class="font-display text-3xl text-navy mb-4">How does surcharge and loading change the spec?</h2>
          <p class="text-cast-700 text-lg leading-relaxed mb-4">
            <strong class="text-navy">Surcharge is the live load behind the wall — a tractor passing,
            an HGV at the parapet, a stockpile, or a building above. It scales the bending moment
            on the post and the lateral pressure on the panel. A 3m wall with 10 kN/m² surcharge
            is a different design from the same height with 30 kN/m² — heavier posts, thicker panels,
            larger sockets.</strong>
          </p>
          <p class="text-cast-700 text-lg leading-relaxed mb-4">
            Surcharge is often the deciding factor between system choices. A king post wall holding back
            a bank with no traffic above is straightforward. The same wall holding back a yard with
            daily HGV traffic at 30 kN/m² needs much heavier posts and panels — at which point a
            cantilever or panel-and-post system becomes cost-competitive.
          </p>
          <p class="text-cast-700 text-lg leading-relaxed">
            Always tell us the surcharge case at design stage — vehicle type, frequency, distance from
            wall, stockpile heights. Designing for actual loads up front is far cheaper than
            re-engineering for them after the wall is up.
          </p>
        </section>

        <aside class="my-8 p-5 border-l-4 border-ember bg-ember/5 rounded-r-md">
          <p class="font-display font-bold text-navy text-base mb-1">Quote a king post wall</p>
          <p class="text-sm text-cast mb-3">Tell us the surcharge case (HGV, tractor, stockpile, building) and we'll size the post and panel schedule.</p>
          <a href="/products/king-post-walls" class="inline-flex items-center gap-1.5 text-ember font-bold link-underline">Start a quote &rarr;</a>
        </aside>

        <section id="foundation" class="mb-12 scroll-mt-24">
          <h2 class="font-display text-3xl text-navy mb-4">How do foundation conditions shift the build?</h2>
          <p class="text-cast-700 text-lg leading-relaxed mb-4">
            <strong class="text-navy">Stiff clay is the cheapest to build into. Sand, gravel and made
            ground need deeper sockets and add a meaningful share to foundation effort. Soft clay,
            peat and high water table can require piling, doubling foundation effort. Rock at 1.5m
            depth+ slows auger progress significantly.</strong>
          </p>
          <p class="text-cast-700 text-lg leading-relaxed mb-4">
            Soil type also affects surcharge tolerance and toe stability. A wall on stiff clay can
            usually take a tractor passing at 1m. The same wall on soft sand might need either heavier
            posts or a 2m exclusion zone. Proper geotechnical input is essential — a Standard Penetration
            Test (SPT) or hand-auger sample at the wall line is a small cost that prevents orders of
            magnitude more on rework.
          </p>
          <p class="text-cast-700 text-lg leading-relaxed">
            Concrete-filled augered post sockets typically run 600mm diameter at 1.5m depth for 2m
            walls, scaling up to 1,200mm × 3.0m for 5m walls. Tolerance is critical — a post 25mm
            out of plumb at the top of the socket becomes 50mm at the top of the wall, and panels
            won't drop in. On rocky ground (Devon and Cornwall slate, granite) socketing rates drop;
            on soft ground we may recommend driven steel piles instead — typically more reliable
            embedment for similar effort per post. We can quote against assumed ground conditions,
            but we always note assumptions in the quote. If actual conditions differ on site, we
            re-quote — never spec a wall against unknown ground.
          </p>
        </section>

        <section id="supply-vs-install" class="mb-12 scroll-mt-24">
          <h2 class="font-display text-3xl text-navy mb-4">Supply-only vs installed — which makes sense?</h2>
          <p class="text-cast-700 text-lg leading-relaxed mb-4">
            <strong class="text-navy">Supply-only suits self-install on smaller walls (under 3m, under
            50m) with experienced groundworks contractors. Installed suits taller walls, complex sites,
            programme-critical jobs and any client without an in-house team. Installed adds crane,
            install labour, embedment tolerance and warranty — but removes re-work risk.</strong>
          </p>
          <p class="text-cast-700 text-lg leading-relaxed mb-4">
            Most farms with a 250 plant ticket and a self-employed digger driver handle 2m walls
            comfortably. Larger civils contractors can manage 4m+ on supply-only. Installed makes
            sense when the wall is on the critical path and any re-work would cause programme
            damage — installed includes performance warranty.
          </p>
          <p class="text-cast-700 text-lg leading-relaxed">
            We do both. About 70% of our retaining wall jobs across the South West are supply-only,
            30% installed. The installed offer always includes setting-out, post embedment to
            tolerance, panel infill, joint sealing and a defects liability period.
          </p>
        </section>

        <section id="access" class="mb-12 scroll-mt-24">
          <h2 class="font-display text-3xl text-navy mb-4">How does site access change the install?</h2>
          <p class="text-cast-700 text-lg leading-relaxed mb-4">
            <strong class="text-navy">Standing space for a piling or auger rig, gate widths for
            articulated trailers, crane reach and turning radius all shape the install method. A
            constrained urban site behind houses costs differently from a green-field cutting on
            a working farm — the same wall on paper, two different builds in practice.</strong>
          </p>
          <p class="text-cast-700 text-lg leading-relaxed mb-4">
            Tight access usually means smaller plant, smaller deliveries and longer install times.
            We routinely build down rural Devon farm tracks — but we need to know about gate widths,
            overhead obstructions and ground bearing at the standing area before we price.
          </p>
          <p class="text-cast-700 text-lg leading-relaxed">
            Tell us at brief stage: postcode, photos of the access route, any known restrictions
            (overhead lines, weak bridges, stock crossings). We'd rather scope it correctly than
            arrive on day one and find we need to remobilise.
          </p>
        </section>

        <section id="checklist" class="mb-12 scroll-mt-24">
          <h2 class="font-display text-3xl text-navy mb-4">What we need to give you an accurate quote (8-point checklist)</h2>
          <div class="bg-bone-200 border-l-4 border-ember p-6 rounded-r">
            <ol class="text-cast-700 text-base leading-relaxed space-y-3 list-decimal pl-5">
              <li>Run length in metres (or a sketched plan with dimensions)</li>
              <li>Maximum retained height (and minimum if the wall steps)</li>
              <li>Surcharge: vehicles, stockpiles, buildings near the wall</li>
              <li>Soil type if known (clay, sand, made ground, rock)</li>
              <li>Site access (road width, gate height, crane standing area)</li>
              <li>Programme dates (start on site, completion)</li>
              <li>Supply-only or installed preferred</li>
              <li>Postcode for delivery costing</li>
            </ol>
          </div>

          <aside class="my-8 p-5 border-l-4 border-ember bg-ember/5 rounded-r-md">
            <p class="font-display font-bold text-navy text-base mb-1">Quote a retaining wall</p>
            <p class="text-sm text-cast mb-3">Send the eight inputs above — we'll come back with a fixed price within 24 hours.</p>
            <a href="/quote?product=retaining-walls" class="inline-flex items-center gap-1.5 text-ember font-bold link-underline">Start a quote &rarr;</a>
          </aside>
        </section>

        <section id="faq" class="mb-12 scroll-mt-24">
          <h2 class="font-display text-3xl text-navy mb-6">Frequently asked questions</h2>
          <div class="space-y-4">
            {faqs.map((f) => (
              <details class="card p-5 group">
                <summary class="font-display text-lg font-bold text-navy cursor-pointer flex items-start justify-between gap-4">
                  <span>{f.q}</span>
                  <svg class="w-5 h-5 mt-1 flex-shrink-0 text-ember transition-transform group-open:rotate-45" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <line x1="12" y1="5" x2="12" y2="19" stroke-linecap="round"/>
                    <line x1="5" y1="12" x2="19" y2="12" stroke-linecap="round"/>
                  </svg>
                </summary>
                <p class="text-cast-700 leading-relaxed mt-4">{f.a}</p>
              </details>
            ))}
          </div>
        </section>

        <section class="bg-navy text-white rounded-lg p-8 md:p-10">
          <h2 class="font-display text-2xl md:text-3xl text-white mb-3">Ready for a fixed quote?</h2>
          <p class="text-white/90 mb-6 leading-relaxed">
            Send us your run length, retained height and surcharge case. We'll come back with a
            fixed price for supply-only and installed within 24 hours.
          </p>
          <div class="flex flex-wrap gap-3">
            <a href="/products/retaining-walls" class="btn-yellow">See retaining wall range</a>
            <a href="/quote" class="btn bg-white text-navy hover:bg-bone">Start a quote</a>
          </div>
        </section>

      </div>

      <aside class="hidden lg:block">
        <div class="sticky top-24">
          <p class="eyebrow text-cast mb-4">On this page</p>
          <ol class="space-y-3 text-sm border-l border-cast-100 pl-4">
            <li><a href="#drivers" class="text-cast hover:text-ember">What drives cost</a></li>
            <li><a href="#height" class="text-cast hover:text-ember">Retained height</a></li>
            <li><a href="#surcharge" class="text-cast hover:text-ember">Surcharge and loading</a></li>
            <li><a href="#foundation" class="text-cast hover:text-ember">Foundation conditions</a></li>
            <li><a href="#supply-vs-install" class="text-cast hover:text-ember">Supply vs installed</a></li>
            <li><a href="#access" class="text-cast hover:text-ember">Site access</a></li>
            <li><a href="#checklist" class="text-cast hover:text-ember">Quote checklist</a></li>
            <li><a href="#faq" class="text-cast hover:text-ember">FAQ</a></li>
          </ol>

          <div class="mt-8 p-4 bg-yellow rounded-lg">
            <p class="text-xs font-bold text-navy uppercase tracking-wide mb-2">Same-day pricing</p>
            <p class="text-sm text-navy mb-3 leading-snug">Send heights, lengths, surcharge — costs back within 24 hours.</p>
            <a href="/quote" class="text-navy font-bold text-sm hover:underline">Start a quote &rarr;</a>
          </div>
        </div>
      </aside>
    </div>
  </article>

  <section class="bg-bone-200 py-16">
    <div class="container-wccp">
      <p class="eyebrow text-cast mb-3">Related guides</p>
      <h2 class="font-display text-display-md mb-8">Keep reading.</h2>

      <div class="grid md:grid-cols-3 gap-5">
        <a href="/guides/retaining-wall-types" class="card p-6 group">
          <span class="eyebrow text-ember mb-3 block">Civils</span>
          <h3 class="font-display text-lg font-bold text-navy mb-2 group-hover:text-ember">King post vs L-block vs cantilever</h3>
          <p class="text-cast text-sm leading-relaxed">Pick the right system before you price it — height, surcharge and run length.</p>
        </a>
        <a href="/guides/concrete-grades" class="card p-6 group">
          <span class="eyebrow text-ember mb-3 block">Materials</span>
          <h3 class="font-display text-lg font-bold text-navy mb-2 group-hover:text-ember">Concrete grades for agricultural use</h3>
          <p class="text-cast text-sm leading-relaxed">C32/40 vs C40/50 explained, exposure classes and panel mix design.</p>
        </a>
        <a href="/guides/prestressed-vs-reinforced" class="card p-6 group">
          <span class="eyebrow text-ember mb-3 block">Materials</span>
          <h3 class="font-display text-lg font-bold text-navy mb-2 group-hover:text-ember">Prestressed vs reinforced panels</h3>
          <p class="text-cast text-sm leading-relaxed">When prestressing pays back — span, load and BS EN 14992.</p>
        </a>
      </div>
    </div>
  </section>

  <section class="container-wccp py-16 text-center">
    <h2 class="font-display text-display-lg mb-4">Talk to the yard.</h2>
    <p class="text-cast-700 text-lg max-w-xl mx-auto mb-8">
      Same-day callback Monday to Friday. We'll talk you through the design before you commit a penny.
    </p>
    <div class="flex flex-wrap justify-center gap-3">
      <a href={`tel:${site.contact.phoneIntl}`} class="btn-secondary">Call {site.contact.phone}</a>
      <a href="/quote" class="btn-primary">Configure a quote</a>
    </div>
  </section>
</BaseLayout>
