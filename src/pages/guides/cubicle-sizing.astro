            <li><a href="#breed-table" class="hover:text-ember">Breed-by-breed sizing table</a></li>
            <li><a href="#bodyweight" class="hover:text-ember">Body weight vs cubicle dimensions</a></li>
            <li><a href="#neck-rail" class="hover:text-ember">Neck rail height</a></li>
            <li><a href="#brisket-board" class="hover:text-ember">Brisket board position</a></li>
            <li><a href="#lunge-space" class="hover:text-ember">Lunge space</a></li>
            <li><a href="#mistakes" class="hover:text-ember">Common sizing mistakes</a></li>
            <li><a href="#checklist" class="hover:text-ember">Sizing checklist</a></li>
            <li><a href="#faq" class="hover:text-ember">FAQ</a></li>
          </ol>
