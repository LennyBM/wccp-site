---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { site } from '@/config/site';

const faqs = [
  {
    q: 'What is the standard UK cattle cubicle size for Holsteins?',
    a: 'A standard UK Holstein-Friesian cubicle is 2.4m long by 1.2m wide, with the neck rail 1.15m above the bed and the brisket board 1.7m forward of the rear kerb. AHDB Dairy 2024 guidance treats this as the baseline for cows of 600–700kg liveweight.',
  },
  {
    q: 'How do I size a cubicle for Jersey cows?',
    a: 'Jerseys are smaller — typically 380–500kg — so cubicles are reduced to 2.2m long by 1.1m wide, with neck rail at 1.05m and brisket board 1.55m from the kerb. Oversizing a Jersey cubicle leads to soiled beds and elevated cell counts.',
  },
  {
    q: 'What size cubicle does a beef suckler cow need?',
    a: 'Suckler beef cubicles run 2.4m × 1.2m for medium frames and 2.5m × 1.25m for Continental breeds (Limousin, Charolais, Simmental). Neck rail sits at 1.20m–1.25m to accommodate the deeper chest and longer rising arc compared with a dairy cow.',
  },
  {
    q: 'How high should the neck rail be?',
    a: 'For a 650kg Holstein, set the neck rail at 1.15m above the bed surface. The rule of thumb is 0.83 × wither height. Too low and cows refuse to enter; too high and they stand half-in, dunging on the bed. Adjust seasonally if bedding depth changes.',
  },
  {
    q: 'Where should the brisket board sit?',
    a: 'The brisket board should be 1.7m from the rear kerb for a Holstein, 1.55m for a Jersey, and 1.75m–1.8m for a large Continental. Maximum height 100mm and rounded — a sharp or tall brisket board causes hock and knee lesions when the cow rises.',
  },
  {
    q: 'Can I retrofit cubicles to a different breed?',
    a: 'Yes. Most WCCP cubicle divisions are bolt-down or socketed, so length, width and neck rail can be repositioned. Brisket boards and head rails are typically replaced rather than moved. Allow half a day per row of 20 cubicles for a full reconfiguration.',
  },
  {
    q: 'What does AHDB say about lunge space?',
    a: 'AHDB Dairy 2024 specifies 0.6m of clear lunge space forward of the brisket board for an open-fronted cubicle, or a head-to-head pair of 4.8m total length. Cows lunge forward 0.6–0.9m when rising, and obstructing that motion causes refusals and injuries.',
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<BaseLayout
  title="What size cattle cubicle does a Holstein, Jersey or beef cow need?"
  description="UK cattle cubicle sizing by breed: 2.4m × 1.2m Holstein, 2.2m × 1.1m Jersey, up to 2.5m × 1.25m beef. Neck rail, brisket board, lunge space and AHDB Dairy 2024 standards."
  image="/images/guides/cubicle-sizing.jpg"
  schema="Article"
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)} slot="head" />
  <!-- Hero -->
  <section class="bg-navy text-white">
    <div class="container-wccp py-14 md:py-16">
      <nav class="text-sm text-white/90 mb-6" aria-label="Breadcrumb">
        <a href="/guides" class="hover:text-yellow">Guides</a>
        <span class="mx-2 text-cast">/</span>
        <span class="text-white/90">Cattle cubicle sizing</span>
      </nav>
      <p class="eyebrow text-yellow mb-4">Cattle housing · Pillar guide</p>
      <h1 class="font-display text-display-xl text-white mb-6 max-w-4xl">
        What size cattle cubicle does a Holstein, Jersey or beef cow need?
      </h1>

      <div class="bg-navy-700 border-l-4 border-yellow p-6 max-w-3xl rounded-r">
        <p class="text-white/90 text-lg leading-relaxed">
          <strong class="text-white">Direct answer:</strong> A standard UK Holstein-Friesian cattle
          cubicle measures 2.4m long by 1.2m wide, with a neck rail at 1.15m and a brisket board
          1.7m from the kerb (AHDB Dairy 2024). Jerseys typically use 2.2m × 1.1m; beef breeds
          2.4m × 1.2m to 2.5m × 1.25m for Continental crosses.
        </p>
      </div>

