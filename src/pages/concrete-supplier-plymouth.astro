---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TrustStrip from '@/components/TrustStrip.astro';
import RelatedProductGrid from '@/components/RelatedProductGrid.astro';
import { site } from '@/config/site';

const city = 'Plymouth';
const county = 'Devon';
const distanceMi = 45;
const driveTime = 'an hour';

const surroundingAreas = [
  'Plympton', 'Plymstock', 'Saltash', 'Tavistock', 'Yelverton',
  'Ivybridge', 'Crownhill', 'Devonport', 'Yealmpton', 'Wembury',
];

const distances = [
  { name: 'Plymouth city centre', mi: 45 },
  { name: 'Tavistock', mi: 32 },
  { name: 'Saltash', mi: 48 },
  { name: 'Ivybridge', mi: 55 },
];

const faqs = [
  { q: `Do you deliver to Plymouth and the South Devon coast?`, a: `Yes — Plymouth is roughly 45 miles from our Holsworthy yard via the A386. Same lorries we run to Tavistock and Yelverton. Most catalogue loads land within 2–3 working days of order, on our own HIAB-equipped trucks.` },
  { q: 'Do you deliver to villages around Plymouth — Plympton, Plymstock, Yealmpton?', a: 'All of them, plus the harder-to-reach spots. Tight farm lanes around Yealmpton and Wembury are normal for us; we will switch to a rigid 8-wheeler from an artic where needed and recce difficult access before the first load.' },
  { q: 'Lead time for a Plymouth job?', a: 'Catalogue items 2–3 weeks. Bespoke and engineered precast — padstones, retaining walls cut to height, civils items — quoted from drawings, typically four to six weeks from approved design.' },
  { q: 'Do you supply Plymouth main contractors and the highways supply chain?', a: 'Yes. We supply precast retaining walls, padstones, headwalls and bespoke civils items into Plymouth-based principal contractors working for Devon County Council, Plymouth City Council and National Highways across the South West.' },
];

const related = [
  { href: '/products/cattle-cubicles',     label: 'Cattle Cubicles',     meta: 'AHDB 2024 sized' },
  { href: '/products/retaining-walls',     label: 'Retaining Walls',     meta: 'L / King-post / Cantilever' },
  { href: '/products/padstones',           label: 'Padstones',           meta: 'Eurocode 6 sized' },
  { href: '/products/culverts',            label: 'Box Culverts',        meta: 'BS EN 1916 / BS 5911' },
];

const serviceSchema = {
  name: `Precast concrete supplier in ${city}`,
  description: `Precast concrete delivered to ${city} and South ${county} from the WCCP yard in Holsworthy — roughly ${distanceMi} miles. Cubicles, retaining walls, padstones, culverts.`,
  serviceType: 'Precast concrete manufacture and delivery',
  areaServed: [{ '@type': 'City', name: city }, { '@type': 'AdministrativeArea', name: 'South Hams' }],
  mainEntityOfPage: `${site.url}/concrete-supplier-plymouth`,
};
---

<BaseLayout
  title={`Precast concrete supplier ${city} · WCCP`}
  description={`Precast concrete supplier delivering to ${city} and the South Hams from our Holsworthy yard, ${distanceMi} miles via the A386. Cubicles, retaining walls, padstones.`}
  schema="Service"
  schemaData={serviceSchema}
>
  <section class="bg-forest-700 text-cream">
    <div class="container-wccp py-20 md:py-28">
      <p class="eyebrow text-cream/70 mb-4">Areas served · {city}</p>
      <h1 class="font-display text-display-2xl text-cream mb-6 max-w-4xl">
        Precast concrete supplier in {city}.<br />
        <em class="text-terracotta not-italic font-display italic">Cast in North Devon. On site in days.</em>
      </h1>
      <p class="text-cream/85 text-lg leading-relaxed max-w-3xl mb-8">
        WCCP delivers precast concrete to {city} from our Holsworthy yard, {driveTime} away
        via the A386. Common Plymouth precast jobs:
        <a href="/products/retaining-walls" class="text-terracotta-300 underline-offset-4 hover:underline">retaining walls</a> for
        city-fringe civils, <a href="/products/padstones" class="text-terracotta-300 underline-offset-4 hover:underline"> padstones</a> for
        new-build steel frames and <a href="/products/cattle-cubicles" class="text-terracotta-300 underline-offset-4 hover:underline"> cattle cubicles</a> for
        South Hams dairies. Lead times: 2–3 weeks for catalogue items, 4–6 weeks bespoke.
        Recent deliveries: Tavistock, Yelverton and Ivybridge.
      </p>
      <div class="flex flex-wrap gap-3">
        <a href="/quote" class="btn-primary">Get a quote</a>
        <a href={`tel:${site.contact.phoneIntl}`} class="btn-yellow">Call {site.contact.phone}</a>
      </div>
    </div>
  </section>

  <TrustStrip />

  <section class="container-wccp py-16 md:py-20 section-reveal">
    <div class="grid lg:grid-cols-2 gap-10 items-start">
      <div>
        <p class="eyebrow text-cast mb-3">From the yard</p>
        <h2 class="font-display text-display-md text-forest-700 mb-4">
          Holsworthy to {city}: roughly {distanceMi} miles.
        </h2>
        <p class="text-cast-700 leading-relaxed">
          A386 south through Tavistock, then A386/A38 into Plymouth. Typical delivery 2–3 days from
          order on catalogue items. We run our own HIAB-equipped lorries — most loads are unloaded
          straight to where the bricklayer needs them, no third-party haulier and no missing kit
          on day one.
        </p>
      </div>
      <ul class="space-y-3">
        {distances.map((d) => (
          <li class="flex items-baseline justify-between border-b border-cast-100 pb-3">
            <span class="font-display text-lg font-semibold text-forest-700">{d.name}</span>
            <span class="text-cast tabular-nums">~{d.mi} mi</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="bg-cream-200 py-16 md:py-20 section-reveal">
    <div class="container-wccp">
      <div class="max-w-3xl mb-10">
        <p class="eyebrow text-cast mb-3">Why {city} contractors and farms choose WCCP</p>
        <h2 class="font-display text-display-md text-forest-700 mb-4">A386 north, hour to the yard.</h2>
      </div>
      <div class="grid md:grid-cols-2 gap-6 max-w-4xl">
        <div class="card p-6">
          <h3 class="font-display text-lg font-bold text-forest-700 mb-2">Plymouth and Devonport contractors</h3>
          <p class="text-cast-700 leading-relaxed">Trusted on Devon CC and Plymouth City Council frameworks for <a href="/products/retaining-walls" class="text-terracotta font-semibold hover:underline">retaining walls</a>, <a href="/products/culverts" class="text-terracotta font-semibold hover:underline">box culverts</a> and <a href="/products/padstones" class="text-terracotta font-semibold hover:underline">padstones</a>.</p>
        </div>
        <div class="card p-6">
          <h3 class="font-display text-lg font-bold text-forest-700 mb-2">South Hams dairy and beef</h3>
          <p class="text-cast-700 leading-relaxed">Yealmpton, Wembury and the South Hams villages — <a href="/products/cattle-cubicles" class="text-terracotta font-semibold hover:underline">cattle cubicles</a> and <a href="/products/feed-troughs" class="text-terracotta font-semibold hover:underline">feed troughs</a> sized to your herd.</p>
        </div>
        <div class="card p-6">
          <h3 class="font-display text-lg font-bold text-forest-700 mb-2">Tight farm-lane access</h3>
          <p class="text-cast-700 leading-relaxed">Devon farm drives are routine for our drivers — we recce in advance and switch from artic to rigid 8-wheeler where the lane demands it.</p>
        </div>
        <div class="card p-6">
          <h3 class="font-display text-lg font-bold text-forest-700 mb-2">Self-build architects</h3>
          <p class="text-cast-700 leading-relaxed">Eurocode 6 <a href="/products/padstones" class="text-terracotta font-semibold hover:underline">padstones</a> cast to drawings inside three weeks for South Devon self-builds and timber-frame houses.</p>
        </div>
      </div>
      <div class="mt-8">
        <a href="/quote" class="btn-primary">Get a quote</a>
      </div>
    </div>
  </section>

  <section class="container-wccp py-16 md:py-20 section-reveal">
    <div class="max-w-2xl mb-10">
      <p class="eyebrow text-cast mb-3">Areas covered</p>
      <h2 class="font-display text-display-md text-forest-700 mb-4">{city} and the South Hams.</h2>
      <p class="text-cast-700">From the city centre out to the rural fringe — same lorry, same lead time.</p>
    </div>
    <ul class="grid sm:grid-cols-2 md:grid-cols-3 gap-x-6 gap-y-2 max-w-3xl">
      {surroundingAreas.map((a) => (
        <li class="flex gap-2 text-cast-700"><span class="text-terracotta font-bold">·</span> {a}</li>
      ))}
    </ul>
  </section>

  <section class="bg-cream-200 py-16 md:py-20 section-reveal">
    <div class="container-wccp">
      <div class="max-w-2xl mb-10">
        <p class="eyebrow text-cast mb-3">What we cast</p>
        <h2 class="font-display text-display-md text-forest-700 mb-4">Most ordered around {city}.</h2>
        <p class="text-cast-700">Dairy and beef sheds in the South Hams, civils work in and around the city.</p>
      </div>
      <RelatedProductGrid items={related} />
      <div class="mt-8 flex flex-wrap gap-6 text-sm">
        <a href="/products" class="text-terracotta font-bold hover:text-terracotta-700">See the full catalogue →</a>
        <a href="/case-studies" class="text-terracotta font-bold hover:text-terracotta-700">Recent case studies →</a>
      </div>
    </div>
  </section>

  <section class="container-wccp py-16 md:py-20 section-reveal">
    <div class="max-w-2xl mb-10">
      <p class="eyebrow text-cast mb-3">Common questions</p>
      <h2 class="font-display text-display-md text-forest-700">Delivering to {city}.</h2>
    </div>
    <div class="max-w-3xl space-y-4">
      {faqs.map((f) => (
        <details class="card p-6 group">
          <summary class="font-display text-lg font-bold text-forest-700 cursor-pointer list-none flex justify-between items-start gap-4">
            <span>{f.q}</span>
            <span class="text-terracotta text-2xl leading-none group-open:rotate-45 transition-transform shrink-0">+</span>
          </summary>
          <p class="text-cast-700 leading-relaxed mt-4">{f.a}</p>
        </details>
      ))}
    </div>
  </section>

  <section class="bg-forest-700 text-cream py-16">
    <div class="container-wccp text-center max-w-2xl mx-auto">
      <h2 class="font-display text-display-md text-cream mb-3">Built for {city} jobs, made up the road.</h2>
      <p class="text-cream/85 mb-8">Send a drawing or just describe the job. We'll quote inside a working day.</p>
      <div class="flex flex-wrap justify-center gap-3">
        <a href="/quote" class="btn-primary">Get a quote</a>
        <a href={`tel:${site.contact.phoneIntl}`} class="btn-yellow">Call {site.contact.phone}</a>
      </div>
    </div>
  </section>
</BaseLayout>
