---
import BaseLayout from '@/layouts/BaseLayout.astro';
import CaseStudyIcon from '@/components/CaseStudyIcon.astro';
import { site } from '@/config/site';

// Sorted by year (most recent first), then grouped sensibly so the grid reads
// like a recent-jobs feed rather than a random pile. Sector filter handles
// drill-down; default order is "newest first" because that is what visitors
// scan for on a portfolio.
const caseStudies = [
  {
    slug: 'trewartha-farm-dairy',
    name: 'Trewartha Farm',
    parish: 'St Erth, Cornwall',
    sector: 'Agricultural',
    sectorTag: 'agricultural',
    region: 'cornwall',
    year: '2025',
    product: 'Lely Astronaut robot bases + slurry panels',
    tonnes: '28t',
    days: '14 days',
    // PLACEHOLDER quote/attribution — needs Kim sign-off on real customer name
    quote: '"Level to the millimetre. The Lely engineers commissioned without a single shim."',
    attribution: 'Dairy farmer · St Erth, Cornwall',
    iconType: 'milking-robot' as const,
  },
  {
    slug: 'example-dairy-farm',
    name: 'Higher Beara Farm',
    parish: 'Bratton Clovelly, Devon',
    sector: 'Agricultural',
    sectorTag: 'agricultural',
    region: 'devon',
    year: '2025',
    product: '250mm slurry panels',
    tonnes: '420t',
    days: '11 days',
    quote: '"They turned up when they said they would. The yard was back in use the following week."',
    attribution: 'Mike, herd manager',
    iconType: 'slurry-store' as const,
  },
  {
    slug: 'boscastle-beef-shed',
    name: 'Boscastle beef shed',
    parish: 'Near Boscastle, North Cornwall',
    sector: 'Agricultural',
    sectorTag: 'agricultural',
    region: 'cornwall',
    year: '2025',
    product: 'Cattle cubicles · 250-head FETF conversion',
    tonnes: '95t',
    days: '5 days',
    // PLACEHOLDER quote/attribution — needs Kim sign-off on real customer name
    quote: '"Fitted right first time. The cattle settled in within forty-eight hours."',
    attribution: 'Beef finisher · North Cornwall',
    iconType: 'cubicle-housing' as const,
  },
  {
    slug: 'ashford-estate-civils',
    name: 'Ashford Estate — three-farm modernisation',
    parish: 'Near Tavistock, Devon',
    sector: 'Civils',
    sectorTag: 'civils',
    region: 'devon',
    year: '2025',
    product: 'L-blocks, silage clamps, cubicle refit · 3 farms',
    tonnes: '680t',
    days: '14 days',
    // PLACEHOLDER quote/attribution — needs Kim sign-off on real customer name
    quote: '"One contract, one supplier, three farms — exactly what we asked for."',
    attribution: 'Land agent · estate office near Tavistock',
    iconType: 'civils-roundabout' as const,
  },
  {
    slug: 'henley-railway-footbridge',
    name: 'Henley-on-Thames railway station',
    parish: 'Henley-on-Thames, Oxfordshire',
    sector: 'Civils',
    sectorTag: 'civils',
    region: 'national',
    year: '2024',
    product: '2× bespoke precast box culverts (BS EN 14844)',
    tonnes: 'Bespoke',
    days: 'Cast + sawn at the yard',
    quote: '"Bespoke precast, designed and cast in one yard, with the visible faces finished before despatch — that is how a rail works package should land on site."',
    attribution: 'WCCP engineering team',
    iconType: 'panel' as const,
  },
  {
    slug: 'wessex-ad-plant',
    name: 'Polmorla AD plant',
    parish: 'Wadebridge, Cornwall',
    sector: 'Bespoke',
    sectorTag: 'bespoke',
    region: 'cornwall',
    year: '2024',
    product: 'Bespoke AD tank panels',
    tonnes: '540t',
    days: '21 days',
    quote: '"They engineered around our digester geometry — no off-the-shelf option fitted."',
    attribution: 'Project engineer',
    iconType: 'panel' as const,
  },
];
---

<BaseLayout
  title="Case studies — slurry stores, cubicles, retaining walls"
  description="Real WCCP precast concrete projects — Devon, Cornwall, Somerset, Dorset, Wiltshire, Wales, Scotland, the Outer Hebrides and into Europe. Slurry stores, cubicle housing, retaining walls, civils and bespoke jobs — with tonnage, install days and customer feedback."
>
  <!-- Hero -->
  <section class="bg-navy text-white">
    <div class="container-wccp py-16 md:py-20">
      <div class="max-w-3xl">
        <p class="eyebrow text-yellow mb-5">Our work</p>
        <h1 class="font-display text-display-xl text-white mb-5">
          The jobs we've cast, delivered and stood behind.
        </h1>

        <!-- Direct answer for AI engines -->
        <div class="bg-navy-700 border-l-4 border-yellow p-6 max-w-3xl rounded-r mb-6">
          <p class="text-white/90 text-lg leading-relaxed">
            <strong class="text-white">Direct answer:</strong> WCCP case studies — recent precast
            jobs from across the UK and Europe. Filter by sector or scroll the grid. Each entry
            shows the project's scope, the products supplied, and the install timeline.
          </p>
        </div>

        <p class="text-lg text-white/90 max-w-2xl leading-relaxed">
          Five hundred-plus farms, civils contractors and architects — Cornwall to the Outer Hebrides
          and out into Europe. Pick a sector or a region and see what good looks like.
        </p>
      </div>
    </div>
  </section>

  <!-- Filters -->
  <section class="bg-bone-200 border-b border-cast-100 sticky top-0 z-20">
    <div class="container-wccp py-4">
      <div class="flex flex-wrap items-center gap-3">
        <span class="text-sm font-bold text-navy uppercase tracking-wide mr-2">Filter:</span>
        <button data-filter="all" class="filter-btn btn-sm bg-navy text-white">All projects</button>
        <button data-filter="agricultural" class="filter-btn btn-sm border-2 border-cast-200 text-navy hover:bg-navy hover:text-white">Agricultural</button>
        <button data-filter="civils" class="filter-btn btn-sm border-2 border-cast-200 text-navy hover:bg-navy hover:text-white">Civils</button>
        <button data-filter="bespoke" class="filter-btn btn-sm border-2 border-cast-200 text-navy hover:bg-navy hover:text-white">Bespoke</button>
        <span class="hidden md:inline-block w-px h-6 bg-cast-200 mx-2"></span>
        <button data-filter="devon" class="filter-btn btn-sm border-2 border-cast-200 text-navy hover:bg-navy hover:text-white">Devon</button>
        <button data-filter="cornwall" class="filter-btn btn-sm border-2 border-cast-200 text-navy hover:bg-navy hover:text-white">Cornwall</button>
        <button data-filter="somerset" class="filter-btn btn-sm border-2 border-cast-200 text-navy hover:bg-navy hover:text-white">Somerset</button>
        <button data-filter="dorset" class="filter-btn btn-sm border-2 border-cast-200 text-navy hover:bg-navy hover:text-white">Dorset</button>
        <button data-filter="wiltshire" class="filter-btn btn-sm border-2 border-cast-200 text-navy hover:bg-navy hover:text-white">Wiltshire</button>
        <button data-filter="wales" class="filter-btn btn-sm border-2 border-cast-200 text-navy hover:bg-navy hover:text-white">Wales</button>
        <button data-filter="scotland" class="filter-btn btn-sm border-2 border-cast-200 text-navy hover:bg-navy hover:text-white">Scotland · Hebrides</button>
        <button data-filter="europe" class="filter-btn btn-sm border-2 border-cast-200 text-navy hover:bg-navy hover:text-white">Europe</button>
      </div>
      <p class="mt-3 text-xs text-forest-700">
        We cast for projects across the UK and into Europe — Cornwall to the Outer Hebrides, Munich to Rotterdam.
      </p>
    </div>
  </section>

  <!-- Grid -->
  <section class="container-wccp py-12 md:py-16">
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5" id="case-grid">
      {caseStudies.map((c) => (
        <a
          href={`/case-studies/${c.slug}`}
          class="case-card card overflow-hidden group flex flex-col"
          data-sector={c.sectorTag}
          data-region={c.region}
        >
          <!-- Editorial spot illustration -->
          <div class="aspect-[4/3] overflow-hidden relative">
            <CaseStudyIcon type={c.iconType} class="transition-transform duration-500 group-hover:scale-105" />
            <div class="absolute top-3 left-3 flex gap-2 z-10">
              <span class="text-[11px] font-bold uppercase tracking-wide bg-forest-700 text-cream px-2 py-1 rounded">{c.sector}</span>
              <span class="text-[11px] font-bold uppercase tracking-wide bg-white/95 text-forest-800 px-2 py-1 rounded border border-cast-200">{c.year}</span>
            </div>
          </div>

          <div class="p-6 flex flex-col flex-1">
            <h3 class="font-display text-xl font-bold text-navy mb-1 group-hover:text-ember transition-colors">{c.name}</h3>
            <p class="text-cast text-sm mb-4">{c.parish}</p>

            <!-- Stat strip -->
            <div class="grid grid-cols-3 gap-2 border-y border-cast-100 py-3 mb-4">
              <div>
                <div class="font-display font-bold text-navy text-lg leading-none">{c.tonnes}</div>
                <div class="text-[10px] text-cast uppercase tracking-wide mt-1">Concrete</div>
              </div>
              <div>
                <div class="font-display font-bold text-navy text-lg leading-none">{c.days}</div>
                <div class="text-[10px] text-cast uppercase tracking-wide mt-1">On site</div>
              </div>
              <div>
                <div class="font-display font-bold text-navy text-sm leading-tight">{c.product}</div>
                <div class="text-[10px] text-cast uppercase tracking-wide mt-1">Product</div>
              </div>
            </div>

            <blockquote class="text-cast text-sm italic leading-relaxed mb-2 flex-1">{c.quote}</blockquote>
            <p class="text-xs text-cast font-medium">— {c.attribution}</p>
          </div>
        </a>
      ))}
    </div>

    <p id="empty-state" class="hidden text-center py-16 text-cast-700 text-lg">No case studies match those filters yet.</p>
  </section>

  <!-- CTA -->
  <section class="bg-yellow text-navy py-12">
    <div class="container-wccp text-center max-w-2xl mx-auto">
      <h2 class="font-display text-display-md mb-3">Could yours be next?</h2>
      <p class="text-navy text-lg mb-6">
        We document every job — and we'll happily put a prospective customer in touch with someone we've already worked for.
      </p>
      <div class="flex flex-wrap justify-center gap-3">
        <a href="/quote" class="btn-secondary">Start a quote</a>
        <a href={`tel:${site.contact.phoneIntl}`} class="btn bg-navy text-white hover:bg-navy-700">Call {site.contact.phone}</a>
      </div>
    </div>
  </section>

  <script>
    const buttons = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
    const cards = document.querySelectorAll<HTMLAnchorElement>('.case-card');
    const empty = document.getElementById('empty-state');
    let activeSector = 'all';
    let activeRegion = 'all';

    const sectors = new Set(['all', 'agricultural', 'civils', 'bespoke']);

    function applyFilter() {
      let visible = 0;
      cards.forEach((card) => {
        const s = card.dataset.sector ?? '';
        const r = card.dataset.region ?? '';
        const show =
          (activeSector === 'all' || s === activeSector) &&
          (activeRegion === 'all' || r === activeRegion);
        card.style.display = show ? '' : 'none';
        if (show) visible++;
      });
      if (empty) empty.classList.toggle('hidden', visible !== 0);
    }

    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const filter = btn.dataset.filter ?? 'all';
        const isSector = sectors.has(filter);
        if (isSector) activeSector = filter; else activeRegion = filter === 'all' ? 'all' : filter;

        // Reset visual state across the relevant group
        buttons.forEach((b) => {
          const f = b.dataset.filter ?? 'all';
          const groupIsSector = sectors.has(f);
          if (groupIsSector === isSector) {
            b.classList.remove('bg-navy', 'text-white');
            b.classList.add('border-2', 'border-cast-200', 'text-navy');
          }
        });
        btn.classList.remove('border-2', 'border-cast-200');
        btn.classList.add('bg-navy', 'text-white');
        applyFilter();
      });
    });
  </script>
</BaseLayout>
