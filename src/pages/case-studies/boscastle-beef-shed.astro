---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { site } from '@/config/site';

const facts = [
  { label: 'Client', value: 'Boscastle beef unit (placeholder name)' },
  { label: 'Location', value: 'Near Boscastle, North Cornwall' },
  { label: 'Sector', value: 'Agricultural — beef finishing' },
  { label: 'Stock', value: '250 store cattle' },
  { label: 'Products', value: '80 cubicle beds, slurry channel, feed-passage panels, footbath' },
  { label: 'Concrete', value: '96 tonnes' },
  { label: 'Lead time', value: '5 days on site' },
  { label: 'Project value', value: '£42,000' },
  { label: 'Funded by', value: 'FETF — Farming Equipment & Technology Fund' },
  { label: 'Completed', value: 'June 2025' },
];

const articleSchema = {
  author: {
    '@type': 'Person',
    name: 'WCCP engineering team',
    description: 'Family-run precast concrete manufacturer in Holsworthy, North Devon, casting since 1971.',
  },
  datePublished: '2025-07-08',
  mainEntityOfPage: 'https://westcountryconcreteproducts.co.uk/case-studies/boscastle-beef-shed',
};
---

<BaseLayout
  title="Boscastle beef shed — FETF-funded conversion, North Cornwall"
  description="WCCP supplied 80 cattle cubicle beds, slurry channels, feed-passage panels and a footbath kit for a 250-head beef finishing conversion near Boscastle. Five days on site."
  image="/images/case-studies/boscastle-beef-shed.jpg"
  schema="Article"
  schemaData={articleSchema}
>
  <section class="relative bg-navy text-white">
    <div class="aspect-[16/7] md:aspect-[16/6] bg-gradient-to-br from-navy via-navy-700 to-cast-700 relative">
      <div class="absolute inset-0 hero-gradient"></div>
      <div class="absolute bottom-0 left-0 right-0 container-wccp pb-10 md:pb-14">
        <nav class="text-sm text-white/90 mb-4" aria-label="Breadcrumb">
          <a href="/case-studies" class="hover:text-yellow">Case studies</a>
          <span class="mx-2 text-cast-300">/</span>
          <span class="text-white/90">Boscastle beef shed</span>
        </nav>
        <p class="eyebrow text-yellow mb-3">Agricultural · Cornwall · 2025</p>
        <h1 class="font-display text-display-xl text-white mb-3 max-w-3xl">Boscastle beef shed — FETF-funded conversion</h1>
        <p class="text-white/90 text-lg max-w-2xl">
          A 250-head beef finishing conversion near Boscastle. Cubicle beds, slurry channels, feed-passage
          panels and a footbath kit — five days from first delivery to handover.
        </p>
      </div>
    </div>
  </section>

  <section class="bg-bone-200 border-b border-cast-100">
    <div class="container-wccp py-8">
      <div class="grid grid-cols-3 gap-6 max-w-3xl mx-auto text-center">
        <div>
          <div class="font-display font-bold text-display-lg text-navy leading-none">96t</div>
          <div class="text-cast text-sm uppercase tracking-wide mt-2">Concrete delivered</div>
        </div>
        <div>
          <div class="font-display font-bold text-display-lg text-navy leading-none">5</div>
          <div class="text-cast text-sm uppercase tracking-wide mt-2">Days on site</div>
        </div>
        <div>
          <div class="font-display font-bold text-display-lg text-navy leading-none">£42k</div>
          <div class="text-cast text-sm uppercase tracking-wide mt-2">Project value</div>
        </div>
      </div>
    </div>
  </section>

  <section class="container-wccp py-12 md:py-16">
    <div class="grid lg:grid-cols-[1fr_18rem] gap-10 lg:gap-16">
      <div class="max-w-3xl">

        <p class="text-2xl font-display text-navy leading-snug mb-10 border-l-4 border-yellow pl-5">
          A small project on a tight budget, with a FETF grant deadline. Five days on site, every panel cast
          to BS 5502, claim approved on first submission.
        </p>

        <h2 class="font-display text-2xl text-navy mb-3">The challenge</h2>
        <p class="text-cast-700 text-lg leading-relaxed mb-8">
          The owners had an old loose-housing shed they wanted converted to a 250-head beef finishing unit
          using FETF funding. The grant window was short, the budget was tight at £42k, and the conversion
          had to fit inside the existing footprint. The lane up to the yard is steep, single-track and
          sharp at the top — a problem on Cornish farms more days than not.
        </p>

        <h2 class="font-display text-2xl text-navy mb-3">The solution</h2>
        <p class="text-cast-700 text-lg leading-relaxed mb-4">
          We specified 80 cattle cubicle beds in our standard 2.4m beef format, BS 5502-40 compliant, with
          precast slurry channel sections cast to fit the existing fall of the shed floor. Feed-passage
          panels at 600mm height — high enough to keep finishers in but low enough for a tractor-mounted
          feeder to clear. A precast footbath kit with integral cross-fall finished the layout.
        </p>
        <p class="text-cast-700 text-lg leading-relaxed mb-4">
          Everything was cast at Holsworthy and sized for an 8-wheel rigid lorry, deliberately, so we could
          get up the lane without splitting loads. Two trips covered the whole shed.
        </p>
        <p class="text-cast-700 text-lg leading-relaxed mb-8">
          Our installer worked with the farmer's regular concreting contractor for the bed run — we set out
          the first row, they ran the rest. The slurry channels went in on day three and the cubicle
          divisions on day four. Day five was footbath, snag and out.
        </p>

        <h2 class="font-display text-2xl text-navy mb-4">From the yard to the field</h2>
        <div class="grid grid-cols-2 md:grid-cols-3 gap-3 mb-10">
          {[1,2,3,4,5,6].map(() => (
            <div class="aspect-square bg-gradient-to-br from-cast-200 to-cast-100 rounded"></div>
          ))}
        </div>

        <blockquote class="bg-navy text-white p-8 md:p-10 rounded-lg mb-10">
          <svg class="w-10 h-10 text-yellow mb-4" viewBox="0 0 24 24" fill="currentColor">
            <path d="M9 7H5a2 2 0 00-2 2v4a2 2 0 002 2h2v2a2 2 0 01-2 2H4v2h1a4 4 0 004-4V7zm10 0h-4a2 2 0 00-2 2v4a2 2 0 002 2h2v2a2 2 0 01-2 2h-1v2h1a4 4 0 004-4V7z"/>
          </svg>
          <p class="font-display text-xl md:text-2xl text-white leading-snug mb-4">
            They split the loads to fit our lane without me asking. Five days, FETF claim signed off, and
            the cattle moved in the following week. Tidy job from start to finish.
          </p>
          <footer class="text-white/90">
            <span class="font-bold text-white">Andrew (placeholder)</span> · Beef finisher near Boscastle, North Cornwall
          </footer>
        </blockquote>

        <h2 class="font-display text-2xl text-navy mb-3">The result</h2>
        <p class="text-cast-700 text-lg leading-relaxed mb-10">
          250 head of finishing cattle housed inside the original footprint, FETF claim approved on first
          submission, project landed at £41,800 against a £42k budget. The unit's first turn through went
          out to slaughter in spring 2026.
        </p>

        <section class="bg-bone-200 border border-cast-100 rounded-lg p-8">
          <h2 class="font-display text-2xl text-navy mb-3">FETF round closing soon?</h2>
          <p class="text-cast-700 leading-relaxed mb-6">
            We've supplied dozens of FETF-funded conversions across Devon and Cornwall. Send the eligible
            item codes and a sketch — we'll come back with prices that fit the grant.
          </p>
          <div class="flex flex-wrap gap-3">
            <a href="/quote" class="btn-primary">Start a quote</a>
            <a href="/products/cattle-cubicles" class="btn-ghost">See cubicle range</a>
          </div>
        </section>
      </div>

      <aside>
        <div class="sticky top-24 card p-6">
          <p class="eyebrow text-cast mb-4">Project facts</p>
          <dl class="space-y-3 text-sm">
            {facts.map((f) => (
              <div>
                <dt class="text-cast text-xs uppercase tracking-wide font-bold">{f.label}</dt>
                <dd class="text-navy font-medium mt-0.5">{f.value}</dd>
              </div>
            ))}
          </dl>

          <hr class="my-6 border-cast-100" />

          <a href="/case-studies" class="text-ember font-bold text-sm hover:text-ember-700 inline-flex items-center gap-2">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <line x1="19" y1="12" x2="5" y2="12" stroke-linecap="round"/>
              <polyline points="12 19 5 12 12 5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Back to all case studies
          </a>
        </div>
      </aside>
    </div>
  </section>

  <section class="container-wccp py-16 text-center">
    <h2 class="font-display text-display-lg mb-4">Talk to the yard.</h2>
    <p class="text-cast-700 text-lg max-w-xl mx-auto mb-8">
      Same-day callback Monday to Friday. We work with what you've got — sketches, photos or full plans.
    </p>
    <div class="flex flex-wrap justify-center gap-3">
      <a href={`tel:${site.contact.phoneIntl}`} class="btn-secondary">Call {site.contact.phone}</a>
      <a href="/quote" class="btn-primary">Configure a quote</a>
    </div>
  </section>
</BaseLayout>
