---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { site } from '@/config/site';

const facts = [
  { label: 'Client', value: 'Higher Beara Farm' },
  { label: 'Parish', value: 'Bratton Clovelly, Devon' },
  { label: 'Herd size', value: '240 Holsteins' },
  { label: 'Product', value: '250mm precast slurry panels' },
  { label: 'Capacity', value: '2,400m³ — 6.5 months' },
  { label: 'Completed', value: 'October 2025' },
  { label: 'Designer', value: 'WCCP engineering team' },
  { label: 'Funded by', value: 'Slurry Infrastructure Grant Round 3' },
];
---

<BaseLayout
  title="Higher Beara Farm — 2,400m³ slurry store, Devon"
  description="WCCP supplied 420 tonnes of 250mm precast slurry panels for a 240-cow Holstein dairy near Bratton Clovelly, Devon. Eleven days on site. SIG Round 3 funded."
  image="/images/case-studies/example-dairy-farm.jpg"
>
  <!-- Hero with photo placeholder -->
  <section class="relative bg-navy text-white">
    <div class="aspect-[16/7] md:aspect-[16/6] bg-gradient-to-br from-navy via-navy-700 to-cast-700 relative">
      <div class="absolute inset-0 hero-gradient"></div>
      <div class="absolute bottom-0 left-0 right-0 container-wccp pb-10 md:pb-14">
        <nav class="text-sm text-white/90 mb-4" aria-label="Breadcrumb">
          <a href="/case-studies" class="hover:text-yellow">Case studies</a>
          <span class="mx-2 text-cast-300">/</span>
          <span class="text-white/90">Higher Beara Farm</span>
        </nav>
        <p class="eyebrow text-yellow mb-3">Agricultural · Devon · 2025</p>
        <h1 class="font-display text-display-xl text-white mb-3 max-w-3xl">Higher Beara Farm — 2,400m³ slurry store</h1>
        <p class="text-white/90 text-lg max-w-2xl">
          A SIG-funded slurry store for a 240-head Holstein dairy near Bratton Clovelly. Cast, delivered and installed in eleven days.
        </p>
      </div>
    </div>
  </section>

  <!-- Stat block -->
  <section class="bg-bone-200 border-b border-cast-100">
    <div class="container-wccp py-8">
      <div class="grid grid-cols-3 gap-6 max-w-3xl mx-auto text-center">
        <div>
          <div class="font-display font-bold text-display-lg text-navy leading-none">420t</div>
          <div class="text-cast text-sm uppercase tracking-wide mt-2">Concrete delivered</div>
        </div>
        <div>
          <div class="font-display font-bold text-display-lg text-navy leading-none">11</div>
          <div class="text-cast text-sm uppercase tracking-wide mt-2">Days on site</div>
        </div>
        <div>
          <div class="font-display font-bold text-display-lg text-navy leading-none">6.5m</div>
          <div class="text-cast text-sm uppercase tracking-wide mt-2">Months capacity</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Body grid -->
  <section class="container-wccp py-12 md:py-16">
    <div class="grid lg:grid-cols-[1fr_18rem] gap-10 lg:gap-16">
      <div class="max-w-3xl">

        <!-- Outcome -->
        <p class="text-2xl font-display text-navy leading-snug mb-10 border-l-4 border-yellow pl-5">
          Higher Beara needed six months of slurry storage to qualify for the Slurry Infrastructure Grant.
          We designed it, cast it, delivered it and had the yard back in working order before the next bulk tanker.
        </p>

        <!-- Challenge -->
        <h2 class="font-display text-2xl text-navy mb-3">The challenge</h2>
        <p class="text-cast-700 text-lg leading-relaxed mb-8">
          Higher Beara's existing lagoon held four months of slurry — short of the SIG Round 3 minimum and
          increasingly out of step with the herd, which had grown from 180 to 240 cows since 2020. The owners
          needed a 2,400m³ store, a working drainage isolation system and an inspection-ready compliance file,
          all delivered around continuous milking and second-cut silage. The site sloped and groundwater was
          high — both of which ruled out a deep below-grade tank.
        </p>

        <!-- Solution -->
        <h2 class="font-display text-2xl text-navy mb-3">The solution</h2>
        <p class="text-cast-700 text-lg leading-relaxed mb-4">
          We specified a rectangular above-ground store using 250mm precast panels in C40/50 sulphate-resisting
          concrete, post-and-panel construction at 1.8m centres on a piled raft to resolve the soft ground.
          Retained slurry depth was 3.0m with 750mm freeboard, agitator points cast into two of the long-wall
          panels, and a bespoke kerb detail at the access ramp where the muck spreader runs alongside the parapet.
        </p>
        <p class="text-cast-700 text-lg leading-relaxed mb-4">
          All panels were cast at our Holsworthy yard ten miles away — short haul, low embodied transport,
          and the same four-man crew who design the store also installed it. Joints were sealed with hydrophilic
          waterstop and slurry-rated polysulphide. We pre-fabricated the steel post cages off-site so on-site
          rebar work was kept to splice and tie only.
        </p>
        <p class="text-cast-700 text-lg leading-relaxed mb-8">
          Drainage from the existing yard was re-routed to a separate dirty-water channel before backfilling,
          and the WQE1 notification was lodged with the Environment Agency 18 days before first delivery.
          Inspection passed first time on completion.
        </p>

        <!-- Photo gallery placeholder -->
        <h2 class="font-display text-2xl text-navy mb-4">From the yard to the field</h2>
        <div class="grid grid-cols-2 md:grid-cols-3 gap-3 mb-10">
          {[1,2,3,4,5,6].map(() => (
            <div class="aspect-square bg-gradient-to-br from-cast-200 to-cast-100 rounded"></div>
          ))}
        </div>

        <!-- Pull quote -->
        <blockquote class="bg-navy text-white p-8 md:p-10 rounded-lg mb-10">
          <svg class="w-10 h-10 text-yellow mb-4" viewBox="0 0 24 24" fill="currentColor">
            <path d="M9 7H5a2 2 0 00-2 2v4a2 2 0 002 2h2v2a2 2 0 01-2 2H4v2h1a4 4 0 004-4V7zm10 0h-4a2 2 0 00-2 2v4a2 2 0 002 2h2v2a2 2 0 01-2 2h-1v2h1a4 4 0 004-4V7z"/>
          </svg>
          <p class="font-display text-xl md:text-2xl text-white leading-snug mb-4">
            They turned up when they said they would, the panels went up like Lego, and the yard was back in
            use the following week. We passed our SIG inspection without a single observation.
          </p>
          <footer class="text-white/90">
            <span class="font-bold text-white">Mike Penberthy</span> · Herd manager, Higher Beara Farm
          </footer>
        </blockquote>

        <!-- Result -->
        <h2 class="font-display text-2xl text-navy mb-3">The result</h2>
        <p class="text-cast-700 text-lg leading-relaxed mb-10">
          Higher Beara now has 6.5 months of compliant slurry storage, a clean separation of clean and dirty
          water, and a SIG Round 3 grant claim approved on first submission. Total install was eleven days from
          first panel delivery to handover — three days inside the original programme. The herd has since
          expanded to 260 head and the store still has headroom.
        </p>

        <!-- CTA -->
        <section class="bg-bone-200 border border-cast-100 rounded-lg p-8">
          <h2 class="font-display text-2xl text-navy mb-3">Need a SIG-ready slurry store?</h2>
          <p class="text-cast-700 leading-relaxed mb-6">
            Round 4 closes 30 September 2026. Send us your livestock numbers and a sketch — we'll come back
            with a panel schedule, capacity calculation and fixed price within 24 hours.
          </p>
          <div class="flex flex-wrap gap-3">
            <a href="/quote" class="btn-primary">Start a quote</a>
            <a href="/products/slurry-storage" class="btn-ghost">See slurry range</a>
          </div>
        </section>
      </div>

      <!-- Project facts sidebar -->
      <aside>
        <div class="sticky top-24 card p-6">
          <p class="eyebrow text-cast mb-4">Project facts</p>
          <dl class="space-y-3 text-sm">
            {facts.map((f) => (
              <div>
                <dt class="text-cast text-xs uppercase tracking-wide font-bold">{f.label}</dt>
                <dd class="text-navy font-medium mt-0.5">{f.value}</dd>
              </div>
            ))}
          </dl>

          <hr class="my-6 border-cast-100" />

          <a href="/case-studies" class="text-ember font-bold text-sm hover:text-ember-700 inline-flex items-center gap-2">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <line x1="19" y1="12" x2="5" y2="12" stroke-linecap="round"/>
              <polyline points="12 19 5 12 12 5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Back to all case studies
          </a>
        </div>
      </aside>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="container-wccp py-16 text-center">
    <h2 class="font-display text-display-lg mb-4">Talk to the yard.</h2>
    <p class="text-cast-700 text-lg max-w-xl mx-auto mb-8">
      Same-day callback Monday to Friday. We work with what you've got — sketches, photos or full plans.
    </p>
    <div class="flex flex-wrap justify-center gap-3">
      <a href={`tel:${site.contact.phoneIntl}`} class="btn-secondary">Call {site.contact.phone}</a>
      <a href="/quote" class="btn-primary">Configure a quote</a>
    </div>
  </section>
</BaseLayout>
