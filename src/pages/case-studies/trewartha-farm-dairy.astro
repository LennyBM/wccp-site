---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { site } from '@/config/site';

const facts = [
  { label: 'Client', value: 'Trewartha Farm (placeholder name)' },
  { label: 'Parish', value: 'St Erth, Cornwall' },
  { label: 'Sector', value: 'Agricultural — dairy' },
  { label: 'Herd size', value: '320 Holsteins' },
  { label: 'Products', value: '240m King Post wall, 8 silage clamp walls, 2× Lely robot bases' },
  { label: 'Concrete', value: '380 tonnes' },
  { label: 'Lead time', value: '14 days on site' },
  { label: 'Project value', value: '£210,000' },
  { label: 'Completed', value: 'August 2025' },
];

const articleSchema = {
  author: {
    '@type': 'Person',
    name: 'WCCP engineering team',
    description: 'Family-run precast concrete manufacturer in Holsworthy, North Devon, casting since 1971.',
  },
  datePublished: '2025-09-12',
  mainEntityOfPage: 'https://westcountryconcreteproducts.co.uk/case-studies/trewartha-farm-dairy',
};
---

<BaseLayout
  title="Trewartha Farm — 320-cow dairy expansion, St Erth, Cornwall"
  description="WCCP supplied 380 tonnes of precast — King Post wall, silage clamp panels and Lely robot bases — for a 320-cow Holstein herd at St Erth. Fourteen days on site."
  image="/images/case-studies/trewartha-farm-dairy.jpg"
  schema="Article"
  schemaData={articleSchema}
>
  <!-- Hero -->
  <section class="relative bg-navy text-white">
    <div class="aspect-[16/7] md:aspect-[16/6] bg-gradient-to-br from-navy via-navy-700 to-cast-700 relative">
      <div class="absolute inset-0 hero-gradient"></div>
      <div class="absolute bottom-0 left-0 right-0 container-wccp pb-10 md:pb-14">
        <nav class="text-sm text-white/90 mb-4" aria-label="Breadcrumb">
          <a href="/case-studies" class="hover:text-yellow">Case studies</a>
          <span class="mx-2 text-cast-300">/</span>
          <span class="text-white/90">Trewartha Farm</span>
        </nav>
        <p class="eyebrow text-yellow mb-3">Agricultural · Cornwall · 2025</p>
        <h1 class="font-display text-display-xl text-white mb-3 max-w-3xl">Trewartha Farm — 320-cow dairy expansion</h1>
        <p class="text-white/90 text-lg max-w-2xl">
          Six months of slurry storage, a new collecting yard and two robot bases, designed and delivered around continuous milking near St Erth.
        </p>
      </div>
    </div>
  </section>

  <!-- Stat block -->
  <section class="bg-bone-200 border-b border-cast-100">
    <div class="container-wccp py-8">
      <div class="grid grid-cols-3 gap-6 max-w-3xl mx-auto text-center">
        <div>
          <div class="font-display font-bold text-display-lg text-navy leading-none">380t</div>
          <div class="text-cast text-sm uppercase tracking-wide mt-2">Concrete delivered</div>
        </div>
        <div>
          <div class="font-display font-bold text-display-lg text-navy leading-none">14</div>
          <div class="text-cast text-sm uppercase tracking-wide mt-2">Days on site</div>
        </div>
        <div>
          <div class="font-display font-bold text-display-lg text-navy leading-none">£210k</div>
          <div class="text-cast text-sm uppercase tracking-wide mt-2">Project value</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Body grid -->
  <section class="container-wccp py-12 md:py-16">
    <div class="grid lg:grid-cols-[1fr_18rem] gap-10 lg:gap-16">
      <div class="max-w-3xl">

        <!-- Outcome -->
        <p class="text-2xl font-display text-navy leading-snug mb-10 border-l-4 border-yellow pl-5">
          Trewartha needed to grow the herd to 320 cows, qualify for slurry compliance and get two milking
          robots running — without a fortnight off the milking parlour. We did the lot in fourteen days.
        </p>

        <!-- Challenge -->
        <h2 class="font-display text-2xl text-navy mb-3">The challenge</h2>
        <p class="text-cast-700 text-lg leading-relaxed mb-8">
          The existing yard was tight, the slurry store held four months and the parlour was working flat
          out. The owners wanted to step up to 320 Holsteins, install two Lely Astronaut A5 robots and bring
          slurry storage to six months, all without losing a milking. The site sloped sharply north to south
          and the new collecting yard had to drain cleanly into a re-sized reception pit.
        </p>

        <!-- Solution -->
        <h2 class="font-display text-2xl text-navy mb-3">The solution</h2>
        <p class="text-cast-700 text-lg leading-relaxed mb-4">
          We specified 240 metres of King Post retaining wall at 3 metre height to terrace the new collecting
          yard and contain the silage push. Eight silage clamp walls were cast in C40/50 sulphate-resisting
          concrete to BS EN 14992, sized to take the new feed regime for the larger herd with headroom for
          maize and wholecrop. Two precast milking robot bases were designed to Lely's setting-out
          drawings — flat to ±2mm across the cow lane, with cast-in conduit runs for the A5 service
          umbilicals.
        </p>
        <p class="text-cast-700 text-lg leading-relaxed mb-4">
          All elements were cast at our Holsworthy yard, batched in sequence so the slurry store walls were
          on site by day four and the robot bases set on day eleven. The King Post wall went up in three
          phases so the dairy crew could keep cows moving through a temporary race while we worked one
          quadrant at a time.
        </p>
        <p class="text-cast-700 text-lg leading-relaxed mb-8">
          Drainage to the reception pit was set out with our engineer on the first morning so the contractor
          could core-drill and seal in one pass. We managed the sequencing day by day with the herd manager
          over WhatsApp — mainly photos of where the muck tanker would and wouldn't fit.
        </p>

        <!-- Photo gallery placeholder -->
        <h2 class="font-display text-2xl text-navy mb-4">From the yard to the field</h2>
        <div class="grid grid-cols-2 md:grid-cols-3 gap-3 mb-10">
          {[1,2,3,4,5,6].map(() => (
            <div class="aspect-square bg-gradient-to-br from-cast-200 to-cast-100 rounded"></div>
          ))}
        </div>

        <!-- Pull quote -->
        <blockquote class="bg-navy text-white p-8 md:p-10 rounded-lg mb-10">
          <svg class="w-10 h-10 text-yellow mb-4" viewBox="0 0 24 24" fill="currentColor">
            <path d="M9 7H5a2 2 0 00-2 2v4a2 2 0 002 2h2v2a2 2 0 01-2 2H4v2h1a4 4 0 004-4V7zm10 0h-4a2 2 0 00-2 2v4a2 2 0 002 2h2v2a2 2 0 01-2 2h-1v2h1a4 4 0 004-4V7z"/>
          </svg>
          <p class="font-display text-xl md:text-2xl text-white leading-snug mb-4">
            We never missed a milking. The robots were calibrating cows by the end of the third week and the
            slurry store passed the inspection without a hitch. WCCP earned their tea.
          </p>
          <footer class="text-white/90">
            <span class="font-bold text-white">Tom (placeholder)</span> · Dairy farmer near St Erth, Cornwall
          </footer>
        </blockquote>

        <!-- Result -->
        <h2 class="font-display text-2xl text-navy mb-3">The result</h2>
        <p class="text-cast-700 text-lg leading-relaxed mb-10">
          Trewartha is now milking 320 cows through two Lely A5 robots, with six months of compliant slurry
          storage and a collecting yard that drains clean. Fourteen days on site, no missed milkings, and
          the herd manager has already asked us back to quote a calf-rearing shed for next spring.
        </p>

        <!-- CTA -->
        <section class="bg-bone-200 border border-cast-100 rounded-lg p-8">
          <h2 class="font-display text-2xl text-navy mb-3">Planning a robot rollout or herd expansion?</h2>
          <p class="text-cast-700 leading-relaxed mb-6">
            Send us your robot supplier's setting-out drawings and a sketch of the yard — we'll come back
            with a panel schedule and a phased install plan that keeps the parlour running.
          </p>
          <div class="flex flex-wrap gap-3">
            <a href="/quote" class="btn-primary">Start a quote</a>
            <a href="/products/milking-robot-bases" class="btn-ghost">See robot bases</a>
          </div>
        </section>
      </div>

      <!-- Project facts sidebar -->
      <aside>
        <div class="sticky top-24 card p-6">
          <p class="eyebrow text-cast mb-4">Project facts</p>
          <dl class="space-y-3 text-sm">
            {facts.map((f) => (
              <div>
                <dt class="text-cast text-xs uppercase tracking-wide font-bold">{f.label}</dt>
                <dd class="text-navy font-medium mt-0.5">{f.value}</dd>
              </div>
            ))}
          </dl>

          <hr class="my-6 border-cast-100" />

          <a href="/case-studies" class="text-ember font-bold text-sm hover:text-ember-700 inline-flex items-center gap-2">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <line x1="19" y1="12" x2="5" y2="12" stroke-linecap="round"/>
              <polyline points="12 19 5 12 12 5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Back to all case studies
          </a>
        </div>
      </aside>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="container-wccp py-16 text-center">
    <h2 class="font-display text-display-lg mb-4">Talk to the yard.</h2>
    <p class="text-cast-700 text-lg max-w-xl mx-auto mb-8">
      Same-day callback Monday to Friday. We work with what you've got — sketches, photos or full plans.
    </p>
    <div class="flex flex-wrap justify-center gap-3">
      <a href={`tel:${site.contact.phoneIntl}`} class="btn-secondary">Call {site.contact.phone}</a>
      <a href="/quote" class="btn-primary">Configure a quote</a>
    </div>
  </section>
</BaseLayout>
