---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { site } from '@/config/site';

const facts = [
  { label: 'Location', value: 'Henley-on-Thames railway station' },
  { label: 'Sector', value: 'Civils — rail infrastructure' },
  { label: 'Products', value: '2× bespoke precast concrete box culverts' },
  { label: 'Standard', value: 'BS EN 14844:2006+A2:2011' },
  { label: 'Outer face', value: 'Sawn to customer specification' },
  { label: 'Application', value: 'Waterway beneath a footbridge' },
  { label: 'Completed', value: 'Early 2024' },
];

const heroImage = '/images/products/culverts/wccp-culverts-img-20240325-wa0010-1024x497.jpg';
const heroAlt = 'Installed precast concrete culvert with stone abutments and galvanised handrails forming a small footbridge — WCCP, Devon';
const gallery = [
  { src: '/images/products/culverts/wccp-culverts-20240308-121028-reduced-1024x768.jpg', alt: 'WCCP precast concrete box culvert section being prepared in the Holsworthy yard for transport' },
  { src: '/images/products/culverts/wccp-culverts-whatsapp-image-2024-03-08-at-22-06-30-5b94be08-1024x768.jpg', alt: 'Two large precast concrete box culverts strapped to a flatbed lorry leaving the WCCP yard for delivery, Devon' },
  { src: '/images/products/culverts/wccp-culverts-img-20240325-wa0013-768x1024.jpg', alt: 'Site team lowering a precast concrete box culvert section into excavation by WCCP, Devon' },
  { src: '/images/products/culverts/wccp-culverts-img-20240325-wa0009-1024x497.jpg', alt: 'Finished precast concrete culvert deck with resin-bound surface and galvanised handrail, WCCP Devon' },
];

const articleSchema = {
  author: {
    '@type': 'Person',
    name: 'WCCP engineering team',
    description: 'Family-run precast concrete manufacturer in Holsworthy, North Devon.',
  },
  datePublished: '2024-04-15',
  mainEntityOfPage: 'https://westcountryconcreteproducts.co.uk/case-studies/henley-railway-footbridge',
};
---

<BaseLayout
  title="Henley-on-Thames railway station — bespoke box culverts under a footbridge"
  description="WCCP manufactured and supplied two bespoke precast concrete box culverts forming a waterway beneath a footbridge for the railway station at Henley-on-Thames. Outer faces sawn to specification, designed to BS EN 14844:2006+A2:2011."
  image="/images/products/culverts/wccp-culverts-img-20240325-wa0010-1024x497.jpg"
  schema="Article"
  schemaData={articleSchema}
>
  <!-- Hero -->
  <section class="relative bg-navy text-white">
    <div class="aspect-[16/7] md:aspect-[16/6] bg-navy relative overflow-hidden">
      <img src={heroImage} alt={heroAlt} class="absolute inset-0 w-full h-full object-cover" loading="eager" decoding="async" />
      <div class="absolute inset-0 bg-gradient-to-t from-navy/90 via-navy/55 to-navy/20"></div>
      <div class="absolute inset-0 hero-gradient"></div>
      <div class="absolute bottom-0 left-0 right-0 container-wccp pb-10 md:pb-14">
        <nav class="text-sm text-white/90 mb-4" aria-label="Breadcrumb">
          <a href="/case-studies" class="hover:text-yellow">Case studies</a>
          <span class="mx-2 text-cast-300">/</span>
          <span class="text-white/90">Henley-on-Thames footbridge</span>
        </nav>
        <p class="eyebrow text-yellow mb-3">Civils · rail · 2024</p>
        <h1 class="font-display text-display-xl text-white mb-3 max-w-3xl">Henley-on-Thames railway station — bespoke box culverts</h1>
        <p class="text-white/90 text-lg max-w-2xl">
          Two precast concrete units forming a waterway beneath a footbridge at the railway station — cast at our Holsworthy yard, outer faces sawn to specification.
        </p>
      </div>
    </div>
  </section>

  <!-- Stat block -->
  <section class="bg-bone-200 border-b border-cast-100">
    <div class="container-wccp py-8">
      <div class="grid grid-cols-3 gap-6 max-w-3xl mx-auto text-center">
        <div>
          <div class="font-display font-bold text-display-lg text-navy leading-none">2</div>
          <div class="text-cast text-sm uppercase tracking-wide mt-2">Bespoke culverts</div>
        </div>
        <div>
          <div class="font-display font-bold text-display-lg text-navy leading-none">EN&nbsp;14844</div>
          <div class="text-cast text-sm uppercase tracking-wide mt-2">Live product standard</div>
        </div>
        <div>
          <div class="font-display font-bold text-display-lg text-navy leading-none">2024</div>
          <div class="text-cast text-sm uppercase tracking-wide mt-2">Completed</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Body grid -->
  <section class="container-wccp py-12 md:py-16">
    <div class="grid lg:grid-cols-[1fr_18rem] gap-10 lg:gap-16">
      <div class="max-w-3xl">

        <!-- Outcome -->
        <p class="text-2xl font-display text-navy leading-snug mb-10 border-l-4 border-yellow pl-5">
          A railway station works package needed two bespoke box culverts to form the waterway under
          a new footbridge. We cast them in Devon, outer faces sawn to the customer's specification,
          and shipped them up the country.
        </p>

        <!-- Challenge -->
        <h2 class="font-display text-2xl text-navy mb-3">The challenge</h2>
        <p class="text-cast-700 text-lg leading-relaxed mb-8">
          The railway station footbridge crossing required a precast concrete waterway underneath —
          two large box culvert units forming a single continuous channel. As a Network Rail-adjacent
          works package the units had to meet the live precast box culvert standard
          (BS&nbsp;EN&nbsp;14844:2006+A2:2011), be designed for the loading condition, and arrive on
          site with the outer faces finished to a specific architectural quality. Most precast yards
          will quote a catalogue size; this needed bespoke geometry, bespoke wall thicknesses and
          bespoke face finish — and the rail compliance paperwork that goes with it.
        </p>

        <!-- Solution -->
        <h2 class="font-display text-2xl text-navy mb-3">The solution</h2>
        <p class="text-cast-700 text-lg leading-relaxed mb-4">
          We engineered the two units to the customer's section requirements — wall thicknesses
          and reinforcement designed to suit the loading and the cover, in accordance with
          BS&nbsp;EN&nbsp;14844:2006+A2:2011 and structural design to BS&nbsp;EN&nbsp;1992
          (Eurocode&nbsp;2). Cast at our Holsworthy yard in C40/50 concrete to BS 8500-1:2023.
        </p>
        <p class="text-cast-700 text-lg leading-relaxed mb-4">
          The architectural face finish was the part most precasters would not touch. The visible
          outer faces were sawn after cure to the specified finish quality — flat, true, and
          matched on both units so that the join under the footbridge reads as a single
          continuous structure. We did the saw work at the yard before despatch so the
          contractor was not waiting on a second specialist on site.
        </p>
        <p class="text-cast-700 text-lg leading-relaxed mb-8">
          Both units shipped on a low-loader with cast-in lifting eyes pre-tested to LOLER, and
          with the structural calcs, mix certificate and dimensional control records handed over
          as a single PDF pack.
        </p>

        <!-- Photo gallery -->
        <h2 class="font-display text-2xl text-navy mb-4">From the yard to the railway</h2>
        <div class="grid grid-cols-2 md:grid-cols-2 gap-3 mb-10">
          {gallery.map((g) => (
            <div class="aspect-[4/3] bg-cast-100 rounded overflow-hidden">
              <img src={g.src} alt={g.alt} class="w-full h-full object-cover" loading="lazy" decoding="async" />
            </div>
          ))}
        </div>

        <!-- Pull quote -->
        <blockquote class="bg-navy text-white p-8 md:p-10 rounded-lg mb-10">
          <svg class="w-10 h-10 text-yellow mb-4" viewBox="0 0 24 24" fill="currentColor">
            <path d="M9 7H5a2 2 0 00-2 2v4a2 2 0 002 2h2v2a2 2 0 01-2 2H4v2h1a4 4 0 004-4V7zm10 0h-4a2 2 0 00-2 2v4a2 2 0 002 2h2v2a2 2 0 01-2 2h-1v2h1a4 4 0 004-4V7z"/>
          </svg>
          <p class="font-display text-xl md:text-2xl text-white leading-snug mb-4">
            Bespoke precast, designed and cast in one yard, with the visible faces finished
            before despatch — that is how a rail works package should land on site.
          </p>
          <footer class="text-white/90">
            <span class="font-bold text-white">WCCP engineering team</span> · Holsworthy, Devon
          </footer>
        </blockquote>

        <!-- Result -->
        <h2 class="font-display text-2xl text-navy mb-3">The result</h2>
        <p class="text-cast-700 text-lg leading-relaxed mb-10">
          Two bespoke box culverts forming the waterway beneath the new footbridge at
          Henley-on-Thames railway station — designed, cast, sawn and delivered from one yard
          in Devon. Proof that bespoke rail-grade civils precast does not need a national
          contractor's price tag, just a yard with the moulds, the engineers and the willingness
          to do the visible-face work properly.
        </p>

        <!-- CTA -->
        <section class="bg-bone-200 border border-cast-100 rounded-lg p-8">
          <h2 class="font-display text-2xl text-navy mb-3">Bespoke civils precast?</h2>
          <p class="text-cast-700 leading-relaxed mb-6">
            Send us the section drawing, fill height, loading and any architectural face requirements
            — we will return a culvert design with wall thicknesses, reinforcement schedule, weight
            calcs and a finish proposal.
          </p>
          <div class="flex flex-wrap gap-3">
            <a href="/quote" class="btn-primary">Start a quote</a>
            <a href="/products/culverts" class="btn-ghost">See box culverts</a>
          </div>
        </section>
      </div>

      <!-- Project facts sidebar -->
      <aside>
        <div class="sticky top-24 card p-6">
          <p class="eyebrow text-cast mb-4">Project facts</p>
          <dl class="space-y-3 text-sm">
            {facts.map((f) => (
              <div>
                <dt class="text-cast text-xs uppercase tracking-wide font-bold">{f.label}</dt>
                <dd class="text-navy font-medium mt-0.5">{f.value}</dd>
              </div>
            ))}
          </dl>

          <hr class="my-6 border-cast-100" />

          <a href="/case-studies" class="text-ember font-bold text-sm hover:text-ember-700 inline-flex items-center gap-2">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <line x1="19" y1="12" x2="5" y2="12" stroke-linecap="round"/>
              <polyline points="12 19 5 12 12 5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Back to all case studies
          </a>
        </div>
      </aside>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="container-wccp py-16 text-center">
    <h2 class="font-display text-display-lg mb-4">Talk to the yard.</h2>
    <p class="text-cast-700 text-lg max-w-xl mx-auto mb-8">
      Same-day callback Monday to Friday. We work with what you've got — sketches, photos or full plans.
    </p>
    <div class="flex flex-wrap justify-center gap-3">
      <a href={`tel:${site.contact.phoneIntl}`} class="btn-secondary">Call {site.contact.phone}</a>
      <a href="/quote" class="btn-primary">Configure a quote</a>
    </div>
  </section>
</BaseLayout>
