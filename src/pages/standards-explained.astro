---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { site } from '@/config/site';

// Deeper "Standards explained" pillar — sister page to /standards (the canonical landing).
// Per-standard <details> blocks (60-100 word plain-English answer) wired into a FAQPage
// schema so AI engines and Google can pull individual answers.

interface StandardEntry {
  id: string;
  code: string;
  title: string;
  // 60-100 word plain-English answer used both visibly and in FAQPage schema.
  answer: string;
  productsLabel: string;
  productsHref: string;
}

const standards: StandardEntry[] = [
  {
    id: 'bs-en-14992',
    code: 'BS EN 14992',
    title: 'Precast concrete — wall elements (the precast structural standard)',
    answer:
      'BS EN 14992 is the harmonised European standard for precast concrete wall elements. It governs prestressed and reinforced wall panels supplied as factory-cast products, sets the geometric tolerances, the mechanical-resistance characteristics (bending, shear, axial), the fire and durability declarations, and the factory production control framework. It is the standard a procurement officer asks for by name on a tender — without it, a panel cannot be legally placed on the UK market as a construction product. Every WCCP prestressed panel ships with a declaration of performance referencing this standard.',
    productsLabel: 'Prestressed wall panels',
    productsHref: '/products/prestressed-panels',
  },
  {
    id: 'bs-8500',
    code: 'BS 8500-1:2023',
    title: 'Concrete classification (the UK mix specification)',
    answer:
      'BS 8500-1:2023 is the UK complement to BS EN 206. It defines designated and designed concrete mixes by exposure class (XC for carbonation, XD for chlorides, XS for seawater, XF for freeze-thaw, XA for chemical attack), by strength class such as C40/50, and by minimum cement content. It also fixes the allowable cement types (CEM I to CEM V) for each exposure. WCCP specifies every mix to BS 8500 with the right exposure class for the duty — sulphate-resistant C40/50 for slurry, C32/40 for retaining duty, and so on.',
    productsLabel: 'Slurry storage',
    productsHref: '/products/slurry-storage',
  },
  {
    id: 'eurocode-2',
    code: 'BS EN 1992 (Eurocode 2)',
    title: 'Structural design (Part 1-1, Part 1-2 fire)',
    answer:
      'BS EN 1992 — Eurocode 2 — is the structural design code for concrete in the UK and EU. Part 1-1 covers general rules and rules for buildings; Part 1-2 covers fire. The code drives every Ultimate-Limit-State and Serviceability-Limit-State calculation behind a WCCP panel — partial safety factors, reinforcement detailing, anchorage, lap lengths, deflection, fatigue and cover for durability. Building Regulations Approved Document A and the Construction Products Regulation route compliance through Eurocode 2, so any modern engineer signing a precast design off works to this code.',
    productsLabel: 'Retaining walls',
    productsHref: '/products/retaining-walls',
  },
  {
    id: 'bs-en-1992-3',
    code: 'BS EN 1992-3',
    title: 'Liquid-retention design (slurry, silage effluent, water)',
    answer:
      'BS EN 1992-3 is the part of Eurocode 2 that covers liquid-retaining and containment structures — slurry tanks, silage clamps, water-retaining walls. It tightens crack-width control to 0.2mm and fixes how a designer must allow for water-tight detailing, reinforcement layout under sustained tensile stress and serviceability under fluid pressure. WCCP uses Part 3 on every slurry storage and silage clamp calculation, alongside SSAFO 2018 and BS 5502-50, so the structure passes Environment Agency inspection and stays leak-free for the 20-year design life.',
    productsLabel: 'Silage clamp walls',
    productsHref: '/products/silage-clamp-walls',
  },
  {
    id: 'bs-5502-22',
    code: 'BS 5502-22:2003',
    title: 'Agricultural buildings (cattle housing)',
    answer:
      'BS 5502-22 is the part of the UK code of practice for agricultural buildings that deals with cattle housing — cubicles, feed barriers, kerbs, slatted floors, gates and water troughs. It informs cubicle dimensions, livestock loadings (Holstein, Jersey, beef), gate and barrier strength, drainage falls and the durability requirements for the slurry, urine and silage environment. WCCP cross-references AHDB Dairy 2024 dimensions against the BS 5502-22 structural rules before casting — so the cubicle is sized for the cow that lies in it and the kerb survives a hundred herd cycles.',
    productsLabel: 'Cattle cubicles',
    productsHref: '/products/cattle-cubicles',
  },
  {
    id: 'ssafo-2018',
    code: 'SSAFO 2018',
    title: 'Silage, Slurry and Agricultural Fuel Oil Regulations 2018',
    answer:
      'SSAFO 2018 is the statutory instrument that governs slurry, silage effluent and agricultural fuel-oil storage in England. It requires a 20-year minimum design life, structural adequacy to BS 5502-50 and BS EN 1992-3, impermeability of the storage envelope and 14 days written notice to the Environment Agency before construction begins. It sets minimum freeboard, effluent capture from clamps, and spacing rules from watercourses and boreholes. WCCP supplies the calculations, the C40/50 sulphate-resisting mix certificate and a written capacity statement so the EA file is complete on day one.',
    productsLabel: 'Slurry storage',
    productsHref: '/products/slurry-storage',
  },
  {
    id: 'ce-ukca',
    code: 'CE / UKCA marking',
    title: 'Construction Products Regulation conformity marks',
    answer:
      'CE and UKCA are the conformity marks under the Construction Products Regulation. The UK currently recognises both during transition. Every WCCP product covered by a harmonised standard — BS EN 14992 wall panels, BS EN 1916 culverts, BS EN 13225 linear elements — ships with a UKCA-marked declaration of performance backed by factory production control to BS EN 13369 and notified-body audit (System 2+ for prestressed elements). Without a valid DoP, a construction product cannot legally be sold or installed. WCCP keeps DoPs available for ten years from supply.',
    productsLabel: 'Conformity hub',
    productsHref: '/standards/conformity',
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: standards.map((s) => ({
    '@type': 'Question',
    name: `What is ${s.code}?`,
    acceptedAnswer: { '@type': 'Answer', text: s.answer },
  })),
};
---

<BaseLayout
  title="Standards explained — BS, BS EN and Eurocodes for UK precast concrete"
  description="Plain-English explainer of every standard WCCP precast is cast to: BS EN 14992 (precast structural), BS 8500-1:2023 (concrete classification), BS EN 1992 / Eurocode 2 (structural design), BS EN 1992-3 (liquid retention), BS 5502-22 (agricultural buildings), SSAFO 2018 and CE/UKCA marking."
  image="/images/standards.jpg"
  schema="Article"
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)} slot="head" />

  <!-- Hero -->
  <section class="bg-navy text-white">
    <div class="container-wccp py-14 md:py-16">
      <nav class="text-sm text-white/90 mb-6" aria-label="Breadcrumb">
        <a href="/standards" class="hover:text-yellow">Standards</a>
        <span class="mx-2 text-cast">/</span>
        <span class="text-white/90">Standards explained</span>
      </nav>
      <p class="eyebrow text-yellow mb-4">Pillar guide · Plain English</p>
      <h1 class="font-display text-display-xl text-white mb-6 max-w-4xl">
        Standards explained — every code, in plain English.
      </h1>

      <!-- Direct answer (40-60 words) -->
      <div class="bg-navy-700 border-l-4 border-yellow p-6 max-w-3xl rounded-r">
        <p class="text-white/90 text-lg leading-relaxed">
          <strong class="text-white">Direct answer:</strong> WCCP precast is cast to BS EN 14992
          (precast structural), BS 8500-1:2023 (concrete classification), BS EN 1992 / Eurocode 2
          (structural design), BS EN 1992-3 (liquid retention — slurry and silage), BS 5502-22
          (agricultural buildings) and SSAFO 2018 (slurry, silage, fuel oil). Every harmonised
          product ships with a CE / UKCA declaration of performance.
        </p>
      </div>

      <!-- Byline -->
      <div class="mt-8 flex flex-wrap items-center gap-x-6 gap-y-2 text-sm text-white/90">
        <div>By <span class="text-white font-semibold">WCCP Engineering Team</span></div>
        <div>Published <time datetime="2026-04-29">29 April 2026</time></div>
        <div>Last reviewed <time datetime="2026-04-29">29 April 2026</time></div>
      </div>
    </div>
  </section>

  <!-- Body -->
  <article class="container-wccp py-12 md:py-16">
    <div class="grid lg:grid-cols-[1fr_18rem] gap-10 lg:gap-16">
      <!-- Main content -->
      <div class="max-w-3xl">

        <!-- Why standards matter -->
        <section id="why" class="mb-12 scroll-mt-24">
          <h2 class="font-display text-3xl text-navy mb-4">Why standards matter on a precast job.</h2>
          <p class="text-cast-700 text-lg leading-relaxed mb-4">
            <strong class="text-navy">Standards are how a designer, a contractor and a manufacturer
            agree what "good" looks like — without writing the rules from scratch on every job.</strong>
            A panel cast to BS EN 14992 means the same thing in Holsworthy as it does in Hull. A
            C40/50 sulphate-resisting mix to BS 8500 performs the same in slurry whether it left
            our yard or someone else's.
          </p>
          <p class="text-cast-700 text-lg leading-relaxed mb-4">
            Below, each standard is broken down into a 60-100 word plain-English answer, the
            products WCCP applies it to, and a link through. If you would rather scan a
            one-screen summary, the canonical <a href="/standards" class="text-ember font-bold underline underline-offset-4">/standards</a>
            page has the seven-row landscape; if you need the paperwork, head to the
            <a href="/standards/conformity" class="text-ember font-bold underline underline-offset-4">conformity hub</a>.
          </p>
        </section>

        <!-- Per-standard explainers as <details> -->
        <section id="explainers" class="mb-12 scroll-mt-24">
          <h2 class="font-display text-3xl text-navy mb-6">The standards, one by one.</h2>
          <div class="space-y-4">
            {standards.map((s) => (
              <details id={s.id} class="card p-5 md:p-6 group scroll-mt-24">
                <summary class="font-display cursor-pointer flex items-start justify-between gap-4">
                  <div>
                    <p class="font-mono text-sm font-bold text-ember">{s.code}</p>
                    <p class="text-lg font-bold text-navy mt-1 leading-snug">{s.title}</p>
                  </div>
                  <svg class="w-5 h-5 mt-1 flex-shrink-0 text-ember transition-transform group-open:rotate-45" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                    <line x1="12" y1="5" x2="12" y2="19" stroke-linecap="round"/>
                    <line x1="5" y1="12" x2="19" y2="12" stroke-linecap="round"/>
                  </svg>
                </summary>
                <div class="mt-4 space-y-3">
                  <p class="text-cast-700 leading-relaxed">{s.answer}</p>
                  <p class="text-sm text-cast">
                    <span class="font-bold text-navy">Applies to:</span>{' '}
                    <a href={s.productsHref} class="text-ember font-bold underline underline-offset-4 hover:text-navy">
                      {s.productsLabel} →
                    </a>
                  </p>
                </div>
              </details>
            ))}
          </div>
        </section>

        <!-- Inline CTA #1 -->
        <section class="card p-8 mb-12 border-2 border-yellow bg-yellow/5">
          <h2 class="font-display text-2xl text-navy mb-3">Specifying for a tender?</h2>
          <p class="text-cast-700 leading-relaxed mb-5">
            Tell us the application and we will reference the right standards on the design,
            the mix certificate and the delivery ticket. Same-day callback Monday to Friday.
          </p>
          <div class="flex flex-wrap gap-3">
            <a href="/quote" class="btn-primary">Configure a quote</a>
            <a href="/standards/conformity" class="btn-ghost">View conformity hub</a>
          </div>
        </section>

        <!-- Conformity downloads CTA -->
        <section class="card p-8 md:p-10 mb-6 border-2 border-yellow bg-yellow/5">
          <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6">
            <div>
              <p class="eyebrow text-ember mb-2">Documentation hub</p>
              <h2 class="font-display text-2xl md:text-3xl text-navy mb-3">Download conformity statements.</h2>
              <p class="text-cast-700 leading-relaxed max-w-xl">
                Every standard above has a downloadable conformity statement —
                BS EN 14992, BS 8500-1:2023, BS EN 13369, Eurocode 2, SSAFO 2018, BS 5502-22
                and UKCA / CE marking. Verified Q1 2026.
              </p>
            </div>
            <a href="/standards/conformity" class="btn-yellow shrink-0 inline-flex items-center gap-2">
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" stroke-linecap="round" stroke-linejoin="round"/>
                <polyline points="7 10 12 15 17 10" stroke-linecap="round" stroke-linejoin="round"/>
                <line x1="12" y1="15" x2="12" y2="3" stroke-linecap="round"/>
              </svg>
              <span>Download conformity statements</span>
            </a>
          </div>
        </section>

        <!-- Inline CTA #2 -->
        <section class="bg-navy text-white rounded-lg p-8 md:p-10">
          <h2 class="font-display text-2xl md:text-3xl text-white mb-3">Need the paperwork pack?</h2>
          <p class="text-white/90 mb-6 leading-relaxed">
            Every WCCP delivery ships with the declaration of performance, the structural calc, the mix
            certificate and the cube-test record — as a single PDF. Tell us the job and we will send a
            sample pack so your QS can review the format before the order.
          </p>
          <div class="flex flex-wrap gap-3">
            <a href={`mailto:${site.contact.quotesEmail}`} class="btn-yellow">Request a sample pack</a>
            <a href="/quote" class="btn bg-white text-navy hover:bg-bone">Start a quote</a>
          </div>
        </section>

      </div>

      <!-- Sticky TOC (desktop) -->
      <aside class="hidden lg:block">
        <div class="sticky top-24">
          <p class="eyebrow text-cast mb-4">On this page</p>
          <ol class="space-y-3 text-sm border-l border-cast-100 pl-4">
            <li><a href="#why" class="text-cast hover:text-ember">Why standards matter</a></li>
            {standards.map((s) => (
              <li><a href={`#${s.id}`} class="text-cast hover:text-ember">{s.code}</a></li>
            ))}
          </ol>

          <div class="mt-8 p-4 bg-yellow rounded-lg">
            <p class="text-xs font-bold text-navy uppercase tracking-wide mb-2">Engineer's pack</p>
            <p class="text-sm text-navy mb-3 leading-snug">DoP, calcs, mix cert, cube tests — one PDF per load.</p>
            <a href={`mailto:${site.contact.quotesEmail}`} class="text-navy font-bold text-sm hover:underline">Request a sample →</a>
          </div>
        </div>
      </aside>
    </div>
  </article>

  <!-- Related guides -->
  <section class="bg-bone-200 py-16">
    <div class="container-wccp">
      <p class="eyebrow text-cast mb-3">Related guides</p>
      <h2 class="font-display text-display-md mb-8">Keep reading.</h2>

      <div class="grid md:grid-cols-3 gap-5">
        <a href="/guides/concrete-grades" class="card p-6 group">
          <span class="eyebrow text-ember mb-3 block">Materials</span>
          <h3 class="font-display text-lg font-bold text-navy mb-2 group-hover:text-ember">Concrete grades for agricultural use</h3>
          <p class="text-cast-700 text-sm leading-relaxed">C32/40 vs C40/50, exposure classes and sulphate-resisting cements explained.</p>
        </a>
        <a href="/guides/ssafo-2018" class="card p-6 group">
          <span class="eyebrow text-ember mb-3 block">Regulations</span>
          <h3 class="font-display text-lg font-bold text-navy mb-2 group-hover:text-ember">SSAFO 2018 compliance checklist</h3>
          <p class="text-cast-700 text-sm leading-relaxed">14-day notice, BS 5502-50 design life, drainage rules and EA inspection rights.</p>
        </a>
        <a href="/guides/prestressed-vs-reinforced" class="card p-6 group">
          <span class="eyebrow text-ember mb-3 block">Engineering</span>
          <h3 class="font-display text-lg font-bold text-navy mb-2 group-hover:text-ember">Prestressed vs reinforced precast</h3>
          <p class="text-cast-700 text-sm leading-relaxed">Where each system suits — span, surcharge, geometry compared.</p>
        </a>
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="container-wccp py-16 text-center">
    <h2 class="font-display text-display-lg mb-4">Talk to the yard.</h2>
    <p class="text-cast-700 text-lg max-w-xl mx-auto mb-8">
      Same-day callback Monday to Friday. We will talk you through the standards before you commit a penny.
    </p>
    <div class="flex flex-wrap justify-center gap-3">
      <a href={`tel:${site.contact.phoneIntl}`} class="btn-secondary">Call {site.contact.phone}</a>
      <a href="/quote" class="btn-primary">Configure a quote</a>
    </div>
  </section>
</BaseLayout>
