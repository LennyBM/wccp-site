---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TrustStrip from '@/components/TrustStrip.astro';
import RelatedProductGrid from '@/components/RelatedProductGrid.astro';
import { site } from '@/config/site';

const city = 'Truro';
const county = 'Cornwall';
const distanceMi = 60;
const driveTime = '90 minutes';

const surroundingAreas = [
  'Falmouth', 'Penryn', 'Redruth', 'Camborne', 'St Austell',
  'Newquay', 'Probus', 'Mitchell', 'Perranporth', 'St Agnes',
];

const distances = [
  { name: 'Truro city centre', mi: 60 },
  { name: 'Falmouth', mi: 70 },
  { name: 'St Austell', mi: 55 },
  { name: 'Newquay', mi: 60 },
];

const faqs = [
  { q: `Do you deliver to Truro and Mid Cornwall?`, a: `Yes — Truro is about 60 miles from Holsworthy down the A30. Catalogue loads usually land within 2–3 working days, on our own HIAB-equipped lorries. We are inside the county border within ten miles of the yard, so Cornwall has been a daily run for fifty years.` },
  { q: 'Do you reach the Lizard, Roseland and the Cornish coast?', a: 'Both. Tight lanes and steep drives are normal — the Roseland and the Lizard are no different from North Cornwall to us. We will switch to a rigid 8-wheeler for borderline access and recce difficult sites before the first load.' },
  { q: 'Lead time for Truro jobs?', a: 'Catalogue items 2–3 weeks. Bespoke and engineered precast quoted from drawings — typically four to six weeks from approved design. We carry stock cubicles, troughs and L-blocks so smaller orders often go inside a week.' },
  { q: 'Do you supply Cornwall civils contractors?', a: 'Yes. We supply precast retaining walls, padstones, headwalls and bespoke civils items to principal contractors working across Cornwall on highways, water and infrastructure schemes.' },
];

const related = [
  { href: '/products/cattle-cubicles',     label: 'Cattle Cubicles',     meta: 'AHDB 2024 sized' },
  { href: '/products/slurry-storage',      label: 'Slurry Storage',      meta: 'SSAFO 2018 · 6-month' },
  { href: '/products/retaining-walls',     label: 'Retaining Walls',     meta: 'L / King-post / Cantilever' },
  { href: '/products/culverts',            label: 'Box Culverts',        meta: 'BS EN 1916 / BS 5911' },
];

const serviceSchema = {
  name: `Precast concrete supplier in ${city}`,
  description: `Precast concrete delivered to ${city} and Mid ${county} from the WCCP yard in Holsworthy — roughly ${distanceMi} miles via the A30.`,
  serviceType: 'Precast concrete manufacture and delivery',
  areaServed: [{ '@type': 'City', name: city }, { '@type': 'AdministrativeArea', name: `Mid ${county}` }],
  mainEntityOfPage: `${site.url}/concrete-supplier-truro`,
};
---

<BaseLayout
  title={`Precast concrete supplier ${city} · WCCP`}
  description={`Precast concrete supplier delivering to ${city} and Mid ${county} from our Holsworthy yard, ${distanceMi} miles via the A30. Cubicles, slurry, retaining walls.`}
  schema="Service"
  schemaData={serviceSchema}
>
  <section class="bg-forest-700 text-cream">
    <div class="container-wccp py-20 md:py-28">
      <p class="eyebrow text-cream/70 mb-4">Areas served · {city}</p>
      <h1 class="font-display text-display-2xl text-cream mb-6 max-w-4xl">
        Precast concrete supplier in {city}.<br />
        <em class="text-terracotta not-italic font-display italic">Cast up the road. On your slab in days.</em>
      </h1>
      <p class="text-cream/85 text-lg leading-relaxed max-w-3xl mb-8">
        WCCP delivers precast concrete to {city} from our Holsworthy yard, around {driveTime}
        away down the A30. Common {city} precast jobs:
        <a href="/products/cattle-cubicles" class="text-terracotta-300 underline-offset-4 hover:underline">cattle cubicles</a> for
        South Cornwall dairies, <a href="/products/retaining-walls" class="text-terracotta-300 underline-offset-4 hover:underline"> retaining walls</a> for
        A30 civils and <a href="/products/culverts" class="text-terracotta-300 underline-offset-4 hover:underline"> box culverts</a> for
        water infrastructure schemes. Lead times: 2–3 weeks for catalogue items, 4–6 weeks bespoke.
        Recent deliveries: Falmouth, St Austell and Newquay.
      </p>
      <div class="flex flex-wrap gap-3">
        <a href="/quote" class="btn-primary">Get a quote</a>
        <a href={`tel:${site.contact.phoneIntl}`} class="btn-yellow">Call {site.contact.phone}</a>
      </div>
    </div>
  </section>

  <TrustStrip />

  <section class="container-wccp py-16 md:py-20 section-reveal">
    <div class="grid lg:grid-cols-2 gap-10 items-start">
      <div>
        <p class="eyebrow text-cast mb-3">From the yard</p>
        <h2 class="font-display text-display-md text-forest-700 mb-4">
          Holsworthy to {city}: roughly {distanceMi} miles.
        </h2>
        <p class="text-cast-700 leading-relaxed">
          A30 west — Launceston, Bodmin, on into Truro. Typical delivery 2–3 days from order on
          catalogue items. We run our own HIAB-equipped lorries straight to the slab — no
          third-party haulier and no missing kit on day one.
        </p>
      </div>
      <ul class="space-y-3">
        {distances.map((d) => (
          <li class="flex items-baseline justify-between border-b border-cast-100 pb-3">
            <span class="font-display text-lg font-semibold text-forest-700">{d.name}</span>
            <span class="text-cast tabular-nums">~{d.mi} mi</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="bg-cream-200 py-16 md:py-20 section-reveal">
    <div class="container-wccp">
      <div class="max-w-3xl mb-10">
        <p class="eyebrow text-cast mb-3">Why {city} farms and contractors choose WCCP</p>
        <h2 class="font-display text-display-md text-forest-700 mb-4">A30 west, daily run for fifty years.</h2>
      </div>
      <div class="grid md:grid-cols-2 gap-6 max-w-4xl">
        <div class="card p-6">
          <h3 class="font-display text-lg font-bold text-forest-700 mb-2">South Cornwall dairy</h3>
          <p class="text-cast-700 leading-relaxed">South Cornwall valley dairies — <a href="/products/cattle-cubicles" class="text-terracotta font-semibold hover:underline">cubicles</a>, SSAFO-compliant <a href="/products/slurry-storage" class="text-terracotta font-semibold hover:underline">slurry stores</a> and <a href="/products/feed-troughs" class="text-terracotta font-semibold hover:underline">feed troughs</a>.</p>
        </div>
        <div class="card p-6">
          <h3 class="font-display text-lg font-bold text-forest-700 mb-2">A30 corridor and Cornwall civils</h3>
          <p class="text-cast-700 leading-relaxed">Supplying principal contractors with engineered <a href="/products/retaining-walls" class="text-terracotta font-semibold hover:underline">retaining walls</a> and <a href="/products/culverts" class="text-terracotta font-semibold hover:underline">box culverts</a> for highways and water infrastructure across Cornwall.</p>
        </div>
        <div class="card p-6">
          <h3 class="font-display text-lg font-bold text-forest-700 mb-2">Roseland, Lizard, north coast</h3>
          <p class="text-cast-700 leading-relaxed">Tight Cornish lanes are routine — we recce in advance and switch from artic to rigid 8-wheeler where the village or drive demands it.</p>
        </div>
        <div class="card p-6">
          <h3 class="font-display text-lg font-bold text-forest-700 mb-2">Stock for fast turnaround</h3>
          <p class="text-cast-700 leading-relaxed">Stock cubicles, troughs and <a href="/products/l-blocks" class="text-terracotta font-semibold hover:underline">L-blocks</a> mean smaller Truro orders often ship inside a week, not three.</p>
        </div>
      </div>
      <div class="mt-8">
        <a href="/quote" class="btn-primary">Get a quote</a>
      </div>
    </div>
  </section>

  <section class="container-wccp py-16 md:py-20 section-reveal">
    <div class="max-w-2xl mb-10">
      <p class="eyebrow text-cast mb-3">Areas covered</p>
      <h2 class="font-display text-display-md text-forest-700 mb-4">{city} and Mid {county}.</h2>
      <p class="text-cast-700">From the cathedral city out to the Roseland and the north coast.</p>
    </div>
    <ul class="grid sm:grid-cols-2 md:grid-cols-3 gap-x-6 gap-y-2 max-w-3xl">
      {surroundingAreas.map((a) => (
        <li class="flex gap-2 text-cast-700"><span class="text-terracotta font-bold">·</span> {a}</li>
      ))}
    </ul>
  </section>

  <section class="bg-cream-200 py-16 md:py-20 section-reveal">
    <div class="container-wccp">
      <div class="max-w-2xl mb-10">
        <p class="eyebrow text-cast mb-3">What we cast</p>
        <h2 class="font-display text-display-md text-forest-700 mb-4">Most ordered around {city}.</h2>
        <p class="text-cast-700">Dairy and beef across the South Cornwall valleys, plus civils for A30 schemes and water infrastructure.</p>
      </div>
      <RelatedProductGrid items={related} />
      <div class="mt-8 flex flex-wrap gap-6 text-sm">
        <a href="/products" class="text-terracotta font-bold hover:text-terracotta-700">See the full catalogue →</a>
        <a href="/case-studies" class="text-terracotta font-bold hover:text-terracotta-700">Recent case studies →</a>
      </div>
    </div>
  </section>

  <section class="container-wccp py-16 md:py-20 section-reveal">
    <div class="max-w-2xl mb-10">
      <p class="eyebrow text-cast mb-3">Common questions</p>
      <h2 class="font-display text-display-md text-forest-700">Delivering to {city}.</h2>
    </div>
    <div class="max-w-3xl space-y-4">
      {faqs.map((f) => (
        <details class="card p-6 group">
          <summary class="font-display text-lg font-bold text-forest-700 cursor-pointer list-none flex justify-between items-start gap-4">
            <span>{f.q}</span>
            <span class="text-terracotta text-2xl leading-none group-open:rotate-45 transition-transform shrink-0">+</span>
          </summary>
          <p class="text-cast-700 leading-relaxed mt-4">{f.a}</p>
        </details>
      ))}
    </div>
  </section>

  <section class="bg-forest-700 text-cream py-16">
    <div class="container-wccp text-center max-w-2xl mx-auto">
      <h2 class="font-display text-display-md text-cream mb-3">Built for {county} weather. Made up the road.</h2>
      <p class="text-cream/85 mb-8">Send a drawing or just describe the job. We'll quote inside a working day.</p>
      <div class="flex flex-wrap justify-center gap-3">
        <a href="/quote" class="btn-primary">Get a quote</a>
        <a href={`tel:${site.contact.phoneIntl}`} class="btn-yellow">Call {site.contact.phone}</a>
      </div>
    </div>
  </section>
</BaseLayout>
