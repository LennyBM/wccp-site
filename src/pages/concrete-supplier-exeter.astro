---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TrustStrip from '@/components/TrustStrip.astro';
import RelatedProductGrid from '@/components/RelatedProductGrid.astro';
import { site } from '@/config/site';

const city = 'Exeter';
const county = 'Devon';
const distanceMi = 40;
const driveTime = 'an hour';

const surroundingAreas = [
  'Crediton', 'Tiverton', 'Cullompton', 'Honiton', 'Ottery St Mary',
  'Topsham', 'Exmouth', 'Dawlish', 'Newton Abbot', 'Okehampton',
];

const distances = [
  { name: 'Exeter city centre', mi: 40 },
  { name: 'Crediton', mi: 30 },
  { name: 'Tiverton', mi: 38 },
  { name: 'Cullompton', mi: 45 },
];

const faqs = [
  { q: `Do you deliver to Exeter and Mid Devon?`, a: `Yes — Exeter is roughly 40 miles from our Holsworthy yard via the A30. Catalogue loads usually land within 2–3 working days, on our own HIAB-equipped lorries. We run loads to Crediton, Tiverton and Cullompton every week.` },
  { q: 'Can you reach farms on Exmoor and the Blackdowns?', a: 'Yes. Tight lanes and steep drives are normal for us — we will switch from artic to a rigid 8-wheeler where access is borderline, and we recce difficult sites before the first load.' },
  { q: 'Lead time for Exeter jobs?', a: 'Catalogue items 2–3 weeks. Bespoke and engineered precast quoted from drawings — typically four to six weeks from approved design. Padstones to a beam schedule we can usually turn around inside three weeks.' },
  { q: 'Do you supply Exeter-based main contractors?', a: 'Yes. We supply precast retaining walls, padstones, headwalls and bespoke civils items into Exeter principal contractors working for Devon County Council, National Highways and the M5/A30 corridor schemes.' },
];

const related = [
  { href: '/products/cattle-cubicles',     label: 'Cattle Cubicles',     meta: 'AHDB 2024 sized' },
  { href: '/products/slurry-storage',      label: 'Slurry Storage',      meta: 'SSAFO 2018 · 6-month' },
  { href: '/products/padstones',           label: 'Padstones',           meta: 'Eurocode 6 sized' },
  { href: '/products/retaining-walls',     label: 'Retaining Walls',     meta: 'L / King-post / Cantilever' },
];

const serviceSchema = {
  name: `Precast concrete supplier in ${city}`,
  description: `Precast concrete delivered to ${city} and Mid ${county} from the WCCP yard in Holsworthy — roughly ${distanceMi} miles via the A30. Cubicles, slurry, retaining walls, padstones, culverts.`,
  serviceType: 'Precast concrete manufacture and delivery',
  areaServed: [{ '@type': 'City', name: city }, { '@type': 'AdministrativeArea', name: `Mid ${county}` }],
  mainEntityOfPage: `${site.url}/concrete-supplier-exeter`,
};
---

<BaseLayout
  title={`Precast concrete supplier ${city} · WCCP`}
  description={`Precast concrete supplier delivering to ${city} and Mid ${county} from our Holsworthy yard, ${distanceMi} miles west via the A30. Cubicles, slurry, retaining walls, padstones.`}
  schema="Service"
  schemaData={serviceSchema}
>
  <section class="bg-forest-700 text-cream">
    <div class="container-wccp py-20 md:py-28">
      <p class="eyebrow text-cream/70 mb-4">Areas served · {city}</p>
      <h1 class="font-display text-display-2xl text-cream mb-6 max-w-4xl">
        Precast concrete supplier in {city}.<br />
        <em class="text-terracotta not-italic font-display italic">Cast in North Devon. On site in days.</em>
      </h1>
      <p class="text-cream/85 text-lg leading-relaxed max-w-3xl mb-8">
        WCCP delivers precast concrete to {city} from our Holsworthy yard, {driveTime} away
        via the A30. Common {city} precast jobs: <a href="/products/padstones" class="text-terracotta-300 underline-offset-4 hover:underline">padstones</a> for
        new-build steel frames, <a href="/products/retaining-walls" class="text-terracotta-300 underline-offset-4 hover:underline"> retaining walls</a> for
        M5-corridor civils and <a href="/products/cattle-cubicles" class="text-terracotta-300 underline-offset-4 hover:underline"> cattle cubicles</a> for
        Mid Devon dairies. Lead times: 2–3 weeks for catalogue items, 4–6 weeks bespoke.
        Recent deliveries: Crediton, Tiverton and Cullompton.
      </p>
      <div class="flex flex-wrap gap-3">
        <a href="/quote" class="btn-primary">Get a quote</a>
        <a href={`tel:${site.contact.phoneIntl}`} class="btn-yellow">Call {site.contact.phone}</a>
      </div>
    </div>
  </section>

  <TrustStrip />

  <section class="container-wccp py-16 md:py-20 section-reveal">
    <div class="grid lg:grid-cols-2 gap-10 items-start">
      <div>
        <p class="eyebrow text-cast mb-3">From the yard</p>
        <h2 class="font-display text-display-md text-forest-700 mb-4">
          Holsworthy to {city}: roughly {distanceMi} miles.
        </h2>
        <p class="text-cast-700 leading-relaxed">
          Straight run east along the A30 — Okehampton, Whiddon Down, into the M5 corridor at
          Exeter. Typical delivery 2–3 days from order on catalogue items. We run our own
          HIAB-equipped lorries, no third-party haulier.
        </p>
      </div>
      <ul class="space-y-3">
        {distances.map((d) => (
          <li class="flex items-baseline justify-between border-b border-cast-100 pb-3">
            <span class="font-display text-lg font-semibold text-forest-700">{d.name}</span>
            <span class="text-cast tabular-nums">~{d.mi} mi</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="bg-cream-200 py-16 md:py-20 section-reveal">
    <div class="container-wccp">
      <div class="max-w-3xl mb-10">
        <p class="eyebrow text-cast mb-3">Why {city} contractors and farms choose WCCP</p>
        <h2 class="font-display text-display-md text-forest-700 mb-4">An hour west, on the A30.</h2>
      </div>
      <div class="grid md:grid-cols-2 gap-6 max-w-4xl">
        <div class="card p-6">
          <h3 class="font-display text-lg font-bold text-forest-700 mb-2">M5 / A30 main contractors</h3>
          <p class="text-cast-700 leading-relaxed">Trusted on Devon CC and National Highways frameworks for engineered <a href="/products/retaining-walls" class="text-terracotta font-semibold hover:underline">retaining walls</a> and <a href="/products/culverts" class="text-terracotta font-semibold hover:underline">box culverts</a>.</p>
        </div>
        <div class="card p-6">
          <h3 class="font-display text-lg font-bold text-forest-700 mb-2">Mid Devon dairy</h3>
          <p class="text-cast-700 leading-relaxed">Crediton and Tiverton dairies — high-yield <a href="/products/cattle-cubicles" class="text-terracotta font-semibold hover:underline">cubicles</a> and SSAFO-compliant <a href="/products/slurry-storage" class="text-terracotta font-semibold hover:underline">slurry stores</a> sized to herd.</p>
        </div>
        <div class="card p-6">
          <h3 class="font-display text-lg font-bold text-forest-700 mb-2">Architects and self-builders</h3>
          <p class="text-cast-700 leading-relaxed">Eurocode 6 <a href="/products/padstones" class="text-terracotta font-semibold hover:underline">padstones</a> cast to your beam schedule — usually inside three weeks. Self-build basements get <a href="/products/king-post-walls" class="text-terracotta font-semibold hover:underline">king-post wall</a> systems.</p>
        </div>
        <div class="card p-6">
          <h3 class="font-display text-lg font-bold text-forest-700 mb-2">No haulier guesswork</h3>
          <p class="text-cast-700 leading-relaxed">Own HIAB lorries, own drivers — kit lands where the bricklayer needs it on day one, not day three.</p>
        </div>
      </div>
      <div class="mt-8">
        <a href="/quote" class="btn-primary">Get a quote</a>
      </div>
    </div>
  </section>

  <section class="container-wccp py-16 md:py-20 section-reveal">
    <div class="max-w-2xl mb-10">
      <p class="eyebrow text-cast mb-3">Areas covered</p>
      <h2 class="font-display text-display-md text-forest-700 mb-4">{city} and the M5 corridor.</h2>
      <p class="text-cast-700">City-centre civils right out to the Mid Devon farms.</p>
    </div>
    <ul class="grid sm:grid-cols-2 md:grid-cols-3 gap-x-6 gap-y-2 max-w-3xl">
      {surroundingAreas.map((a) => (
        <li class="flex gap-2 text-cast-700"><span class="text-terracotta font-bold">·</span> {a}</li>
      ))}
    </ul>
  </section>

  <section class="bg-cream-200 py-16 md:py-20 section-reveal">
    <div class="container-wccp">
      <div class="max-w-2xl mb-10">
        <p class="eyebrow text-cast mb-3">What we cast</p>
        <h2 class="font-display text-display-md text-forest-700 mb-4">Most ordered around {city}.</h2>
        <p class="text-cast-700">Dairy and beef cubicle sheds across Mid Devon, plus steady civils flow into the M5/A30 schemes.</p>
      </div>
      <RelatedProductGrid items={related} />
      <div class="mt-8 flex flex-wrap gap-6 text-sm">
        <a href="/products" class="text-terracotta font-bold hover:text-terracotta-700">See the full catalogue →</a>
        <a href="/case-studies" class="text-terracotta font-bold hover:text-terracotta-700">Recent case studies →</a>
      </div>
    </div>
  </section>

  <section class="container-wccp py-16 md:py-20 section-reveal">
    <div class="max-w-2xl mb-10">
      <p class="eyebrow text-cast mb-3">Common questions</p>
      <h2 class="font-display text-display-md text-forest-700">Delivering to {city}.</h2>
    </div>
    <div class="max-w-3xl space-y-4">
      {faqs.map((f) => (
        <details class="card p-6 group">
          <summary class="font-display text-lg font-bold text-forest-700 cursor-pointer list-none flex justify-between items-start gap-4">
            <span>{f.q}</span>
            <span class="text-terracotta text-2xl leading-none group-open:rotate-45 transition-transform shrink-0">+</span>
          </summary>
          <p class="text-cast-700 leading-relaxed mt-4">{f.a}</p>
        </details>
      ))}
    </div>
  </section>

  <section class="bg-forest-700 text-cream py-16">
    <div class="container-wccp text-center max-w-2xl mx-auto">
      <h2 class="font-display text-display-md text-cream mb-3">Cast in North Devon, delivered to {city}.</h2>
      <p class="text-cream/85 mb-8">Send a drawing or just describe the job. We'll quote inside a working day.</p>
      <div class="flex flex-wrap justify-center gap-3">
        <a href="/quote" class="btn-primary">Get a quote</a>
        <a href={`tel:${site.contact.phoneIntl}`} class="btn-yellow">Call {site.contact.phone}</a>
      </div>
    </div>
  </section>
</BaseLayout>
