---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TrustStrip from '@/components/TrustStrip.astro';
import RelatedProductGrid from '@/components/RelatedProductGrid.astro';
import { site } from '@/config/site';

const city = 'Yeovil';
const county = 'Somerset';
const distanceMi = 75;

const surroundingAreas = [
  'Sherborne', 'Crewkerne', 'Ilminster', 'Chard', 'Martock',
  'Wincanton', 'Castle Cary', 'Bruton', 'Somerton', 'Langport',
];

const distances = [
  { name: 'Yeovil town centre', mi: 75 },
  { name: 'Crewkerne', mi: 70 },
  { name: 'Sherborne', mi: 78 },
  { name: 'Wincanton', mi: 85 },
];

const faqs = [
  { q: `Do you deliver to Yeovil and South Somerset?`, a: `Yes — Yeovil is roughly 75 miles from Holsworthy via the A30 and A303. Catalogue loads typically arrive within 3 working days, on our own HIAB-equipped lorries. We run east into South Somerset and West Dorset every week.` },
  { q: 'Do you reach the South Somerset villages and the Dorset border?', a: 'Yes. Sherborne, Castle Cary, Bruton, Crewkerne — all regular drops. Tight rural lanes are routine; on borderline access we will recce and switch to a rigid 8-wheeler if needed.' },
  { q: 'Lead time for Yeovil jobs?', a: 'Catalogue items 2–3 weeks. Bespoke and engineered precast quoted from drawings — typically four to six weeks from approved design.' },
  { q: 'Do you supply Somerset and West Dorset main contractors?', a: 'Yes. We supply precast retaining walls, padstones, headwalls and bespoke civils items into the South Somerset / West Dorset civils chain — including A303 corridor schemes, agricultural framework jobs and large dairy units.' },
];

const related = [
  { href: '/products/cattle-cubicles',     label: 'Cattle Cubicles',     meta: 'AHDB 2024 sized' },
  { href: '/products/slurry-storage',      label: 'Slurry Storage',      meta: 'SSAFO 2018 · 6-month' },
  { href: '/products/silage-clamp-walls',  label: 'Silage Clamp Walls',  meta: 'BS EN 1992' },
  { href: '/products/retaining-walls',     label: 'Retaining Walls',     meta: 'L / King-post / Cantilever' },
];

const localBusinessSchema = {
  areaServed: { '@type': 'City', name: `${city}, ${county}, United Kingdom` },
  mainEntityOfPage: `${site.url}/concrete-supplier-yeovil`,
};
---

<BaseLayout
  title={`Precast concrete supplier · ${city}`}
  description={`Precast concrete delivered to ${city} and South Somerset from the WCCP yard in Holsworthy — roughly ${distanceMi} miles. Cubicles, slurry, silage, retaining walls. Cast in North Devon.`}
  schema="LocalBusiness"
  schemaData={localBusinessSchema}
>
  <section class="bg-forest-700 text-cream">
    <div class="container-wccp py-20 md:py-28">
      <p class="eyebrow text-cream/70 mb-4">Areas served · {city}</p>
      <h1 class="font-display text-display-2xl text-cream mb-6 max-w-4xl">
        Precast concrete delivered to {city} and South {county}.<br />
        <em class="text-terracotta not-italic font-display italic">Made in Devon. On your slab in days.</em>
      </h1>
      <p class="text-cream/85 text-lg leading-relaxed max-w-2xl mb-8">
        Family-led North Devon precast, {distanceMi} miles east of {city} via the A30 / A303. Same lorries
        we run to Sherborne, Crewkerne and Wincanton.
      </p>
      <div class="flex flex-wrap gap-3">
        <a href="/quote" class="btn-primary">Get a quote</a>
        <a href={`tel:${site.contact.phoneIntl}`} class="btn-yellow">Call {site.contact.phone}</a>
      </div>
    </div>
  </section>

  <TrustStrip />

  <section class="container-wccp py-16 md:py-20 section-reveal">
    <div class="grid lg:grid-cols-2 gap-10 items-start">
      <div>
        <p class="eyebrow text-cast mb-3">From the yard</p>
        <h2 class="font-display text-display-md text-forest-700 mb-4">
          Holsworthy to {city}: roughly {distanceMi} miles.
        </h2>
        <p class="text-cast-700 leading-relaxed">
          A30 east through Honiton, then A303 across the Blackdown Hills into Yeovil. Typical
          delivery 3 days from order on catalogue items. Our own HIAB-equipped lorries unload
          straight to the slab.
        </p>
      </div>
      <ul class="space-y-3">
        {distances.map((d) => (
          <li class="flex items-baseline justify-between border-b border-cast-100 pb-3">
            <span class="font-display text-lg font-semibold text-forest-700">{d.name}</span>
            <span class="text-cast tabular-nums">~{d.mi} mi</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="bg-cream-200 py-16 md:py-20 section-reveal">
    <div class="container-wccp">
      <div class="max-w-2xl mb-10">
        <p class="eyebrow text-cast mb-3">Areas covered</p>
        <h2 class="font-display text-display-md text-forest-700 mb-4">{city} and South {county}.</h2>
        <p class="text-cast-700">From Yeovil town across the A303 corridor and into the Dorset border.</p>
      </div>
      <ul class="grid sm:grid-cols-2 md:grid-cols-3 gap-x-6 gap-y-2 max-w-3xl">
        {surroundingAreas.map((a) => (
          <li class="flex gap-2 text-cast-700"><span class="text-terracotta font-bold">·</span> {a}</li>
        ))}
      </ul>
    </div>
  </section>

  <section class="container-wccp py-16 md:py-20 section-reveal">
    <div class="max-w-2xl mb-10">
      <p class="eyebrow text-cast mb-3">What we cast</p>
      <h2 class="font-display text-display-md text-forest-700 mb-4">Most ordered around {city}.</h2>
      <p class="text-cast-700">Big dairy across South Somerset, silage clamps and slurry stores ahead of the SIG 2026 deadline.</p>
    </div>
    <RelatedProductGrid items={related} />
    <div class="mt-8 flex flex-wrap gap-6 text-sm">
      <a href="/products" class="text-terracotta font-bold hover:text-terracotta-700">See the full catalogue →</a>
      <a href="/case-studies" class="text-terracotta font-bold hover:text-terracotta-700">Recent case studies →</a>
    </div>
  </section>

  <section class="bg-cream-200 py-16 md:py-20 section-reveal">
    <div class="container-wccp">
      <div class="max-w-2xl mb-10">
        <p class="eyebrow text-cast mb-3">Common questions</p>
        <h2 class="font-display text-display-md text-forest-700">Delivering to {city}.</h2>
      </div>
      <div class="max-w-3xl space-y-4">
        {faqs.map((f) => (
          <details class="card p-6 group">
            <summary class="font-display text-lg font-bold text-forest-700 cursor-pointer list-none flex justify-between items-start gap-4">
              <span>{f.q}</span>
              <span class="text-terracotta text-2xl leading-none group-open:rotate-45 transition-transform shrink-0">+</span>
            </summary>
            <p class="text-cast-700 leading-relaxed mt-4">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-forest-700 text-cream py-16">
    <div class="container-wccp text-center max-w-2xl mx-auto">
      <h2 class="font-display text-display-md text-cream mb-3">Made for {county} farms and civils.</h2>
      <p class="text-cream/85 mb-8">Send a drawing or just describe the job. We'll quote inside a working day.</p>
      <div class="flex flex-wrap justify-center gap-3">
        <a href="/quote" class="btn-primary">Get a quote</a>
        <a href={`tel:${site.contact.phoneIntl}`} class="btn-yellow">Call {site.contact.phone}</a>
      </div>
    </div>
  </section>
</BaseLayout>
