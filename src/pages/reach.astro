---
// reach.astro
//
// Where we deliver — UK + Northern Europe footprint, with recent jobs pinned
// on a hand-traced SVG outline. The map IS the content.
//
// Coordinate system: viewBox 0 0 800 700, with a stylised UK + N Europe.
// Pin colours:
//   - Yellow (#fff005) = UK jobs
//   - Ember  (#FF6B35) = European jobs
//   - Navy   (#3a5cb5) = Holsworthy yard (origin)

import BaseLayout from '@/layouts/BaseLayout.astro';
import TrustStrip from '@/components/TrustStrip.astro';
import { site } from '@/config/site';

type Pin = {
  id: string;
  name: string;
  region: 'uk' | 'europe' | 'origin';
  cx: number;
  cy: number;
  job: string;
  detail: string;
};

// Each pin: cx/cy chosen against the simplified path below so the geometry
// reads roughly correctly. UK jobs in yellow, Europe in ember, origin navy.
const pins: Pin[] = [
  { id: 'hebrides',  name: 'Outer Hebrides (Stornoway)', region: 'uk',     cx: 200, cy: 130, job: 'Estate retaining walls, 2025', detail: 'Low-loader run via Ullapool — full panel set + commissioning crew on site for 5 days.' },
  { id: 'aberdeen',  name: 'Aberdeen',                   region: 'uk',     cx: 320, cy: 170, job: 'Slurry tower, dairy estate',   detail: 'Round prestressed tower, 1,800 m³, paired with parlour wash reception pit.' },
  { id: 'edinburgh', name: 'Edinburgh',                  region: 'uk',     cx: 280, cy: 245, job: 'Cantilever retaining wall',    detail: 'Civils contract — 4.5m cantilever units to BS EN 1992, 320 lin m.' },
  { id: 'belfast',   name: 'Belfast',                    region: 'uk',     cx: 175, cy: 270, job: 'Bespoke precast culverts',     detail: 'NI Water — twin-cell box culverts, 2.4m × 1.8m internal, sulphate-resisting mix.' },
  { id: 'dublin',    name: 'Dublin',                     region: 'uk',     cx: 175, cy: 320, job: 'Civils padstones',             detail: 'Steel-frame padstones for a Dublin distribution centre — 180 units, fast-track 3-week run.' },
  { id: 'truro',     name: 'Truro',                      region: 'uk',     cx: 215, cy: 510, job: 'Cattle cubicle shed',          detail: 'Holstein-spec cubicles + pre-cast end walls, single-day install.' },
  { id: 'holsworthy',name: 'Holsworthy (WCCP yard)',     region: 'origin', cx: 245, cy: 490, job: 'WCCP yard',                    detail: 'Cast in North Devon. Every panel on the map ships from here.' },
  { id: 'rennes',    name: 'Brittany (Rennes)',          region: 'europe', cx: 360, cy: 530, job: 'Cubicle end walls export',     detail: 'French dairy co-op order — 240 cubicle end walls, low-loader via Roscoff.' },
  { id: 'rotterdam', name: 'Rotterdam',                  region: 'europe', cx: 470, cy: 380, job: 'Container basing slabs',       detail: 'Port-side basing slabs, 200mm reinforced, sized for 40ft container stacks.' },
  { id: 'munich',    name: 'Munich',                     region: 'europe', cx: 580, cy: 480, job: 'DIN-spec retaining walls, 240t', detail: 'Ground engineering job — 240 tonnes of L-blocks to German DIN spec, 8 lorry loads.' },
];

const recentRuns = pins.filter((p) => p.region !== 'origin');

const serviceSchema = {
  '@type': 'Service',
  name: 'Precast concrete delivery — UK & Europe',
  serviceType: 'Precast concrete supply and delivery',
  provider: { '@type': 'Organization', name: site.name, url: site.url },
  areaServed: site.areasServed.map((a) => ({ '@type': 'AdministrativeArea', name: a })),
  description:
    'Own-fleet UK delivery and planned-run Europe delivery of precast concrete from the WCCP yard in Holsworthy, North Devon.',
};
---

<BaseLayout
  title="Where we deliver — UK-wide & into Europe"
  description="Recent precast concrete deliveries from the WCCP yard in Holsworthy, North Devon — to Cornwall, the Outer Hebrides, Northern Ireland, Germany, the Netherlands and beyond."
  schema="Service"
  schemaData={serviceSchema}
>
  <TrustStrip />

  <!-- ====== Hero ====== -->
  <section class="bg-navy text-white border-b border-navy-700">
    <div class="container-wccp py-16 md:py-20">
      <div class="max-w-3xl">
        <p class="eyebrow text-yellow mb-4">
          <span class="inline-block w-8 h-px bg-yellow align-middle mr-3"></span>
          Delivery footprint
        </p>
        <h1 class="font-display text-display-xl text-white mb-5">
          Cast in North Devon. Delivered wherever the slab is.
        </h1>
        <p class="text-lg text-white/90 leading-relaxed max-w-2xl">
          Our own-fleet lorries cover the UK door-to-door — Cornwall to Caithness,
          and across the water to Belfast, Dublin and the Outer Hebrides. For
          European jobs, we run planned shipments to Germany, the Netherlands,
          France and beyond — same factory, same paperwork, same SSAFO/DIN-spec
          finish on the slab.
        </p>
      </div>
    </div>
  </section>

  <!-- ====== Map ====== -->
  <section class="container-wccp section-rhythm">
    <div class="max-w-2xl mb-10">
      <p class="eyebrow text-cast mb-3">Recent jobs · 2024–2025</p>
      <h2 class="font-display text-display-lg mb-4">Ten recent deliveries on the map.</h2>
      <p class="text-cast-700 text-lg">
        Hover or tap a pin for the spec. Yellow pins are UK jobs, orange pins are
        European, the navy marker is the yard.
      </p>
    </div>

    <figure class="card bg-bone-200 p-4 md:p-8 overflow-hidden">
      <div
        class="relative aspect-[8/7] w-full"
        role="img"
        aria-label="Map of the UK and Northern Europe with pins marking recent WCCP precast concrete deliveries"
      >
        <svg
          viewBox="0 0 800 700"
          class="w-full h-full"
          xmlns="http://www.w3.org/2000/svg"
          preserveAspectRatio="xMidYMid meet"
        >
          <!-- Sea / background tint -->
          <rect width="800" height="700" fill="#F0EBDF" />

          <!-- Grid (subtle) -->
          <g aria-hidden="true" stroke="#D9D2C0" stroke-width="0.5" fill="none">
            {Array.from({ length: 8 }).map((_, i) => (
              <line x1={100 * (i + 1)} y1={0} x2={100 * (i + 1)} y2={700} />
            ))}
            {Array.from({ length: 7 }).map((_, i) => (
              <line x1={0} y1={100 * (i + 1)} x2={800} y2={100 * (i + 1)} />
            ))}
          </g>

          <!-- ============= LANDMASS (simplified, traceable outlines) ============= -->
          <!-- Mainland Great Britain -->
          <path
            d="M 220 120
               L 270 100
               L 320 130
               L 340 180
               L 320 230
               L 305 280
               L 290 320
               L 270 360
               L 235 405
               L 215 445
               L 205 490
               L 215 530
               L 195 555
               L 175 540
               L 195 500
               L 200 460
               L 175 425
               L 165 390
               L 175 350
               L 195 310
               L 200 270
               L 205 220
               L 210 175
               L 220 120 Z"
            fill="#E8E1CD"
            stroke="#B8AB8C"
            stroke-width="1.5"
            stroke-linejoin="round"
          />

          <!-- Northern Scotland / Highland tail -->
          <path
            d="M 270 100
               L 295 75
               L 320 80
               L 335 110
               L 320 130 Z"
            fill="#E8E1CD"
            stroke="#B8AB8C"
            stroke-width="1.5"
            stroke-linejoin="round"
          />

          <!-- Outer Hebrides -->
          <path
            d="M 188 120 L 200 110 L 210 125 L 208 145 L 195 150 Z"
            fill="#E8E1CD"
            stroke="#B8AB8C"
            stroke-width="1.5"
            stroke-linejoin="round"
          />

          <!-- Ireland (Northern + Republic, simplified single landmass) -->
          <path
            d="M 130 250
               L 160 240
               L 195 250
               L 205 280
               L 200 320
               L 185 345
               L 160 350
               L 135 340
               L 120 315
               L 115 285
               L 130 250 Z"
            fill="#E8E1CD"
            stroke="#B8AB8C"
            stroke-width="1.5"
            stroke-linejoin="round"
          />

          <!-- Brittany / France (NW coast) -->
          <path
            d="M 320 540
               L 380 530
               L 440 545
               L 480 575
               L 510 620
               L 470 670
               L 380 680
               L 320 660
               L 295 620
               L 305 580
               L 320 540 Z"
            fill="#E8E1CD"
            stroke="#B8AB8C"
            stroke-width="1.5"
            stroke-linejoin="round"
          />

          <!-- Netherlands / Belgium / NW Germany lowlands -->
          <path
            d="M 430 350
               L 490 340
               L 540 360
               L 560 400
               L 545 440
               L 510 460
               L 470 455
               L 440 430
               L 425 395
               L 430 350 Z"
            fill="#E8E1CD"
            stroke="#B8AB8C"
            stroke-width="1.5"
            stroke-linejoin="round"
          />

          <!-- Germany / S Germany (Bavaria) -->
          <path
            d="M 540 360
               L 610 370
               L 660 405
               L 680 460
               L 670 510
               L 620 530
               L 570 515
               L 545 480
               L 545 440
               L 560 400
               L 540 360 Z"
            fill="#E8E1CD"
            stroke="#B8AB8C"
            stroke-width="1.5"
            stroke-linejoin="round"
          />

          <!-- ============= ROUTE LINES (yard → each pin, very subtle) ============= -->
          <g stroke="#B8AB8C" stroke-width="0.75" stroke-dasharray="3 4" fill="none" opacity="0.6">
            {pins.filter((p) => p.region !== 'origin').map((p) => (
              <line x1={245} y1={490} x2={p.cx} y2={p.cy} />
            ))}
          </g>

          <!-- ============= PINS ============= -->
          {pins.map((p) => {
            const isOrigin = p.region === 'origin';
            const isUK     = p.region === 'uk';
            const fill     = isOrigin ? '#3a5cb5' : isUK ? '#fff005' : '#FF6B35';
            const stroke   = isOrigin ? '#fff005' : '#FFFFFF';
            const r        = isOrigin ? 9 : 6;
            return (
              <g class="map-pin" data-pin={p.id}>
                {/* Soft halo */}
                <circle cx={p.cx} cy={p.cy} r={r + 6} fill={fill} opacity="0.18" />
                {/* Main pin */}
                <circle
                  cx={p.cx}
                  cy={p.cy}
                  r={r}
                  fill={fill}
                  stroke={stroke}
                  stroke-width="2"
                  class="cursor-pointer transition-all"
                >
                  <title>{p.name} — {p.job}</title>
                </circle>
                {isOrigin && (
                  <text
                    x={p.cx + 14}
                    y={p.cy + 4}
                    fill="#3a5cb5"
                    font-family="ui-monospace, monospace"
                    font-size="11"
                    font-weight="700"
                  >YARD</text>
                )}
              </g>
            );
          })}

          <!-- Compass / scale flourish -->
          <g aria-hidden="true" transform="translate(720, 60)">
            <circle r="22" fill="#FFFFFF" stroke="#B8AB8C" stroke-width="1" />
            <path d="M 0 -16 L 5 0 L 0 16 L -5 0 Z" fill="#3a5cb5" />
            <text x="0" y="-26" text-anchor="middle" fill="#3a5cb5" font-family="ui-monospace, monospace" font-size="10" font-weight="700">N</text>
          </g>
        </svg>

        <!-- Legend -->
        <div class="absolute left-3 bottom-3 md:left-6 md:bottom-6 bg-white/95 border border-cast-100 rounded p-3 md:p-4 shadow-soft text-xs md:text-sm">
          <p class="eyebrow text-cast mb-2">Legend</p>
          <ul class="space-y-1.5">
            <li class="flex items-center gap-2">
              <span aria-hidden="true" class="inline-block w-3 h-3 rounded-full bg-navy ring-2 ring-yellow"></span>
              <span class="text-navy font-bold">Holsworthy yard</span>
            </li>
            <li class="flex items-center gap-2">
              <span aria-hidden="true" class="inline-block w-3 h-3 rounded-full bg-yellow ring-2 ring-white"></span>
              <span class="text-navy">UK delivery</span>
            </li>
            <li class="flex items-center gap-2">
              <span aria-hidden="true" class="inline-block w-3 h-3 rounded-full bg-ember ring-2 ring-white"></span>
              <span class="text-navy">Europe delivery</span>
            </li>
          </ul>
        </div>
      </div>

      <figcaption class="mt-4 text-cast text-xs">
        Stylised map for context only. Pins indicate the destination of recent
        WCCP precast deliveries between 2024 and 2025.
      </figcaption>
    </figure>
  </section>

  <!-- ====== Recent runs grid ====== -->
  <section class="bg-bone-200 section-rhythm border-t border-cast-100">
    <div class="container-wccp">
      <div class="max-w-2xl mb-10">
        <p class="eyebrow text-cast mb-3">Recent runs</p>
        <h2 class="font-display text-display-lg mb-4">Nine recent jobs, in order of distance from the yard.</h2>
        <p class="text-cast-700 text-lg">
          Same factory, same Carey-cast finish, same paperwork — whether the lorry
          is going to Cornwall or Bavaria.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 reveal-stagger">
        {recentRuns.map((p) => {
          const isUK = p.region === 'uk';
          const tag  = isUK ? 'UK' : 'Europe';
          const dotClass = isUK ? 'bg-yellow' : 'bg-ember';
          return (
            <article class="card p-6 group">
              <div class="flex items-center gap-2 mb-3">
                <span aria-hidden="true" class={`inline-block w-2.5 h-2.5 rounded-full ${dotClass}`}></span>
                <span class="font-mono text-[11px] uppercase tracking-wider text-cast">{tag} · {p.name.split(' (')[0]}</span>
              </div>
              <h3 class="font-display text-lg font-bold text-navy mb-2 group-hover:text-ember transition-colors">
                {p.job}
              </h3>
              <p class="text-cast-700 text-sm leading-relaxed">{p.detail}</p>
            </article>
          );
        })}
      </div>
    </div>
  </section>

  <!-- ====== Mid-page CTA strip — postcode prompt ====== -->
  <section class="bg-yellow text-navy py-12 border-t border-cast-100">
    <div class="container-wccp">
      <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6">
        <div>
          <p class="eyebrow text-navy mb-2">Not on the map?</p>
          <h2 class="font-display text-display-md">Not sure if we deliver to you? Send a postcode.</h2>
          <p class="text-navy/80 mt-2 max-w-xl">
            We will come back the same day with a haulage figure and a lead time —
            no obligation, no chase-up call.
          </p>
        </div>
        <div class="flex flex-wrap gap-3 shrink-0">
          <a
            href={`https://wa.me/${site.contact.whatsapp.replace('+', '')}?text=${encodeURIComponent('Hi WCCP — can you deliver to postcode [        ]? Looking at [product].')}`}
            class="btn bg-navy text-white hover:bg-navy-700"
            target="_blank"
            rel="noopener"
            aria-label="WhatsApp WCCP a postcode"
          >
            WhatsApp a postcode
          </a>
          <a href={`tel:${site.contact.phoneIntl}`} class="btn-secondary" aria-label={`Call WCCP on ${site.contact.phone}`}>
            Call {site.contact.phone}
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ====== Final CTA ====== -->
  <section class="container-wccp section-rhythm text-center reveal">
    <p class="eyebrow text-cast mb-4">No call centre. No menu options.</p>
    <h2 class="font-display text-display-xl mb-4">Talk to the yard.</h2>
    <p class="text-cast text-lg max-w-xl mx-auto mb-10">
      Send us a sketch and a postcode — we will quote inside 24 hours, including
      haulage to your gate.
    </p>
    <div class="flex flex-wrap justify-center gap-3">
      <a href={`tel:${site.contact.phoneIntl}`} class="btn-secondary">
        Call {site.contact.phone}
      </a>
      <a
        href={`https://wa.me/${site.contact.whatsapp.replace('+', '')}`}
        class="btn-yellow"
        target="_blank"
        rel="noopener"
      >
        WhatsApp us
      </a>
      <a href="/quote" class="btn-primary">Configure a quote</a>
    </div>
  </section>
</BaseLayout>

<style>
  /* Subtle pin hover lift — works even with vanilla SVG */
  .map-pin > circle:nth-of-type(2) {
    transform-box: fill-box;
    transform-origin: center;
    transition: transform 200ms ease, filter 200ms ease;
  }
  .map-pin:hover > circle:nth-of-type(2),
  .map-pin:focus-within > circle:nth-of-type(2) {
    transform: scale(1.4);
    filter: drop-shadow(0 0 8px rgba(255, 107, 53, 0.6));
  }
</style>
