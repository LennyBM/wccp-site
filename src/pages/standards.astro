---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { site } from '@/config/site';

// Canonical Standards landing page — short overview, links out to:
//  - /standards-explained (deeper per-standard explainer with FAQ)
//  - /standards/conformity (DoP / DoC document hub)

const summary = [
  {
    code: 'BS EN 14992',
    label: 'Precast wall elements',
    note: 'Harmonised EN — basis of the UKCA mark on every WCCP panel.',
    products: '/products/prestressed-panels',
  },
  {
    code: 'BS 8500-1:2023',
    label: 'Concrete classification',
    note: 'UK mix specification — exposure class, strength, cement content.',
    products: '/products/slurry-storage',
  },
  {
    code: 'BS EN 1992 (Eurocode 2)',
    label: 'Structural design',
    note: 'Design code for every WCCP structural calc — Parts 1-1, 1-2 and 3.',
    products: '/products/retaining-walls',
  },
  {
    code: 'BS EN 1992-3',
    label: 'Liquid-retention design',
    note: 'Crack-width control to 0.2mm for slurry, silage and water tanks.',
    products: '/products/slurry-storage',
  },
  {
    code: 'BS 5502-22',
    label: 'Agricultural buildings',
    note: 'Cubicle dimensions, livestock loadings, durability for the dairy.',
    products: '/products/cattle-cubicles',
  },
  {
    code: 'SSAFO 2018',
    label: 'Slurry, silage, fuel oil',
    note: '20-year design life, EA notification, impermeability rules.',
    products: '/products/silage-clamp-walls',
  },
  {
    code: 'CE / UKCA',
    label: 'Conformity marking',
    note: 'Construction Products Regulation — DoP issued with every load.',
    products: '/standards/conformity',
  },
];
---

<BaseLayout
  title="Standards — the codes WCCP precast is cast to"
  description="The standards landscape for WCCP precast concrete: BS EN 14992 (precast structural), BS 8500-1:2023 (concrete classification), BS EN 1992 / Eurocode 2 (structural design), BS EN 1992-3 (liquid retention), BS 5502-22 (agricultural buildings), SSAFO 2018 and CE/UKCA conformity."
  image="/images/standards.jpg"
  schema="Article"
>
  <!-- Hero -->
  <section class="bg-navy text-white">
    <div class="container-wccp py-14 md:py-16">
      <nav class="text-sm text-white/90 mb-6" aria-label="Breadcrumb">
        <a href="/" class="hover:text-yellow">Home</a>
        <span class="mx-2 text-cast">/</span>
        <span class="text-white/90">Standards</span>
      </nav>
      <p class="eyebrow text-yellow mb-4">Standards · Trust signals</p>
      <h1 class="font-display text-display-xl text-white mb-6 max-w-4xl">
        The standards every WCCP cast is signed off against.
      </h1>

      <!-- Direct answer (40-60 words) -->
      <div class="bg-navy-700 border-l-4 border-yellow p-6 max-w-3xl rounded-r">
        <p class="text-white/90 text-lg leading-relaxed">
          <strong class="text-white">Direct answer:</strong> WCCP precast is cast to BS EN 14992
          (precast structural), BS 8500-1:2023 (concrete classification), BS EN 1992 / Eurocode 2
          (structural design), BS EN 1992-3 (liquid retention — slurry and silage), BS 5502-22
          (agricultural buildings) and SSAFO 2018 (slurry, silage, fuel oil). Every harmonised
          product ships with a CE / UKCA declaration of performance.
        </p>
      </div>
    </div>
  </section>

  <!-- Summary table -->
  <section class="container-wccp py-12 md:py-16">
    <div class="max-w-3xl mb-8">
      <p class="eyebrow text-cast mb-3">At a glance</p>
      <h2 class="font-display text-display-md mb-4">The standards landscape.</h2>
      <p class="text-cast-700 text-lg leading-relaxed">
        Seven codes cover most of what we make. Each links to the products it governs. For the
        full plain-English explainer with FAQ, see <a href="/standards-explained" class="text-ember font-bold underline underline-offset-4 hover:text-navy">Standards explained</a>.
        For downloadable DoP/DoC paperwork, see <a href="/standards/conformity" class="text-ember font-bold underline underline-offset-4 hover:text-navy">Declarations of conformity</a>.
      </p>
    </div>

    <div class="grid gap-3" role="list">
      {summary.map((s) => (
        <a href={s.products} class="card p-5 md:p-6 group block" role="listitem">
          <div class="grid md:grid-cols-[16rem_1fr_auto] gap-3 md:gap-6 items-start md:items-center">
            <div>
              <p class="font-mono text-sm font-bold text-navy tracking-tight">{s.code}</p>
              <p class="font-display text-base font-bold text-navy mt-1 leading-snug">{s.label}</p>
            </div>
            <p class="text-cast-700 text-sm leading-relaxed">{s.note}</p>
            <span class="text-ember font-bold text-sm group-hover:text-navy whitespace-nowrap">View related products →</span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- Cross-links -->
  <section class="bg-bone-200 py-16">
    <div class="container-wccp">
      <p class="eyebrow text-cast mb-3">Go deeper</p>
      <h2 class="font-display text-display-md mb-8">Two ways to dig in.</h2>

      <div class="grid md:grid-cols-2 gap-5">
        <a href="/standards-explained" class="card p-8 group">
          <p class="eyebrow text-ember mb-3 block">Pillar guide</p>
          <h3 class="font-display text-2xl font-bold text-navy mb-3 group-hover:text-ember">Standards explained.</h3>
          <p class="text-cast-700 leading-relaxed mb-4">
            Each standard with a 60-100 word plain-English explainer, the products it applies
            to and the FAQs engineers actually ask. FAQPage schema for AI answer engines.
          </p>
          <span class="text-ember font-bold text-sm">Read the explainer →</span>
        </a>
        <a href="/standards/conformity" class="card p-8 group">
          <p class="eyebrow text-ember mb-3 block">Documentation hub</p>
          <h3 class="font-display text-2xl font-bold text-navy mb-3 group-hover:text-ember">Declarations of conformity.</h3>
          <p class="text-cast-700 leading-relaxed mb-4">
            Downloadable conformity statements, sample DoP fields and the email line for
            product-specific paperwork — <a href="mailto:standards@wccp.co.uk" class="underline">standards@wccp.co.uk</a>.
          </p>
          <span class="text-ember font-bold text-sm">View conformity hub →</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="container-wccp py-16 text-center">
    <h2 class="font-display text-display-lg mb-4">Specifying for a tender?</h2>
    <p class="text-cast-700 text-lg max-w-xl mx-auto mb-8">
      Tell us the application — slurry store, retaining wall, padstone, culvert — and we cast
      to the right standards, supply the right paperwork and reference the right codes on the
      delivery ticket. Same-day callback Monday to Friday.
    </p>
    <div class="flex flex-wrap justify-center gap-3">
      <a href={`tel:${site.contact.phoneIntl}`} class="btn-secondary">Call {site.contact.phone}</a>
      <a href="/quote" class="btn-primary">Configure a quote</a>
      <a href="/quote" class="btn-yellow">Start a project</a>
    </div>
  </section>
</BaseLayout>
