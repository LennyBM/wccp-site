<script>
  function toggleHow(btn) {
    var block = btn.nextElementSibling;
    var open = block.classList.toggle('open');
    btn.textContent = (open ? '▼' : '▶') + ' How to do this';
  }

  function tick(cb) {
    var item = cb.closest('.item');
    if (cb.checked) item.classList.add('done');
    else item.classList.remove('done');
    updateProgress();
  }

  function updateProgress() {
    var sections = ['s1','s2','s3','s4','s5','s6','s7','s8a','s8b','s8c','s8d','s8e','s8f'];
    var totalDone = 0, totalAll = 0;
    sections.forEach(function(id, i) {
      var section = document.getElementById(id);
      if (!section) return;
      var all = section.querySelectorAll('input[type="checkbox"]');
      var done = section.querySelectorAll('input[type="checkbox"]:checked');
      var pct = all.length ? Math.round((done.length / all.length) * 100) : 0;
      var fill = document.getElementById('p' + (i + 1));
      var label = document.getElementById('l' + (i + 1));
      if (fill) fill.style.width = pct + '%';
      if (label) label.textContent = done.length + ' / ' + all.length + ' done';
      totalDone += done.length;
      totalAll += all.length;
    });
    var totalFill = document.getElementById('p-total');
    var totalLabel = document.getElementById('l-total');
    var totalPct = totalAll ? Math.round((totalDone / totalAll) * 100) : 0;
    if (totalFill) totalFill.style.width = totalPct + '%';
    if (totalLabel) totalLabel.textContent = totalDone + ' / ' + totalAll;
  }

  updateProgress();
</script>
