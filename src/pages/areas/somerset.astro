---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { site } from '@/config/site';

const towns = [
  { name: 'Taunton', drive: '90 min' },
  { name: 'Bridgwater', drive: '95 min' },
  { name: 'Yeovil', drive: '110 min' },
  { name: 'Wells', drive: '110 min' },
  { name: 'Glastonbury', drive: '105 min' },
  { name: 'Frome', drive: '130 min' },
  { name: 'Burnham-on-Sea', drive: '95 min' },
  { name: 'Wellington', drive: '85 min' },
  { name: 'Minehead', drive: '110 min' },
  { name: 'Chard', drive: '95 min' },
  { name: 'Shepton Mallet', drive: '115 min' },
  { name: 'Crewkerne', drive: '100 min' },
];

const faqs = [
  {
    q: 'Do you deliver across Somerset?',
    a: "Yes. The M5 corridor from Tiverton to Bridgwater is a regular run for our fleet — we're typically in Somerset two or three days a week. Levels and Mendip dairies are well within day-trip range from the Holsworthy yard.",
  },
  {
    q: 'Do you supply Somerset cheese and dairy producers?',
    a: 'We do. Somerset has one of the densest dairy populations in the UK, and we\'ve supplied slurry stores, cubicle housing and silage clamp walls into farms across the Levels, the Mendips and South Somerset.',
  },
  {
    q: 'Can you reach the Somerset Levels in winter?',
    a: 'Yes — we plan deliveries around flood warnings and use 8-wheel rigid lorries that handle wet ground. If your access is borderline, we\'ll do a recce ahead of the first load and route around standing water.',
  },
  {
    q: 'Do you work with Somerset Council and Somerset civils contractors?',
    a: 'Yes. We supply precast retaining walls, padstones and bespoke civils items into the Somerset Council framework supply chain and to principal contractors on M5, A303 and Hinkley-related schemes.',
  },
  {
    q: 'Do you supply Hinkley Point C subcontractors?',
    a: 'We have supplied bespoke precast items to Tier 2 contractors working on the Hinkley supply chain. If you have an HPC drawing pack, send it through — our engineering team will quote against the spec.',
  },
];

const localBusinessSchema = {
  areaServed: {
    '@type': 'AdministrativeArea',
    name: 'Somerset, United Kingdom',
  },
  mainEntityOfPage: 'https://westcountryconcreteproducts.co.uk/areas/somerset',
};
---

<BaseLayout
  title="Precast concrete supplier serving Somerset farms and contractors"
  description="WCCP precast concrete delivered across Somerset — Taunton, Yeovil, Bridgwater, Wells, Glastonbury, Frome and beyond. Slurry stores, cubicles, retaining walls. Cast in North Devon."
  schema="LocalBusiness"
  schemaData={localBusinessSchema}
>
  <!-- Hero -->
  <section class="bg-navy text-white">
    <div class="container-wccp py-16 md:py-20">
      <nav class="text-sm text-white/90 mb-6" aria-label="Breadcrumb">
        <a href="/" class="hover:text-yellow">Home</a>
        <span class="mx-2 text-cast">/</span>
        <a href="/areas" class="hover:text-yellow">Areas served</a>
        <span class="mx-2 text-cast">/</span>
        <span class="text-white/90">Somerset</span>
      </nav>
      <p class="eyebrow text-yellow mb-5">Somerset · up the M5</p>
      <h1 class="font-display text-display-xl text-white mb-5 max-w-4xl">
        Precast concrete supplier serving Somerset farms and contractors.
      </h1>
      <p class="text-lg text-white/90 max-w-2xl leading-relaxed mb-8">
        Up the A361 and onto the M5 — Somerset's two hours from the yard at most, and we run loads
        into the Levels, the Mendips and the south of the county every week. Cheese country, civils
        country, Hinkley country.
      </p>
      <div class="flex flex-wrap gap-3">
        <a href="/quote" class="btn-primary">Get a Somerset quote</a>
        <a href={`tel:${site.contact.phoneIntl}`} class="btn-yellow">Call {site.contact.phone}</a>
      </div>
    </div>
  </section>

  <!-- Coverage map placeholder + drive times -->
  <section class="container-wccp py-16">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <div>
        <p class="eyebrow text-cast mb-3">Where we deliver</p>
        <h2 class="font-display text-display-lg mb-5">Two hours up the M5 — Somerset's well within reach.</h2>
        <p class="text-cast-700 text-lg leading-relaxed mb-4">
          From the yard at Holsworthy we route via Tiverton onto the M5 — Taunton in 90 minutes,
          Bridgwater in 95, Yeovil in 110. Big jobs we'll send dedicated artics; smaller items
          piggyback on a weekly multi-drop run.
        </p>
        <p class="text-cast-700 text-lg leading-relaxed">
          The Levels and Mendip dairies are part of our standard delivery patch. Civils projects on
          the M5, A303 and Hinkley supply chain we quote against the drawing pack.
        </p>
      </div>

      <div class="aspect-[4/3] bg-bone-200 rounded-lg border border-cast-100 relative overflow-hidden">
        <div class="absolute inset-0 flex items-center justify-center">
          <svg viewBox="0 0 200 200" class="w-3/4 h-3/4 text-navy/10">
            <path d="M40 70 Q50 40 100 45 Q150 40 170 75 Q175 110 155 135 Q110 155 70 145 Q35 130 30 100 Q28 85 40 70 Z" fill="currentColor" />
          </svg>
        </div>
        <div class="absolute bottom-[28%] left-[12%] w-3 h-3 rounded-full bg-ember ring-4 ring-ember/20"></div>
        <div class="absolute bottom-[35%] left-[5%] text-xs font-bold text-navy bg-white px-2 py-1 rounded shadow-soft">
          Holsworthy yard
        </div>
        <div class="absolute bottom-3 right-3 text-[11px] text-cast">Coverage map · placeholder</div>
      </div>
    </div>
  </section>

  <!-- Towns served -->
  <section class="bg-bone-200 py-16">
    <div class="container-wccp">
      <p class="eyebrow text-cast mb-3">Towns we cover</p>
      <h2 class="font-display text-display-lg mb-8">Drive times from the Holsworthy yard</h2>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3">
        {towns.map((t) => (
          <div class="card p-4 flex items-center justify-between">
            <span class="font-display font-bold text-navy">{t.name}</span>
            <span class="text-xs text-cast font-medium">{t.drive}</span>
          </div>
        ))}
      </div>
      <p class="text-sm text-cast mt-6 italic">
        Outside this list? Bath, Bristol fringe and the M4 corridor are all on our regular routes — call the yard for a haulage quote.
      </p>
    </div>
  </section>

  <!-- Local case studies teaser -->
  <section class="container-wccp py-16">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between mb-8 gap-4">
      <div>
        <p class="eyebrow text-cast mb-3">Somerset work</p>
        <h2 class="font-display text-display-lg">Recent jobs in the county.</h2>
      </div>
      <a href="/case-studies" class="text-ember font-bold hover:text-ember-700 inline-flex items-center gap-2">
        All Somerset case studies
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <line x1="5" y1="12" x2="19" y2="12" stroke-linecap="round"/>
          <polyline points="12 5 19 12 12 19" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>

    <div class="grid md:grid-cols-3 gap-5">
      <a href="/case-studies/somerset-grain-store" class="card p-6 group">
        <span class="eyebrow text-ember mb-3 block">Curry Rivel · 2024</span>
        <h3 class="font-display text-lg font-bold text-navy mb-2 group-hover:text-ember">Hillside Farms — L-block grain bays</h3>
        <p class="text-cast text-sm leading-relaxed">310 tonnes of L-block walls fitted in four days. Movable, reusable, and well below the cost of poured.</p>
      </a>
      <a href="/case-studies/somerset-robot-base" class="card p-6 group">
        <span class="eyebrow text-ember mb-3 block">Wells · 2026</span>
        <h3 class="font-display text-lg font-bold text-navy mb-2 group-hover:text-ember">Manor Farm Dairy — Lely robot bases</h3>
        <p class="text-cast text-sm leading-relaxed">28 tonnes of milking robot bases level to the millimetre. Lely commissioned without a shim.</p>
      </a>
      <a href="/case-studies" class="card p-6 group">
        <span class="eyebrow text-ember mb-3 block">More Somerset jobs</span>
        <h3 class="font-display text-lg font-bold text-navy mb-2 group-hover:text-ember">Browse all Somerset case studies</h3>
        <p class="text-cast text-sm leading-relaxed">Filter the case study index by Somerset to see every project we've documented in the county.</p>
      </a>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-bone-200 py-16">
    <div class="container-wccp max-w-3xl">
      <p class="eyebrow text-cast mb-3">Somerset FAQ</p>
      <h2 class="font-display text-display-lg mb-8">Local questions, local answers.</h2>
      <div class="space-y-3">
        {faqs.map((f) => (
          <details class="card p-5 group">
            <summary class="font-display text-lg font-bold text-navy cursor-pointer flex items-start justify-between gap-4">
              <span>{f.q}</span>
              <svg class="w-5 h-5 mt-1 flex-shrink-0 text-ember transition-transform group-open:rotate-45" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <line x1="12" y1="5" x2="12" y2="19" stroke-linecap="round"/>
                <line x1="5" y1="12" x2="19" y2="12" stroke-linecap="round"/>
              </svg>
            </summary>
            <p class="text-cast-700 leading-relaxed mt-4">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="bg-yellow text-navy py-12">
    <div class="container-wccp text-center max-w-2xl mx-auto">
      <h2 class="font-display text-display-md mb-3">Somerset job to spec?</h2>
      <p class="text-navy text-lg mb-6">
        Call the yard, send a sketch on WhatsApp, or fill in the quote form — same-day callback Mon–Fri.
      </p>
      <div class="flex flex-wrap justify-center gap-3">
        <a href={`tel:${site.contact.phoneIntl}`} class="btn-secondary">Call {site.contact.phone}</a>
        <a href="/quote" class="btn bg-navy text-white hover:bg-navy-700">Start a quote</a>
      </div>
    </div>
  </section>
</BaseLayout>
