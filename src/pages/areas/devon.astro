---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { site } from '@/config/site';

const towns = [
  { name: 'Holsworthy', drive: 'On the doorstep' },
  { name: 'Bideford', drive: '30 min' },
  { name: 'Barnstaple', drive: '45 min' },
  { name: 'Torrington', drive: '25 min' },
  { name: 'South Molton', drive: '50 min' },
  { name: 'Okehampton', drive: '35 min' },
  { name: 'Tavistock', drive: '50 min' },
  { name: 'Exeter', drive: '70 min' },
  { name: 'Honiton', drive: '90 min' },
  { name: 'Tiverton', drive: '70 min' },
  { name: 'Newton Abbot', drive: '90 min' },
  { name: 'Plymouth', drive: '70 min' },
];

const faqs = [
  {
    q: 'How far do you deliver in Devon?',
    a: "Anywhere in the county. We're based ten miles from the Cornwall border in Holsworthy and our own lorries reach Exeter, Plymouth and the South Hams comfortably inside a working day. Coastal North Devon is on our doorstep.",
  },
  {
    q: 'Do you offer site visits in Devon?',
    a: "Yes. For projects above £15k we'll come out and survey the site at no cost. Our engineers usually combine a site visit with a delivery to a nearby job, which keeps mileage costs out of your quote.",
  },
  {
    q: 'Which Devon farms have you supplied recently?',
    a: 'In the last twelve months we\'ve supplied dairies near Bratton Clovelly and Holsworthy, beef units around Torrington and Bideford, plus civils contractors on the A30 corridor. See the case studies index for examples.',
  },
  {
    q: 'Can you handle awkward access on Devon farm tracks?',
    a: "Most of our customers are on tight tracks and steep drives — that's North Devon. We deliver on 8-wheel rigid lorries and four-axle artics depending on access, and we'll do a recce before the first load if the lane is borderline.",
  },
  {
    q: 'Do you supply Devon County Council and the highways supply chain?',
    a: 'Yes. We supply precast retaining walls, padstones and bespoke civils items to principal contractors working for Devon CC, National Highways and Network Rail across the South West.',
  },
];

const localBusinessSchema = {
  areaServed: {
    '@type': 'AdministrativeArea',
    name: 'Devon, United Kingdom',
  },
  mainEntityOfPage: 'https://westcountryconcreteproducts.co.uk/areas/devon',
};
---

<BaseLayout
  title="Precast concrete supplier serving Devon farms and contractors"
  description="WCCP precast concrete delivered across Devon — Barnstaple, Exeter, Plymouth, Tavistock and beyond. Slurry stores, cubicles, retaining walls. Manufacturing in North Devon."
  schema="LocalBusiness"
  schemaData={localBusinessSchema}
>
  <!-- Hero -->
  <section class="bg-navy text-white">
    <div class="container-wccp py-16 md:py-20">
      <nav class="text-sm text-white/90 mb-6" aria-label="Breadcrumb">
        <a href="/" class="hover:text-yellow">Home</a>
        <span class="mx-2 text-cast">/</span>
        <a href="/areas" class="hover:text-yellow">Areas served</a>
        <span class="mx-2 text-cast">/</span>
        <span class="text-white/90">Devon</span>
      </nav>
      <p class="eyebrow text-yellow mb-5">Devon · home county</p>
      <h1 class="font-display text-display-xl text-white mb-5 max-w-4xl">
        Precast concrete supplier serving Devon farms and contractors.
      </h1>
      <p class="text-lg text-white/90 max-w-2xl leading-relaxed mb-8">
        We've cast concrete in North Devon since 1971. From Holsworthy to Honiton, Bideford to
        Plymouth — if it's precast and it's going on a Devon farm, civils job or self-build, the
        odds are we've already made one.
      </p>
      <div class="flex flex-wrap gap-3">
        <a href="/quote" class="btn-primary">Get a Devon quote</a>
        <a href={`tel:${site.contact.phoneIntl}`} class="btn-yellow">Call {site.contact.phone}</a>
      </div>
    </div>
  </section>

  <!-- Coverage map placeholder + drive times -->
  <section class="container-wccp py-16">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <div>
        <p class="eyebrow text-cast mb-3">Where we deliver</p>
        <h2 class="font-display text-display-lg mb-5">From the yard at Holsworthy, all of Devon's inside our patch.</h2>
        <p class="text-cast-700 text-lg leading-relaxed mb-4">
          Our depot sits on the A3072 ten miles east of the Cornwall border. From there our own fleet
          covers the county door-to-door — 8-wheelers for tight farm tracks, artics for civils sites
          where the access is straight.
        </p>
        <p class="text-cast-700 text-lg leading-relaxed">
          Most Devon deliveries are next-day or week-of-order. Bigger jobs we schedule against
          casting capacity at the yard, but we've never told a Devon farmer "next month".
        </p>
      </div>

      <div class="aspect-[4/3] bg-bone-200 rounded-lg border border-cast-100 relative overflow-hidden">
        <!-- Map placeholder with stylised county outline -->
        <div class="absolute inset-0 flex items-center justify-center">
          <svg viewBox="0 0 200 200" class="w-3/4 h-3/4 text-navy/10">
            <path d="M40 60 Q50 30 90 35 Q130 30 160 60 Q170 100 150 140 Q120 175 80 170 Q40 160 30 120 Q25 90 40 60 Z" fill="currentColor" />
          </svg>
        </div>
        <div class="absolute top-1/3 left-1/3 w-3 h-3 rounded-full bg-ember ring-4 ring-ember/20"></div>
        <div class="absolute top-1/3 left-1/3 transform translate-x-4 -translate-y-2 text-xs font-bold text-navy bg-white px-2 py-1 rounded shadow-soft">
          Holsworthy yard
        </div>
        <div class="absolute bottom-3 right-3 text-[11px] text-cast">Coverage map · placeholder</div>
      </div>
    </div>
  </section>

  <!-- Towns served -->
  <section class="bg-bone-200 py-16">
    <div class="container-wccp">
      <p class="eyebrow text-cast mb-3">Towns we cover</p>
      <h2 class="font-display text-display-lg mb-8">Drive times from the Holsworthy yard</h2>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3">
        {towns.map((t) => (
          <div class="card p-4 flex items-center justify-between">
            <span class="font-display font-bold text-navy">{t.name}</span>
            <span class="text-xs text-cast font-medium">{t.drive}</span>
          </div>
        ))}
      </div>
      <p class="text-sm text-cast mt-6 italic">
        Outside this list? We deliver county-wide and beyond — call the yard for a haulage quote.
      </p>
    </div>
  </section>

  <!-- Local case studies teaser -->
  <section class="container-wccp py-16">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between mb-8 gap-4">
      <div>
        <p class="eyebrow text-cast mb-3">Devon work</p>
        <h2 class="font-display text-display-lg">Recent jobs in the county.</h2>
      </div>
      <a href="/case-studies" class="text-ember font-bold hover:text-ember-700 inline-flex items-center gap-2">
        All Devon case studies
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <line x1="5" y1="12" x2="19" y2="12" stroke-linecap="round"/>
          <polyline points="12 5 19 12 12 19" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>

    <div class="grid md:grid-cols-3 gap-5">
      <a href="/case-studies/example-dairy-farm" class="card p-6 group">
        <span class="eyebrow text-ember mb-3 block">Bratton Clovelly · 2025</span>
        <h3 class="font-display text-lg font-bold text-navy mb-2 group-hover:text-ember">Higher Beara Farm — 2,400m³ slurry store</h3>
        <p class="text-cast text-sm leading-relaxed">420 tonnes of 250mm panels, eleven days on site, SIG Round 3 funded.</p>
      </a>
      <a href="/case-studies/devon-retaining-wall-civils" class="card p-6 group">
        <span class="eyebrow text-ember mb-3 block">A30 Sourton · 2025</span>
        <h3 class="font-display text-lg font-bold text-navy mb-2 group-hover:text-ember">A30 King Post retaining walls</h3>
        <p class="text-cast text-sm leading-relaxed">680 tonnes of King Post retaining wall, beat the principal contractor's programme by three days.</p>
      </a>
      <a href="/case-studies" class="card p-6 group">
        <span class="eyebrow text-ember mb-3 block">More Devon jobs</span>
        <h3 class="font-display text-lg font-bold text-navy mb-2 group-hover:text-ember">Browse all Devon case studies</h3>
        <p class="text-cast text-sm leading-relaxed">Filter the case study index by Devon to see every project we've documented in the county.</p>
      </a>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-bone-200 py-16">
    <div class="container-wccp max-w-3xl">
      <p class="eyebrow text-cast mb-3">Devon FAQ</p>
      <h2 class="font-display text-display-lg mb-8">Local questions, local answers.</h2>
      <div class="space-y-3">
        {faqs.map((f) => (
          <details class="card p-5 group">
            <summary class="font-display text-lg font-bold text-navy cursor-pointer flex items-start justify-between gap-4">
              <span>{f.q}</span>
              <svg class="w-5 h-5 mt-1 flex-shrink-0 text-ember transition-transform group-open:rotate-45" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <line x1="12" y1="5" x2="12" y2="19" stroke-linecap="round"/>
                <line x1="5" y1="12" x2="19" y2="12" stroke-linecap="round"/>
              </svg>
            </summary>
            <p class="text-cast-700 leading-relaxed mt-4">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="bg-yellow text-navy py-12">
    <div class="container-wccp text-center max-w-2xl mx-auto">
      <h2 class="font-display text-display-md mb-3">Devon job to spec?</h2>
      <p class="text-navy text-lg mb-6">
        Call the yard, send a sketch on WhatsApp, or fill in the quote form — same-day callback Mon–Fri.
      </p>
      <div class="flex flex-wrap justify-center gap-3">
        <a href={`tel:${site.contact.phoneIntl}`} class="btn-secondary">Call {site.contact.phone}</a>
        <a href="/quote" class="btn bg-navy text-white hover:bg-navy-700">Start a quote</a>
      </div>
    </div>
  </section>
</BaseLayout>
