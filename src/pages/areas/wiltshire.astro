---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { site } from '@/config/site';

const towns = [
  { name: 'Salisbury', drive: '2 hr 30' },
  { name: 'Swindon', drive: '3 hr' },
  { name: 'Trowbridge', drive: '2 hr 20' },
  { name: 'Chippenham', drive: '2 hr 30' },
  { name: 'Devizes', drive: '2 hr 25' },
  { name: 'Warminster', drive: '2 hr 15' },
  { name: 'Marlborough', drive: '2 hr 45' },
  { name: 'Calne', drive: '2 hr 35' },
  { name: 'Melksham', drive: '2 hr 25' },
  { name: 'Westbury', drive: '2 hr 15' },
  { name: 'Amesbury', drive: '2 hr 35' },
  { name: 'Tisbury', drive: '2 hr 15' },
];

const faqs = [
  {
    q: 'Which Wiltshire farms have you supplied recently?',
    a: 'Arable holdings near Marlborough, dairy units around Trowbridge and Melksham, and a beef finishing operation near Warminster. We also supplied bunker walls for a feed merchant near Devizes in 2025. The case study index has more.',
  },
  {
    q: 'Do you supply Wiltshire civils and infrastructure projects?',
    a: 'Yes. We supply L-blocks, box culverts and padstones to principal contractors on schemes across the A303, A36 and M4 corridors. Recent work has included retaining walls for a junction improvement scheme and bespoke padstones for a Wiltshire substation.',
  },
  {
    q: 'How does coverage work for Wiltshire from Holsworthy?',
    a: "Wiltshire's at the eastern edge of our regular patch, but our fleet runs there every week. North Wiltshire goes on the M4 / A303 leg, south Wiltshire on the A30 corridor. For larger jobs we'll allocate a dedicated delivery cycle and pre-survey the site access before the first load.",
  },
  {
    q: 'What are typical lead times into Wiltshire?',
    a: 'Catalogue items are usually 2–3 weeks from order. Larger civils packages, prestressed panels and bespoke commissions run 6–10 weeks depending on programme. We confirm a delivery slot in writing before you commit to ground works or possessions.',
  },
  {
    q: 'What standards do you cast to for Wiltshire work?',
    a: 'C40/50 sulphate-resisting concrete is standard. Civils elements are designed to BS EN 1992-1-1 (Eurocode 2), agricultural buildings to BS 5502, slurry stores to SSAFO 2018, watertight structures to BS 8007 principles, and box culverts to BS EN 14844. Prestressed panels are produced to BS EN 13369 and BS EN 14992.',
  },
];

const localBusinessSchema = {
  areaServed: {
    '@type': 'AdministrativeArea',
    name: 'Wiltshire, United Kingdom',
  },
  mainEntityOfPage: 'https://westcountryconcreteproducts.co.uk/areas/wiltshire',
};
---

<BaseLayout
  title="Precast concrete supplier serving Wiltshire farms and contractors"
  description="WCCP precast concrete delivered across Wiltshire — Salisbury, Swindon, Trowbridge, Chippenham and beyond. Slurry stores, cubicles, retaining walls. North Devon-made precast."
  schema="LocalBusiness"
  schemaData={localBusinessSchema}
>
  <section class="bg-navy text-white">
    <div class="container-wccp py-16 md:py-20">
      <nav class="text-sm text-white/90 mb-6" aria-label="Breadcrumb">
        <a href="/" class="hover:text-yellow">Home</a>
        <span class="mx-2 text-cast">/</span>
        <a href="/areas" class="hover:text-yellow">Areas served</a>
        <span class="mx-2 text-cast">/</span>
        <span class="text-white/90">Wiltshire</span>
      </nav>
      <p class="eyebrow text-yellow mb-5">Wiltshire · across the West Country</p>
      <h1 class="font-display text-display-xl text-white mb-5 max-w-4xl">
        Precast concrete supplier serving Wiltshire farms and contractors.
      </h1>
      <p class="text-lg text-white/90 max-w-2xl leading-relaxed mb-8">
        From Salisbury Plain to the Cotswold edge — Wiltshire's a weekly run for our fleet. Dairy, arable,
        civils, prestressed cladding for industrial sheds. Cast in Holsworthy, delivered across the county.
      </p>
      <div class="flex flex-wrap gap-3">
        <a href="/quote" class="btn-primary">Get a Wiltshire quote</a>
        <a href={`tel:${site.contact.phoneIntl}`} class="btn-yellow">Call {site.contact.phone}</a>
      </div>
    </div>
  </section>

  <section class="container-wccp py-16">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <div>
        <p class="eyebrow text-cast mb-3">Where we deliver</p>
        <h2 class="font-display text-display-lg mb-5">All of Wiltshire's inside our regular delivery patch.</h2>
        <p class="text-cast-700 text-lg leading-relaxed mb-4">
          The yard's in North Devon, on the A3072. From there the M5 / A303 / A36 leg gets us across
          Wiltshire in a long but routine working day. We run 8-wheelers for farm tracks and four-axle
          artics for civils sites and yard gates with straight access.
        </p>
        <p class="text-cast-700 text-lg leading-relaxed">
          Most Wiltshire deliveries are scheduled against other South-East routes to keep haulage
          cost-effective. Bigger jobs run dedicated, with a pre-delivery site survey if access is borderline.
        </p>
      </div>

      <div class="aspect-[4/3] bg-bone-200 rounded-lg border border-cast-100 relative overflow-hidden">
        <div class="absolute inset-0 flex items-center justify-center">
          <svg viewBox="0 0 200 200" class="w-3/4 h-3/4 text-navy/10">
            <path d="M50 40 Q90 30 130 45 Q160 60 165 100 Q160 140 130 160 Q90 170 60 155 Q35 130 35 90 Q40 60 50 40 Z" fill="currentColor" />
          </svg>
        </div>
        <div class="absolute top-1/2 right-1/3 w-3 h-3 rounded-full bg-ember ring-4 ring-ember/20"></div>
        <div class="absolute top-1/2 right-1/3 transform translate-x-4 -translate-y-2 text-xs font-bold text-navy bg-white px-2 py-1 rounded shadow-soft">
          Wiltshire coverage
        </div>
        <div class="absolute bottom-3 right-3 text-[11px] text-cast">Coverage map · placeholder</div>
      </div>
    </div>
  </section>

  <section class="bg-bone-200 py-16">
    <div class="container-wccp">
      <p class="eyebrow text-cast mb-3">Towns we cover</p>
      <h2 class="font-display text-display-lg mb-8">Drive times from the Holsworthy yard</h2>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3">
        {towns.map((t) => (
          <div class="card p-4 flex items-center justify-between">
            <span class="font-display font-bold text-navy">{t.name}</span>
            <span class="text-xs text-cast font-medium">{t.drive}</span>
          </div>
        ))}
      </div>
      <p class="text-sm text-cast mt-6 italic">
        Outside this list? We deliver county-wide and beyond — call the yard for a haulage quote.
      </p>
    </div>
  </section>

  <section class="container-wccp py-16">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between mb-8 gap-4">
      <div>
        <p class="eyebrow text-cast mb-3">Wiltshire work</p>
        <h2 class="font-display text-display-lg">Recent jobs in the county.</h2>
      </div>
      <a href="/case-studies" class="text-ember font-bold hover:text-ember-700 inline-flex items-center gap-2">
        All case studies
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <line x1="5" y1="12" x2="19" y2="12" stroke-linecap="round"/>
          <polyline points="12 5 19 12 12 19" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>

    <div class="grid md:grid-cols-3 gap-5">
      <a href="/case-studies/higgins-civils-roundabout" class="card p-6 group">
        <span class="eyebrow text-ember mb-3 block">Civils · 2024</span>
        <h3 class="font-display text-lg font-bold text-navy mb-2 group-hover:text-ember">Highways roundabout — box culverts and L-block wall</h3>
        <p class="text-cast text-sm leading-relaxed">1,160 tonnes for a Highways scheme — civils work like this runs across Wiltshire too.</p>
      </a>
      <a href="/case-studies/wessex-ad-plant" class="card p-6 group">
        <span class="eyebrow text-ember mb-3 block">Bespoke · 2024</span>
        <h3 class="font-display text-lg font-bold text-navy mb-2 group-hover:text-ember">Wessex AD — bespoke digestate tanks</h3>
        <p class="text-cast text-sm leading-relaxed">Custom precast for a Somerset AD plant — same approach we take for Wiltshire bespoke jobs.</p>
      </a>
      <a href="/case-studies" class="card p-6 group">
        <span class="eyebrow text-ember mb-3 block">More jobs</span>
        <h3 class="font-display text-lg font-bold text-navy mb-2 group-hover:text-ember">Browse all case studies</h3>
        <p class="text-cast text-sm leading-relaxed">Filter the case study index to see every project we've documented across the West Country.</p>
      </a>
    </div>
  </section>

  <section class="bg-bone-200 py-16">
    <div class="container-wccp max-w-3xl">
      <p class="eyebrow text-cast mb-3">Wiltshire FAQ</p>
      <h2 class="font-display text-display-lg mb-8">Local questions, local answers.</h2>
      <div class="space-y-3">
        {faqs.map((f) => (
          <details class="card p-5 group">
            <summary class="font-display text-lg font-bold text-navy cursor-pointer flex items-start justify-between gap-4">
              <span>{f.q}</span>
              <svg class="w-5 h-5 mt-1 flex-shrink-0 text-ember transition-transform group-open:rotate-45" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <line x1="12" y1="5" x2="12" y2="19" stroke-linecap="round"/>
                <line x1="5" y1="12" x2="19" y2="12" stroke-linecap="round"/>
              </svg>
            </summary>
            <p class="text-cast-700 leading-relaxed mt-4">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-yellow text-navy py-12">
    <div class="container-wccp text-center max-w-2xl mx-auto">
      <h2 class="font-display text-display-md mb-3">Wiltshire job to spec?</h2>
      <p class="text-navy text-lg mb-6">
        Call the yard, send a sketch on WhatsApp, or fill in the quote form — same-day callback Mon–Fri.
      </p>
      <div class="flex flex-wrap justify-center gap-3">
        <a href={`tel:${site.contact.phoneIntl}`} class="btn-secondary">Call {site.contact.phone}</a>
        <a href="/quote" class="btn bg-navy text-white hover:bg-navy-700">Start a quote</a>
      </div>
    </div>
  </section>
</BaseLayout>
