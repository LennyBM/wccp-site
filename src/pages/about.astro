---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import CTAStrip from '@/components/CTAStrip.astro';
import { site } from '@/config/site';

const timeline = [
  {
    year: '1971',
    eyebrow: 'The beginning',
    title: 'Founded outside South Molton',
    body: 'A small yard, a few moulds, and a clear idea — cast concrete that outlasts the job. The first customers were local farms. They still are.',
    keyFact: 'Year one',
  },
  {
    year: '1980s',
    eyebrow: 'Catalogue grows',
    title: 'Into Shebbear and the dairy boom',
    body: 'The yard moves to Endford Works, Shebbear. The catalogue grows with the South West dairy industry — cubicles, troughs, panels, slurry walls. Featured in the BBC Doomsday Reloaded project, 1986.',
    keyFact: '15 years in',
  },
  {
    year: '1990s',
    eyebrow: 'Going national',
    title: 'Beyond the West Country',
    body: 'Word travels. Civils contractors and farmers from across the UK start ordering. We add prestressed wall panels, retaining systems, bespoke moulds.',
    keyFact: 'Nationwide delivery',
  },
  {
    year: '2009',
    eyebrow: 'New chapter',
    title: 'Limited company, single ownership',
    body: 'Kim Rumsam takes sole ownership. The trading business of nearly four decades is consolidated into West Country Concrete Products Limited. Same yard, same standards, same answer to the same question.',
    keyFact: 'Family ownership',
  },
  {
    year: '2022',
    eyebrow: 'Capital strengthening',
    title: 'Investment and expansion plan',
    body: 'Share capital raised to £150,100, then £190,100 in 2023, funding a major plant relocation. The Shebbear site has done its 50 years — time for a yard built for the next 50.',
    keyFact: '£190k capital',
  },
  {
    year: '2023',
    eyebrow: 'New yard',
    title: 'Purpose-built in Chilsworthy',
    body: 'A brand-new factory adjacent to the Severn Trent Holsworthy biogas plant. Production buildings, batching plant, silos, water tower, workshops, offices — and 46 new jobs. Same family, properly equipped.',
    keyFact: '46 jobs created',
  },
  {
    year: 'Today',
    eyebrow: 'Where we are',
    title: 'Made in North Devon, sold across the UK',
    body: 'Five decades on, still answering the same question. Bespoke or catalogue. Farm or civils. We design, manufacture, deliver — and increasingly install. Always, the team you spoke to last time still picks up the phone.',
    keyFact: '55 years and counting',
  },
];

const team = [
  { name: 'Kim Rumsam',     role: 'Owner & Director',          since: 'Sole owner since 2009' },
  { name: 'Claire Mumford', role: 'Office & Operations',       since: 'Front-line of the yard' },
  { name: 'Paige',          role: 'Sales & Customer Liaison',  since: 'Quotes, dispatch, the lot' },
  { name: 'Jake',           role: 'Driver — C+E',              since: 'Recently passed his C+E' },
];

const principles = [
  { eyebrow: '01', title: 'If you want it lasting', body: 'We don\'t cut corners on cement, cover, cure or compaction. The product on a farm in 1985 is still doing its job. That\'s the brief.' },
  { eyebrow: '02', title: 'If you want it bespoke', body: 'In-house design, in-house mould-making. If it\'s precast and it can be delivered, we can make it. Drawing in Friday, quote on Monday.' },
  { eyebrow: '03', title: 'If you want a name to call', body: 'No call centres. The same six or seven people you\'d met on day one are the people who pick up the phone today. Talk to the yard.' },
];
---

<BaseLayout
  title="Our story"
  description="55 years manufacturing precast concrete in North Devon. The story of West Country Concrete Products — founded 1971, purpose-built site 2023, family-owned, made to last."
  schema="Organization"
>
  <!-- ====== Hero ====== -->
  <section class="relative bg-navy-700 text-white overflow-hidden">
    <div aria-hidden="true" class="absolute inset-0 grid-pattern opacity-30"></div>
    <div
      aria-hidden="true"
      class="absolute -top-1/2 -right-1/4 w-[120%] h-[200%] opacity-[0.04]"
      style="background-image: repeating-linear-gradient(45deg, #FBF547 0, #FBF547 2px, transparent 2px, transparent 24px); transform: rotate(-12deg);"
    ></div>

    <div class="relative container-wccp py-12 lg:py-16">
      <div class="mb-10">
        <Breadcrumbs items={[{ label: 'About' }]} variant="navy" />
      </div>

      <div class="grid lg:grid-cols-12 gap-10 items-end">
        <div class="lg:col-span-8">
          <p class="eyebrow text-yellow mb-6 animate-fade-in-down">
            <span class="inline-block w-8 h-px bg-yellow align-middle mr-3"></span>
            Our story · Since 1971
          </p>
          <h1 class="font-display text-display-2xl text-white animate-fade-in-up" style="animation-delay: 100ms;">
            Five decades<br />
            of <span class="relative inline-block">
              <span class="relative z-10">cast iron</span>
              <span aria-hidden="true" class="absolute inset-x-0 bottom-1 h-3 bg-yellow/30 -z-0"></span>
            </span> answers<br />
            in <span class="text-yellow">North Devon.</span>
          </h1>
        </div>
        <div class="lg:col-span-4 lg:pb-4 animate-fade-in-up" style="animation-delay: 220ms;">
          <p class="text-lg lg:text-xl text-white/80 leading-relaxed">
            One family-owned yard. One straightforward question every product
            we cast has to answer — <strong class="text-white">what'll outlast the job?</strong>
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ====== Mini-stats bar ====== -->
  <section class="bg-bone-200 border-b border-cast-100">
    <div class="container-wccp">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-px">
        {[
          { v: '55', s: 'yrs', l: 'In North Devon' },
          { v: '46', s: '',   l: 'Currently on the team' },
          { v: '500', s: '+', l: 'Farms supplied' },
          { v: '100', s: '%', l: 'UK manufactured' },
        ].map((s) => (
          <div class="bg-bone py-8 lg:py-10 px-6 text-center">
            <div class="stat-counter text-display-md mb-1">
              {s.v}<span class="text-yellow">{s.s}</span>
            </div>
            <div class="text-cast text-xs font-bold uppercase tracking-wider">{s.l}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ====== Timeline — premium editorial ====== -->
  <section class="container-wccp section-rhythm border-t border-cast-100">
    <div class="max-w-3xl mb-16">
      <p class="eyebrow text-cast mb-4">The timeline</p>
      <h2 class="font-display text-display-lg mb-4">Fifty-five years. One family. One yard, three sites.</h2>
      <p class="text-cast-700 text-lg leading-relaxed">
        From a moulds-and-mixer outfit outside South Molton in 1971
        to a purpose-built factory in Chilsworthy in 2023, with the
        same answer to the same question all the way through.
      </p>
    </div>

    <div class="relative">
      <!-- Vertical guide rail (desktop) -->
      <div aria-hidden="true" class="hidden lg:block absolute top-0 bottom-0 left-1/2 -translate-x-1/2 w-px bg-gradient-to-b from-cast-200 via-cast-300 to-cast-200"></div>

      <ol class="space-y-16 lg:space-y-32">
        {timeline.map((item, idx) => {
          const isLeft = idx % 2 === 0;
          return (
            <li class="relative reveal">
              <!-- Desktop timeline node -->
              <div aria-hidden="true" class="hidden lg:block absolute top-12 left-1/2 -translate-x-1/2 z-10">
                <div class="relative">
                  <div class="w-4 h-4 rounded-full bg-yellow ring-4 ring-bone shadow-soft"></div>
                  <div class="absolute inset-0 w-4 h-4 rounded-full bg-yellow animate-pulse-soft opacity-50"></div>
                </div>
              </div>

              <div class={`grid lg:grid-cols-2 gap-8 lg:gap-20 items-center`}>
                <!-- Year column (huge editorial type) -->
                <div class={`lg:order-${isLeft ? '1' : '2'}`}>
                  <div class={`${isLeft ? 'lg:text-right lg:pr-8' : 'lg:text-left lg:pl-8'}`}>
                    <p class="eyebrow text-ember mb-2">{item.eyebrow}</p>
                    <div class="font-display font-semibold leading-none text-navy-700 tracking-tighter" style="font-size: clamp(4rem, 8vw, 8rem); font-variation-settings: 'wdth' 75;">
                      {item.year}
                    </div>
                    <p class="mt-3 text-xs font-bold text-cast uppercase tracking-widest">{item.keyFact}</p>
                  </div>
                </div>

                <!-- Story column -->
                <div class={`lg:order-${isLeft ? '2' : '1'}`}>
                  <div class={`${isLeft ? 'lg:pl-8' : 'lg:pr-8'} max-w-prose-wide`}>
                    <h3 class="font-display text-display-sm text-navy-700 mb-4">{item.title}</h3>
                    <p class="text-cast-700 text-base lg:text-lg leading-relaxed">{item.body}</p>
                  </div>
                </div>
              </div>
            </li>
          );
        })}
      </ol>
    </div>
  </section>

  <!-- ====== Three principles ====== -->
  <section class="bg-bone-200 section-rhythm">
    <div class="container-wccp">
      <div class="max-w-2xl mb-12">
        <p class="eyebrow text-cast mb-3">How we work</p>
        <h2 class="font-display text-display-lg">Three things, never not the case.</h2>
      </div>

      <div class="grid md:grid-cols-3 gap-6 reveal-stagger">
        {principles.map((p) => (
          <div class="card p-8 group">
            <div class="font-display font-semibold text-yellow text-display-md mb-4 leading-none" style="font-variation-settings: 'wdth' 75;">{p.eyebrow}</div>
            <h3 class="font-display text-display-sm text-navy-700 mb-3 text-balance">{p.title}</h3>
            <p class="text-cast-700 leading-relaxed">{p.body}</p>
            <div aria-hidden="true" class="mt-6 h-0.5 bg-yellow scale-x-0 origin-left group-hover:scale-x-100 transition-transform duration-500"></div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ====== The team ====== -->
  <section class="container-wccp section-rhythm border-t border-cast-100">
    <div class="grid lg:grid-cols-12 gap-10 lg:gap-16 items-start">
      <div class="lg:col-span-5 lg:sticky lg:top-32">
        <p class="eyebrow text-cast mb-4">The yard team</p>
        <h2 class="font-display text-display-lg mb-6">No call centre. Six or seven of us.</h2>
        <p class="text-cast-700 text-lg leading-relaxed mb-6">
          When you ring 01409 281437 you'll get one of the people below.
          When you visit the yard, same lot. We've been working together
          a long time and we like it that way.
        </p>
        <p class="text-cast-700 text-lg leading-relaxed mb-8">
          Plus a wider crew of yard staff, drivers, machine operators,
          and apprentices. 46 jobs at the new site, all of them North Devon.
        </p>
        <a href="/careers" class="btn-ghost">Working with us</a>
      </div>

      <div class="lg:col-span-7">
        <ul class="divide-y divide-cast-100 border-y border-cast-100">
          {team.map((m, i) => (
            <li class="grid grid-cols-12 gap-4 py-6 items-center group hover:bg-bone-200/50 transition-colors duration-200 -mx-4 px-4 rounded">
              <div class="col-span-1 font-mono text-mono-label text-cast">0{i + 1}</div>
              <div class="col-span-5 font-display text-display-sm text-navy-700 group-hover:text-ember transition-colors duration-200">{m.name}</div>
              <div class="col-span-3 text-sm font-semibold text-cast-700">{m.role}</div>
              <div class="col-span-3 text-xs text-cast hidden md:block">{m.since}</div>
            </li>
          ))}
        </ul>

        <p class="mt-8 text-sm text-cast italic">
          Photographs of the team coming after the next site shoot.
        </p>
      </div>
    </div>
  </section>

  <CTAStrip
    eyebrow="Talk to the yard"
    title="A quote in 24 hours, or a phone call inside the day."
    description="We don't have call centres. The number rings on a desk, and the desk has someone at it Monday to Friday."
    primaryCta={{ href: '/quote', label: 'Configure a quote' }}
    secondaryCta={{ href: `tel:${site.contact.phoneIntl}`, label: `Call ${site.contact.phone}` }}
    variant="navy"
  />
</BaseLayout>
