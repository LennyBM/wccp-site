---
import '@/styles/global.css';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import MobileStickyBar from '@/components/MobileStickyBar.astro';
import SchemaOrg from '@/components/SchemaOrg.astro';
import CookieBanner from '@/components/CookieBanner.astro';
import Analytics from '@/components/Analytics.astro';
import { ClientRouter } from 'astro:transitions';
import { site } from '@/config/site';
import fs from 'node:fs';
import path from 'node:path';

const ogDir = path.join(process.cwd(), 'public', 'og');
const ogFiles = new Set(
  fs.existsSync(ogDir) ? fs.readdirSync(ogDir).map((f: string) => f.toLowerCase()) : [],
);

interface Props {
  title?: string;
  description?: string;
  /** Path or absolute URL for the OG/Twitter card image. Pages can override per-route. */
  image?: string;
  /** Optional alt text for the OG image (Twitter requires it for accessibility). */
  imageAlt?: string;
  noindex?: boolean;
  schema?: 'Organization' | 'LocalBusiness' | 'Product' | 'Article' | 'FAQPage' | 'HowTo' | 'BreadcrumbList' | 'Service';
  schemaData?: Record<string, unknown>;
  canonical?: string;
  /** Pre-fills the WhatsApp deep-link in the header / sticky bar with a page-specific
   * subject. e.g. "Cattle Cubicles" → "Hi WCCP — I'd like to ask about Cattle Cubicles". */
  whatsappContext?: string;
}

const {
  title,
  description = site.description,
  image,
  imageAlt = 'West Country Concrete Products — precast concrete cast in North Devon',
  noindex = false,
  schema = 'Organization',
  schemaData,
  canonical,
  whatsappContext,
} = Astro.props;

// Pick a sensible per-route OG card if the caller didn't override `image`.
// Falls back to /og-default.png. All paths point at assets that exist in
// public/og/ — purpose-built 1200x630 cards.
const ogImageFromPath = (path: string): string => {
  const p = path !== '/' && path.endsWith('/') ? path.slice(0, -1) : path;

  const staticMap: Record<string, string> = {
    '/':                       '/og/home.png',
    '/sectors/agricultural':   '/og/sectors-agricultural.png',
    '/sectors/civils':         '/og/sectors-civils.png',
    '/sectors/bespoke':        '/og/sectors-bespoke.png',
    '/products':               '/og/products.png',
  };
  if (staticMap[p]) return staticMap[p];

  const slug = p.split('/').pop();
  if (slug && ogFiles.has(`${slug}.png`)) {
    return `/og/${slug}.png`;
  }
  return '/og-default.png';
};

const resolvedImage = image ?? ogImageFromPath(Astro.url.pathname);
const pageTitle = title ? `${title} | ${site.name}` : `${site.name} — ${site.shortTagline}`;
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, site.url).toString();
const ogImage = new URL(resolvedImage, site.url).toString();
// Only preload the OG image if it's a same-origin asset path (skip absolute
// external URLs — they'd waste bandwidth on a resource the social crawler,
// not the user, will fetch).
const ogImageIsLocal = resolvedImage.startsWith('/');
// Note: the homepage hero is rendered via astro:assets <Image>, which hashes
// its output URL at build time. A fixed <link rel="preload"> here would not
// match those hashed URLs and would fire an "unused preload" warning. The
// hero element itself already carries fetchpriority="high" + loading="eager",
// which gives it equivalent priority without the URL-mismatch risk.
---

<!doctype html>
<html lang="en-GB" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonicalUrl} />

    <!-- hreflang self-reference (en-GB primary, x-default fallback) -->
    <link rel="alternate" hreflang="en-GB" href={canonicalUrl} />
    <link rel="alternate" hreflang="x-default" href={canonicalUrl} />

    <!-- Theming for browser UI. #3a5cb5 = brand navy-700 (cobalt) per
         tailwind.config.mjs. msapplication-TileColor is intentionally
         omitted — Edge has long since deprecated it and theme-color
         covers the same ground for current Microsoft surfaces. -->
    <meta name="theme-color" content="#3a5cb5" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#3a5cb5" media="(prefers-color-scheme: dark)" />

    <!-- Stop iOS from auto-styling phone numbers throughout the page; we
         render explicit tel: links where we want them to be tappable. -->
    <meta name="format-detection" content="telephone=no" />

    <!-- Preconnect to high-traffic outbound destinations to shave the TLS+DNS cost
         on the most-clicked links: WhatsApp, tel-handler, Companies House lookups. -->
    <link rel="preconnect" href="https://wa.me" crossorigin />
    <link rel="dns-prefetch" href="https://wa.me" />
    <link rel="dns-prefetch" href="https://www.facebook.com" />

    <!-- Preload the OG/social card so it's ready for any in-page reference
         (e.g. share dialogs that read the meta tag). Only same-origin
         assets — absolute external URLs are skipped. The body Inter font
         is NOT preloaded here: it's already loaded via @fontsource-variable
         in src/styles/global.css and double-preloading would waste bytes. -->
    {ogImageIsLocal && <link rel="preload" as="image" href={ogImage} />}

    <!-- Astro View Transitions — enables native page-to-page animations across
         the site. The ClientRouter is included below in <head>. -->
    <ClientRouter />

    <!-- Open Graph / Twitter -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content={imageAlt} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:locale" content="en_GB" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={imageAlt} />

    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.svg" />
    <link rel="manifest" href="/manifest.webmanifest" />

    <!-- Premium typography: Bricolage Grotesque (display) + Inter (body)
         self-hosted via @fontsource-variable; loaded by src/styles/global.css. -->

    <!-- Sitemap + RSS -->
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="alternate" type="application/rss+xml" title={site.name} href="/feed.xml" />

    <!-- Schema.org JSON-LD -->
    <SchemaOrg type={schema} data={schemaData} pathname={Astro.url.pathname} />

    <!-- Analytics (Plausible no-cookie / GA4 consent-gated; both env-controlled) -->
    <Analytics />

    {whatsappContext && <meta name="wccp-whatsapp-context" content={whatsappContext} />}

    <slot name="head" />
  </head>
  <body>
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-[100] focus:bg-navy focus:text-white focus:px-4 focus:py-2 focus:rounded"
    >
      Skip to main content
    </a>
    <a
      href="#footer-accreditations"
      class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-44 focus:z-[100] focus:bg-navy focus:text-white focus:px-4 focus:py-2 focus:rounded"
    >
      Skip to footer accreditations
    </a>

    <div class="scroll-progress" aria-hidden="true"></div>

    <Header />

    <main id="main" class="flex-1">
      <span id="main-content" class="sr-only" aria-hidden="true"></span>
      <slot />
    </main>

    <Footer />
    <MobileStickyBar />
    <CookieBanner />

    <!-- Global: section-reveal IntersectionObserver + top scroll-progress bar.
         Idempotent (skips re-binding) and respects prefers-reduced-motion. -->
    <script is:inline>
      (function () {
        if (window.__wccpGlobalUI) return;
        window.__wccpGlobalUI = true;

        var prefersReduced = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;

        // ---- section-reveal IO ----
        function initReveal() {
          var els = document.querySelectorAll('.section-reveal:not(.is-visible)');
          if (!els.length) return;
          if (prefersReduced || !('IntersectionObserver' in window)) {
            els.forEach(function (el) { el.classList.add('is-visible'); });
            return;
          }
          var io = new IntersectionObserver(function (entries) {
            entries.forEach(function (e) {
              if (e.isIntersecting) {
                e.target.classList.add('is-visible');
                io.unobserve(e.target);
              }
            });
          }, { threshold: 0.12, rootMargin: '0px 0px -8% 0px' });
          els.forEach(function (el) { io.observe(el); });
        }

        // ---- scroll-progress bar ----
        var bar = document.querySelector('.scroll-progress');
        function onScrollProgress() {
          if (!bar) return;
          var h = document.documentElement.scrollHeight - window.innerHeight;
          var p = h > 0 ? Math.min(1, Math.max(0, window.scrollY / h)) : 0;
          bar.style.setProperty('--scroll-progress', String(p));
        }
        if (!prefersReduced) {
          window.addEventListener('scroll', onScrollProgress, { passive: true });
          onScrollProgress();
        } else if (bar) {
          bar.style.display = 'none';
        }

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', initReveal);
        } else {
          initReveal();
        }

        // Astro view-transitions: re-init on each navigation
        document.addEventListener('astro:page-load', function () {
          initReveal();
          onScrollProgress();
        });
      })();
    </script>
  </body>
</html>
