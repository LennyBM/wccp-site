---
// Editorial spot-illustration for case study cards.
// Forest stroke, terracotta accent, cream background — minimal line art.
//
// Usage: <CaseStudyIcon type="slurry-store" />

interface Props {
  type:
    | 'slurry-store'
    | 'cubicle-housing'
    | 'retaining-wall'
    | 'padstone'
    | 'milking-robot'
    | 'civils-roundabout'
    | 'feed-trough'
    | 'silage-clamp'
    | 'culvert'
    | 'panel'
    | 'bespoke';
  class?: string;
}

const { type, class: className = '' } = Astro.props;

const FOREST = '#3a5cb5';
const TERRA  = '#fff005';
---

<div class:list={[
  'relative w-full h-full flex items-center justify-center overflow-hidden',
  'bg-gradient-to-br from-cream-50 to-cream-200',
  className,
]}>
  <!-- Subtle grid background -->
  <div
    aria-hidden="true"
    class="absolute inset-0 opacity-[0.06]"
    style="background-image: linear-gradient(rgba(10,26,79,0.6) 1px, transparent 1px), linear-gradient(90deg, rgba(10,26,79,0.6) 1px, transparent 1px); background-size: 24px 24px;"
  ></div>

  <!-- Faint terracotta corner accent -->
  <div aria-hidden="true" class="absolute -top-6 -right-6 w-20 h-20 rounded-full bg-terracotta/10"></div>

  <svg viewBox="0 0 240 180" class="relative w-2/3 max-w-[200px]" stroke-linecap="round" stroke-linejoin="round" fill="none">
    {type === 'slurry-store' && (
      <g stroke={FOREST} stroke-width="3">
        <!-- Tank section -->
        <ellipse cx="120" cy="55" rx="80" ry="14"/>
        <path d="M40 55 L40 145 Q40 160 120 160 Q200 160 200 145 L200 55"/>
        <ellipse cx="120" cy="55" rx="80" ry="14" fill={FOREST} fill-opacity="0.04"/>
        <!-- Slurry level -->
        <path d="M50 110 Q120 116 190 110" stroke={TERRA} stroke-width="2.5" stroke-dasharray="4 4"/>
        <!-- Side ladder -->
        <line x1="195" y1="65" x2="195" y2="150" stroke-width="2"/>
        <line x1="190" y1="80" x2="200" y2="80" stroke-width="2"/>
        <line x1="190" y1="100" x2="200" y2="100" stroke-width="2"/>
        <line x1="190" y1="120" x2="200" y2="120" stroke-width="2"/>
        <line x1="190" y1="140" x2="200" y2="140" stroke-width="2"/>
      </g>
    )}

    {type === 'cubicle-housing' && (
      <g stroke={FOREST} stroke-width="3">
        <!-- Roof -->
        <path d="M30 60 L120 25 L210 60"/>
        <line x1="20" y1="60" x2="220" y2="60"/>
        <!-- Cubicle loops -->
        <g stroke-width="2.5">
          <path d="M50 60 L50 130 Q50 140 60 140"/>
          <path d="M95 60 L95 130 Q95 140 105 140"/>
          <path d="M140 60 L140 130 Q140 140 150 140"/>
          <path d="M185 60 L185 130 Q185 140 195 140"/>
        </g>
        <!-- Floor -->
        <line x1="20" y1="155" x2="220" y2="155" stroke-width="3"/>
        <!-- Cattle silhouette accent -->
        <ellipse cx="75" cy="125" rx="12" ry="6" fill={TERRA} fill-opacity="0.5" stroke="none"/>
        <ellipse cx="165" cy="125" rx="12" ry="6" fill={TERRA} fill-opacity="0.5" stroke="none"/>
      </g>
    )}

    {type === 'retaining-wall' && (
      <g stroke={FOREST} stroke-width="3">
        <!-- L-block stepped wall -->
        <path d="M30 160 L30 80 L80 80 L80 60 L130 60 L130 40 L180 40 L180 160 Z"/>
        <!-- Block divisions -->
        <line x1="30" y1="120" x2="80" y2="120" stroke-width="2"/>
        <line x1="80" y1="100" x2="130" y2="100" stroke-width="2"/>
        <line x1="130" y1="80" x2="180" y2="80" stroke-width="2"/>
        <line x1="130" y1="120" x2="180" y2="120" stroke-width="2"/>
        <!-- Earth fill behind -->
        <path d="M180 40 L210 30 L215 160 L180 160 Z" fill={TERRA} fill-opacity="0.18" stroke="none"/>
        <line x1="180" y1="40" x2="210" y2="30" stroke={TERRA} stroke-width="2"/>
      </g>
    )}

    {type === 'padstone' && (
      <g stroke={FOREST} stroke-width="3">
        <!-- Beam -->
        <rect x="30" y="40" width="180" height="22"/>
        <line x1="30" y1="50" x2="210" y2="50" stroke-width="1.5"/>
        <!-- Padstone -->
        <rect x="80" y="62" width="80" height="32" fill={TERRA} fill-opacity="0.15"/>
        <line x1="80" y1="78" x2="160" y2="78" stroke-width="1.5"/>
        <!-- Wall -->
        <rect x="60" y="94" width="120" height="56"/>
        <line x1="60" y1="115" x2="180" y2="115" stroke-width="1.5"/>
        <line x1="60" y1="135" x2="180" y2="135" stroke-width="1.5"/>
        <line x1="100" y1="94" x2="100" y2="150" stroke-width="1.5"/>
        <line x1="140" y1="94" x2="140" y2="150" stroke-width="1.5"/>
        <!-- Load arrow -->
        <path d="M120 18 L120 38 M114 32 L120 38 L126 32" stroke={TERRA} stroke-width="2.5"/>
      </g>
    )}

    {type === 'milking-robot' && (
      <g stroke={FOREST} stroke-width="3">
        <!-- Base -->
        <rect x="50" y="120" width="140" height="30"/>
        <line x1="50" y1="135" x2="190" y2="135" stroke-width="1.5"/>
        <!-- Robot housing -->
        <rect x="80" y="50" width="80" height="70"/>
        <circle cx="120" cy="80" r="12" fill={TERRA} fill-opacity="0.5" stroke={TERRA}/>
        <!-- Cable duct hint -->
        <circle cx="65" cy="135" r="4" stroke-width="2"/>
        <circle cx="175" cy="135" r="4" stroke-width="2"/>
        <!-- Level rule -->
        <line x1="40" y1="158" x2="200" y2="158" stroke={TERRA} stroke-width="2" stroke-dasharray="3 3"/>
      </g>
    )}

    {type === 'civils-roundabout' && (
      <g stroke={FOREST} stroke-width="3">
        <circle cx="120" cy="90" r="55"/>
        <circle cx="120" cy="90" r="22" fill={TERRA} fill-opacity="0.18"/>
        <!-- Approach roads -->
        <line x1="120" y1="20" x2="120" y2="35"/>
        <line x1="105" y1="20" x2="105" y2="35"/>
        <line x1="135" y1="20" x2="135" y2="35"/>
        <line x1="120" y1="160" x2="120" y2="145"/>
        <line x1="105" y1="160" x2="105" y2="145"/>
        <line x1="135" y1="160" x2="135" y2="145"/>
        <line x1="20" y1="90" x2="50" y2="90"/>
        <line x1="20" y1="75" x2="50" y2="75"/>
        <line x1="20" y1="105" x2="50" y2="105"/>
        <line x1="220" y1="90" x2="190" y2="90"/>
        <line x1="220" y1="75" x2="190" y2="75"/>
        <line x1="220" y1="105" x2="190" y2="105"/>
      </g>
    )}

    {type === 'feed-trough' && (
      <g stroke={FOREST} stroke-width="3">
        <!-- J-shape trough cross-section -->
        <path d="M40 60 L40 130 Q40 150 60 150 L180 150 Q200 150 200 130 L200 100 L170 100 L170 130 Q170 135 165 135 L75 135 Q70 135 70 130 L70 60 Z"/>
        <!-- Feed inside -->
        <path d="M75 105 Q120 115 165 105 L165 132 L75 132 Z" fill={TERRA} fill-opacity="0.25" stroke="none"/>
        <line x1="75" y1="105" x2="165" y2="105" stroke={TERRA} stroke-width="2"/>
      </g>
    )}

    {type === 'silage-clamp' && (
      <g stroke={FOREST} stroke-width="3">
        <!-- Two L-shape walls -->
        <path d="M30 50 L30 150 L70 150 L70 60"/>
        <path d="M210 50 L210 150 L170 150 L170 60"/>
        <!-- Floor -->
        <line x1="30" y1="150" x2="210" y2="150" stroke-width="3"/>
        <!-- Silage between -->
        <path d="M70 80 Q120 70 170 80 L170 150 L70 150 Z" fill={TERRA} fill-opacity="0.18" stroke="none"/>
        <path d="M70 80 Q120 70 170 80" stroke={TERRA} stroke-width="2"/>
      </g>
    )}

    {type === 'culvert' && (
      <g stroke={FOREST} stroke-width="3">
        <!-- Box culvert face -->
        <rect x="40" y="50" width="160" height="100"/>
        <rect x="60" y="70" width="120" height="60" fill={TERRA} fill-opacity="0.18"/>
        <!-- Water -->
        <path d="M65 110 Q120 116 175 110" stroke={TERRA} stroke-width="2.5"/>
        <path d="M65 120 Q120 126 175 120" stroke={TERRA} stroke-width="2"/>
        <!-- Wing wall lines -->
        <line x1="20" y1="160" x2="40" y2="150" stroke-width="2"/>
        <line x1="200" y1="150" x2="220" y2="160" stroke-width="2"/>
      </g>
    )}

    {type === 'panel' && (
      <g stroke={FOREST} stroke-width="3">
        <!-- Stacked prestressed panels in perspective -->
        <path d="M40 60 L180 50 L210 65 L70 75 Z"/>
        <path d="M40 95 L180 85 L210 100 L70 110 Z"/>
        <path d="M40 130 L180 120 L210 135 L70 145 Z"/>
        <!-- Strand dots -->
        <circle cx="60" cy="68" r="2" fill={TERRA} stroke="none"/>
        <circle cx="120" cy="63" r="2" fill={TERRA} stroke="none"/>
        <circle cx="180" cy="58" r="2" fill={TERRA} stroke="none"/>
      </g>
    )}

    {type === 'bespoke' && (
      <g stroke={FOREST} stroke-width="3">
        <!-- Drawing compass + sheet -->
        <rect x="50" y="40" width="140" height="100"/>
        <line x1="50" y1="60" x2="190" y2="60" stroke-width="1.5"/>
        <!-- Sketch lines -->
        <line x1="65" y1="80" x2="120" y2="80" stroke-width="2"/>
        <line x1="65" y1="95" x2="160" y2="95" stroke-width="2"/>
        <line x1="65" y1="110" x2="100" y2="110" stroke-width="2"/>
        <!-- Pencil/arrow -->
        <path d="M150 105 L185 130" stroke={TERRA} stroke-width="3"/>
        <circle cx="185" cy="130" r="4" fill={TERRA} stroke="none"/>
      </g>
    )}
  </svg>
</div>
