---
interface Props {
  posterImage?: string;
  videoSrc?: string;
  caption: string;
}

const {
  posterImage = '/images/factory-hero.jpg',
  videoSrc,
  caption,
} = Astro.props;

const hasVideo = Boolean(videoSrc);
---

<figure class="reveal">
  <div
    class="relative w-full aspect-video bg-navy-700 rounded-lg overflow-hidden shadow-soft ring-1 ring-cast-100"
    role="group"
    aria-label="Yard walk-through video"
  >
    {hasVideo ? (
      <video
        class="w-full h-full object-cover"
        controls
        preload="metadata"
        poster={posterImage}
        playsinline
        aria-label={caption}
      >
        <source src={videoSrc} type="video/mp4" />
        <track kind="captions" srclang="en" label="English captions" />
        Sorry, your browser does not support embedded video.
      </video>
    ) : (
      <>
        <img
          src={posterImage}
          alt="The Holsworthy yard — a still from the planned walk-through video"
          class="absolute inset-0 w-full h-full object-cover"
          loading="lazy"
          decoding="async"
        />

        <div aria-hidden="true" class="absolute inset-0 bg-gradient-to-t from-navy-700/70 via-navy-700/20 to-transparent"></div>

        <div class="absolute inset-0 flex items-center justify-center">
          <div
            aria-hidden="true"
            class="flex items-center justify-center w-20 h-20 lg:w-24 lg:h-24 rounded-full bg-yellow text-navy shadow-soft ring-4 ring-white/30"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              class="w-9 h-9 lg:w-11 lg:h-11 ml-1"
              fill="currentColor"
              role="presentation"
            >
              <path d="M8 5v14l11-7z" />
            </svg>
          </div>
        </div>

        <div class="absolute bottom-4 left-4 right-4 flex items-end justify-between gap-3">
          <span class="inline-flex items-center gap-2 px-3 py-1.5 bg-navy-700/80 text-white text-xs font-bold uppercase tracking-wider rounded backdrop-blur-sm">
            <span aria-hidden="true" class="w-1.5 h-1.5 rounded-full bg-yellow animate-pulse-soft"></span>
            Video coming soon
          </span>
        </div>
      </>
    )}
  </div>

  <figcaption class="mt-3 text-sm text-cast italic">{caption}</figcaption>

  {!hasVideo && (
    <div class="mt-4">
      <a
        href="/contact"
        class="inline-flex items-center gap-2 px-4 py-2 bg-bone-200 hover:bg-yellow text-navy text-sm font-bold uppercase tracking-wider rounded transition-colors duration-200 ring-1 ring-cast-100"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M3 12l2-2 4 4 8-8 4 4" />
        </svg>
        Request a yard tour
      </a>
    </div>
  )}
</figure>
