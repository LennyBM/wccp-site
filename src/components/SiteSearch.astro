---
// SiteSearch.astro — Pagefind-powered site search.
// The Pagefind index is generated at build time by `pagefind --site dist`
// (see package.json build script) and lives at /pagefind/* in the deployed site.
//
// During `astro dev` the index doesn't exist yet, so the modal shows a hint
// to run `npm run build` first. In production it just works.
---

<!-- Trigger button (icon-only on mobile, icon+text on desktop).
     Hidden by default — JS unhides it once it confirms the Pagefind index
     is reachable, so a half-deployed search never shows on production. -->
<button
  type="button"
  id="site-search-trigger"
  class="hidden inline-flex items-center gap-2 px-3 py-2 rounded-lg text-navy-700 hover:bg-cast-50 transition-colors duration-200 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-yellow-500"
  aria-label="Search the site"
  aria-haspopup="dialog"
  aria-controls="site-search-modal"
  data-search-trigger
>
  <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25">
    <circle cx="11" cy="11" r="7" />
    <line x1="21" y1="21" x2="16.5" y2="16.5" stroke-linecap="round" />
  </svg>
  <span class="hidden xl:inline text-sm font-semibold">Search</span>
  <kbd class="hidden xl:inline-flex items-center px-1.5 py-0.5 text-[10px] font-mono font-semibold text-cast-700 bg-cast-100 border border-cast-200 rounded">⌘K</kbd>
</button>

<!-- Modal backdrop + dialog -->
<div
  id="site-search-modal"
  role="dialog"
  aria-modal="true"
  aria-labelledby="site-search-title"
  class="hidden fixed inset-0 z-[100] items-start justify-center pt-[10vh] px-4"
>
  <div id="site-search-backdrop" class="absolute inset-0 bg-navy-ink/70 backdrop-blur-sm" aria-hidden="true"></div>

  <div class="relative w-full max-w-2xl bg-white rounded-lg shadow-lifted ring-1 ring-cast-100 overflow-hidden">
    <div class="flex items-center justify-between px-5 py-3 border-b border-cast-100 bg-bone">
      <h2 id="site-search-title" class="font-display text-base font-bold text-navy">Search the site</h2>
      <button
        type="button"
        id="site-search-close"
        class="p-2 -mr-2 text-cast-700 hover:text-navy hover:bg-cast-100 rounded transition-colors"
        aria-label="Close search"
      >
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25">
          <line x1="18" y1="6" x2="6" y2="18" stroke-linecap="round"/>
          <line x1="6" y1="6" x2="18" y2="18" stroke-linecap="round"/>
        </svg>
      </button>
    </div>

    <div class="px-5 py-5">
      <!-- Pagefind injects its UI here -->
      <div id="site-search-mount"></div>
      <p id="site-search-fallback" class="hidden text-sm text-cast-700 mt-3">
        Search is unavailable right now. Browse <a href="/products" class="text-ember font-bold hover:text-ember-700 underline">our products</a> or
        <a href="/contact" class="text-ember font-bold hover:text-ember-700 underline">call the yard</a>.
      </p>
    </div>
  </div>
</div>

<style is:global>
  /* Pagefind default UI overrides — match WCCP brand */
  #site-search-mount {
    --pagefind-ui-scale: 0.92;
    --pagefind-ui-primary: #1e3a8a;       /* navy */
    --pagefind-ui-text: #1a2236;
    --pagefind-ui-background: #ffffff;
    --pagefind-ui-border: #e2e3e7;
    --pagefind-ui-tag: #f5f5f0;           /* bone */
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 8px;
    --pagefind-ui-image-border-radius: 6px;
    --pagefind-ui-image-box-ratio: 4 / 3;
    --pagefind-ui-font: 'Inter Variable', system-ui, sans-serif;
  }
  #site-search-mount .pagefind-ui__search-input {
    font-size: 1rem;
    padding: 0.625rem 2.5rem 0.625rem 0.875rem;
  }
  #site-search-mount .pagefind-ui__result-title a {
    color: #1e3a8a;
    font-weight: 700;
  }
  #site-search-mount .pagefind-ui__result-title a:hover {
    color: #c2410c;     /* ember */
  }
</style>

<script is:inline>
  (function () {
    function initSiteSearch() {
      const trigger = document.getElementById('site-search-trigger');
      const modal = document.getElementById('site-search-modal');
      const backdrop = document.getElementById('site-search-backdrop');
      const closeBtn = document.getElementById('site-search-close');
      const mount = document.getElementById('site-search-mount');
      const fallback = document.getElementById('site-search-fallback');

      if (!trigger || !modal || !mount) return;
      if (trigger.dataset.wccpBound === '1') return;
      trigger.dataset.wccpBound = '1';

      // Probe: only reveal the search triggers if Pagefind is actually reachable.
      // Half-deployed search (or running on the dev server with no built index)
      // stays hidden so the UI never advertises a feature it can't deliver.
      fetch('/pagefind/pagefind-entry.json', { method: 'HEAD' }).then(function (r) {
        if (!r.ok) return;
        document.querySelectorAll('[data-search-trigger]').forEach(function (el) {
          el.classList.remove('hidden');
          if (el.hasAttribute('data-mobile-search-trigger')) el.classList.add('flex');
          else el.classList.add('inline-flex');
        });
      }).catch(function () { /* silent — keeps button hidden */ });

      var pagefindLoaded = false;
      var lastFocused = null;

      function loadPagefind() {
        // Inject CSS
        if (!document.querySelector('link[data-pagefind-ui-css]')) {
          var css = document.createElement('link');
          css.rel = 'stylesheet';
          css.href = '/pagefind/pagefind-ui.css';
          css.setAttribute('data-pagefind-ui-css', '1');
          document.head.appendChild(css);
        }
        // pagefind-ui.js is an IIFE that registers window.PagefindUI — load via <script>, not import().
        return new Promise(function (resolve, reject) {
          if (window.PagefindUI) { resolve(window.PagefindUI); return; }
          var existing = document.querySelector('script[data-pagefind-ui-js]');
          if (existing) {
            existing.addEventListener('load', function () { resolve(window.PagefindUI); });
            existing.addEventListener('error', function () { reject(new Error('Pagefind script failed to load')); });
            return;
          }
          var s = document.createElement('script');
          s.src = '/pagefind/pagefind-ui.js';
          s.async = true;
          s.setAttribute('data-pagefind-ui-js', '1');
          s.onload = function () {
            if (window.PagefindUI) resolve(window.PagefindUI);
            else reject(new Error('Pagefind UI loaded but PagefindUI not exposed'));
          };
          s.onerror = function () { reject(new Error('Pagefind script failed to load')); };
          document.head.appendChild(s);
        }).then(function (PagefindUI) {
          new PagefindUI({
            element: '#site-search-mount',
            showSubResults: true,
            showImages: false,
            resetStyles: false,
            translations: { placeholder: 'Search products, specs, case studies…', clear_search: 'Clear', zero_results: 'No matches for [SEARCH_TERM]. Try a wider term, or call the yard.' },
          });
          return true;
        });
      }

      function open() {
        lastFocused = document.activeElement;
        modal.classList.remove('hidden');
        modal.classList.add('flex');
        document.body.style.overflow = 'hidden';

        if (!pagefindLoaded) {
          loadPagefind().then(function () {
            pagefindLoaded = true;
            setTimeout(function () {
              var input = mount.querySelector('input.pagefind-ui__search-input');
              if (input) input.focus();
            }, 60);
          }).catch(function (err) {
            console.warn('Pagefind not available:', err);
            if (fallback) fallback.classList.remove('hidden');
          });
        } else {
          setTimeout(function () {
            var input = mount.querySelector('input.pagefind-ui__search-input');
            if (input) input.focus();
          }, 60);
        }
      }

      function close() {
        modal.classList.add('hidden');
        modal.classList.remove('flex');
        document.body.style.overflow = '';
        if (lastFocused && typeof lastFocused.focus === 'function') lastFocused.focus();
      }

      trigger.addEventListener('click', open);
      if (closeBtn) closeBtn.addEventListener('click', close);
      if (backdrop) backdrop.addEventListener('click', close);

      // Wire any mobile-menu search triggers to the same handler
      document.querySelectorAll('[data-mobile-search-trigger]').forEach(function (el) {
        el.addEventListener('click', function () {
          var mobileMenu = document.getElementById('mobile-menu');
          var menuBackdrop = document.getElementById('mobile-menu-backdrop');
          if (mobileMenu && mobileMenu.getAttribute('aria-hidden') === 'false') {
            mobileMenu.classList.add('translate-x-full');
            mobileMenu.setAttribute('aria-hidden', 'true');
            if (menuBackdrop) {
              menuBackdrop.classList.remove('opacity-100');
              menuBackdrop.classList.add('opacity-0');
              setTimeout(function () { menuBackdrop.classList.add('hidden'); }, 300);
            }
            setTimeout(function () { mobileMenu.classList.add('hidden'); }, 300);
          }
          setTimeout(open, 320);
        });
      });

      document.addEventListener('keydown', function (e) {
        if ((e.metaKey || e.ctrlKey) && e.key && e.key.toLowerCase() === 'k') {
          e.preventDefault();
          if (modal.classList.contains('hidden')) open();
          else close();
        }
        if (e.key === '/' && !(e.target instanceof HTMLInputElement) && !(e.target instanceof HTMLTextAreaElement) && modal.classList.contains('hidden')) {
          e.preventDefault();
          open();
        }
        if (e.key === 'Escape' && !modal.classList.contains('hidden')) {
          close();
        }
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initSiteSearch);
    } else {
      initSiteSearch();
    }
    document.addEventListener('astro:page-load', initSiteSearch);
  })();
</script>
