---
// Pillar guide → quote conversion bridge.
// A reusable sticky aside that pairs the relevant product with a quote CTA
// alongside the body of a pillar guide. Hidden on mobile (the inline
// mid-article CTA card carries the conversion path on small screens).
interface Props {
  product: string;
  productHref: string;
  productImage: string;
  productSpec: string;
  /**
   * Slug appended to /quote as ?product=... so the configurator can
   * pre-select the right product type.
   */
  productSlug?: string;
}

const { product, productHref, productImage, productSpec, productSlug } = Astro.props;
const quoteHref = productSlug ? `/quote?product=${productSlug}` : '/quote';
---

<aside class="hidden lg:block">
  <div class="lg:sticky lg:top-32">
    <p class="eyebrow text-cast mb-3">Quote this product</p>
    <div class="card p-4">
      <div class="aspect-[4/3] bg-bone-200 rounded overflow-hidden mb-4">
        <img
          src={productImage}
          alt={product}
          loading="lazy"
          decoding="async"
          class="w-full h-full object-cover"
        />
      </div>
      <h3 class="font-display text-lg font-bold text-navy-700 mb-1">
        <a href={productHref} class="hover:text-ember transition-colors duration-200">{product}</a>
      </h3>
      <p class="text-cast text-sm leading-snug mb-4">{productSpec}</p>
      <a href={quoteHref} class="btn-primary btn-sm w-full justify-center group">
        <span>Get a quote for this</span>
        <svg class="w-3.5 h-3.5 arrow-float" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <line x1="5" y1="12" x2="19" y2="12" stroke-linecap="round"/>
          <polyline points="12 5 19 12 12 19" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
      <p class="mt-3 text-xs text-cast text-center">Reply within 24 hours · same-day callback</p>
    </div>
  </div>
</aside>
