---
// Reusable WCCP logo lockup.
// A properly drawn SVG wordmark — square frame in raw logo navy,
// "WCCP" in raw logo yellow, set in Bricolage Grotesque with
// tighter optical kerning than the default.
//
// Brand discipline: this is the ONE place the raw logo colours
// (#0000FE / #FBF547) are used. Everywhere else uses the refined
// palette (navy-700 / yellow / ember).
interface Props {
  size?: number;
  class?: string;
  withWordmark?: boolean;
}

const { size = 50, class: className = '', withWordmark = false } = Astro.props;
---

{withWordmark ? (
  <span class={`inline-flex items-center gap-3 ${className}`}>
    <svg
      width={size}
      height={size}
      viewBox="0 0 50 50"
      role="img"
      aria-label="WCCP logo"
      class="block transition-transform duration-400 ease-spring group-hover:scale-105"
    >
      <rect width="50" height="50" rx="3" fill="#0000FE" />
      <text
        x="25"
        y="25"
        text-anchor="middle"
        dominant-baseline="central"
        font-family="'Bricolage Grotesque', 'Inter', system-ui, sans-serif"
        font-weight="700"
        font-size="14"
        letter-spacing="-0.04em"
        fill="#FBF547"
      >WCCP</text>
    </svg>
    <span class="hidden sm:block leading-tight">
      <span class="block font-display font-semibold text-navy-700 text-sm lg:text-base tracking-tight">West Country</span>
      <span class="block font-display font-semibold text-navy-700 text-sm lg:text-base tracking-tight">Concrete Products</span>
    </span>
  </span>
) : (
  <svg
    width={size}
    height={size}
    viewBox="0 0 50 50"
    role="img"
    aria-label="WCCP logo"
    class={`block ${className}`}
  >
    <rect width="50" height="50" rx="3" fill="#0000FE" />
    <text
      x="25"
      y="25"
      text-anchor="middle"
      dominant-baseline="central"
      font-family="'Bricolage Grotesque', 'Inter', system-ui, sans-serif"
      font-weight="700"
      font-size="14"
      letter-spacing="-0.04em"
      fill="#FBF547"
    >WCCP</text>
  </svg>
)}
