---
import { site } from '@/config/site';
import SocialIcon from './SocialIcon.astro';
---

<!-- Mobile sticky CTA bar — phone, WhatsApp (brand-correct), quote.
     The three actions farmers actually press. -->
<div
  class="lg:hidden fixed bottom-0 left-0 right-0 z-50 bg-navy-700 text-white shadow-[0_-4px_16px_rgba(10,26,79,0.18)] safe-area-pb"
  role="region"
  aria-label="Quick contact"
>
  <div class="grid grid-cols-3 divide-x divide-navy-600">
    <a
      href={`tel:${site.contact.phoneIntl}`}
      class="flex flex-col items-center justify-center gap-1 py-3 hover:bg-navy-600 active:bg-navy-800 transition-colors duration-200"
      aria-label={`Call ${site.contact.phone}`}
    >
      <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <span class="text-xs font-bold">Call</span>
    </a>
    <a
      href={`https://wa.me/${site.contact.whatsapp.replace('+', '')}?text=${encodeURIComponent('Hi WCCP — I\'d like to ask about ')}`}
      target="_blank"
      rel="noopener noreferrer"
      class="flex flex-col items-center justify-center gap-1 py-3 bg-[#25D366] hover:bg-[#1FBA56] active:bg-[#179649] transition-colors duration-200"
      aria-label="Message us on WhatsApp"
    >
      <SocialIcon network="whatsapp" size={20} />
      <span class="text-xs font-bold">WhatsApp</span>
    </a>
    <a
      href="/quote"
      class="flex flex-col items-center justify-center gap-1 py-3 bg-ember hover:bg-ember-600 active:bg-ember-700 transition-colors duration-200"
      aria-label="Get a quote"
    >
      <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" stroke-linecap="round" stroke-linejoin="round"/>
        <polyline points="14 2 14 8 20 8" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <span class="text-xs font-bold">Quote</span>
    </a>
  </div>
</div>

<style>
  .safe-area-pb { padding-bottom: env(safe-area-inset-bottom); }
</style>
