---
import { productThumbnails } from '@/config/product-thumbnails';

interface Props {
  items: { href: string; label: string; meta: string }[];
}
const { items } = Astro.props;
---
<div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
  {items.map((r) => (
    <a href={r.href} class="card p-5 group">
      <div class="aspect-[16/10] bg-cast-100 mb-4 rounded overflow-hidden">
        {productThumbnails[r.href] ? (
          <img src={productThumbnails[r.href]} alt={r.label} class="w-full h-full object-cover" loading="lazy" decoding="async" />
        ) : (
          <div class="w-full h-full flex items-center justify-center" style="background: linear-gradient(135deg, #3a5cb5 0%, #2e4796 100%);">
            <span class="font-display italic text-cream/40 text-xl">WCCP</span>
          </div>
        )}
      </div>
      <h3 class="font-display text-base font-bold text-navy mb-1 group-hover:text-ember">{r.label}</h3>
      <p class="text-cast text-xs">{r.meta}</p>
    </a>
  ))}
</div>
