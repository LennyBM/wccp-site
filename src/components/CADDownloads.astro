---
// CADDownloads — request-by-email block for BIM packs.
//
// Honest framing: WCCP packs are sent direct from engineering rather than
// served as static downloads. Each card opens a pre-filled mailto so the
// engineer on the other end has the project context to respond fast.

interface Props {
  productSlug: string;
  productName: string;
}

const { productName } = Astro.props;

const engineeringEmail = 'engineering@wccp.co.uk';

interface RequestLink {
  label: string;
  ext: string;
  formatLong: string;
  desc: string;
}

const links: RequestLink[] = [
  {
    label: 'AutoCAD',
    ext: '.dwg',
    formatLong: 'AutoCAD .dwg',
    desc: 'Plan, section and elevation — 2D drawings.',
  },
  {
    label: 'Revit',
    ext: '.rfa',
    formatLong: 'Revit .rfa family',
    desc: 'Parametric Revit family for BIM.',
  },
  {
    label: 'IFC4',
    ext: '.ifc',
    formatLong: 'IFC4 model',
    desc: 'Open BIM exchange format.',
  },
  {
    label: 'PDF spec sheet',
    ext: '.pdf',
    formatLong: 'PDF spec sheet',
    desc: 'Specs, loadings, certification refs.',
  },
];

const buildMailto = (formatLong: string) => {
  const subject = `BIM pack request — ${productName} — ${formatLong}`;
  const body = [
    'Hi WCCP engineering,',
    '',
    `Please send the ${formatLong} for ${productName}.`,
    '',
    'Project details:',
    '• Project name:',
    '• Site location:',
    '• Required version (BS EN 14992 / BS 5502-22):',
    '• Stamped drawing required: yes / no',
    '',
    'Thanks',
  ].join('\n');
  return `mailto:${engineeringEmail}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
};
---

<section class="container-wccp py-16 md:py-20">
  <div class="card p-6 md:p-10 bg-bone-200">
    <div class="max-w-2xl mb-8">
      <p class="eyebrow text-ember mb-3">BIM-ready packs</p>
      <h3 class="font-display text-2xl md:text-3xl font-bold text-navy mb-3">
        {productName} — engineer pack, on request.
      </h3>
      <p class="text-cast-700 leading-relaxed">
        BIM-ready packs sent direct from engineering. Email goes to a real engineer —
        typical turnaround 24 working hours, with the version cross-referenced to your
        spec (BS EN 14992 / BS 5502-22 where applicable).
      </p>
    </div>

    <ul class="grid sm:grid-cols-2 gap-3" role="list">
      {links.map((l) => (
        <li>
          <a
            href={buildMailto(l.formatLong)}
            class="card p-5 group flex items-start gap-4 bg-white"
            aria-label={`Request ${productName} ${l.label} ${l.ext} file by email`}
          >
            <!-- Format icon -->
            <span class="shrink-0 w-12 h-14 rounded border-2 border-navy flex flex-col items-center justify-center bg-white group-hover:bg-navy group-hover:text-white transition-colors duration-200" aria-hidden="true">
              <svg class="w-5 h-5 text-navy group-hover:text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" stroke-linecap="round" stroke-linejoin="round"/>
                <polyline points="14 2 14 8 20 8" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <span class="font-mono text-[9px] font-bold mt-0.5 tracking-tight">{l.ext.toUpperCase().replace('.', '')}</span>
            </span>
            <!-- Label and description -->
            <div class="flex-1 min-w-0">
              <div class="flex items-baseline justify-between gap-2 mb-1">
                <p class="font-display text-base font-bold text-navy group-hover:text-ember">
                  {l.label} <span class="font-mono text-xs text-cast">{l.ext}</span>
                </p>
                <span class="text-xs font-bold text-terracotta inline-flex items-center gap-1 shrink-0 group-hover:gap-2 transition-all duration-200">
                  <!-- Envelope icon -->
                  <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" aria-hidden="true">
                    <rect x="3" y="5" width="18" height="14" rx="2" stroke-linecap="round" stroke-linejoin="round"/>
                    <polyline points="3 7 12 13 21 7" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                  Request
                  <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                    <line x1="5" y1="12" x2="19" y2="12" stroke-linecap="round"/>
                    <polyline points="12 5 19 12 12 19" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </span>
              </div>
              <p class="text-cast text-sm leading-relaxed">{l.desc}</p>
            </div>
          </a>
        </li>
      ))}
    </ul>

    <p class="text-xs text-cast mt-6 leading-relaxed">
      All packs versioned to BS EN 14992 / BS 5502-22 where applicable. Email goes direct to
      <a href={`mailto:${engineeringEmail}`} class="text-navy font-bold hover:text-terracotta underline underline-offset-2">{engineeringEmail}</a>
      — stamped drawings on the same thread.
    </p>
  </div>
</section>
