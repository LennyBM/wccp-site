---
// Sticky right-hand TOC for long product pages.
// Pass `sections={[{ id, label }]}`. Items are anchor links; scroll-spy
// highlights the active one via IntersectionObserver.
interface Section {
  id: string;
  label: string;
}
interface Props {
  sections: Section[];
}
const { sections } = Astro.props;
---

<aside
  class="hidden xl:block fixed top-32 right-6 z-20 w-[200px] bg-cream/85 backdrop-blur-sm rounded-md p-4 border border-cast-100 shadow-soft"
  aria-label="On this page"
  data-toc
>
  <p class="eyebrow text-cast mb-3">On this page</p>
  <ul class="space-y-1 border-l border-cast-200">
    {sections.map((s) => (
      <li>
        <a
          href={`#${s.id}`}
          data-toc-link
          data-target={s.id}
          class="block -ml-px pl-4 py-1 text-xs text-cast-700 hover:text-forest-700 border-l-2 border-transparent transition-colors leading-snug"
        >
          {s.label}
        </a>
      </li>
    ))}
  </ul>
</aside>

<style>
  [data-toc] [data-toc-link][data-active="true"] {
    color: theme('colors.forest.700');
    font-weight: 600;
    border-color: theme('colors.terracotta.DEFAULT');
  }
</style>

<script is:inline>
  (function () {
    var toc = document.querySelector('[data-toc]');
    if (!toc) return;
    var links = toc.querySelectorAll('[data-toc-link]');
    if (!links.length || !('IntersectionObserver' in window)) return;
    var ids = Array.prototype.map.call(links, function (a) { return a.getAttribute('data-target'); });
    var sections = ids
      .map(function (id) { return document.getElementById(id); })
      .filter(Boolean);
    if (!sections.length) return;

    var setActive = function (id) {
      links.forEach(function (a) {
        a.setAttribute('data-active', a.getAttribute('data-target') === id ? 'true' : 'false');
      });
    };

    var io = new IntersectionObserver(function (entries) {
      // pick the entry highest on the page that is intersecting
      var visible = entries.filter(function (e) { return e.isIntersecting; });
      if (!visible.length) return;
      visible.sort(function (a, b) { return a.boundingClientRect.top - b.boundingClientRect.top; });
      setActive(visible[0].target.id);
    }, { rootMargin: '-30% 0px -55% 0px', threshold: 0 });

    sections.forEach(function (s) { io.observe(s); });
  })();
</script>
