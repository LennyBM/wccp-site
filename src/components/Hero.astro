---
interface CTA { href: string; label: string; }

interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  primaryCta?: CTA;
  secondaryCta?: CTA;
  tertiaryCta?: CTA;
  variant?: 'navy' | 'bone' | 'yellow';
  imageUrl?: string;
  /** Additional content slot */
  align?: 'left' | 'center';
}

const {
  eyebrow,
  title,
  subtitle,
  primaryCta,
  secondaryCta,
  tertiaryCta,
  variant = 'navy',
  imageUrl,
  align = 'left',
} = Astro.props;

const variantClasses = {
  navy:   'bg-forest-700 text-cream',
  bone:   'bg-cream text-ink',
  yellow: 'bg-cream text-forest',
}[variant];

const eyebrowColor = variant === 'navy' ? 'text-cream/80' : 'text-cast';
const titleColor   = variant === 'navy' ? 'text-cream' : 'text-forest-700';
const subtitleColor = variant === 'navy' ? 'text-cream/85' : 'text-cast-700';
const alignClass = align === 'center' ? 'mx-auto text-center' : '';
---

<section class={`relative overflow-hidden ${variantClasses}`}>
  {/* Background image with hero gradient */}
  {imageUrl && (
    <div aria-hidden="true" class="absolute inset-0">
      <img src={imageUrl} alt="" class="w-full h-full object-cover opacity-40" />
      <div class="absolute inset-0 hero-gradient"></div>
    </div>
  )}

  {/* Quiet forest gradient for the navy variant when no image is supplied */}
  {variant === 'navy' && !imageUrl && (
    <div
      aria-hidden="true"
      class="absolute inset-0 opacity-60"
      style="background: linear-gradient(135deg, #3a5cb5 0%, #2e4796 60%, #1f2f6a 100%);"
    />
  )}

  {/* Subtle grain — replaces the old diagonal yellow-stripe motif */}
  {variant === 'navy' && <div aria-hidden="true" class="grain-overlay"></div>}

  <div class="relative container-wccp py-20 md:py-24 lg:py-28">
    <div class={`max-w-3xl ${alignClass}`}>
      {eyebrow && (
        <p class={`eyebrow mb-6 ${eyebrowColor} animate-fade-in-down`}>
          <span class={`inline-block w-8 h-px align-middle mr-3 ${variant === 'navy' ? 'bg-terracotta' : 'bg-terracotta'}`}></span>
          {eyebrow}
        </p>
      )}

      <h1 class={`font-display text-display-2xl mb-6 animate-fade-in-up ${titleColor}`} style="animation-delay: 100ms;" set:html={title} />

      {subtitle && (
        <p class={`text-lg md:text-xl max-w-2xl mb-10 leading-relaxed animate-fade-in-up ${subtitleColor}`}
           style="animation-delay: 220ms;"
           set:html={subtitle} />
      )}

      {(primaryCta || secondaryCta || tertiaryCta) && (
        <div class={`flex flex-wrap gap-3 ${align === 'center' ? 'justify-center' : ''} animate-fade-in-up`} style="animation-delay: 340ms;">
          {primaryCta && (
            <a href={primaryCta.href} class="btn-primary group">
              <span>{primaryCta.label}</span>
              <svg class="w-4 h-4 arrow-float" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <line x1="5" y1="12" x2="19" y2="12" stroke-linecap="round"/>
                <polyline points="12 5 19 12 12 19" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          )}
          {secondaryCta && (
            <a href={secondaryCta.href} class={variant === 'navy' ? 'btn-yellow' : 'btn-secondary'}>
              {secondaryCta.label}
            </a>
          )}
          {tertiaryCta && (
            <a href={tertiaryCta.href} class={variant === 'navy' ? 'btn-ghost border-cream text-cream hover:bg-cream hover:text-forest-700' : 'btn-ghost'}>
              {tertiaryCta.label}
            </a>
          )}
        </div>
      )}

      <slot />
    </div>
  </div>
</section>
