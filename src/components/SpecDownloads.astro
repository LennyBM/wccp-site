---
// SpecDownloads.astro
// Renders a "Spec sheets" section listing every PDF available for a product.
// Used near the bottom of product pages, between FAQs and the final CTA.

interface DownloadItem {
  /** URL of the PDF, e.g. /downloads/specs/water-troughs/wccp-water-troughs-180-gallon-drinker.pdf */
  href: string;
  /** Human-readable title — e.g. "180 Gallon drinker" */
  title: string;
  /** Optional subtitle / format hint, e.g. "PDF · 320 KB" */
  meta?: string;
}

interface Props {
  eyebrow?: string;
  heading?: string;
  intro?: string;
  downloads: DownloadItem[];
}

const {
  eyebrow = 'Spec sheets',
  heading = 'Download the technical data.',
  intro = 'PDF spec sheets — dimensions, weights, fittings, lifting points.',
  downloads,
} = Astro.props as Props;
---

<section class="bg-navy text-white py-16 lg:py-20">
  <div class="container-wccp">
    <div class="max-w-2xl mb-10">
      <p class="eyebrow text-yellow mb-3">{eyebrow}</p>
      <h2 class="font-display text-display-lg mb-4">{heading}</h2>
      <p class="text-white/80">{intro}</p>
    </div>
    <ul class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4" role="list">
      {downloads.map((d) => (
        <li>
          <a
            href={d.href}
            download
            class="flex items-center gap-4 bg-white/5 hover:bg-white/10 border border-white/10 hover:border-yellow/40 rounded p-4 transition-colors group"
            aria-label={`Download ${d.title} (PDF)`}
          >
            <span class="shrink-0 w-10 h-12 rounded border border-yellow/60 flex flex-col items-center justify-center text-yellow group-hover:bg-yellow group-hover:text-navy transition-colors" aria-hidden="true">
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" stroke-linecap="round" stroke-linejoin="round"/>
                <polyline points="7 10 12 15 17 10" stroke-linecap="round" stroke-linejoin="round"/>
                <line x1="12" y1="15" x2="12" y2="3" stroke-linecap="round"/>
              </svg>
              <span class="font-mono text-[8px] font-bold mt-0.5 tracking-tight">PDF</span>
            </span>
            <span class="min-w-0 flex-1">
              <span class="block font-bold text-white group-hover:text-yellow transition-colors leading-snug">{d.title}</span>
              {d.meta && <span class="block text-xs text-white/60 mt-1">{d.meta}</span>}
            </span>
          </a>
        </li>
      ))}
    </ul>
  </div>
</section>
