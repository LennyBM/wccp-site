---
// Accreditation strip — confident editorial typography, no circular pills.
// Each accreditation reads as a wordmark: uppercase letterspaced label on top,
// thin descriptor below, separated by a hairline terracotta rule.
//
// The component auto-detects whether it sits on a dark (forest/navy) surface
// via the `tone` prop. On dark surfaces: cream type + cream/15 separators.
// On light surfaces: forest type + cream-300 separators.

interface Props {
  layout?: 'grid' | 'strip' | 'card';
  filter?: 'all' | 'current' | 'pending';
  showPending?: boolean;
  tone?: 'auto' | 'dark' | 'light';
}

const {
  layout = 'grid',
  filter = 'all',
  showPending = true,
  tone = 'auto',
} = Astro.props;

type Accreditation = {
  id: string;
  short: string;
  descriptor: string;
  status: 'current' | 'pending' | 'placeholder';
};

const accreditations: Accreditation[] = [
  { id: 'ce-ukca',         short: 'CE / UKCA',       descriptor: 'Marked & certified',          status: 'current' },
  { id: 'bs-en-14992',     short: 'BS EN 14992',     descriptor: 'Precast wall panels',         status: 'current' },
  { id: 'bs-8500',         short: 'BS 8500-1:2023',  descriptor: 'Concrete specification',      status: 'current' },
  { id: 'eurocode-2',      short: 'Eurocode 2',      descriptor: 'BS EN 1992 structural design',status: 'current' },
  { id: 'iso-9001',        short: 'ISO 9001',        descriptor: 'Quality management',          status: 'pending' },
  { id: 'iso-14001',       short: 'ISO 14001',       descriptor: 'Environmental management',    status: 'pending' },
  { id: 'iso-45001',       short: 'ISO 45001',       descriptor: 'Occupational H&S',            status: 'pending' },
  { id: 'bes-6001',        short: 'BES 6001',        descriptor: 'Responsible sourcing',        status: 'pending' },
  { id: 'mpa-precast',     short: 'MPA Precast',     descriptor: 'Trade body member',           status: 'placeholder' },
  { id: 'made-in-britain', short: 'Made in Britain', descriptor: 'UK-manufactured',             status: 'placeholder' },
];

const visible = accreditations.filter((a) => {
  if (filter === 'current' && a.status !== 'current') return false;
  if (filter === 'pending' && a.status !== 'pending') return false;
  if (!showPending && a.status !== 'current') return false;
  return true;
});

// Tone classes
const isDark = tone === 'dark';
const labelClass = isDark
  ? 'text-cream'
  : 'text-forest-800';
const descriptorClass = isDark
  ? 'text-cream/70'
  : 'text-forest-600';
const separatorClass = isDark
  ? 'bg-cream/15'
  : 'bg-cream-300';
const dimClass = isDark ? 'opacity-70' : 'opacity-60';
---

{layout === 'strip' && (
  <div class="flex flex-wrap items-stretch justify-center gap-x-0 gap-y-6">
    {visible.map((a, i) => (
      <>
        {i > 0 && (
          <span aria-hidden="true" class={`hidden sm:block w-px self-stretch mx-5 lg:mx-7 ${separatorClass}`}></span>
        )}
        <div class={`flex flex-col items-center text-center px-3 ${a.status !== 'current' ? dimClass : ''}`}>
          <div class={`font-display font-semibold text-[15px] lg:text-base uppercase tracking-[0.18em] ${labelClass}`}>
            {a.short}
          </div>
          <div class={`mt-1.5 text-[11px] lg:text-xs ${descriptorClass}`}>
            {a.descriptor}
          </div>
        </div>
      </>
    ))}
  </div>
)}

{layout === 'grid' && (
  <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-x-6 gap-y-8">
    {visible.map((a) => (
      <div class={`flex flex-col items-start text-left border-l-2 border-terracotta pl-4 ${a.status !== 'current' ? dimClass : ''}`}>
        <div class={`font-display font-semibold text-sm lg:text-base uppercase tracking-[0.18em] ${labelClass}`}>
          {a.short}
        </div>
        <div class={`mt-1.5 text-xs ${descriptorClass}`}>
          {a.descriptor}
        </div>
        {a.status !== 'current' && (
          <div class={`mt-2 text-[10px] uppercase tracking-widest ${descriptorClass}`}>
            {a.status === 'pending' ? 'In progress' : 'Pursuing'}
          </div>
        )}
      </div>
    ))}
  </div>
)}

{layout === 'card' && (
  <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
    {visible.map((a) => (
      <div class={`card p-5 ${a.status !== 'current' ? dimClass : ''}`}>
        <div class={`font-display font-semibold text-sm uppercase tracking-[0.18em] ${labelClass}`}>
          {a.short}
        </div>
        <div class="mt-2 h-px w-8 bg-terracotta"></div>
        <div class={`mt-3 text-xs ${descriptorClass}`}>
          {a.descriptor}
        </div>
      </div>
    ))}
  </div>
)}
