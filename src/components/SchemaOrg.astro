---
// CLIENT CONSTRAINT (Kim, WCCP): no public prices anywhere on the site,
// including in JSON-LD. This component MUST strip price/priceCurrency/
// priceRange/lowPrice/highPrice from any incoming Offer or AggregateOffer
// object, and any hasOfferCatalog content that contains prices is dropped.
// Keyed off site.pricingPolicy === 'no-public-prices'. Do not relax without
// explicit sign-off from the client.
import { site } from '@/config/site';

interface Props {
  type:
    | 'Organization'
    | 'LocalBusiness'
    | 'Product'
    | 'Article'
    | 'FAQPage'
    | 'HowTo'
    | 'BreadcrumbList'
    | 'Service';
  data?: Record<string, unknown>;
}

const { type, data = {} } = Astro.props;

// Always include Organization on every page; add the page-specific schema on top.
// alternateName combines the short name with any historical trading names from
// site.previousNames (e.g. South Molton Concrete Products Limited).
const previousNames = (site as { previousNames?: readonly string[] }).previousNames ?? [];
const alternateNames = [site.shortName, ...previousNames].filter(Boolean);

const orgSchema = {
  '@type': 'Organization',
  '@id': `${site.url}/#organization`,
  name: site.name,
  alternateName: alternateNames.length > 1 ? alternateNames : site.shortName,
  legalName: site.legalName,
  url: site.url,
  logo: `${site.url}/logo.png`,
  foundingDate: site.founded,
  description: site.description,
  sameAs: Object.values(site.socials).filter(Boolean),
  contactPoint: {
    '@type': 'ContactPoint',
    telephone: site.contact.phoneIntl,
    contactType: 'sales',
    areaServed: ['GB', 'IE', 'DE', 'NL', 'FR', 'BE'],
    availableLanguage: 'English',
  },
  address: {
    '@type': 'PostalAddress',
    streetAddress: site.address.street,
    addressLocality: site.address.town,
    addressRegion: site.address.region,
    postalCode: site.address.postcode,
    addressCountry: site.address.country,
  },
  identifier: site.companyNumber,
};

const localBusinessSchema = {
  '@type': 'LocalBusiness',
  '@id': `${site.url}/#localbusiness`,
  name: site.name,
  image: `${site.url}/og-default.png`,
  url: site.url,
  telephone: site.contact.phoneIntl,
  address: orgSchema.address,
  geo: {
    '@type': 'GeoCoordinates',
    latitude: site.address.geo.latitude,
    longitude: site.address.geo.longitude,
  },
  openingHoursSpecification: site.hours.openingHoursSpec,
  areaServed: site.areasServed.map((name) => ({ '@type': 'AdministrativeArea', name })),
};

// Shared price-field stripper. Removes anything the client (Kim) doesn't want
// surfaced — applied to Offer, AggregateOffer, and hasOfferCatalog entries.
const PRICE_KEYS = new Set([
  'price',
  'priceCurrency',
  'priceRange',
  'lowPrice',
  'highPrice',
  'priceSpecification',
]);

function stripPriceFields<T extends Record<string, unknown>>(o: T): Omit<T, never> {
  const out: Record<string, unknown> = {};
  for (const [k, v] of Object.entries(o)) {
    if (!PRICE_KEYS.has(k)) out[k] = v;
  }
  return out as T;
}

// Recursively check if a value mentions any price field. Used to gate
// hasOfferCatalog: we only attach the catalog if it's price-free.
function containsPriceFields(value: unknown): boolean {
  if (value === null || value === undefined) return false;
  if (Array.isArray(value)) return value.some(containsPriceFields);
  if (typeof value === 'object') {
    for (const [k, v] of Object.entries(value as Record<string, unknown>)) {
      if (PRICE_KEYS.has(k)) return true;
      if (containsPriceFields(v)) return true;
    }
  }
  return false;
}

// Build a Service schema with provider auto-filled from Organization.
function buildServiceSchema(d: Record<string, unknown>) {
  const provider = d.provider ?? {
    '@type': 'Organization',
    '@id': `${site.url}/#organization`,
    name: site.name,
    url: site.url,
    telephone: site.contact.phoneIntl,
  };

  const areaServedRaw = (d.areaServed ?? site.areasServed) as unknown;
  const areaServed = Array.isArray(areaServedRaw)
    ? areaServedRaw.map((a) =>
        typeof a === 'string' ? { '@type': 'AdministrativeArea', name: a } : a,
      )
    : areaServedRaw;

  // hasOfferCatalog: only include if it is entirely price-free.
  // If any nested entry mentions price/priceCurrency/priceRange/etc., drop
  // the whole catalog rather than risk leaking pricing into JSON-LD.
  const { provider: _p, areaServed: _a, hasOfferCatalog: catalog, ...rest } = d;
  const safeCatalog =
    catalog !== undefined && !containsPriceFields(catalog) ? { hasOfferCatalog: catalog } : {};

  return {
    '@type': 'Service',
    provider,
    areaServed,
    ...rest,
    ...safeCatalog,
  };
}

// Build a Product schema with Offer auto-completed (availability, seller).
// Price fields are stripped from both Offer and AggregateOffer per client policy.
function buildProductSchema(d: Record<string, unknown>) {
  const seller = {
    '@type': 'Organization',
    '@id': `${site.url}/#organization`,
    name: site.name,
    url: site.url,
  };

  // Note: no price/priceCurrency/priceRange — client (Kim) does not want
  // any pricing information surfaced on the site, including in JSON-LD.
  let offers: unknown = d.offers;
  if (offers) {
    const normaliseOffer = (o: Record<string, unknown>) => ({
      '@type': 'Offer',
      availability: 'https://schema.org/InStock',
      seller,
      ...stripPriceFields(o),
    });

    if (Array.isArray(offers)) {
      offers = offers.map((o) => normaliseOffer(o as Record<string, unknown>));
    } else {
      offers = normaliseOffer(offers as Record<string, unknown>);
    }
  }

  // AggregateOffer: same price-stripping treatment. Schema.org requires
  // offerCount; pass through whatever the caller supplied minus price keys.
  let aggregateOffer: unknown = d.aggregateOffer;
  if (aggregateOffer) {
    const normaliseAggregate = (a: Record<string, unknown>) => ({
      '@type': 'AggregateOffer',
      seller,
      ...stripPriceFields(a),
    });
    aggregateOffer = Array.isArray(aggregateOffer)
      ? aggregateOffer.map((a) => normaliseAggregate(a as Record<string, unknown>))
      : normaliseAggregate(aggregateOffer as Record<string, unknown>);
  }

  const { offers: _o, aggregateOffer: _ao, ...rest } = d;
  return {
    '@type': 'Product',
    ...rest,
    ...(offers ? { offers } : {}),
    ...(aggregateOffer ? { aggregateOffer } : {}),
  };
}

// Build an Article schema with required fields (headline, author, datePublished)
// falling back to site config so a missing prop never crashes the build.
function buildArticleSchema(d: Record<string, unknown>) {
  const headline = (d.headline as string | undefined) ?? site.name;
  const author = d.author ?? {
    '@type': 'Organization',
    '@id': `${site.url}/#organization`,
    name: site.name,
    url: site.url,
  };
  const datePublished = (d.datePublished as string | undefined) ?? new Date().toISOString().slice(0, 10);

  const { headline: _h, author: _au, datePublished: _dp, ...rest } = d;
  return {
    '@type': 'Article',
    headline,
    author,
    datePublished,
    ...rest,
  };
}

const pageSchema = (() => {
  switch (type) {
    case 'LocalBusiness':
      return localBusinessSchema;
    case 'Organization':
      return orgSchema;
    case 'Service':
      return buildServiceSchema(data);
    case 'Product':
      return buildProductSchema(data);
    case 'Article':
      return buildArticleSchema(data);
    default:
      return { '@type': type, ...data };
  }
})();

const graph =
  type === 'LocalBusiness' || type === 'Organization' ? [pageSchema] : [orgSchema, pageSchema];

const ldjson = {
  '@context': 'https://schema.org',
  '@graph': graph,
};
---

<script type="application/ld+json" set:html={JSON.stringify(ldjson)} />
