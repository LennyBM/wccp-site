---
import { buildSchemaGraph } from '@/config/schema';
import type { SchemaType } from '@/config/schema';

interface Props {
  type: SchemaType;
  data?: Record<string, unknown>;
  pathname?: string;
}

const { type, data = {}, pathname = '/' } = Astro.props;
const ldjson = buildSchemaGraph(type, data, pathname);
---

<script type="application/ld+json" set:html={JSON.stringify(ldjson)} />
